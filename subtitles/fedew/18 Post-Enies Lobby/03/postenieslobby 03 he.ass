Dialogue: 0,0:15:51.15,0:15:55.57,Captions,Franky,0,1080,498,,{\fad(50,1000}‫אינספור
Dialogue: 0,0:15:51.32,0:15:55.57,Captions,Franky,0,1080,446,,{\fad(50,1000}‫הגלים
Dialogue: 0,0:15:51.36,0:15:55.57,Captions,Franky,0,1080,394,,{\fad(50,1000}‫ישר
Dialogue: 0,0:15:51.78,0:15:55.57,Captions,Franky,0,1080,342,,{\fad(50,1000}‫ובטוח
Dialogue: 0,0:15:52.07,0:15:55.57,Captions,Franky,0,1080,290,,{\fad(50,1000}‫כאילו
Dialogue: 0,0:15:52.28,0:15:55.57,Captions,Franky,0,1080,238,,{\fad(50,1000}‫הוא
Dialogue: 0,0:15:52.91,0:15:55.57,Captions,Franky,0,1080,186,,{\fad(50,1000}‫היה
Dialogue: 0,0:15:53.11,0:15:55.57,Captions,Franky,0,1080,134,,{\fad(50,1000}‫אריה
Dialogue: 0,0:15:53.28,0:15:55.57,Captions,Franky,0,1080,82,,{\fad(50,1000}‫
