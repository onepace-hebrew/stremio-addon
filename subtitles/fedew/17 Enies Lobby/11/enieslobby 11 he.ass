Dialogue: 0,0:00:00.00,0:00:05.00,Main-207-,,0,0,0,,{\an8}‫תרגום לעברית — That One Gerbil
Dialogue: 0,0:01:53.09,0:01:54.64,Flashbacks,,0,0,0,,‫אל תחשוב שתצליח להישאר בחיים...
Dialogue: 0,0:01:54.64,0:01:56.38,Flashbacks,,0,0,0,,‫אחרי שהפכת את כל העולם\N‫לאויב שלך!
Dialogue: 0,0:01:56.61,0:02:01.47,Flashbacks,,0,0,0,,‫בואו, קדימה!
Dialogue: 0,0:02:03.98,0:02:07.77,Title,,0,0,250,,‫קפצו אל המפל!!{\fad(1000,0)}
Dialogue: 0,0:02:07.77,0:02:13.73,Captions,,975,0,310,,‫הרחבה שמחוץ לבית המשפט{\fad(500,0)}
Dialogue: 0,0:02:13.73,0:02:18.74,Captions,,950,0,335,,‫המגדל השמאלי\N‫(מוזו ולולו){\fad(500,0)}
Dialogue: 0,0:02:22.16,0:02:24.65,Main,,0,0,0,,‫יש! משכנו את הידית!
Dialogue: 0,0:02:24.65,0:02:27.75,Main,,0,0,0,,‫עשינו את ז{\i1}ה - ו{\i1}ו{\i0}איני!
Dialogue: 0,0:02:27.75,0:02:32.72,Captions,,0,930,290,,‫המגדל הימני\N‫(קיווי וטיילסטון){\fad(500,0)}
Dialogue: 0,0:02:36.68,0:02:39.51,Main,,0,0,0,,‫נראה שגם מוזו והאחרים\N‫סיימו - וואיני{\i1}{\i0}.
Dialogue: 0,0:02:39.51,0:02:42.26,Main,,0,0,0,,‫קדימה, כובע קש!
Dialogue: 0,0:02:46.00,0:02:47.64,Main,,0,0,0,,‫הגשר מתחיל לרדת!
Dialogue: 0,0:02:48.23,0:02:51.00,Main,,0,0,0,,‫נראה שהם הסתדרו.
Dialogue: 0,0:02:51.00,0:02:52.70,Main,,0,0,0,,‫בדיוק בזמן.
Dialogue: 0,0:02:58.14,0:02:59.97,Main,,0,0,0,,‫א-אני רועד מהתרגשות!
Dialogue: 0,0:03:01.57,0:03:03.36,Main,,0,0,0,,‫כבר תורידו את הגשר.
Dialogue: 0,0:03:04.64,0:03:06.04,Main,,0,0,0,,‫אתה נראה רע.
Dialogue: 0,0:03:08.38,0:03:09.37,Main,,0,0,0,,‫רובין!
Dialogue: 0,0:03:10.81,0:03:13.33,Main,,0,0,0,,‫לא נעצור עד שנחזיר אותך!
Dialogue: 0,0:03:14.80,0:03:16.29,Main,,0,0,0,,‫תישארי שם!
Dialogue: 0,0:03:17.05,0:03:18.63,Main,,0,0,0,,‫הם ממש נלהבים.
Dialogue: 0,0:03:19.60,0:03:22.03,Main,,0,0,0,,‫חשבתי שהם לא מפחדים\N‫מדגל הממשלה...
Dialogue: 0,0:03:22.03,0:03:23.59,Main,,0,0,0,,‫כמה עלוב.
Dialogue: 0,0:03:23.59,0:03:26.76,Main,,0,0,0,,‫אין שום סיכוי\N‫שהם יביסו אותנו.
Dialogue: 0,0:03:27.04,0:03:29.12,Main,,0,0,0,,‫אל תעברו!
Dialogue: 0,0:03:29.12,0:03:31.33,Main,,0,0,0,,‫הגשר מתחיל לרדת!
Dialogue: 0,0:03:31.33,0:03:33.77,Main,,0,0,0,,‫קדימה! כובע קש!
Dialogue: 0,0:03:34.02,0:03:36.55,Main,,0,0,0,,‫ארורים הפיראטים האלו!
Dialogue: 0,0:03:36.55,0:03:39.11,Main,,0,0,0,,‫לא ניתן לזה לקרות!
Dialogue: 0,0:03:39.11,0:03:41.46,Main,,0,0,0,,‫הכינו את התותח!
Dialogue: 0,0:03:41.46,0:03:44.45,Main,,0,0,0,,‫עצרו את הגשר!\N‫תשברו אותו אם צריך!
Dialogue: 0,0:03:44.77,0:03:46.66,Main,,0,0,0,,‫לא אתן לך לעשות את זה!
Dialogue: 0,0:03:46.66,0:03:48.87,Main,,0,0,0,,‫חיתוך קשר צינור!{\fad(150,150)}
Dialogue: 0,0:03:48.99,0:03:51.22,Main,,0,0,0,,‫זה הסוף שלך!
Dialogue: 0,0:03:51.22,0:03:54.36,Main,,0,0,0,,‫מהלומת הריסה!{\fad(150,150)}
Dialogue: 0,0:04:14.77,0:04:17.07,Main,,0,0,0,,‫השופט הראשי באסקרוויל!
Dialogue: 0,0:04:20.51,0:04:22.11,Main,,0,0,0,,‫זה לא טוב!
Dialogue: 0,0:04:22.11,0:04:24.70,Main,,0,0,0,,‫אנחנו בעצם\N‫שלושת השופטים הראשיים!
Dialogue: 0,0:04:25.32,0:04:26.41,Main,,0,0,0,,‫מה?!
Dialogue: 0,0:04:26.41,0:04:29.87,Main,,0,0,0,,‫אני, באסקרוויל השמאלי,\N‫שמי בס!
Dialogue: 0,0:04:29.87,0:04:33.33,Main,,0,0,0,,‫אני, באסקרוויל הימני,\N‫שמי קרוויל!
Dialogue: 0,0:04:33.33,0:04:36.58,Main,,0,0,0,,‫ואני, באסקרוויל המרכזי,\N‫השם שלי...
Dialogue: 0,0:04:36.58,0:04:37.84,Main,,0,0,0,,‫נסיכה!
Dialogue: 0,0:04:37.94,0:04:39.30,Main,,0,0,0,,‫על מה אתה מדבר?!
Dialogue: 0,0:04:39.30,0:04:42.75,Main,,0,0,0,,‫אז הם פשוט הדביקו אותם יחד?
Dialogue: 0,0:04:42.75,0:04:44.26,Main,,0,0,0,,‫בשביל מה?!
Dialogue: 0,0:04:44.26,0:04:47.22,Main,,0,0,0,,‫אנחנו חברים טובים!
Dialogue: 0,0:04:47.22,0:04:48.83,Main,,0,0,0,,‫שתוק!
Dialogue: 0,0:04:49.58,0:04:51.68,Main,,0,0,0,,‫תפתחו באש מהתותח!
Dialogue: 0,0:05:02.69,0:05:04.07,Main,,0,0,0,,‫הגשר נעצר?!
Dialogue: 0,0:05:04.07,0:05:05.76,Main,,0,0,0,,‫אתה עומד בדרכנו!
Dialogue: 0,0:05:05.76,0:05:07.03,Main,,0,0,0,,‫הכלבים האלו!
Dialogue: 0,0:05:07.72,0:05:10.59,Main,,0,0,0,,‫מי עשה את זה?!
Dialogue: 0,0:05:13.04,0:05:14.86,Main,,0,0,0,,‫ראש ספאנדם!
Dialogue: 0,0:05:23.92,0:05:26.63,Main,,0,0,0,,‫יופי! עבודה טובה!
Dialogue: 0,0:05:30.74,0:05:32.51,Main,,0,0,0,,‫בואי, ניקו רובין!
Dialogue: 0,0:05:32.51,0:05:34.77,Main,,0,0,0,,‫מישהו! הביאו את קטי פלאם!
Dialogue: 0,0:05:35.12,0:05:36.14,Main,,0,0,0,,‫רובין!
Dialogue: 0,0:05:37.20,0:05:39.90,Main,,0,0,0,,‫הפיראטים האלו הם כלום.
Dialogue: 0,0:06:07.74,0:06:09.06,Main,,0,0,0,,‫קטי פלאם...
Dialogue: 0,0:06:17.23,0:06:18.65,Main,,0,0,0,,‫זה...
Dialogue: 0,0:06:18.65,0:06:20.35,Main,,0,0,0,,‫רגע... אל תגיד לי...
Dialogue: 0,0:06:26.94,0:06:29.08,Main,,0,0,0,,‫הם האמיתיים.
Dialogue: 0,0:06:29.08,0:06:30.57,Main,,0,0,0,,‫אתה מאמין לי?
Dialogue: 0,0:06:47.55,0:06:49.59,Main,,0,0,0,,‫חשבתי שזה לא ייתכן...
Dialogue: 0,0:06:58.06,0:07:00.42,Main,,0,0,0,,‫א-אלה האמיתיים?!
Dialogue: 0,0:07:00.42,0:07:01.98,Main,,0,0,0,,‫אלה האמיתיים?!
Dialogue: 0,0:07:08.18,0:07:09.57,Main,,0,0,0,,‫ניקו רובין.
Dialogue: 0,0:07:22.10,0:07:24.18,Main,,0,0,0,,‫שמנסה להשתמש בכלי לרעה.
Dialogue: 0,0:07:25.59,0:07:31.16,Main,,0,0,0,,‫בנאי הספינות של ווטר 7\N‫לא מעבירים לדורות הבאים...
Dialogue: 0,0:07:31.16,0:07:34.58,Main,,0,0,0,,‫את הידע איך לבנות את הנשק.
Dialogue: 0,0:07:42.34,0:07:44.51,Flashbacks,,0,0,0,,‫בכל מקרה, כל עוד יש סיכון...
Dialogue: 0,0:07:53.18,0:07:55.28,Main,,0,0,0,,‫היי, ספאנדם.
Dialogue: 0,0:07:55.30,0:07:59.40,Main,,0,0,0,,‫את התרשימים שתום{\i1}-{\i0} ואייסברג\N‫סיכנו את חייהם כדי להגן עליהם...
Dialogue: 0,0:07:59.40,0:08:00.75,Main,,0,0,0,,‫כבר תיתן לי אותם!
Dialogue: 0,0:08:23.78,0:08:25.73,Main,,0,0,0,,‫היא עדיין מסוכנת.
Dialogue: 0,0:08:25.73,0:08:28.31,Main,,0,0,0,,‫אבל יש לה חברים...
Dialogue: 0,0:08:32.26,0:08:33.49,Main,,0,0,0,,‫אז אני...
Dialogue: 0,0:08:34.91,0:08:36.91,Main,,0,0,0,,‫אקח סיכון!
Dialogue: 0,0:08:37.56,0:08:38.90,Main,,0,0,0,,‫יש רק דרך אחת שאני רואה...
Dialogue: 0,0:08:38.90,0:08:43.87,Main,,0,0,0,,‫כדי לכבד את רצונו של המורה במצב הזה.
Dialogue: 0,0:08:46.61,0:08:48.09,Main,,0,0,0,,‫אלה שלי!
Dialogue: 0,0:09:09.26,0:09:10.83,Main,,0,0,0,,‫זה נשרף לגמרי!
Dialogue: 0,0:09:13.03,0:09:14.29,Main,,0,0,0,,‫לעזאזל!
Dialogue: 0,0:09:14.29,0:09:15.82,Main,,0,0,0,,‫אני אהרוג אותך!
Dialogue: 0,0:09:16.28,0:09:19.78,Main,,0,0,0,,‫חמש שנות העבודה שלנו...
Dialogue: 0,0:09:48.95,0:09:50.48,Main,,0,0,0,,‫זה יהיה חסר תקווה.
Dialogue: 0,0:09:50.48,0:09:53.11,Main,,0,0,0,,‫אבל אם כובע הקש ינצח...
Dialogue: 0,0:09:57.96,0:10:01.91,Main,,0,0,0,,‫הימרתי על הניצחון שלהם.
Dialogue: 0,0:10:01.91,0:10:04.41,Main,,0,0,0,,‫איך אתה מעז לעלוב בי...?
Dialogue: 0,0:10:09.42,0:10:11.36,Main,,0,0,0,,‫אח!
Dialogue: 0,0:10:12.33,0:10:14.70,Main,,0,0,0,,‫אח!
Dialogue: 0,0:10:15.34,0:10:18.30,Main,,0,0,0,,‫אח גדול פרנקי!
Dialogue: 0,0:10:18.30,0:10:19.26,Main,,0,0,0,,‫היי, תראו!
Dialogue: 0,0:10:19.26,0:10:20.68,Main,,0,0,0,,‫אח גדול במגדל הצדק!
Dialogue: 0,0:10:20.68,0:10:22.55,Main,,0,0,0,,‫יופי! הוא בסדר!
Dialogue: 0,0:10:22.55,0:10:24.26,Main,,0,0,0,,‫זה אח{\i1} גדול{\i0}!
Dialogue: 0,0:10:24.26,0:10:25.61,Main,,0,0,0,,‫אח!
Dialogue: 0,0:10:25.61,0:10:27.77,Main,,0,0,0,,‫באנו להציל אות{\i1}ך{\i0}!
Dialogue: 0,0:10:27.77,0:10:31.19,Main,,0,0,0,,‫באנו עם כובע הקש!
Dialogue: 0,0:10:33.99,0:10:35.19,Main,,0,0,0,,‫אח!
Dialogue: 0,0:10:35.19,0:10:37.07,Main,,0,0,0,,‫בוא הביתה איתנו!
Dialogue: 0,0:10:37.07,0:10:39.93,Main,,0,0,0,,‫אתה פצוע?!
Dialogue: 0,0:10:39.93,0:10:42.74,Main,,0,0,0,,‫א... אתם באמת...
Dialogue: 0,0:10:42.74,0:10:44.68,Main,,0,0,0,,‫אתם אידיוטים...
Dialogue: 0,0:10:45.07,0:10:47.24,Main,,0,0,0,,‫מי ביקש מכם לבוא...
Dialogue: 0,0:10:47.79,0:10:51.28,Main,,0,0,0,,‫לבוא להציל אותי?!
Dialogue: 0,0:10:55.34,0:10:57.04,Main,,0,0,0,,‫אתם אידיוטים!
Dialogue: 0,0:10:57.04,0:11:00.28,Main,,0,0,0,,‫מנוולים! אני לא בוכה!
Dialogue: 0,0:11:08.60,0:11:11.17,Main,,0,0,0,,‫שתוק אתה, מנוול!
Dialogue: 0,0:11:11.61,0:11:13.19,Main,,0,0,0,,‫מה אתה, שד?!
Dialogue: 0,0:11:13.19,0:11:14.77,Main,,0,0,0,,‫רובין מחכה!
Dialogue: 0,0:11:16.65,0:11:18.53,Main,,0,0,0,,‫אה, כן, נכון.
Dialogue: 0,0:11:18.53,0:11:20.28,Main,,0,0,0,,‫מהר, מנוולים!
Dialogue: 0,0:11:20.28,0:11:21.38,Main,,0,0,0,,‫נכון מאוד!
Dialogue: 0,0:11:24.24,0:11:26.32,Main,,0,0,0,,‫א-כן, אתה צודק.
Dialogue: 0,0:11:26.32,0:11:29.87,Main,,0,0,0,,‫אני אוהב אותך גם ככה,\N‫כשאת לא עקבית, נאמי{\i1}{\i0}!
Dialogue: 0,0:11:29.87,0:11:31.87,Main,,0,0,0,,‫היי, כובע קש!
Dialogue: 0,0:11:36.41,0:11:38.30,Main,,0,0,0,,‫אבל הפעם,
Dialogue: 0,0:11:38.30,0:11:40.31,Main,,0,0,0,,‫אני, הבוס שלהם, פרנקי הגדול,
Dialogue: 0,0:11:43.30,0:11:45.05,Main,,0,0,0,,‫עשו מה שתרצו!
Dialogue: 0,0:11:53.64,0:11:55.49,Main,,0,0,0,,‫קטי פלאם...
Dialogue: 0,0:11:56.29,0:11:58.58,Main,,0,0,0,,‫איך אתה מעז...
Dialogue: 0,0:12:00.12,0:12:02.32,Main,,0,0,0,,‫לשרוף את התרשימים שלי?!
Dialogue: 0,0:12:11.74,0:12:14.21,Main,,0,0,0,,‫אה! אח!
Dialogue: 0,0:12:14.79,0:12:19.17,Main,,0,0,0,,‫אח גדול נופל אל המפל!
Dialogue: 0,0:12:19.17,0:12:21.23,Main,,0,0,0,,‫פרנקי!
Dialogue: 0,0:12:22.88,0:12:24.57,Main,,0,0,0,,‫מה?! קוקורו{\i1}{\i0}?!
Dialogue: 0,0:12:28.11,0:12:29.41,Main,,0,0,0,,‫עוד מעט.
Dialogue: 0,0:12:31.35,0:12:34.60,Main,,0,0,0,,‫חצי הדרך זה מספיק!
Dialogue: 0,0:12:34.60,0:12:36.81,Main,,0,0,0,,‫נגיע לשם בעוד ארבע שניות.
Dialogue: 0,0:12:38.23,0:12:39.71,Main,,0,0,0,,‫מה זה לעזאזל?!
Dialogue: 0,0:12:42.64,0:12:45.16,Main,,0,0,0,,‫זה... מקודם...!
Dialogue: 0,0:12:46.74,0:12:48.22,Main,,0,0,0,,‫זו הסבתא?
Dialogue: 0,0:12:48.22,0:12:49.26,Main,,0,0,0,,‫למה היא התכוונה?
Dialogue: 0,0:12:49.26,0:12:50.33,Main,,0,0,0,,‫אין לי מושג.
Dialogue: 0,0:12:59.13,0:13:00.77,Main,,0,0,0,,‫א-רכבת הים?!
Dialogue: 0,0:13:00.77,0:13:02.53,Main,,0,0,0,,‫למה היא בבית המשפט?!
Dialogue: 0,0:13:04.09,0:13:07.11,Main,,0,0,0,,‫ארובה, בואי תשטפי את הגרון הזה.
Dialogue: 0,0:13:07.11,0:13:08.43,Main,,0,0,0,,‫בסדר!
Dialogue: 0,0:13:11.92,0:13:13.52,Main,,0,0,0,,‫זה נשמע כמו רכבת ים...
Dialogue: 0,0:13:16.49,0:13:18.44,Main,,0,0,0,,‫מה פשר החיוך הזה?
Dialogue: 0,0:13:18.79,0:13:19.95,Main,,0,0,0,,‫שופט ראשי!
Dialogue: 0,0:13:19.95,0:13:21.94,Main,,0,0,0,,‫בבקשה תצא מכאן!
Dialogue: 0,0:13:23.11,0:13:25.15,Main,,0,0,0,,‫עצרי!
Dialogue: 0,0:13:36.35,0:13:37.67,Main,,0,0,0,,‫קדימה!
Dialogue: 0,0:13:38.20,0:13:40.00,Main,,0,0,0,,‫ידעתי!
Dialogue: 0,0:13:43.92,0:13:45.88,Main,,0,0,0,,‫לא!
Dialogue: 0,0:13:48.02,0:13:50.99,Main,,0,0,0,,‫רוקטמן עוד מסוגלת לדהור!
Dialogue: 0,0:13:50.99,0:13:54.46,Main,,0,0,0,,‫אל תזלזל בעובדים של תום,
Dialogue: 0,0:13:54.46,0:13:56.56,Main,,0,0,0,,‫בנאי הספינות האגדי!
Dialogue: 0,0:14:00.44,0:14:01.94,Main,,0,0,0,,‫א-רוקטמן?!
Dialogue: 0,0:14:07.86,0:14:09.82,Main,,0,0,0,,‫היא עפה שוב!
Dialogue: 0,0:14:24.13,0:14:25.40,Main,,0,0,0,,‫מה?!
Dialogue: 0,0:14:25.40,0:14:27.59,Main,,0,0,0,,‫הם באים!
Dialogue: 0,0:14:32.51,0:14:33.98,Main,,0,0,0,,‫זה מפל!
Dialogue: 0,0:14:37.91,0:14:40.68,Thoughts,,0,0,0,,‫זה מעלה זיכרונות,\N‫נכון, תום{\i1}{\i0}?
Dialogue: 0,0:14:44.33,0:14:47.61,Flashbacks,,0,0,0,,‫על העזרה לאותו בחור, רוג'ר...
Dialogue: 0,0:14:47.61,0:14:51.28,Flashbacks,,0,0,0,,‫אני באמת גאה שעשיתי את זה!
Dialogue: 0,0:14:51.28,0:14:52.37,Flashbacks,,0,0,0,,‫אני לופי.
Dialogue: 0,0:14:54.22,0:14:54.85,Flashbacks,,0,0,0,,‫באמת?!
Dialogue: 0,0:14:54.85,0:14:55.37,Flashbacks,,0,0,0,,‫כן.
Dialogue: 0,0:14:56.81,0:14:59.29,Thoughts,,0,0,0,,‫רוג'ר...
Dialogue: 0,0:15:02.82,0:15:07.06,Thoughts,,0,0,0,,‫ועזרת לו.
Dialogue: 0,0:15:07.06,0:15:08.99,Thoughts,,0,0,0,,‫נראה שלא למדנו את הלקח.
Dialogue: 0,0:15:16.74,0:15:20.73,Thoughts,,0,0,0,,‫היית עושה אותו דבר,\N‫נכון, תום{\i1}{\i0}?
Dialogue: 0,0:15:29.54,0:15:31.54,Main,,0,0,0,,‫אנחנו עומדים לפגוע בקיר!
Dialogue: 0,0:15:31.54,0:15:34.07,Main,,0,0,0,,‫א-אנחנו עומדים להתרסק!
Dialogue: 0,0:15:50.16,0:15:51.80,Main,,0,0,0,,‫הוא חמק!
Dialogue: 0,0:16:07.17,0:16:08.32,Main,,0,0,0,,‫הם כאן...
Dialogue: 0,0:16:08.32,0:16:09.81,Main,,0,0,0,,‫הם כאן!
Dialogue: 0,0:16:09.81,0:16:11.21,Main,,0,0,0,,‫לעזאזל!
Dialogue: 0,0:16:11.21,0:16:12.68,Main,,0,0,0,,‫היי, בואו אחריי!
Dialogue: 0,0:16:20.58,0:16:24.00,Main,,0,0,0,,‫עכשיו, אני משחרר אתכם, CP9!
Dialogue: 0,0:16:32.97,0:16:35.48,Main,,0,0,0,,‫לוצ'י! בוא איתי!
Dialogue: 0,0:16:37.93,0:16:39.28,Main,,0,0,0,,‫הבנת?!
Dialogue: 0,0:16:39.28,0:16:40.92,Main,,0,0,0,,‫פאנקפריד!
Dialogue: 0,0:16:54.20,0:16:57.87,Captions,,0,0,275,,‫חרב הפיל\N‫פאנקפריד\N‫פרי הפיל-פיל{\fad(500,0)}
Dialogue: 0,0:17:06.47,0:17:08.96,Main,,0,0,0,,‫עכשיו, בואו נצא לשערי הצדק!
Dialogue: 0,0:17:13.57,0:17:15.36,Main,,0,0,0,,‫אח גדול פרנקי בסדר!
Dialogue: 0,0:17:19.04,0:17:21.31,Main,,0,0,0,,‫אח גדול כבר לא שבוי!
Dialogue: 0,0:17:21.31,0:17:23.12,Main,,0,0,0,,‫נראה שהוא מצטרף לקרב!
Dialogue: 0,0:17:25.42,0:17:27.98,Main,,0,0,0,,‫תכסח אותם, אח!
Dialogue: 0,0:17:27.98,0:17:30.73,Main,,0,0,0,,‫קדימה! כובע קש!
Dialogue: 0,0:17:36.85,0:17:38.78,Main,,0,0,0,,‫היי, אתם בסדר?!
Dialogue: 0,0:17:40.79,0:17:42.66,Main,,0,0,0,,‫בשביל מה באת לכאן,
Dialogue: 0,0:17:46.44,0:17:48.83,Main,,0,0,0,,‫א-טוב, זה הציל גם אותי, אבל...
Dialogue: 0,0:17:51.00,0:17:53.70,Main,,0,0,0,,‫היי! אני מחזיק אותך! אל תמות!
Dialogue: 0,0:17:53.70,0:17:55.79,Main,,0,0,0,,‫אל תמות!
Dialogue: 0,0:18:08.05,0:18:09.45,Main,,0,0,0,,‫יש לי דימום מהאף.
Dialogue: 0,0:18:13.13,0:18:15.41,Main,,0,0,0,,‫יופי! הגענו!
Dialogue: 0,0:18:16.86,0:18:17.86,Main,,0,0,0,,‫כובע קש...!
Dialogue: 0,0:18:17.86,0:18:19.13,Main,,0,0,0,,‫שלום!
Dialogue: 0,0:18:19.13,0:18:21.57,Main,,0,0,0,,‫תודה, סבתא המפלצת!
Dialogue: 0,0:18:24.31,0:18:25.99,Main,,0,0,0,,‫זה היה כלום!
Dialogue: 0,0:18:26.67,0:18:29.40,Main,,0,0,0,,‫אתה מגומי. אל תכניס אותנו לזה איתך.
Dialogue: 0,0:18:32.90,0:18:34.67,Main,,0,0,0,,‫אתה חושב שאנחנו בסדר...?
Dialogue: 0,0:18:35.46,0:18:40.61,Main,,0,0,0,,‫אין מצב!
Dialogue: 0,0:18:40.61,0:18:42.14,Main,,0,0,0,,‫כן, כולם בסדר.
Dialogue: 0,0:18:42.14,0:18:44.85,Main,,0,0,0,,‫גם אתם כולכם מוזרים, אז...
Dialogue: 0,0:18:44.85,0:18:46.64,Main,,0,0,0,,‫רק אומר.
Dialogue: 0,0:18:46.64,0:18:48.30,Main,,0,0,0,,‫יש שם מדרגות!
Dialogue: 0,0:18:48.30,0:18:50.20,Main,,0,0,0,,‫בואו נמהר ונחזיר את רובין!
Dialogue: 0,0:18:57.74,0:18:58.90,Main,,0,0,0,,‫חכו.
Dialogue: 0,0:19:00.93,0:19:02.07,Main,,0,0,0,,‫מה כל זה?!
Dialogue: 0,0:19:02.07,0:19:03.99,Main,,0,0,0,,‫צ'פפפפ...
Dialogue: 0,0:19:03.99,0:19:06.40,Main,,0,0,0,,‫הצלחתם לפרוץ פנימה.
Dialogue: 0,0:19:08.52,0:19:10.62,Main,,0,0,0,,‫ניקו רובין כבר לא שם,
Dialogue: 0,0:19:13.37,0:19:14.41,Main,,0,0,0,,‫מה?!
Dialogue: 0,0:19:14.41,0:19:16.90,Main,,0,0,0,,‫אה, וגם הראש שלנו שם.
Dialogue: 0,0:19:19.32,0:19:20.17,Main,,0,0,0,,‫אה, באמת?!
Dialogue: 0,0:19:22.82,0:19:25.43,Main,,0,0,0,,‫צ'פפפ... שוב פלטתי סוד...
Dialogue: 0,0:19:25.87,0:19:27.64,Main,,0,0,0,,‫איזה בחור מצחיק.
Dialogue: 0,0:19:27.64,0:19:28.80,Main,,0,0,0,,‫אה, טוב...
Dialogue: 0,0:19:28.80,0:19:30.92,Main,,0,0,0,,‫הם בדרך לשם עכשיו,
Dialogue: 0,0:19:30.92,0:19:32.91,Main,,0,0,0,,‫אבל לא אגיד לכם איך להגיע,
Dialogue: 0,0:19:35.78,0:19:39.74,Main,,0,0,0,,‫יש לנו פקודה להשמיד אתכם.
Dialogue: 0,0:19:39.74,0:19:41.61,Thoughts,,0,0,0,,‫פקודת השמדה...?
Dialogue: 0,0:19:41.61,0:19:44.82,Main,,0,0,0,,‫אלא אם תביסו אותנו,
Dialogue: 0,0:19:47.82,0:19:48.61,Main,,0,0,0,,‫כן.
Dialogue: 0,0:19:51.29,0:19:52.44,Main,,0,0,0,,‫צ'פפפ...
Dialogue: 0,0:19:52.44,0:19:54.72,Main,,0,0,0,,‫איזה בחור נלהב.
Dialogue: 0,0:19:54.72,0:19:57.00,Main,,0,0,0,,‫אבל תן לי להגיד לך עוד דבר אחד.
Dialogue: 0,0:19:57.00,0:19:59.02,Main,,0,0,0,,‫מה?! עשה מה שאתה רוצה.
Dialogue: 0,0:19:59.02,0:20:01.87,Main,,0,0,0,,‫אה, תודה.
Dialogue: 0,0:20:01.87,0:20:03.72,Main,,0,0,0,,‫אז אדבר בגלוי.
Dialogue: 0,0:20:04.30,0:20:05.97,Main,,0,0,0,,‫תראה את זה!
Dialogue: 0,0:20:05.97,0:20:07.40,Main,,0,0,0,,‫מפתח?
Dialogue: 0,0:20:07.40,0:20:08.43,Main,,0,0,0,,‫בשביל מה?!
Dialogue: 0,0:20:09.16,0:20:11.69,Main,,0,0,0,,‫זה המפתח שפותח...
Dialogue: 0,0:20:11.69,0:20:14.73,Main,,0,0,0,,‫את אזיקי אבן הים על ניקו רובין!
Dialogue: 0,0:20:14.73,0:20:16.08,Main,,0,0,0,,‫אבן ים?
Dialogue: 0,0:20:22.93,0:20:26.08,Main,,0,0,0,,‫אז לכן רובין לא נאבקת עכשיו,
Dialogue: 0,0:20:26.08,0:20:27.78,Main,,0,0,0,,‫למרות כמה חזקה היא באמת.
Dialogue: 0,0:20:27.78,0:20:29.09,Main,,0,0,0,,‫כן.
Dialogue: 0,0:20:29.09,0:20:30.73,Main,,0,0,0,,‫בנסיבות רגילות,
Dialogue: 0,0:20:34.47,0:20:36.42,Main,,0,0,0,,‫היא בטוח מתוסכלת.
Dialogue: 0,0:20:36.42,0:20:37.96,Main,,0,0,0,,‫הבנתי.
Dialogue: 0,0:20:44.90,0:20:48.43,Main,,0,0,0,,‫האזיקים יישארו עליה לנצח.
Dialogue: 0,0:20:49.04,0:20:50.50,Main,,0,0,0,,‫צ'פפפ...
Dialogue: 0,0:20:50.50,0:20:52.02,Main,,0,0,0,,‫שוב פלטתי סוד.
Dialogue: 0,0:20:52.46,0:20:54.35,Main,,0,0,0,,‫הוא באמת מצחיק.
Dialogue: 0,0:20:58.59,0:21:01.03,Main,,0,0,0,,‫צ'פפפפפפ!
Dialogue: 0,0:21:01.35,0:21:02.99,Main,,0,0,0,,‫טוב, אז...
Dialogue: 0,0:21:03.34,0:21:06.36,Main,,0,0,0,,‫תן לנו את זה!
Dialogue: 0,0:21:13.35,0:21:14.96,Main,,0,0,0,,‫אל תיחפז כל כך.
Dialogue: 0,0:21:15.31,0:21:18.56,Main,,0,0,0,,‫לא אמרתי שזה המפתח הנכון.
Dialogue: 0,0:21:18.56,0:21:20.97,Main,,0,0,0,,‫מה?!
Dialogue: 0,0:21:22.38,0:21:25.55,Main,,0,0,0,,‫אולי הוא...
Dialogue: 0,0:21:25.55,0:21:28.46,Main,,0,0,0,,‫מתאים לאזיקים אחרים.
Dialogue: 0,0:21:28.46,0:21:30.70,Main,,0,0,0,,‫צ'פפפ אבא!
Dialogue: 0,0:21:31.39,0:21:33.81,Main,,0,0,0,,‫יש חמישה חברי CP9,
Dialogue: 0,0:21:33.81,0:21:38.63,Main,,0,0,0,,‫כולל אותי, במגדל הזה.
Dialogue: 0,0:21:38.63,0:21:42.25,Main,,0,0,0,,‫לכל אחד יש מפתח...
Dialogue: 0,0:21:39.85,0:21:42.25,Secondary,,0,0,0,,‫אחת, שתיים, קדימה!
Dialogue: 0,0:21:42.25,0:21:46.24,Main,,0,0,0,,‫והוא ממתין לכם.
Dialogue: 0,0:21:42.25,0:21:44.69,Secondary,,0,0,0,,‫אחת, שתיים, אש!
Dialogue: 0,0:21:45.22,0:21:46.24,Secondary,,0,0,0,,‫יו?!
Dialogue: 0,0:21:49.33,0:21:51.54,Main,,0,0,0,,‫תנסו אותם על האזיקים של רובין,
Dialogue: 0,0:21:53.83,0:21:56.51,Main,,0,0,0,,‫כמה טיפשי... מנסה למשוך זמן?
Dialogue: 0,0:21:56.51,0:21:57.98,Main,,0,0,0,,‫בזמן שאנחנו עוצרים כאן,
Dialogue: 0,0:21:57.98,0:22:01.35,Main,,0,0,0,,‫אתם, החבורה, מנסים לקחת את רובין-{\i1}צ'אן{\i0}\N‫לשערי הצדק, נכון?!
Dialogue: 0,0:22:08.81,0:22:11.23,Main,,0,0,0,,‫בואו נתעלם מהמוזר הזה ונמהר!
Dialogue: 0,0:22:11.23,0:22:12.06,Main,,0,0,0,,‫צ'פ!
Dialogue: 0,0:22:12.06,0:22:17.64,Note,,0,0,0,,‫המוזר הזה
Dialogue: 0,0:22:12.54,0:22:13.90,Main,,0,0,0,,‫צ'פפפ!
Dialogue: 0,0:22:13.90,0:22:16.28,Main,,0,0,0,,‫אתה חכם.
Dialogue: 0,0:22:16.28,0:22:18.57,Main,,0,0,0,,‫אבל אם תעשו את זה,
Dialogue: 0,0:22:25.61,0:22:28.39,Main,,0,0,0,,‫אנחנו נותנים לכם הזדמנות.
Dialogue: 0,0:22:28.39,0:22:28.95,Main,,0,0,0,,‫להתראות.
Dialogue: 0,0:22:29.46,0:22:31.53,Main,,0,0,0,,‫אה! חכה, נבל שכמוך!
Dialogue: 0,0:22:31.53,0:22:32.74,Main,,0,0,0,,‫היי, חכה!
Dialogue: 0,0:22:33.64,0:22:35.89,Main,,0,0,0,,‫עצור כבר, לעזאזל!
Dialogue: 0,0:22:36.91,0:22:39.34,Main,,0,0,0,,‫חכה! עוד רגע!
Dialogue: 0,0:22:43.10,0:22:45.85,Main,,0,0,0,,‫אה! תעזוב אותי!
Dialogue: 0,0:22:45.85,0:22:48.25,Main,,0,0,0,,‫תירגע, כובע קש{\i1}{\i0}.
Dialogue: 0,0:22:48.25,0:22:51.09,Secondary,,0,0,0,,‫תעזוב אותי!
Dialogue: 0,0:22:48.78,0:22:51.09,Main,,0,0,0,,‫לוצ'י זה הבחור היוני הזה?
Dialogue: 0,0:22:51.09,0:22:53.16,Main,,0,0,0,,‫כן, נכון.
Dialogue: 0,0:22:53.16,0:22:55.97,Main,,0,0,0,,‫אם הוא עם רובין,
Dialogue: 0,0:22:59.23,0:23:00.42,Main,,0,0,0,,‫לופי.
Dialogue: 0,0:23:02.98,0:23:05.50,Main,,0,0,0,,‫תעזוב אותי! תעזוב אותי!
Dialogue: 0,0:23:05.50,0:23:08.38,Main,,0,0,0,,‫אנחנו שישה חוץ מלופי.
Dialogue: 0,0:23:08.38,0:23:11.26,Main,,0,0,0,,‫הוא אמר שיש כאן חמישה חברי CP9.
Dialogue: 0,0:23:11.26,0:23:15.14,Main,,0,0,0,,‫נשיג מהם את חמשת המפתחות לאזיקים\N‫של רובין-{\i1}צ'אן{\i0} ונרדוף אחרי לופי.
Dialogue: 0,0:23:16.40,0:23:19.02,Main,,0,0,0,,‫אם רובין{\i1}{\i0} תעבור את\N‫השערים, הכל ייגמר.
Dialogue: 0,0:23:19.02,0:23:21.62,Main,,0,0,0,,‫זה מרוץ נגד הזמן!
Dialogue: 0,0:23:26.75,0:23:28.88,Main,,0,0,0,,‫כולם! נצחו בכל מחיר!
Dialogue: 0,0:23:28.88,0:23:29.99,Main,,0,0,0,,‫כן!
Dialogue: 0,0:23:29.99,0:23:32.84,Main,,0,0,0,,‫בהצלחה!
Dialogue: 0,0:23:33.37,0:23:37.10,Main,,0,0,0,,‫חבר'ה פיראטים!
Dialogue: 0,0:23:41.67,0:23:43.80,Main,,0,0,0,,‫ארובה? גונבה?
Dialogue: 0,0:23:43.80,0:23:45.90,Main,,0,0,0,,‫לאן הם הלכו?
Dialogue: 0,0:23:45.90,0:23:48.94,Main,,0,0,0,,‫הם היו כאן רק לפני רגע!
Dialogue: 0,0:23:49.32,0:23:51.24,Main,,0,0,0,,‫אני בטוח שאתפוס אותם איפשהו!
Dialogue: 0,0:23:54.62,0:23:57.24,Main,,0,0,0,,‫רובין!
Dialogue: 0,0:24:00.05,0:24:02.08,Main,,0,0,0,,‫עזרה לא תבוא, ניקו רובין.
Dialogue: 0,0:24:14.97,0:24:17.81,Main,,0,0,0,,‫קדימה! נבל יוני שכמוך!
Dialogue: 0,0:24:17.81,0:24:20.31,Main,,0,0,0,,‫זה לא טוב... לפני שאני מתחיל...
Dialogue: 0,0:24:20.31,0:24:22.85,Main,,0,0,0,,‫איפה המטבח?!
Dialogue: 0,0:24:29.54,0:24:32.36,Main,,0,0,0,,‫רוקנתי יותר משני בקבוקים היום!
Dialogue: 0,0:24:38.08,0:24:40.04,Main,,0,0,0,,‫האזור הזה נראה כמו מטבח!
Dialogue: 0,0:24:46.77,0:24:50.36,Main,,0,0,0,,‫צ'פפפפפ...
Dialogue: 0,0:24:50.36,0:24:52.21,Main,,0,0,0,,‫אני "פוקורו השתקן"...
Dialogue: 0,0:24:52.21,0:24:54.13,Main,,0,0,0,,‫אני מת על רכילות!
Dialogue: 0,0:24:54.57,0:24:56.10,Main,,0,0,0,,‫אתה רוצה את המפתח?
Dialogue: 0,0:24:56.10,0:24:57.11,Main,,0,0,0,,‫לעזאזל!
Dialogue: 0,0:24:57.11,0:24:58.85,Main,,0,0,0,,‫עוד לא מילאתי את הקולה שלי!
Dialogue: 0,0:24:58.85,0:25:00.36,Main,,0,0,0,,‫צ'פ...!
Dialogue: 0,0:25:12.68,0:25:14.52,Main,,0,0,0,,‫אף אחד לא היה שם.
Dialogue: 0,0:25:18.21,0:25:19.43,Main,,0,0,0,,‫אף אחד לא כאן.
Dialogue: 0,0:25:21.75,0:25:23.16,Main,,0,0,0,,‫הממ, גם לא כאן.
Dialogue: 0,0:25:25.59,0:25:26.87,Main,,0,0,0,,‫טוב, אף אחד לא כאן.
Dialogue: 0,0:25:31.26,0:25:33.40,Thoughts,,0,0,0,,‫אם אין כאן אף אחד, זה בסדר.
Dialogue: 0,0:25:38.79,0:25:40.88,Main,,0,0,0,,‫הם בטח פחדו ממני...
Dialogue: 0,0:25:40.88,0:25:42.97,Main,,0,0,0,,‫אה...!
Dialogue: 0,0:25:43.36,0:25:44.93,Thoughts,,0,0,0,,‫יש כאן מישהו!
Dialogue: 0,0:25:50.40,0:25:51.97,Main,,0,0,0,,‫הוא ישן...
Dialogue: 0,0:25:52.75,0:25:54.70,Main,,0,0,0,,‫גם הוא חלק מ-CP9?
Dialogue: 0,0:26:14.26,0:26:16.47,Main,,0,0,0,,‫יויוי!
Dialogue: 0,0:26:16.98,0:26:20.51,Main,,0,0,0,,‫אתה פיראט, לעזאזל!
Dialogue: 0,0:26:26.62,0:26:30.10,Main,,0,0,0,,‫חכה...
Dialogue: 0,0:26:30.10,0:26:34.65,Main,,0,0,0,,‫שנייה...!
Dialogue: 0,0:26:36.69,0:26:37.99,Main,,0,0,0,,‫יויוי!
Dialogue: 0,0:26:42.45,0:26:44.08,Thoughts,,0,0,0,,‫כמה מעצבן...
Dialogue: 0,0:26:44.08,0:26:45.95,Main,,0,0,0,,‫מה עם החדר הזה?!
Dialogue: 0,0:26:48.76,0:26:50.34,Main,,0,0,0,,‫לעזאזל...
Dialogue: 0,0:26:50.95,0:26:53.00,Main,,0,0,0,,‫גם כאן אין אף אחד.
Dialogue: 0,0:27:01.63,0:27:03.60,Main,,0,0,0,,‫בבקשה, תרגיש בבית.
Dialogue: 0,0:27:05.81,0:27:09.27,Main,,0,0,0,,‫שאני... אכין קצת תה?
Dialogue: 0,0:27:23.79,0:27:25.87,Main,,0,0,0,,‫כן, בבקשה!
Dialogue: 0,0:27:35.78,0:27:38.34,Main,,0,0,0,,‫כבר שלפת את החרבות שלך?
