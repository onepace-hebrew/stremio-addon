Dialogue: 0,0:00:00.00,0:00:05.00,Main-207-,,0,0,0,,{\an8}‫תרגום לעברית — That One Gerbil
Dialogue: 0,0:01:43.54,0:01:45.41,Main-207-,,0,0,0,,‫יש דו-קרב!
Dialogue: 0,0:01:46.52,0:01:49.48,Main-207-,,0,0,0,,‫הגנרליסימו יילחם\N‫נגד הנסיך המפורסם סאנג'י!
Dialogue: 0,0:01:49.48,0:01:50.71,Main-207-,,0,0,0,,‫הנסיך סאנג'י?
Dialogue: 0,0:01:50.71,0:01:52.54,Main-207-,,0,0,0,,‫איזה סוג של בחור הוא?!
Dialogue: 0,0:01:52.54,0:01:54.67,Main-207-,,0,0,0,,‫כל מה שאנחנו יודעים זה איך הוא נראה!
Dialogue: 0,0:02:01.14,0:02:03.98,Main-207-,,0,0,0,,‫שמעתי שהוא עדיין מסרב להתחתן,
Dialogue: 0,0:02:03.98,0:02:05.93,Main-207-,,0,0,0,,‫אז ניסיתי ללמד אותו\N‫שיעור בשם אבא.
Dialogue: 0,0:02:05.93,0:02:08.73,Main-207-,,0,0,0,,‫בדיוק כמו פעם.
Dialogue: 0,0:02:08.73,0:02:13.98,Main-207-,,0,0,0,,‫וזה מה שקרה!\N‫הוא ישלם על זה! סאנג'י, הנבל הזה!
Dialogue: 0,0:02:13.98,0:02:17.61,Main-207-,,0,0,0,,‫לא, הוד מעלתך, פטיש לא יעזור כאן.
Dialogue: 0,0:02:25.61,0:02:28.90,Main-207-,,0,0,0,,‫אני הולך ללחוץ. עמוד בשקט.
Dialogue: 0,0:02:31.88,0:02:33.80,Main-207-,,0,0,0,,‫תוקן.
Dialogue: 0,0:02:37.34,0:02:43.18,Main-207-,,0,0,0,,‫לעזאזל!\N‫הנבל הזה! הוא סתם כישלון...
Dialogue: 0,0:02:46.18,0:02:48.83,Main-207-,,0,0,0,,‫אז זה הנסיך סאנג'י!
Dialogue: 0,0:02:53.40,0:02:55.57,Main-207-,,0,0,0,,‫אתה מוכן?
Dialogue: 0,0:02:57.03,0:02:58.61,Main-207-,,0,0,0,,‫מתי שתרצה.
Dialogue: 0,0:02:58.61,0:02:59.70,Main-207-,,0,0,0,,‫בסדר!
Dialogue: 0,0:03:01.28,0:03:02.87,Main-207-,,0,0,0,,‫הנה אני בא!
Dialogue: 0,0:03:21.43,0:03:22.82,Main-207-,,0,0,0,,‫איזה מהירות!
Dialogue: 0,0:03:22.82,0:03:26.76,Main-207-,,0,0,0,,‫בדיוק מה שהיית מצפה ממנו\N‫מפיראט מבוקש!
Dialogue: 0,0:03:41.36,0:03:43.90,Main-207-,,0,0,0,,‫איך אתה מעז לבעוט באביך האמיתי!
Dialogue: 0,0:03:44.12,0:03:46.70,Main-207-,,0,0,0,,‫תפסיק! אתה התחלת את זה!
Dialogue: 0,0:03:46.70,0:03:50.83,Main-207-,,0,0,0,,‫ותפסיק לומר\N‫שאתה האבא שלי!
Dialogue: 0,0:03:52.83,0:03:56.70,Main-207-,,0,0,0,,‫אתה הבן שלי שחזר! סאנג'י!
Dialogue: 0,0:03:56.70,0:03:59.42,Main-207-,,0,0,0,,‫אל תגיד את זה בזמן שאתה תוקף אותי!
Dialogue: 0,0:03:59.49,0:04:00.82,Main-207-,,0,0,0,,‫הוא חזק!
Dialogue: 0,0:04:00.82,0:04:03.40,Main-207-,,0,0,0,,‫אפילו אין לו חליפת פשיטה!
Dialogue: 0,0:04:04.43,0:04:08.76,Main-207-,,0,0,0,,‫אחזור לאנייה הפיראטית שלי\N‫ברגע שמסיבת התה תסתיים.
Dialogue: 0,0:04:08.76,0:04:10.64,Main-207-,,0,0,0,,‫אני רק אעמיד פנים שאני מתחתן איתה!
Dialogue: 0,0:04:10.64,0:04:12.23,Main-207-,,0,0,0,,‫אתה עדיין אומר את זה?!
Dialogue: 0,0:04:14.90,0:04:19.73,Main-207-,,0,0,0,,‫אתם רק רוצים את הקשר בינכם\N‫לבין ביג מאם, נכון?
Dialogue: 0,0:04:19.73,0:04:22.45,Main-207-,,0,0,0,,‫אז לא משנה לי איפה אני אגמור!
Dialogue: 0,0:04:22.86,0:04:24.52,Main-207-,,0,0,0,,‫אתה לא יכול לעשות את זה!
Dialogue: 0,0:04:24.52,0:04:27.12,Main-207-,,0,0,0,,‫זה ייראה כ\N‫בגידה של משפחת וינסמוק!
Dialogue: 0,0:04:27.12,0:04:29.79,Main-207-,,0,0,0,,‫אתה חושב שביג מאם תסכים לזה?!
Dialogue: 0,0:04:29.79,0:04:34.20,Main-207-,,0,0,0,,‫לא אכפת לי מה יקרה לכם אחר כך.
Dialogue: 0,0:04:34.20,0:04:38.21,Main-207-,,0,0,0,,‫באתי לכאן רק כדי להגן על החברים שלי!
Dialogue: 0,0:04:38.21,0:04:40.55,Main-207-,,0,0,0,,‫אתה תנטוש את המשפחה שלך?!
Dialogue: 0,0:04:41.80,0:04:45.26,Main-207-,,0,0,0,,‫אתם לא המשפחה שלי!
Dialogue: 0,0:04:48.47,0:04:50.92,Flashbacks-207-,,0,0,0,,‫הוא היה במטבח, כמו שחשבתי.
Dialogue: 0,0:04:50.92,0:04:54.78,Flashbacks-207-,,0,0,0,,‫הוא שוב הכין אוכל לחולדות!
Dialogue: 0,0:04:56.85,0:04:59.70,Flashbacks-207-,,0,0,0,,‫בני מלוכה אסור לבשל.
Dialogue: 0,0:05:00.44,0:05:03.44,Flashbacks-207-,,0,0,0,,‫שתוק! תחזיר את זה!
Dialogue: 0,0:05:04.49,0:05:06.74,Flashbacks-207-,,0,0,0,,‫אאוץ'...
Dialogue: 0,0:05:09.41,0:05:11.06,Flashbacks-207-,,0,0,0,,‫אידיוט!
Dialogue: 0,0:05:11.06,0:05:13.25,Flashbacks-207-,,0,0,0,,‫אל תיגע בי!
Dialogue: 0,0:05:15.24,0:05:17.63,Flashbacks-207-,,0,0,0,,‫הוא כל כך חלש ומסכן!
Dialogue: 0,0:05:17.63,0:05:19.54,Flashbacks-207-,,0,0,0,,‫כולנו נולדנו באותו יום!
Dialogue: 0,0:05:19.88,0:05:22.50,Flashbacks-207-,,0,0,0,,‫למה אתה כזה כישלון, בעוד שאנחנו לא?!
Dialogue: 0,0:05:33.77,0:05:35.56,Flashbacks-207-,,0,0,0,,‫כישלון!
Dialogue: 0,0:05:48.15,0:05:50.53,Flashbacks-207-,,0,0,0,,‫אה, אבא!
Dialogue: 0,0:05:52.08,0:05:54.24,Flashbacks-207-,,0,0,0,,‫אתם שוב מכים את סאנג'י?
Dialogue: 0,0:05:57.48,0:05:59.38,Flashbacks-207-,,0,0,0,,‫עזרו לי!
Dialogue: 0,0:06:00.46,0:06:02.21,Flashbacks-207-,,0,0,0,,‫אבא!
Dialogue: 0,0:06:03.76,0:06:05.36,Flashbacks-207-,,0,0,0,,‫למה?
Dialogue: 0,0:06:06.88,0:06:10.09,Flashbacks-207-,,0,0,0,,‫"למה?"
Dialogue: 0,0:06:10.09,0:06:15.10,Flashbacks-207-,,0,0,0,,‫אני לא חושב שתהיה חייל טוב בעתיד.
Dialogue: 0,0:06:15.10,0:06:19.35,Flashbacks-207-,,0,0,0,,‫אין לי שום חובה לעזור לך,\N‫ואתה לא שווה לגדל.
Dialogue: 0,0:06:25.32,0:06:27.27,Flashbacks-207-,,0,0,0,,‫אבא!
Dialogue: 0,0:06:27.27,0:06:30.66,Flashbacks-207-,,0,0,0,,‫אתה מביש את המשפחה שלנו!
Dialogue: 0,0:06:40.08,0:06:43.13,Flashbacks-207-,,0,0,0,,‫קום! אאמן אותך!
Dialogue: 0,0:06:45.09,0:06:47.88,Flashbacks-207-,,0,0,0,,‫בושה לוינסמוקים!
Dialogue: 0,0:06:47.88,0:06:50.35,Flashbacks-207-,,0,0,0,,‫קדימה, תעשה סיבוב לעברו, יונג'י.
Dialogue: 0,0:06:50.35,0:06:52.09,Flashbacks-207-,,0,0,0,,‫בסדר!
Dialogue: 0,0:07:20.58,0:07:23.60,Main-207-,,0,0,0,,‫נזכרת במשהו?!
Dialogue: 0,0:07:25.17,0:07:27.05,Main-207-,,0,0,0,,‫הוא חסם את הלהב עם הרגל שלו!
Dialogue: 0,0:07:31.59,0:07:34.60,Main-207-,,0,0,0,,‫לחשוב שסאנג'י שהכרתי יכול עכשיו להשתמש בהאקי...
Dialogue: 0,0:07:35.22,0:07:36.72,Main-207-,,0,0,0,,‫תביאו לי חרב!
Dialogue: 0,0:07:36.72,0:07:38.31,Main-207-,,0,0,0,,‫כ-כן, אדוני!
Dialogue: 0,0:07:42.32,0:07:43.44,Main-207-,,0,0,0,,‫קח.
Dialogue: 0,0:07:45.18,0:07:46.60,Main-207-,,0,0,0,,‫מה קרה?
Dialogue: 0,0:07:46.60,0:07:49.40,Main-207-,,0,0,0,,‫חשבתי שלימדתי אותך איך להשתמש בחרב.
Dialogue: 0,0:07:54.45,0:07:59.66,Main-207-,,0,0,0,,‫אני לא הולך להשתמש בידיים שלי לשטויות כאלה.
Dialogue: 0,0:08:08.70,0:08:10.63,Main-207-,,0,0,0,,‫הידיים שלי...
Dialogue: 0,0:08:10.63,0:08:13.55,Main-207-,,0,0,0,,‫הן רק לבישול.
Dialogue: 0,0:08:45.79,0:08:49.71,Main-207-,,0,0,0,,‫אה, אותו סאנג'י חלש וקטן\N‫הפך לחזק כל כך...
Dialogue: 0,0:08:49.71,0:08:52.84,Main-207-,,0,0,0,,‫בישול? זה אבסורד!
Dialogue: 0,0:08:52.84,0:08:58.10,Main-207-,,0,0,0,,‫אתה עדיין מבשל לחולדות?\N‫בני מלוכה לא מספקים שירותים!
Dialogue: 0,0:08:58.10,0:08:59.69,Main-207-,,0,0,0,,‫כמה מביך!
Dialogue: 0,0:09:00.42,0:09:02.18,Main-207-,,0,0,0,,‫זה מגוחך.
Dialogue: 0,0:09:09.15,0:09:13.90,Main-207-,,0,0,0,,‫מה הבעיה שלך עם החתונה הזאת?!
Dialogue: 0,0:09:23.16,0:09:25.02,Main-207-,,0,0,0,,‫לחימת יד-ביד של הגנרליסימו!
Dialogue: 0,0:09:25.02,0:09:27.75,Main-207-,,0,0,0,,‫סגנון הלחימה של האיש\N‫המכונה "גארודה"!
Dialogue: 0,0:09:27.75,0:09:29.84,Main-207-,,0,0,0,,‫נדיר לראות דבר כזה!
Dialogue: 0,0:09:29.84,0:09:33.88,Main-207-,,0,0,0,,‫התקפה אווירית?\N‫אבל זה בדיוק המגרש שלי.
Dialogue: 0,0:09:34.74,0:09:36.95,Main-207-,,0,0,0,attack,{\fad(150,150}Diable Jambe!
Dialogue: 0,0:09:36.95,0:09:38.28,Main-207-,,0,0,0,attack,{\fad(150,150}Collier...
Dialogue: 0,0:09:41.25,0:09:43.16,Main-207-,,0,0,0,attack,{\fad(150,150}Shoot!
Dialogue: 0,0:09:55.07,0:09:58.41,Main-207-,,0,0,0,,‫המלחמה מקדמת את המדע!
Dialogue: 0,0:10:00.34,0:10:02.64,Main-207-,,0,0,0,attack,{\fad(150,150}Electromagnetic Crack!
Dialogue: 0,0:10:04.57,0:10:07.02,Main-207-,,0,0,0,attack,{\fad(150,150}Blaster!
Dialogue: 0,0:10:25.72,0:10:30.84,Main-207-,,0,0,0,,‫הגרמה שהכרת פעם\N‫שייכת לעבר!
Dialogue: 0,0:10:56.08,0:10:57.42,Main-207-,,0,0,0,,‫אז, היי...
Dialogue: 0,0:10:58.04,0:11:00.05,Main-207-,,0,0,0,,‫אפשר לשאול אותך משהו?
Dialogue: 0,0:11:03.89,0:11:08.48,Main-207-,,0,0,0,,‫אתה חושב שהיות הורה ביולוגי\N‫מזכה מישהו בכבוד?
Dialogue: 0,0:11:09.81,0:11:11.65,Main-207-,,0,0,0,,‫אין לך...
Dialogue: 0,0:11:15.04,0:11:19.86,Main-207-,,0,0,0,,‫אפילו זיכרון טוב אחד\N‫ממנו... נכון?
Dialogue: 0,0:11:26.80,0:11:27.99,Main-207-,,0,0,0,,‫אתה...
Dialogue: 0,0:11:28.32,0:11:31.58,Flashbacks-207-,,0,0,0,,‫אבא! תוציא אותי מכאן!
Dialogue: 0,0:11:32.88,0:11:34.66,Main-207-,,0,0,0,,‫...סבלת כל כך הרבה.
Dialogue: 0,0:11:43.34,0:11:47.56,Flashbacks-207-,,0,0,0,,‫אבא! חשוך מדי!
Dialogue: 0,0:11:50.55,0:11:54.00,Main-207-,,0,0,0,,{\fad(150,150}Poêle à Frire...
Dialogue: 0,0:11:54.54,0:11:58.23,Thoughts-207-,,0,0,0,,‫יש לך רק איבה כלפיו.
Dialogue: 0,0:12:01.85,0:12:02.88,Thoughts-207-,,0,0,0,,Wall!
Dialogue: 0,0:12:07.83,0:12:10.08,Main-207-,,0,0,0,,‫היי, חבר'ה, תזוזו!
Dialogue: 0,0:12:34.59,0:12:35.82,Main-207-,,0,0,0,attack,{\fad(150,150}Electromagnetic...
Dialogue: 0,0:12:35.82,0:12:37.13,Main-207-,,0,0,0,attack,{\fad(150,150)}Shaft!
Dialogue: 0,0:13:01.61,0:13:04.26,Main-207-,,0,0,0,,‫אתה קשוח מאוד. אני מופתע.
Dialogue: 0,0:13:08.35,0:13:13.02,Main-207-,,0,0,0,,‫אני לא מאמין שאתה\N‫אותו סאנג'י חלש וקטן.
Dialogue: 0,0:13:13.02,0:13:14.82,Main-207-,,0,0,0,,‫זה נהיה מגוחך.
Dialogue: 0,0:13:14.82,0:13:17.60,Main-207-,,0,0,0,,‫אני רוצה ללכת למסיבת התה\N‫ולצאת מכאן כבר.
Dialogue: 0,0:13:17.60,0:13:21.03,Main-207-,,0,0,0,,‫ואז אהיה חופשי\N‫מהקללה של ההזמנה של ביג מאם.
Dialogue: 0,0:13:21.53,0:13:26.20,Main-207-,,0,0,0,,‫חשבתי שאולי השתנית קצת,\N‫אבל למעשה נהית גרוע יותר!
Dialogue: 0,0:13:26.20,0:13:29.99,Main-207-,,0,0,0,,‫צא מהחדר הזה, זקן!\N‫אתה זר בשבילי!
Dialogue: 0,0:13:29.99,0:13:35.41,Main-207-,,0,0,0,,‫לא, הדם שלי זורם בעורקיך.
Dialogue: 0,0:13:35.41,0:13:39.08,Main-207-,,0,0,0,,‫אל תבין אותי לא נכון.\N‫כל חיילי גרמה הם...
Dialogue: 0,0:13:39.08,0:13:46.80,Main-207-,,0,0,0,,‫אנשים שמוכנים למות\N‫למשפחת וינסמוק בהרף עין!
Dialogue: 0,0:13:46.80,0:13:50.97,Main-207-,,0,0,0,,‫הם הכוח הצבאי הגדול ביותר של גרמה!
Dialogue: 0,0:13:53.36,0:13:58.35,Main-207-,,0,0,0,,‫אז למה לא תשתמש בהם\N‫כדי להגשים את החלום הטיפשי שלך?
Dialogue: 0,0:13:58.35,0:14:04.10,Main-207-,,0,0,0,,‫כיבוש הנורת' בלו? מצוין!\N‫מושלם לארגון רשע.
Dialogue: 0,0:14:04.10,0:14:07.65,Main-207-,,0,0,0,,‫אתה חד.\N‫נכון.
Dialogue: 0,0:14:07.65,0:14:09.86,Main-207-,,0,0,0,,‫על ידי הצטרפות ידיים עם ביג מאם,
Dialogue: 0,0:14:09.86,0:14:12.62,Main-207-,,0,0,0,,‫זה יהפוך למטרה\N‫שבטוח אוכל להשיג!
Dialogue: 0,0:14:12.62,0:14:15.87,Main-207-,,0,0,0,,‫מטרה... שבטוח אוכל להשיג!
Dialogue: 0,0:14:18.46,0:14:23.00,Main-207-,,0,0,0,,‫אם אתה מבין את זה,\N‫אין לי יותר מה להגיד.
Dialogue: 0,0:14:23.89,0:14:28.43,Main-207-,,0,0,0,,‫רציתי איכשהו לסיים את זה\N‫איתך בשלום, אבל...
Dialogue: 0,0:14:32.10,0:14:37.60,Main-207-,,0,0,0,,‫אני צריך את העזרה של ביג מאם,\N‫אבל התנאי הוא יצירת קשרי דם.
Dialogue: 0,0:14:37.60,0:14:39.78,Main-207-,,0,0,0,,‫זו רק חתונה,
Dialogue: 0,0:14:39.78,0:14:45.11,Main-207-,,0,0,0,,‫אבל אני לא יכול לתת לאף אחד מהבנים היקרים שלי\N‫להתחתן עם מישהי ממשפחת הזקנה המשוגעת הזאת!
Dialogue: 0,0:14:46.61,0:14:51.88,Main-207-,,0,0,0,,‫אז נזכרתי... יש לי עוד בן...
Dialogue: 0,0:14:51.88,0:14:54.22,Main-207-,,0,0,0,,‫שהיה כישלון.
Dialogue: 0,0:14:55.45,0:14:59.23,Main-207-,,0,0,0,,‫אתה קורבן, סאנג'י.
Dialogue: 0,0:14:59.23,0:15:02.02,Main-207-,,0,0,0,,‫לא השתניתי.
Dialogue: 0,0:15:02.02,0:15:06.92,Main-207-,,0,0,0,,‫אני לא חושב עליך כבן שלי אפילו לא קצת!
Dialogue: 0,0:15:11.31,0:15:13.47,Main-207-,,0,0,0,,‫היי, מה אלה?
Dialogue: 0,0:15:13.47,0:15:16.16,Main-207-,,0,0,0,,‫אמרת שהידיים שלך חשובות לך.
Dialogue: 0,0:15:16.16,0:15:17.77,Main-207-,,0,0,0,,‫מצוין.
Dialogue: 0,0:15:18.39,0:15:23.01,Main-207-,,0,0,0,,‫אתה מכיר את אזיקי הצווארון\N‫שעבדי דרקוני השמים עונדים?
Dialogue: 0,0:15:23.61,0:15:28.32,Main-207-,,0,0,0,,‫אם הם מנסים לברוח מהאדונים שלהם,\N‫הם מתפוצצים יחד עם הראש שלהם.
Dialogue: 0,0:15:28.80,0:15:30.88,Main-207-,,0,0,0,,‫אלה עובדים אותו דבר.
Dialogue: 0,0:15:30.88,0:15:34.95,Main-207-,,0,0,0,,‫אם תנסה לברוח מהאי הזה,\N‫הידיים שלך יתפוצצו!
Dialogue: 0,0:15:35.45,0:15:37.79,Main-207-,,0,0,0,,‫לעזאזל איתך! תוריד אותם!
Dialogue: 0,0:15:37.79,0:15:41.46,Main-207-,,0,0,0,,‫לביג מאם הייתה הצפייה להשאיל לי אותם.
Dialogue: 0,0:15:41.46,0:15:44.13,Main-207-,,0,0,0,,‫המפתח אצלה.
Dialogue: 0,0:15:44.13,0:15:45.79,Main-207-,,0,0,0,,‫מה?!
Dialogue: 0,0:15:49.34,0:15:51.00,Main-207-,,0,0,0,,‫אל תעשה את זה.
Dialogue: 0,0:15:54.65,0:15:57.93,Main-207-,,0,0,0,,‫אתה לא יכול לנסות לקרוע אותם.
Dialogue: 0,0:15:57.93,0:16:02.85,Main-207-,,0,0,0,,‫רק שימוש במפתח יוריד אותם,\N‫כמובן.
Dialogue: 0,0:16:05.32,0:16:08.07,Main-207-,,0,0,0,,‫אתה לא יכול לברוח.
Dialogue: 0,0:16:08.07,0:16:10.36,Main-207-,,0,0,0,,‫ובכן, קודם כל,
Dialogue: 0,0:16:10.91,0:16:15.12,Main-207-,,0,0,0,,‫אנחנו הגרמה לא נתן לך לברוח!
Dialogue: 0,0:16:18.08,0:16:20.91,Main-207-,,0,0,0,,‫אתה חייב להתחתן!
Dialogue: 0,0:16:25.89,0:16:29.34,Main-207-,,0,0,3,,‫חדשות! חדשות!
Dialogue: 0,0:16:29.34,0:16:32.05,Main-207-,,0,0,0,,‫הבוס ג'ינביי בגד בנו?!
Dialogue: 0,0:16:32.05,0:16:35.05,Main-207-,,0,0,0,,‫זה קרה בינו לבין מאמה אתמול?
Dialogue: 0,0:16:36.31,0:16:42.31,Main-207-,,0,0,0,,‫הבוס ג'ינביי היה כל כך מגניב\N‫כשעצר את התפרצות מאמה.
Dialogue: 0,0:16:42.31,0:16:45.56,Main-207-,,0,0,0,,‫הוא התחצף ואמר\N‫שרוצה לעזוב את הצוות שלה,
Dialogue: 0,0:16:45.56,0:16:49.28,Main-207-,,0,0,0,,‫אבל נבהל מהמחיר שהיה צריך לשלם\N‫ונסוג!
Dialogue: 0,0:16:49.28,0:16:52.20,Main-207-,,0,0,0,,‫כן? זה עלוב!
Dialogue: 0,0:16:53.08,0:16:54.78,Main-207-,,0,0,0,,‫מה לוזר!
Dialogue: 0,0:16:54.78,0:16:58.74,Main-207-,,0,0,0,,‫כנראה ש"אביר הים" זה רק תואר.\N‫איבדתי את הכבוד שלי אליו.
Dialogue: 0,0:16:58.74,0:17:02.04,Main-207-,,0,0,0,,‫אז הוא היה פחדן ובוגד.
Dialogue: 0,0:17:05.92,0:17:07.46,Thoughts-207-,,0,0,0,,‫ג'ינביי{\i1}{\i0}...
Dialogue: 0,0:17:07.46,0:17:10.84,Thoughts-207-,,0,0,0,,‫לא ידעתי שאתה עובד תחת ביג מאם.
Dialogue: 0,0:17:10.84,0:17:14.63,Thoughts-207-,,0,0,0,,‫לכן אי הדגים\N‫הוגן על ידי ביג מאם.
Dialogue: 0,0:17:16.24,0:17:20.72,Main-207-,,0,0,0,,‫ג'ינביי הוא בעל ברית ממשלתי לשעבר, נכון?
Dialogue: 0,0:17:20.72,0:17:23.18,Main-207-,,0,0,0,,‫אני לא מאמין שמישהו עם מעמד כזה הוא הכפוף שלה.
Dialogue: 0,0:17:23.18,0:17:26.28,Main-207-,,0,0,0,,‫ברוק, אתה מכיר את האיש הזה?
Dialogue: 0,0:17:26.28,0:17:30.85,Main-207-,,0,0,0,,{\fad(0,200)}‫כן, הוא אדם חשוב מאוד עבורנו.
Dialogue: 0,0:17:30.85,0:17:36.40,Flashbacks-207-,,0,0,0,,{\fad(200,0)}‫אני עדיין חייב להשלים את המסע הזה. \N‫ברגע שאוכל לנוע חופשי שוב,
Dialogue: 0,0:17:36.40,0:17:42.08,Flashbacks-207-,,0,0,0,,‫אני מבטיח שאצטרף לצוות שלכם.
Dialogue: 0,0:17:42.16,0:17:46.65,Thoughts-207-,,0,0,0,,‫אני מניח שהוא סירב\N‫להצטרף לצוות שלנו באותו יום,
Dialogue: 0,0:17:46.65,0:17:50.54,Thoughts-207-,,0,0,0,,‫כי רצה למלא\N‫את חובתו לביג מאם.
Dialogue: 0,0:17:51.59,0:17:56.36,Thoughts-207-,,0,0,0,,‫עכשיו, הכתבה הזאת...\N‫זה לא נשמע כמו משהו שהוא היה עושה.
Dialogue: 0,0:17:56.36,0:17:59.28,Thoughts-207-,,0,0,0,,‫הוא לא יבוא ויצטרף אלינו יותר?
Dialogue: 0,0:17:59.28,0:18:01.59,Main-207-,,0,0,0,,‫היי, ברוק!
Dialogue: 0,0:18:03.99,0:18:06.95,Main-207-,,0,0,0,,‫בבקשה! אני צריך ללכת למקום מסוים!
Dialogue: 0,0:18:06.95,0:18:11.24,Main-207-,,0,0,0,,‫אין שום דבר חשוב יותר עבורך עכשיו\N‫מלבחור שמלה!
Dialogue: 0,0:18:11.24,0:18:14.48,Main-207-,,0,0,0,,‫תפסיק להתנהג כמו ילד - {\i1}s'il vous plaît{\i},\N‫מאדאם פודינג!
Dialogue: 0,0:18:14.48,0:18:15.71,Main-207-,,0,0,0,,‫אבל...
Dialogue: 0,0:18:15.71,0:18:17.74,Main-207-,,0,0,0,,‫מאדאם פודינג!
Dialogue: 0,0:18:17.74,0:18:19.70,Main-207-,,0,0,0,,‫מה דעתך על השמלה הזאת?
Dialogue: 0,0:18:19.70,0:18:21.33,Main-207-,,0,0,0,,‫וואו, זה נראה מעולה עלייך!
Dialogue: 0,0:18:21.33,0:18:26.29,Main-207-,,0,0,0,,‫מה דעתך על זאת? ידעתי, מאדאם פודינג!\N‫זה מושלם!
Dialogue: 0,0:18:26.29,0:18:29.50,Main-207-,,0,0,0,,‫הכל נראה טוב עלייך!
Dialogue: 0,0:18:29.50,0:18:32.06,Main-207-,,0,0,0,,‫איזו אחת את אוהבת, מאדאם פודינג?
Dialogue: 0,0:18:32.06,0:18:33.35,Main-207-,,0,0,0,,‫אממ...
Dialogue: 0,0:18:33.35,0:18:36.71,Main-207-,,0,0,0,,‫מאדאם פודינג,\N‫את יודעת מה החתן אוהב?
Dialogue: 0,0:18:36.71,0:18:40.61,Main-207-,,0,0,0,,‫מה?!\N‫לא! נפגשתי איתו רק פעם אחת, אז...
Dialogue: 0,0:18:40.61,0:18:42.30,Main-207-,,0,0,0,,‫מה?!
Dialogue: 0,0:18:42.30,0:18:46.11,Main-207-,,0,0,0,,‫רגע, פודינג{\i1}{\i},\N‫מה היא עושה כאן?!
Dialogue: 0,0:18:46.11,0:18:49.56,Main-207-,,0,0,0,,‫כנראה שנתפסה על ידי המשרתים שלה.
Dialogue: 0,0:18:49.56,0:18:52.54,Main-207-,,0,0,0,,‫הנחתי שהיא כבר הוציאה את סאנג'{\i1}{\i} החוצה
Dialogue: 0,0:18:52.54,0:18:55.70,Main-207-,,0,0,0,,‫לפגוש את לופי{\i1}{\i} והאחרים עד עכשיו.
Dialogue: 0,0:18:55.70,0:19:00.29,Main-207-,,0,0,0,,‫מסתכל על זה, אני מוכן להמר שסאנג'י\N‫אפילו לא יודע שאנחנו כאן.
Dialogue: 0,0:19:00.29,0:19:03.95,Main-207-,,0,0,0,,‫אז מי לופי{\i1}{\i} ראה בחוף?
Dialogue: 0,0:19:03.95,0:19:08.79,Main-207-,,0,0,0,,‫אני לא יודע.\N‫אולי הוא פשוט ראה מישהו אחר.
Dialogue: 0,0:19:11.46,0:19:16.89,Main-207-,,0,0,0,,‫זה... אם אני לא טועה,\N‫הוא היה על הספינה של ביג מאם...
Dialogue: 0,0:19:16.89,0:19:19.17,Main-207-,,0,0,0,,‫כן, אני מכיר אותו מאוד טוב.
Dialogue: 0,0:19:19.17,0:19:21.43,Main-207-,,0,0,0,,‫הברון טמאגו!
Dialogue: 0,0:19:24.83,0:19:28.45,Main-207-,,0,0,0,,‫הברון טמאגו, אפשר לדבר איתך?
Dialogue: 0,0:19:33.96,0:19:36.27,Main-207-,,0,0,0,,‫מה זה - {\i1}soir{\fs15} {\r}?
Dialogue: 0,0:19:36.27,0:19:40.24,Main-207-,,0,0,0,,‫הספינה של כובעי הקש שעצרה\N‫בשוקולת טאון אתמול...
Dialogue: 0,0:19:40.32,0:19:43.16,Thoughts-207-,,0,0,0,,‫הם כבר יודעים!
Dialogue: 0,0:19:43.16,0:19:50.33,Main-207-,,0,0,0,,‫כשיצאו, מר פקומס שהוביל אותם,\N‫כבר לא היה שם, אומרים.
Dialogue: 0,0:19:50.33,0:19:52.62,Thoughts-207-,,0,0,0,,‫הם יודעים הכל!
Dialogue: 0,0:19:52.62,0:19:57.89,Main-207-,,0,0,0,,‫ומה לגבי ארבעת כובעי הקש\N‫שנכנסו ליער הפיתוי היום...
Dialogue: 0,0:19:56.26,0:20:01.72,Note,,0,0,0,,Carrot's Poster: "Bunny Mink."
Dialogue: 0,0:19:57.89,0:20:01.72,Main-207-,,0,0,0,,‫הם כבר מוקפים!\N‫כמו שנתפסו!
Dialogue: 0,0:20:01.72,0:20:05.51,Thoughts-207-,,0,0,0,,‫לופי{\i1}{\i0} והאחרים נתפסו?!
Dialogue: 0,0:20:05.51,0:20:08.77,Main-207-,,0,0,0,,‫אבל עדיין לא מצאנו את שניים הנותרים.
Dialogue: 0,0:20:08.77,0:20:10.93,Note,,0,0,0,,Pedro's Poster: "Leopard Mink."
Dialogue: 0,0:20:08.77,0:20:10.93,Main-207-,,0,0,0,,‫שניים אלה.
Dialogue: 0,0:20:10.98,0:20:13.94,Thoughts-207-,,0,0,0,,‫זה אנחנו!
Dialogue: 0,0:20:13.94,0:20:17.52,Main-207-,,0,0,0,,‫זה דלף לגמרי!\N‫הם ידעו הכל מההתחלה!
Dialogue: 0,0:20:17.52,0:20:20.28,Main-207-,,0,0,0,,‫מאיפה הם צפו בנו?!
Dialogue: 0,0:20:20.28,0:20:24.89,Main-207-,,0,0,0,,‫המינק הזה הוא לא נמר - {\i1}soir{\i}.
Dialogue: 0,0:20:20.28,0:20:24.89,Note,,0,0,0,,Pedro's Poster: "Leopard Mink."
Dialogue: 0,0:20:24.87,0:20:28.53,Main-207-,,0,0,0,,‫הוא מינק יגואר. שמו פדרו.
Dialogue: 0,0:20:29.08,0:20:30.50,Main-207-,,0,0,0,,‫אתה מכיר אותו?
Dialogue: 0,0:20:31.06,0:20:34.29,Main-207-,,0,0,0,,‫קצת מהעבר.
Dialogue: 0,0:20:37.65,0:20:43.84,Main-207-,,0,0,0,,‫אני יודע מה הוא היה עושה - {\i1}feuille{\i}.
Dialogue: 0,0:20:43.84,0:20:48.39,Main-207-,,0,0,0,,‫– בכל אופן, אני רוצה שתחפשו את פקומס.\N‫– כן, אדוני.
Dialogue: 0,0:20:50.83,0:20:55.66,Main-207-,,0,0,0,,‫פקומס. מאחר שהוא היה בחיים - {\i1}bon{\i},
Dialogue: 0,0:20:55.66,0:20:58.14,Main-207-,,0,0,0,,‫למען השותפות\N‫הוותיקה שלנו,
Dialogue: 0,0:20:58.14,0:21:02.65,Main-207-,,0,0,0,,‫רציתי לבקש\N‫ממאמה שתסלח לו.
Dialogue: 0,0:21:04.76,0:21:07.95,Main-207-,,0,0,0,,‫הוא גורם לי הרבה צרות - {\i1}marron{\i}.
Dialogue: 0,0:21:07.95,0:21:12.79,Thoughts-207-,,0,0,0,,‫אנחנו בצרה גדולה!
Dialogue: 0,0:21:15.60,0:21:18.46,Main-207-,,0,0,3,,‫היי, תפסיק, קטן!
Dialogue: 0,0:21:18.46,0:21:20.84,Main-207-,,0,0,0,,‫שקט!
Dialogue: 0,0:21:26.34,0:21:30.22,Main-207-,,0,0,3,,‫אה, הוא מצחיק! יופי!
Dialogue: 0,0:21:33.10,0:21:38.10,Main-207-,,0,0,3,,‫טוב, טוב, טוב, טוב! ילד טוב!
Dialogue: 0,0:21:38.10,0:21:43.99,Main-207-,,0,0,0,,‫היי, קטן.\N‫אני מקווה שתהיה בוס גדול כמוני יום אחד.
Dialogue: 0,0:21:46.36,0:21:49.12,Main-207-,,0,0,0,,‫אני לא יכול לסבול לראות את זה!
Dialogue: 0,0:21:49.97,0:21:52.51,Main-207-,,0,0,0,,‫הוא מסנוור, לא?
Dialogue: 0,0:21:52.51,0:21:55.54,Main-207-,,0,0,0,,‫הוא רק נולד.
Dialogue: 0,0:21:55.54,0:21:58.62,Main-207-,,0,0,0,,‫ואתה הולך למות.
Dialogue: 0,0:22:00.10,0:22:05.63,Main-207-,,0,0,0,,‫אתה לא חושב שזה ניגוד מרהיב?\N‫זה כמו ציור.
Dialogue: 0,0:22:07.01,0:22:10.65,Main-207-,,0,0,0,,‫זה מה שבחרת.
Dialogue: 0,0:22:10.65,0:22:13.85,Main-207-,,0,0,0,,‫פקומס. נתתי לך הזדמנות.
Dialogue: 0,0:22:13.85,0:22:17.85,Main-207-,,0,0,0,,‫זה לא נראה לי כמו הזדמנות.
Dialogue: 0,0:22:17.85,0:22:20.56,Main-207-,,0,0,0,,‫זכור מה שקרה לך בזואו.
Dialogue: 0,0:22:20.56,0:22:24.19,Main-207-,,0,0,0,,‫אמפתיה אנושית לא שווה כלום.
Dialogue: 0,0:22:25.99,0:22:30.78,Main-207-,,0,0,0,,‫אתה לא מתאים לעסק הזה.
Dialogue: 0,0:22:31.45,0:22:36.83,Main-207-,,0,0,0,,‫זה המקום המושלם\N‫להיפטר ממישהו.
Dialogue: 0,0:22:43.46,0:22:45.55,Main-207-,,0,0,0,,‫יש לך מילים אחרונות?
Dialogue: 0,0:23:11.24,0:23:14.62,Main-207-,,0,0,0,,‫אתה מזלזל יותר מדי במאמה!
Dialogue: 0,0:23:51.11,0:23:53.87,Flashbacks-207-,,0,0,0,,‫עכשיו, בוא נראה את הידיים שלך.
Dialogue: 0,0:23:55.53,0:23:57.54,Flashbacks-207-,,0,0,0,,‫הן מכוסות בחבורות.
Dialogue: 0,0:24:06.37,0:24:08.25,Flashbacks-207-,,0,0,0,,‫חצילון קטן!
Dialogue: 0,0:24:08.80,0:24:10.59,Flashbacks-207-,,0,0,0,,‫אאוץ'!
Dialogue: 0,0:24:16.06,0:24:17.97,Flashbacks-207-,,0,0,0,,‫מה הבעיה שלך, זקן מטורף?!
Dialogue: 0,0:24:17.97,0:24:22.19,Flashbacks-207-,,0,0,0,,‫הידיים שלך הן לקרבות?!
Dialogue: 0,0:24:35.19,0:24:37.56,Main-207-,,0,0,0,,‫לעזאזל!
Dialogue: 0,0:24:52.59,0:24:58.89,Main-207-,,0,0,0,,‫אני חושב שהשקעתי מספיק כסף,\N‫קיסר קלאון.
Dialogue: 0,0:24:58.89,0:25:04.10,Main-207-,,0,0,0,,‫כ-כ-כ-כן!\N‫וכמובן, לא הפסקתי לחקור!
Dialogue: 0,0:25:04.70,0:25:07.21,Main-207-,,0,0,0,,‫החלום שלי הוא...
Dialogue: 0,0:25:22.37,0:25:27.00,Main-207-,,0,0,0,,‫שכל הגזעים ב\N‫עולם יהפכו למשפחה
Dialogue: 0,0:25:27.00,0:25:31.57,Main-207-,,0,0,0,,‫וישבו סביב שולחן האוכל\N‫באותה גובה העיניים.
Dialogue: 0,0:25:31.57,0:25:34.67,Main-207-,,0,0,0,,‫הם ישתו מה שאני שותה,
Dialogue: 0,0:25:36.26,0:25:39.97,Main-207-,,0,0,0,,‫ויאכלו מה שאני אוכל!
Dialogue: 0,0:25:47.81,0:25:50.82,Main-207-,,0,0,0,,‫האם זה לא חלום נפלא?!
Dialogue: 0,0:25:50.82,0:25:55.28,Main-207-,,0,0,0,,‫ואתה תגשים את זה בשבילי,\N‫קיסר!
Dialogue: 0,0:25:57.16,0:26:03.50,Main-207-,,0,0,0,,‫אני רוצה שתהפוך את בני משפחתי לענקים\N‫בכוח המדע.
Dialogue: 0,0:26:03.50,0:26:06.89,Main-207-,,0,0,0,,‫אתה כל הזמן אמרת לי
Dialogue: 0,0:26:06.89,0:26:13.50,Main-207-,,0,0,0,,‫שאתה כמעט מסיים,\N‫אבל צריך עוד קצת כסף לחקירה.
Dialogue: 0,0:26:13.50,0:26:17.32,Main-207-,,0,0,0,,‫התרגשתי\N‫והוצאתי לא מעט כסף.
Dialogue: 0,0:26:17.32,0:26:20.09,Main-207-,,0,0,0,,‫אז מה התוצאות?
Dialogue: 0,0:26:20.09,0:26:24.18,Main-207-,,0,0,0,,‫ובכן, הודות לך, הן ממש טובות!
Dialogue: 0,0:26:24.96,0:26:29.41,Thoughts-207-,,0,0,0,,‫הפיכת גוף אנושי לענק.\N‫כן, עשיתי ניסויים.
Dialogue: 0,0:26:29.41,0:26:33.46,Thoughts-207-,,0,0,0,,‫כל העולם\N‫מחפש טכנולוגיה כזאת.
Dialogue: 0,0:26:33.46,0:26:39.34,Thoughts-207-,,0,0,0,,‫אבל ביצעתי ניסויים\N‫להפוך ילדים לענקים. זה היה קטלני.
Dialogue: 0,0:26:39.34,0:26:43.72,Thoughts-207-,,0,0,0,,‫זה בלתי אפשרי להכין סם\N‫שיהפוך בקסם
Dialogue: 0,0:26:43.72,0:26:47.08,Thoughts-207-,,0,0,0,,‫אנשים לענקים\N‫כמו שהזקנה הזאת רוצה.
Dialogue: 0,0:26:47.08,0:26:51.38,Thoughts-207-,,0,0,0,,‫לכן פשוט הברחתי ממנה את הכסף,\N‫ו...
Dialogue: 0,0:26:55.05,0:26:58.10,Thoughts-207-,,0,0,0,,‫קראתי לאוניות של בנות\N‫לאי כל לילה,
Dialogue: 0,0:26:58.10,0:27:02.99,Thoughts-207-,,0,0,0,,‫ובזבזתי את כל הכסף\N‫על אלכוהול ונשים!
Dialogue: 0,0:27:05.99,0:27:11.86,Thoughts-207-,,0,0,0,,‫אלה היו הימים הטובים!\N‫השתגעתי מאחורי הגב של ג'וקר!
Dialogue: 0,0:27:11.86,0:27:13.06,Note,,0,0,0,,"Doflamingo Falls!"
Dialogue: 0,0:27:13.15,0:27:16.48,Thoughts-207-,,0,0,0,,‫לא ציפיתי שג'וקר יובס...
Dialogue: 0,0:27:23.07,0:27:27.20,Thoughts-207-,,0,0,0,,‫וחיי יהפכו לאומללים כל כך!
Dialogue: 0,0:27:27.20,0:27:32.33,Thoughts-207-,,0,0,0,,‫לעזאזל! הרבה יותר קל היה אז!
Dialogue: 0,0:27:32.33,0:27:35.25,Thoughts-207-,,0,0,0,,‫כל זה בגלל אותו...
Dialogue: 0,0:27:35.25,0:27:37.26,Main-207-,,0,0,0,,‫אתה מבצע הצגת פנים?
Dialogue: 0,0:27:38.91,0:27:40.34,Main-207-,,0,0,0,,‫לא!
Dialogue: 0,0:27:40.34,0:27:46.06,Main-207-,,0,0,0,,‫זה! וזה! והכל!\N‫כל זה אשמת לופי כובע הקש!
Dialogue: 0,0:27:46.06,0:27:50.98,Main-207-,,0,0,0,,‫ביג מאם! הייתי עושה מחקר\N‫בלי לישון בכלל!
Dialogue: 0,0:27:50.98,0:27:54.44,Main-207-,,0,0,0,,‫וכשזה כמעט הושלם,
Dialogue: 0,0:27:54.44,0:27:58.69,Main-207-,,0,0,0,,‫כובע הקש וטראפלגר לאו הופיעו!
Dialogue: 0,0:28:05.62,0:28:10.54,Main-207-,,0,0,0,,‫לולא הם,\N‫סם הענקיות היה מוכן!
Dialogue: 0,0:28:10.54,0:28:13.42,Main-207-,,0,0,0,,‫כי אני גאון!
Dialogue: 0,0:28:14.46,0:28:17.58,Main-207-,,0,0,0,,‫חבל שהמעבדה\N‫שבנתה הממשלה העולמית,
Dialogue: 0,0:28:17.58,0:28:20.17,Main-207-,,0,0,0,,‫עם כל הטכנולוגיה המתקדמת שלה,\N‫נהרסה!
Dialogue: 0,0:28:20.17,0:28:24.72,Main-207-,,0,0,0,,‫יכולתי להשיג את התוצאות\N‫בסביבה המבוקרת בצורה מושלמת הזאת!
Dialogue: 0,0:28:26.53,0:28:31.73,Main-207-,,0,0,0,,‫כמות הכסף העצומה שהשקעת\N‫ואותה מעבדה!
Dialogue: 0,0:28:31.73,0:28:38.44,Main-207-,,0,0,0,,‫איבדתי אותם, ולכן אני לא יכול ליצור\N‫את סם הענקיות עכשיו!
Dialogue: 0,0:28:38.44,0:28:41.28,Main-207-,,0,0,0,,‫אני לא יכול!
Dialogue: 0,0:28:53.02,0:28:57.79,Main-207-,,0,0,0,,‫בניתי מעבדה זהה בדיוק\N‫לזו שהייתה בפאנק הייזארד.
Dialogue: 0,0:28:57.79,0:28:58.84,Main-207-,,0,0,0,,‫מה?!
Dialogue: 0,0:28:58.84,0:29:02.09,Main-207-,,0,0,0,,‫קיבלתי את התוכניות שלה מזמן.
Dialogue: 0,0:29:02.09,0:29:08.22,Main-207-,,0,0,0,,‫כישורי האמזאיקו של שרת הסוכריות שלנו \N{\i1}‫הם רב-שימושיים למדי.{\i0}
Dialogue: 0,0:29:02.09,0:29:08.22,Note,,0,0,0,,"Amezaiku" – Japanese candy craft artistry
Dialogue: 0,0:29:08.22,0:29:12.19,Main-207-,,0,0,0,,‫אתה יכול להוציא כמה כסף שתרצה\N‫על המחקר.
Dialogue: 0,0:29:12.19,0:29:13.77,Main-207-,,0,0,0,,‫מה?!
Dialogue: 0,0:29:13.77,0:29:16.94,Main-207-,,0,0,0,,‫א-א-א-א... אתה בטוח?!
Dialogue: 0,0:29:16.94,0:29:20.28,Main-207-,,0,0,0,,‫כלומר, אני מעריך את זה!
Dialogue: 0,0:29:20.28,0:29:21.15,Main-207-,,0,0,0,,‫אז?
Dialogue: 0,0:29:21.76,0:29:22.82,Main-207-,,0,0,0,,‫"אז?"
Dialogue: 0,0:29:24.45,0:29:26.36,Main-207-,,0,0,0,,‫מתי זה יהיה מוכן?
Dialogue: 0,0:29:29.28,0:29:33.25,Main-207-,,0,0,0,,‫בשבוע? או שבועיים?
Dialogue: 0,0:29:37.63,0:29:40.96,Main-207-,,0,0,0,,‫אני לא יכול לחכות!
Dialogue: 0,0:29:41.75,0:29:47.14,Thoughts-207-,,0,0,0,,‫אל תהיה מגוחך!\N‫האנושות עושה את המחקר הזה מאות שנים,
Dialogue: 0,0:29:47.14,0:29:50.18,Thoughts-207-,,0,0,0,,‫אבל אף אחד אף פעם לא הצליח!
Dialogue: 0,0:29:55.35,0:29:58.02,Main-207-,,0,0,0,,‫לקק! לקק!
Dialogue: 0,0:29:58.02,0:30:01.52,Main-207-,,0,0,0,,‫אתה אוהב את זה, קיסר - {\i1}kun{\fs12} {\r}?
Dialogue: 0,0:30:04.03,0:30:07.20,Main-207-,,0,0,3,,‫זה נראה די אמיתי, לא?
Dialogue: 0,0:30:08.36,0:30:12.62,Main-207-,,0,0,3,,‫הפנים זהות לגמרי כמו שהיה. לקק!
Dialogue: 0,0:30:17.29,0:30:19.00,Thoughts-207-,,0,0,0,,‫זה...
Dialogue: 0,0:30:19.00,0:30:21.25,Thoughts-207-,,0,0,0,,‫לא! אל תעשה את זה!
Dialogue: 0,0:30:23.59,0:30:25.84,Main-207-,,0,0,0,,‫זה מהנה.
Dialogue: 0,0:30:31.18,0:30:33.52,Thoughts-207-,,0,0,0,,‫לעזאזל!
Dialogue: 0,0:30:35.70,0:30:38.90,Flashbacks-207-,,0,0,0,,{\fad(300,0)}‫הגענו לאי כיכר השלם.
Dialogue: 0,0:30:41.61,0:30:44.36,Flashbacks-207-,,0,0,0,,‫רגע! היי, רגל שחורה!
Dialogue: 0,0:30:44.36,0:30:47.74,Flashbacks-207-,,0,0,0,,‫החזר לי את הלב שלי לפני שתלך!
Dialogue: 0,0:30:47.74,0:30:49.61,Flashbacks-207-,,0,0,0,,‫אה.
Dialogue: 0,0:30:49.61,0:30:50.70,Flashbacks-207-,,0,0,0,,‫בסדר.
Dialogue: 0,0:30:56.50,0:31:01.42,Main-207-,,0,0,0,,{\fad(300,0)}‫יש לך שבועיים בלבד\N‫לייצר את סם הענקיות!
Dialogue: 0,0:31:01.42,0:31:07.55,Main-207-,,0,0,0,,‫אם זה יקח יותר מזה,\N‫אהפוך אותך לאיש סוכריות ואלקק אותך!
Dialogue: 0,0:31:09.47,0:31:11.50,Thoughts-207-,,0,0,0,,‫אהרג בעוד שבועיים!
Dialogue: 0,0:31:11.50,0:31:14.22,Thoughts-207-,,0,0,0,,‫אני חייב לעשות משהו!
Dialogue: 0,0:31:20.73,0:31:24.69,Main-207-,,0,0,0,,‫ראיתי אותך עשרות פעמים עד עכשיו.
Dialogue: 0,0:31:27.36,0:31:29.00,Main-207-,,0,0,0,,‫שוב אתה.
Dialogue: 0,0:31:29.00,0:31:30.53,Main-207-,,0,0,0,,‫מצאתי עוד אחד.
Dialogue: 0,0:31:33.70,0:31:36.90,Main-207-,,0,0,0,,‫יש כל כך הרבה מהם!
Dialogue: 0,0:31:52.13,0:31:54.70,Main-207-,,0,0,0,,‫בכל מקרה...
Dialogue: 0,0:32:11.57,0:32:14.62,Main-207-,,0,0,0,,‫איך אתם התרבתם?!
