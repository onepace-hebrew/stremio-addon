Dialogue: 0,0:00:00.00,0:00:05.00,Main-207-,,0,0,0,,{\an8}‫תרגום לעברית — That One Gerbil
Dialogue: 0,0:01:34.94,0:01:39.90,Main-207-,,0,0,0,,‫לינלין! אני אשים לך קץ\N‫בידיים שלי!
Dialogue: 0,0:01:42.65,0:01:44.61,Main-207-,,0,0,0,,{\i1}‫סמלור{\i0}...
Dialogue: 0,0:02:03.71,0:02:05.01,Main-207-,,0,0,0,,‫לא, לינלין!
Dialogue: 0,0:02:06.48,0:02:07.89,Main-207-,,0,0,0,,{\i1}‫ס{\i0}...
Dialogue: 0,0:02:07.89,0:02:09.10,Main-207-,,0,0,0,,‫יורל!
Dialogue: 0,0:02:09.10,0:02:11.11,Main-207-,,0,0,0,,{\i1}‫מ{\i0}...
Dialogue: 0,0:02:11.11,0:02:12.52,Main-207-,,0,0,0,,{\i1}‫לור{\fs12} {\r}!
Dialogue: 0,0:02:34.03,0:02:35.67,Main-207-,,0,0,0,,‫ראש שבט זקן המפל!
Dialogue: 0,0:02:35.67,0:02:37.11,Main-207-,,0,0,0,,‫ראש שבט יורל!
Dialogue: 0,0:02:40.76,0:02:43.59,Main-207-,,0,0,0,,{\i1}‫סמלור{\fs12} {\r}!
Dialogue: 0,0:02:43.59,0:02:45.02,Main-207-,,0,0,0,,‫תחזיקו את לינלין!
Dialogue: 0,0:02:45.02,0:02:47.17,Main-207-,,0,0,0,,‫תכבו את האש בכפר!
Dialogue: 0,0:02:48.22,0:02:51.05,Main-207-,,0,0,0,,‫– תכם אותה כבר!\N‫– בסדר!
Dialogue: 0,0:02:51.05,0:02:53.36,Main-207-,,0,0,0,,‫אל תפגעו בה!
Dialogue: 0,0:02:53.36,0:02:54.86,Main-207-,,0,0,0,,‫אפשר להכין {\i1}סמלור{\fs15} {\r}?
Dialogue: 0,0:02:54.86,0:02:57.45,Main-207-,,0,0,0,,‫יש בשביל החג\N‫במחסן הכפר!
Dialogue: 0,0:02:57.45,0:02:58.87,Main-207-,,0,0,0,,‫תביאו עכשיו!
Dialogue: 0,0:02:58.87,0:03:00.65,Main-207-,,0,0,0,,‫א-אוקיי!
Dialogue: 0,0:03:09.35,0:03:12.62,Main-207-,,0,0,0,,‫– אמא, מה את עושה?!\N‫– זה מסוכן!
Dialogue: 0,0:03:12.62,0:03:14.45,Main-207-,,0,0,0,,‫תעמדו מאחור!
Dialogue: 0,0:03:26.82,0:03:28.95,Main-207-,,0,0,0,,{\fad(150,150)}‫גבור...
Dialogue: 0,0:03:37.56,0:03:41.06,Main-207-,,0,0,0,,‫אמא!
Dialogue: 0,0:03:50.64,0:03:54.01,Main-207-,,0,0,0,,{\fad(150,150)}‫...טשטאג!
Dialogue: 0,0:03:50.64,0:03:54.01,Note,,0,0,0,,"Gerburtstag" - Birthday
Dialogue: 0,0:03:59.92,0:04:02.47,Main-207-,,0,0,0,,‫אמא!
Dialogue: 0,0:04:02.52,0:04:04.56,Main-207-,,0,0,0,,‫אתן לך קול.
Dialogue: 0,0:04:09.40,0:04:11.07,Main-207-,,0,0,0,,‫מה זה?
Dialogue: 0,0:04:23.81,0:04:26.28,Main-207-,,0,0,0,,‫שמע לפקודתי.
Dialogue: 0,0:04:27.57,0:04:29.60,Main-207-,,0,0,0,,‫– יש פרצוף באש!\N‫– מה?!
Dialogue: 0,0:04:29.60,0:04:31.62,Main-207-,,0,0,0,,‫אני פוחד...
Dialogue: 0,0:04:32.00,0:04:33.66,Main-207-,,0,0,0,,‫זה כמו שד!
Dialogue: 0,0:04:35.40,0:04:38.61,Main-207-,,0,0,0,,‫שמך הוא פנדורה!
Dialogue: 0,0:04:41.67,0:04:43.05,Main-207-,,0,0,0,,‫הבאתי!
Dialogue: 0,0:04:43.05,0:04:45.04,Main-207-,,0,0,0,,‫מהר, תאכיל אותה!
Dialogue: 0,0:04:45.88,0:04:47.28,Main-207-,,0,0,0,,{\i1}‫סמלור{\fs12} {\r}!
Dialogue: 0,0:04:47.28,0:04:49.43,Main-207-,,0,0,0,,‫זה טעים! זה טעים!
Dialogue: 0,0:04:51.63,0:04:53.77,Main-207-,,0,0,0,,‫תירגעי!
Dialogue: 0,0:05:24.24,0:05:26.48,Main-207-,,0,0,0,,‫האש...
Dialogue: 0,0:05:26.48,0:05:28.05,Main-207-,,0,0,0,,‫נעלמה.
Dialogue: 0,0:05:28.72,0:05:30.05,Main-207-,,0,0,0,,‫הי, תסתכלו!
Dialogue: 0,0:05:32.47,0:05:34.18,Main-207-,,0,0,0,,‫כמה חמוד!
Dialogue: 0,0:05:34.18,0:05:36.02,Main-207-,,0,0,0,,‫שלום, אמא!
Dialogue: 0,0:05:36.02,0:05:37.60,Main-207-,,0,0,0,,‫אמא...
Dialogue: 0,0:05:37.60,0:05:39.69,Main-207-,,0,0,0,,‫...עשתה נס!
Dialogue: 0,0:05:39.69,0:05:43.19,Main-207-,,0,0,0,,‫לא, לא הייתי זאת אני.
Dialogue: 0,0:05:44.85,0:05:48.89,Main-207-,,0,0,0,,‫אלוהי השמש הרגיע את האסון הזה.
Dialogue: 0,0:05:51.19,0:05:54.44,Main-207-,,0,0,0,,‫אני כל כך שמחה!
Dialogue: 0,0:05:55.66,0:06:01.19,Main-207-,,0,0,0,,‫תענישו אותה... היא לא סתם ילדה...
Dialogue: 0,0:06:01.19,0:06:08.18,Main-207-,,0,0,0,,‫אם לא נעשה משהו עכשיו...\N‫היא תביא עוד יותר אסונות בעתיד!
Dialogue: 0,0:06:08.84,0:06:11.22,Main-207-,,0,0,0,,‫– ראש שבט יורל!\N‫– מהר, עזרו לו!
Dialogue: 0,0:06:13.25,0:06:15.22,Main-207-,,0,0,0,,‫ראש שבט זקן ההר!
Dialogue: 0,0:06:16.84,0:06:18.81,Main-207-,,0,0,0,,‫לינלין...
Dialogue: 0,0:06:24.94,0:06:26.76,Main-207-,,0,0,0,,‫בבקשה, סלחו לה!
Dialogue: 0,0:06:32.19,0:06:35.16,Main-207-,,0,0,0,,‫את מנסה לעצור אותי, קרמל?
Dialogue: 0,0:06:36.61,0:06:41.65,Main-207-,,0,0,0,,‫יורל היה חבר שלי בקרב במשך 300 שנה.
Dialogue: 0,0:06:44.91,0:06:49.49,Main-207-,,0,0,0,,‫הוא זקן מדי. אני לא חושבת שהוא ישרוד הפעם.
Dialogue: 0,0:06:50.00,0:06:55.93,Main-207-,,0,0,0,,‫להיות לוחם זה לא עניין של לחיות הרבה...\N‫זה עניין של איך מתים!
Dialogue: 0,0:06:56.42,0:06:58.50,Main-207-,,0,0,0,,‫אנחנו חייבים לשים לכך קץ...
Dialogue: 0,0:06:58.50,0:07:03.36,Main-207-,,0,0,0,,‫אנחנו לא יכולים לסלוח\N‫למי שמתנגד לחוקי אלבאף.
Dialogue: 0,0:07:03.36,0:07:07.15,Main-207-,,0,0,0,,‫אני מבינה!\N‫אבל גם אם לא ניתן לסלוח לה,
Dialogue: 0,0:07:07.15,0:07:11.32,Main-207-,,0,0,0,,‫לינלין היא ילדה עלובה שננטשה.
Dialogue: 0,0:07:11.32,0:07:15.20,Main-207-,,0,0,0,,‫היא כעת בטיפול\N‫בית הכבשים!
Dialogue: 0,0:07:15.20,0:07:18.31,Main-207-,,0,0,0,,‫אני לא יכולה לנטוש אותה!
Dialogue: 0,0:07:19.65,0:07:22.00,Main-207-,,0,0,0,,‫מה תעשי איתה?
Dialogue: 0,0:07:22.94,0:07:27.96,Main-207-,,0,0,0,,‫אקח אותה ואעזוב את המקום הזה!
Dialogue: 0,0:07:29.13,0:07:30.09,Main-207-,,0,0,0,,‫קרמל!
Dialogue: 0,0:07:34.97,0:07:38.08,Main-207-,,0,0,0,,‫ראש שבט זקן ההר!\N‫אתה חייב להרוג את לינלין!
Dialogue: 0,0:07:38.08,0:07:43.15,Main-207-,,0,0,0,,‫למה שנסלח לה\N‫אחרי שעשתה דבר נורא כזה?!
Dialogue: 0,0:07:43.15,0:07:45.90,Main-207-,,0,0,0,,‫מה קרה לגאוות אלבאף שלך?
Dialogue: 0,0:07:56.97,0:08:01.78,Main-207-,,0,0,0,,‫בסדר, אז למה לא\N‫תסתלק מפניי עכשיו?!
Dialogue: 0,0:08:05.49,0:08:06.74,Main-207-,,0,0,0,,‫למה?!
Dialogue: 0,0:08:06.74,0:08:07.48,Main-207-,,0,0,0,,‫הייג'רודין!
Dialogue: 0,0:08:07.48,0:08:12.00,Main-207-,,0,0,0,,‫שחרר אותי! שחרר!
Dialogue: 0,0:08:20.72,0:08:23.22,Main-207-,,0,0,0,,‫מה קרה לראש שבט זקן המפל?
Dialogue: 0,0:08:23.90,0:08:25.76,Main-207-,,0,0,0,,‫הוא מת.
Dialogue: 0,0:08:25.76,0:08:28.44,Main-207-,,0,0,0,,‫היא לא זוכרת?
Dialogue: 0,0:08:29.18,0:08:33.53,Narrator,,0,0,0,,‫יורל, גיבור הענקים, מת,
Dialogue: 0,0:08:34.95,0:08:39.90,Narrator,,0,0,0,,‫ובין ההרס של לינלין ונס קרמל...
Dialogue: 0,0:08:41.58,0:08:44.12,Narrator,,0,0,0,,‫אירועי אותו יום...
Dialogue: 0,0:08:44.12,0:08:50.88,Narrator,,0,0,0,,‫התפשטו לרחבי היישובים הספורים של הענקים בעולם.
Dialogue: 0,0:08:50.88,0:08:55.30,Narrator,,0,0,0,,‫יחד עם יתומי בית הכבשים,\N‫שלא יכלו לסבול את הפרידה מאמם,
Dialogue: 0,0:08:55.30,0:09:00.39,Narrator,,0,0,0,,‫ועם אויבת הענקים המושבעת החדשה,\N‫שרלוט לינלין,
Dialogue: 0,0:09:00.39,0:09:04.54,Narrator,,0,0,0,,‫אמא קרמל עזבה את אלבאף.
Dialogue: 0,0:09:04.54,0:09:10.30,Narrator,,0,0,0,,‫ואז, הם התחילו חיים מחדש\N‫בבית כבשים שנוסד מחדש.
Dialogue: 0,0:09:10.30,0:09:12.80,Main-207-,,0,0,0,,‫גמרנו! זה מספיק טוב?
Dialogue: 0,0:09:12.80,0:09:17.36,Main-207-,,0,0,0,,‫זה כל מה שצריך.\N‫סורי שביקשתי ממך את כל זה.
Dialogue: 0,0:09:17.36,0:09:23.75,Main-207-,,0,0,0,,‫בלי עזרתך, אי אפשר היה לבנות בית\N‫כל כך עמוק בהרים.
Dialogue: 0,0:09:23.75,0:09:28.21,Main-207-,,0,0,0,,‫אל תדאגי. להיות כנה,\N‫אני לא רוצה לראות את פרצוף לינלין,
Dialogue: 0,0:09:28.21,0:09:32.36,Main-207-,,0,0,0,,‫אבל את האמא הקדושה שלנו\N‫גם אנחנו, הענקים, קרמל.
Dialogue: 0,0:09:32.36,0:09:34.06,Main-207-,,0,0,0,,‫אם תצטרכי אותנו, רק תגידי!
Dialogue: 0,0:09:34.06,0:09:35.74,Main-207-,,0,0,0,,‫תודה!
Dialogue: 0,0:09:36.58,0:09:43.10,Narrator,,0,0,0,,‫כדי להרגיע את הילדים החרדים,\N‫קרמל החלה לחייך יותר ויותר.
Dialogue: 0,0:09:45.06,0:09:47.27,Main-207-,,0,0,0,,‫רגע, רגע!
Dialogue: 0,0:09:47.27,0:09:53.25,Narrator,,0,0,0,,‫כמה ימים אחרי העזיבה מאלבאף,\N‫הכל חזר להיות כרגיל...
Dialogue: 0,0:09:53.25,0:09:55.80,Main-207-,,0,0,0,,‫לא, לינלין תהרוג אותי!
Dialogue: 0,0:09:55.80,0:09:58.49,Main-207-,,0,0,0,,‫רגע, רגע!
Dialogue: 0,0:09:58.99,0:10:03.95,Narrator,,0,0,0,,‫ובית הכבשים שוב התמלא\N‫בצחוק של הילדים.
Dialogue: 0,0:10:03.95,0:10:05.97,Main-207-,,0,0,0,,‫תשמרו על הבית בזמן שאני נעדרת.
Dialogue: 0,0:10:05.97,0:10:08.10,Main-207-,,0,0,0,,‫אני אנקה את השירותים!
Dialogue: 0,0:10:08.10,0:10:10.33,Main-207-,,0,0,0,,‫אני אעשה את הכביסה!
Dialogue: 0,0:10:10.33,0:10:13.20,Main-207-,,0,0,0,,‫מתי תחזרי?
Dialogue: 0,0:10:13.20,0:10:16.53,Main-207-,,0,0,0,,‫אחזור אחרי שאגמור לקנות מצרכים.
Dialogue: 0,0:10:16.53,0:10:18.73,Main-207-,,0,0,0,,‫צריכים משהו?
Dialogue: 0,0:10:19.48,0:10:20.89,Main-207-,,0,0,0,,‫עוגה!
Dialogue: 0,0:10:20.89,0:10:23.68,Main-207-,,0,0,0,,‫– חפיסת קלפים!\N‫– חרבות צעצוע לקרבות סמוראים!
Dialogue: 0,0:10:23.68,0:10:25.71,Main-207-,,0,0,0,,‫בסדר.
Dialogue: 0,0:10:26.56,0:10:30.46,Main-207-,,0,0,0,,‫להתראות, אמא! תיזהרי!
Dialogue: 0,0:10:33.36,0:10:36.68,Narrator,,0,0,0,,‫לשאר העולם,\N‫בית הכבשים היה מקום...
Dialogue: 0,0:10:37.52,0:10:40.80,Narrator,,0,0,0,,‫שבו האמא האדוקה הייתה\N‫משקמת ילדים בעייתיים בדרך נסית
Dialogue: 0,0:10:40.80,0:10:43.83,Narrator,,0,0,0,,‫עד שהיו מוכנים לבית טוב...
Dialogue: 0,0:10:49.52,0:10:51.51,Main-207-,,0,0,0,,‫הגעת בזמן...
Dialogue: 0,0:10:52.97,0:10:59.01,Main-207-,,0,0,0,,‫כמובן. האם אי פעם אכזבתי אותך?
Dialogue: 0,0:10:59.01,0:11:01.89,Main-207-,,0,0,0,,‫בוא ניגש לעסקים.
Dialogue: 0,0:11:07.69,0:11:10.90,Main-207-,,0,0,0,,‫הנה ילדה טובה.
Dialogue: 0,0:11:16.66,0:11:19.44,Main-207-,,0,0,0,,‫לא חשבתי שתעזבי את אלבאף...
Dialogue: 0,0:11:20.12,0:11:24.00,Main-207-,,0,0,0,,‫הייתי חייבת. לא רציתי לוותר על הילדה הזאת.
Dialogue: 0,0:11:37.80,0:11:39.90,Main-207-,,0,0,0,,‫תחשוב על זה.
Dialogue: 0,0:11:39.90,0:11:44.60,Main-207-,,0,0,0,,‫בגיל חמש בלבד, היא הצליחה\N‫להרוס חצי מכפר באלבאף.
Dialogue: 0,0:11:44.60,0:11:46.66,Main-207-,,0,0,0,,‫אבל המחיר שאת דורשת הוא...
Dialogue: 0,0:11:46.66,0:11:48.98,Main-207-,,0,0,0,,‫אני יודעת שאתה יכול לשלם.
Dialogue: 0,0:11:48.98,0:11:52.83,Main-207-,,0,0,0,,‫אם הייתה בצי, יום אחד יכולה הייתה להיות\N‫אדמירל ואפילו אדמירל-הצי.
Dialogue: 0,0:11:52.83,0:11:57.41,Main-207-,,0,0,0,,‫אם הייתה בסייפר פול, הייתה\N‫מגן מצוין לדרקוני השמיים.
Dialogue: 0,0:11:58.82,0:12:02.00,Main-207-,,0,0,0,,‫אני בעסק סחר בילדים כבר 50 שנה,
Dialogue: 0,0:12:02.00,0:12:05.58,Main-207-,,0,0,0,,‫והילדה הזאת היא המוצר הטוב ביותר שהיה לי אי פעם!
Dialogue: 0,0:12:06.79,0:12:12.21,Main-207-,,0,0,0,,‫אחרי התרגיל ההוא עם הצי לפני 37 שנה,\N‫יכולתי לחיות באלבאף...
Dialogue: 0,0:12:12.21,0:12:18.02,Main-207-,,0,0,0,,‫מה שהביא לכם את המגויס הראשון מסוגו,\N‫ענק בצי... ג'ון ג'יאנט!
Dialogue: 0,0:12:18.02,0:12:20.97,Main-207-,,0,0,0,,‫זה היה הכל הודות לי!
Dialogue: 0,0:12:21.91,0:12:25.60,Main-207-,,0,0,0,,‫אני מנהלת את בית הכבשים בנקיות,\N‫והילדים האלה לא יודעים
Dialogue: 0,0:12:25.60,0:12:30.15,Main-207-,,0,0,0,,‫שאני מוכרת את הנלהבים שבהם\N‫לממשלה כל שנתיים.
Dialogue: 0,0:12:30.84,0:12:34.07,Main-207-,,0,0,0,,‫יתומים עושים מרגלים טובים, נכון?
Dialogue: 0,0:12:34.07,0:12:36.30,Main-207-,,0,0,0,,‫אין להם היסטוריה לאתר!
Dialogue: 0,0:12:36.30,0:12:39.37,Main-207-,,0,0,0,,‫בסדר! בסדר!\N‫אביא לך את הכסף!
Dialogue: 0,0:12:40.12,0:12:42.49,Main-207-,,0,0,0,,‫כמובן שתביא!
Dialogue: 0,0:12:42.49,0:12:45.85,Main-207-,,0,0,3,,‫לא קל להיות האמא הקדושה.
Dialogue: 0,0:12:46.63,0:12:52.34,Main-207-,,0,0,3,,‫אני חושבת שאשתמש בהזדמנות לפרוש אחרי זה,
Dialogue: 0,0:12:52.34,0:12:57.05,Main-207-,,0,0,3,,‫אז זה יהיה העסקה האחרונה שלי. אני צריכה שתשלם לי במלואו.
Dialogue: 0,0:13:01.58,0:13:04.35,Main-207-,,0,0,0,,‫מה תרצו לשיר היום?
Dialogue: 0,0:13:04.35,0:13:06.60,Main-207-,,0,0,0,,‫"סאקה של בינקס"!
Dialogue: 0,0:13:06.60,0:13:09.56,Main-207-,,0,0,0,,‫באמת? אבל זה שיר של פיראטים.
Dialogue: 0,0:13:09.56,0:13:12.65,Main-207-,,0,0,0,,‫נכון!\N‫אנחנו הולכים להיות פיראטים יום אחד!
Dialogue: 0,0:13:12.65,0:13:15.07,Main-207-,,0,0,0,,‫אוה, זה נשמע מגניב!
Dialogue: 0,0:13:17.70,0:13:21.87,Musical,,0,0,0,,{\fad(150,150)}♪ Making a delivery,\Nbringing it across the sea ♪
Dialogue: 0,0:13:21.87,0:13:25.95,Musical,,0,0,0,,{\fad(150,150)}♪ Binks' sake in the hold\Nas we sail through the breeze ♪
Dialogue: 0,0:13:25.95,0:13:30.25,Musical,,0,0,0,,{\fad(150,150)}♪ Far across the eye can see,\Nthe sun is shining merrily ♪
Dialogue: 0,0:13:30.25,0:13:34.84,Musical,,0,0,0,,{\fad(150,150)}♪ As the birds fly in the sky\Nas they sing out with glee ♪
Dialogue: 0,0:13:32.75,0:13:37.09,Thoughts-207-,,0,0,0,,{\an8}‫ימכרו אתכם לממשלה\N‫לפני שתספיקו להיות פיראטים.
Dialogue: 0,0:13:34.84,0:13:39.25,Musical,,0,0,0,,{\fad(150,150)}♪ Bid adieu to everyone,\Nso long to port renowned ♪
Dialogue: 0,0:13:39.25,0:13:43.66,Musical,,0,0,0,,{\fad(150,150)}♪ Sailing on from dusk 'til dawn\Nand singing out as one ♪
Dialogue: 0,0:13:43.66,0:13:47.94,Musical,,0,0,0,,{\fad(150,150)}♪ Cross the gold and silver waves,\Nchanging into water sprays ♪
Dialogue: 0,0:13:47.94,0:13:52.55,Musical,,0,0,0,,{\fad(150,150)}♪ Sailing out on our journey\Nto the ends of the sea! ♪
Dialogue: 0,0:13:52.55,0:13:55.25,Main-207-,,0,0,0,,‫אחת, שתיים, שלוש!
Dialogue: 0,0:13:55.25,0:14:00.21,Main-207-,,0,0,0,,‫יום הולדת שמח, לינלין!
Dialogue: 0,0:13:55.25,0:13:57.20,Note,,0,0,0,,"Happy birthday, Linlin".
Dialogue: 0,0:14:02.66,0:14:06.51,Main-207-,,0,0,0,,‫תודה, כולם!
Dialogue: 0,0:14:06.51,0:14:12.02,Main-207-,,0,0,0,,‫אנחנו יודעים כמה את אוהבת {\i1}סמלור{\i0}, לינלין... אז עשינו מהם {\i1}קרוקמבוש{\i0}!
Dialogue: 0,0:14:12.02,0:14:13.98,Main-207-,,0,0,0,,‫מקווים שזה טעים!
Dialogue: 0,0:14:13.98,0:14:17.90,Main-207-,,0,0,0,,‫הוא נקרא {\i1}קרוקמבוש{\fs12} {\r}?\N‫זה נראה מעדן!
Dialogue: 0,0:14:20.82,0:14:22.19,Main-207-,,0,0,0,,‫בואו נעשה מסיבת תה!
Dialogue: 0,0:14:22.19,0:14:23.70,Main-207-,,0,0,0,,‫מסיבת תה?
Dialogue: 0,0:14:23.70,0:14:29.82,Main-207-,,0,0,0,,‫נשב בחן סביב השולחנות,\N‫נשתה תה ונאכל ממתקים!
Dialogue: 0,0:14:29.82,0:14:33.42,Main-207-,,0,0,0,,‫זה נשמע נהדר!\N‫רוצה! מסיבת תה!
Dialogue: 0,0:14:33.42,0:14:35.80,Main-207-,,0,0,0,,‫– בואו נכין תה.\N‫– בואי איתנו, אמא!
Dialogue: 0,0:14:35.80,0:14:37.54,Main-207-,,0,0,0,,‫בסדר, בסדר.
Dialogue: 0,0:14:37.90,0:14:39.38,Main-207-,,0,0,0,,‫תודה!
Dialogue: 0,0:14:39.38,0:14:40.50,Main-207-,,0,0,0,,‫יאי!
Dialogue: 0,0:14:42.23,0:14:44.15,Main-207-,,0,0,0,,‫בסדר, מתחילים!
Dialogue: 0,0:14:44.15,0:14:46.76,Main-207-,,0,0,0,,‫– תאכלו כמה שרוצים!\N‫– אכלו, אכלו!
Dialogue: 0,0:14:46.76,0:14:49.28,Main-207-,,0,0,0,,‫אוה-הוה! תודה!
Dialogue: 0,0:14:50.80,0:14:53.84,Main-207-,,0,0,0,,‫זה כל כך טעים!
Dialogue: 0,0:14:55.35,0:14:57.35,Main-207-,,0,0,0,,‫היא אוכלת כל כך מהר!
Dialogue: 0,0:15:00.32,0:15:03.15,Main-207-,,0,0,0,,‫מסיבת התה כיפית!
Dialogue: 0,0:15:04.42,0:15:08.53,Main-207-,,0,0,0,,‫אני כל כך שמחה! זה כל כך טעים!
Dialogue: 0,0:15:09.16,0:15:13.29,Narrator,,0,0,0,,‫יום אחד, אמא קרמל פשוט נעלמה.
Dialogue: 0,0:15:13.29,0:15:19.38,Narrator,,0,0,0,,‫וזה קרה ביום ההולדת הטוב ביותר\N‫שלינלין אי פעם חוותה.
Dialogue: 0,0:15:25.08,0:15:29.09,Narrator,,0,0,0,,‫היא הייתה עם חברותיה בבית הכבשים,\N‫ילדים שעברו את אותם קשיים,
Dialogue: 0,0:15:29.62,0:15:32.89,Narrator,,0,0,0,,‫ועם אמה האהובה, בעלת הלב הטוב.
Dialogue: 0,0:15:33.31,0:15:39.06,Narrator,,0,0,0,,‫מוקפת בכל החיוכים האלה,\N‫ואוכלת את עוגת יום ההולדת המתוקה שלה,
Dialogue: 0,0:15:39.06,0:15:43.23,Narrator,,0,0,0,,‫לינלין לא יכלה לעצור את דמעותיה.
Dialogue: 0,0:15:43.23,0:15:45.36,Main-207-,,0,0,0,,‫תאכלי כמה שתרצי, לינלין.
Dialogue: 0,0:15:45.36,0:15:47.86,Main-207-,,0,0,0,,‫אני אוכלת... אני אוכלת הכל!
Dialogue: 0,0:15:48.46,0:15:54.07,Narrator,,0,0,0,,‫איזה יום נפלא זה היה...\N‫היא בקושי ראתה דרך דמעותיה.
Dialogue: 0,0:15:56.70,0:15:59.40,Main-207-,,0,0,0,,‫הי, הי, אל תמהרי, לינלין!
Dialogue: 0,0:15:59.40,0:16:01.50,Main-207-,,0,0,0,,‫עשינו את זה בשבילך!
Dialogue: 0,0:16:01.50,0:16:02.96,Main-207-,,0,0,0,,‫הכל בשבילך, לינלין!
Dialogue: 0,0:16:02.96,0:16:04.98,Main-207-,,0,0,0,,‫תודה!
Dialogue: 0,0:16:08.63,0:16:10.05,Main-207-,,0,0,0,,‫תאכלי עוד!
Dialogue: 0,0:16:10.05,0:16:12.18,Main-207-,,0,0,0,,‫בואו נישאר חברים!
Dialogue: 0,0:16:12.18,0:16:13.50,Main-207-,,0,0,0,,‫אוה-הוה, אוה-הוה!
Dialogue: 0,0:16:15.36,0:16:17.89,Main-207-,,0,0,0,,‫בואו נישאר ביחד ונשמח!
Dialogue: 0,0:16:17.89,0:16:19.02,Main-207-,,0,0,0,,‫כן!
Dialogue: 0,0:16:19.02,0:16:21.59,Main-207-,,0,0,0,,‫זה כל כך טעים!
Dialogue: 0,0:16:21.59,0:16:25.91,Narrator,,0,0,0,,‫איזה יום הולדת נפלא באמת.
Dialogue: 0,0:16:25.91,0:16:27.70,Main-207-,,0,0,0,,‫ליקוק!
Dialogue: 0,0:16:27.70,0:16:33.90,Main-207-,,0,0,0,,‫אוה, אני כל כך שמחה! אכלתי כל כך הרבה,\N‫שאפילו נגסתי קצת מהשולחן.
Dialogue: 0,0:16:33.90,0:16:39.78,Main-207-,,0,0,0,,‫תודה לכולם!\N‫לעולם לא אשכח את היום הזה עד סוף ה...
Dialogue: 0,0:16:45.70,0:16:47.23,Main-207-,,0,0,0,,‫מה?
Dialogue: 0,0:16:47.50,0:16:50.02,Main-207-,,0,0,0,,‫כולם?
Dialogue: 0,0:16:50.02,0:16:51.23,Main-207-,,0,0,0,,‫אמא?
Dialogue: 0,0:16:52.20,0:16:56.19,Narrator,,0,0,0,,‫יום אחד, אמא קרמל...
Dialogue: 0,0:16:54.65,0:16:56.20,Main-207-,,0,0,0,,‫לאן הם הלכו?
Dialogue: 0,0:16:56.20,0:16:58.98,Narrator,,0,0,0,,‫...נעלמה פתאום.
Dialogue: 0,0:16:58.98,0:17:02.15,Main-207-,,0,0,0,,‫הממ? מה?
Dialogue: 0,0:17:02.15,0:17:05.78,Main-207-,,0,0,0,,‫איפה אתם?! כולם!\N‫האם אתם בבית?
Dialogue: 0,0:17:17.84,0:17:19.65,Main-207-,,0,0,0,,‫הי!
Dialogue: 0,0:17:21.36,0:17:23.22,Main-207-,,0,0,0,,‫כולם!
Dialogue: 0,0:17:25.76,0:17:26.93,Main-207-,,0,0,0,,‫לינלין!
Dialogue: 0,0:17:31.81,0:17:34.23,Main-207-,,0,0,0,,‫אה, הנה את!
Dialogue: 0,0:17:34.68,0:17:36.29,Main-207-,,0,0,0,,‫מה?
Dialogue: 0,0:17:43.44,0:17:46.62,Main-207-,,0,0,0,,‫אל תשאירו אותי לבד...
Dialogue: 0,0:17:49.57,0:17:52.58,Main-207-,,0,0,0,,‫איפה אתם, כולם?
Dialogue: 0,0:18:01.82,0:18:04.84,Flashbacks-207-,,0,0,0,,‫הי, אמא...
Dialogue: 0,0:18:04.84,0:18:09.22,Flashbacks-207-,,0,0,0,,‫למה פשוט נעלמת?
Dialogue: 0,0:18:21.60,0:18:24.00,Main-207-,,0,0,0,,‫לאן הלכת,
Dialogue: 0,0:18:24.00,0:18:27.06,Main-207-,,0,0,0,,‫אמא?!
Dialogue: 0,0:18:27.06,0:18:28.91,Main-207-,,0,0,0,,‫מאמא!
Dialogue: 0,0:18:29.66,0:18:35.05,Narrator,,0,0,0,,‫לפני 63 שנה, אמא קרמל\N‫והילדים האחרים פשוט נעלמו.
Dialogue: 0,0:18:35.94,0:18:38.60,Narrator,,0,0,0,,‫גם ביג מאם בעצמה לא יודעת\N‫את האמת של מה שקרה,
Dialogue: 0,0:18:38.60,0:18:43.55,Narrator,,0,0,0,,{\fad(0,3000)}‫אבל היו שני אנשים\N‫שהיו עדים לכל הדבר...
Dialogue: 0,0:18:44.85,0:18:46.98,Main-207-,,0,0,0,,‫לאן הלכת?
Dialogue: 0,0:18:46.98,0:18:51.50,Narrator,,0,0,0,,‫האחד היה לוחם מאלבאף שדאג לבית הכבשים,
Dialogue: 0,0:18:51.50,0:18:53.27,Narrator,,0,0,0,,‫אז בא לבדוק אותם.
Dialogue: 0,0:18:53.97,0:18:56.20,Main-207-,,0,0,0,,‫מ-מפלצת!
Dialogue: 0,0:18:56.20,0:18:59.16,Narrator,,0,0,0,,‫הענק חוור, ברח,
Dialogue: 0,0:18:59.16,0:19:02.94,Narrator,,0,0,0,,‫ולא חזר לאי.
Dialogue: 0,0:19:05.02,0:19:10.45,Narrator,,0,0,0,,‫בסופו של דבר, הידיעה על אותו יום הגיעה לאלבאף,\N‫ואז לכל הענקים בעולם,
Dialogue: 0,0:19:10.45,0:19:15.62,Narrator,,0,0,0,,‫ומאותו רגע ואילך,\N‫השם "שרלוט לינלין" הפך
Dialogue: 0,0:19:15.62,0:19:19.12,Narrator,,0,0,0,,‫לשנוא כל כך\N‫שאף ענק לא היה מוציא את שמה מפיו.
Dialogue: 0,0:19:22.22,0:19:26.75,Main-207-,,0,0,0,,‫לאן הלכת?! אמא! כולם!
Dialogue: 0,0:19:26.75,0:19:30.22,Narrator,,0,0,0,,‫בינתיים, העד השני
Dialogue: 0,0:19:30.22,0:19:35.14,Narrator,,0,0,0,,‫היה טבח פיראטי כושל\N‫שסיים לגור באי
Dialogue: 0,0:19:35.14,0:19:37.64,Narrator,,0,0,0,,‫ושמו סטרויזן.
Dialogue: 0,0:19:42.78,0:19:46.01,Narrator,,0,0,0,,‫הוא מצא את זה מבדר מאוד.
Dialogue: 0,0:20:01.94,0:20:03.74,Narrator,,0,0,0,,‫הייתה לו היכולת
Dialogue: 0,0:20:03.74,0:20:06.90,Narrator,,0,0,0,,‫להפוך כל חפץ לאוכל,
Dialogue: 0,0:20:06.90,0:20:09.26,Narrator,,0,0,0,,‫הודות לפרי השטן שלו, פרי הבישול-בישול.
Dialogue: 0,0:20:16.28,0:20:18.89,Main-207-,,0,0,0,,‫מעולם לא ראיתי מפלצת כזאת.
Dialogue: 0,0:20:18.89,0:20:22.10,Main-207-,,0,0,0,,‫אל תשאיר אותי לבד...
Dialogue: 0,0:20:23.54,0:20:26.98,Main-207-,,0,0,0,,‫בקצב הזה, היא הולכת למות.\N‫איזה בזבוז זה יהיה.
Dialogue: 0,0:20:33.33,0:20:35.78,Main-207-,,0,0,0,,‫לאן הלכת, אמא?
Dialogue: 0,0:20:38.22,0:20:41.46,Main-207-,,0,0,0,,‫הי, מה קרה, ילדה קטנה?
Dialogue: 0,0:20:41.46,0:20:44.46,Main-207-,,0,0,0,,‫אם תמשיכי לבכות,\N‫רק תרגישי יותר רעב.
Dialogue: 0,0:20:45.32,0:20:50.20,Main-207-,,0,0,0,,‫אמרי לי, ילדה קטנה,\N‫בואי נדבר על החלומות שלך?
Dialogue: 0,0:20:50.20,0:20:51.80,Main-207-,,0,0,0,,‫מי אתה, זקן?
Dialogue: 0,0:20:51.80,0:20:53.55,Main-207-,,0,0,0,,‫הי, אל תתקרב יותר מדי.
Dialogue: 0,0:20:53.55,0:20:59.64,Main-207-,,0,0,0,,‫הי, זקן, ראית את אמא?\N‫אתה יודע לאן כולם הלכו?
Dialogue: 0,0:20:59.64,0:21:03.03,Main-207-,,0,0,0,,‫לא יודע,\N‫אבל אני מניח שהם יחזרו בקרוב.
Dialogue: 0,0:21:03.50,0:21:04.80,Main-207-,,0,0,0,,‫אתה חושב?
Dialogue: 0,0:21:04.80,0:21:07.64,Main-207-,,0,0,0,,‫כן, אשאר איתך עד אז.
Dialogue: 0,0:21:07.64,0:21:12.74,Main-207-,,0,0,0,,‫אני שף טוב.\N‫לא תרעבי בזמן שאני כאן.
Dialogue: 0,0:21:16.20,0:21:19.28,Main-207-,,0,0,0,,‫אני רעבה...
Dialogue: 0,0:21:19.28,0:21:21.69,Main-207-,,0,0,0,,‫תוכלי לסמוך עלי.
Dialogue: 0,0:21:40.98,0:21:42.48,Main-207-,,0,0,0,,‫ראית?
Dialogue: 0,0:21:42.48,0:21:49.07,Narrator,,0,0,0,,‫המפגש בין השניים\N‫הוביל להקמת כנופיית ביג מאם.
Dialogue: 0,0:22:07.04,0:22:09.21,Main-207-,,0,0,0,,‫לינלין!
Dialogue: 0,0:22:09.21,0:22:12.71,Main-207-,,0,0,0,,‫תתעשתי!\N‫הם הולכים לירות בך!
Dialogue: 0,0:22:13.64,0:22:16.30,Flashbacks-207-,,0,0,0,,‫אז, במסיבת התה היום,
Dialogue: 0,0:22:16.30,0:22:21.17,Flashbacks-207-,,0,0,0,,‫אם נשבור את התמונה הזאת לשניים,\N‫מה לדעתך יקרה?
Dialogue: 0,0:22:21.77,0:22:23.60,Flashbacks-207-,,0,0,0,,‫מאמא תהיה מדוכדכת!
Dialogue: 0,0:22:23.60,0:22:28.61,Flashbacks-207-,,0,0,0,,‫ואף אחד שם לא יוכל לזוז\N‫יותר מחמש שניות.
Dialogue: 0,0:22:28.61,0:22:32.82,Flashbacks-207-,,0,0,0,,‫אז, משגר ה-KX\N‫יראה את הכוח האמיתי שלו...
Dialogue: 0,0:22:34.11,0:22:37.49,Flashbacks-207-,,0,0,0,,‫והקיסרית ביג מאם תמות!
Dialogue: 0,0:22:43.64,0:22:46.29,Main-207-,,0,0,0,,‫גמרת, ביג מאם!
Dialogue: 0,0:22:47.64,0:22:49.04,Main-207-,,0,0,0,,‫מאמא!
Dialogue: 0,0:23:07.64,0:23:09.92,Thoughts-207-,,0,0,0,,‫אמא.
Dialogue: 0,0:23:09.92,0:23:13.28,Thoughts-207-,,0,0,0,,‫כולם מנסים לעצור אותי.
Dialogue: 0,0:23:17.84,0:23:23.91,Main-207-,,0,0,0,,‫אנשים הם הכי מאושרים כשהם שווים.
Dialogue: 0,0:23:23.91,0:23:29.59,Main-207-,,0,0,0,,‫אבל בעולם של היום, מדינה כזאת\N‫כמעט בלתי אפשרי למצוא.
Dialogue: 0,0:23:29.59,0:23:34.13,Main-207-,,0,0,0,,‫לכן צריך להקים מדינה כזאת בעצמנו כאן!
Dialogue: 0,0:23:34.13,0:23:37.80,Main-207-,,0,0,0,,‫זו תהיה מדינה שבה כולם שווים!
Dialogue: 0,0:23:37.80,0:23:39.18,Main-207-,,0,0,0,,‫מדינה?!
Dialogue: 0,0:23:39.18,0:23:43.20,Main-207-,,0,0,0,,‫נכון. מקום שבו\N‫כל הגזעים יכולים לחיות יחד בשלום.
Dialogue: 0,0:23:43.20,0:23:46.10,Main-207-,,0,0,0,,‫ושבו כולם\N‫יהיו באותה גובה עיניים!
Dialogue: 0,0:23:46.85,0:23:49.69,Main-207-,,0,0,0,,‫אותה גובה עיניים? זה נשמע נהדר!
Dialogue: 0,0:23:50.12,0:23:53.27,Main-207-,,0,0,0,,‫אז כולם יהיו גדולים כמוני!
Dialogue: 0,0:23:54.07,0:23:56.44,Main-207-,,0,0,0,,‫וואו! כמה מגניב!
Dialogue: 0,0:23:56.99,0:23:59.65,Main-207-,,0,0,0,,‫זה חלום יפה, אמא!
Dialogue: 0,0:24:05.54,0:24:08.58,Main-207-,,0,0,0,,‫לינלין!
Dialogue: 0,0:24:09.64,0:24:13.67,Main-207-,,0,0,0,,‫כולם, בואו נעבוד קשה ביחד.
Dialogue: 0,0:24:13.87,0:24:15.20,Main-207-,,0,0,0,,‫אני אעשה כמיטב יכולתי!
Dialogue: 0,0:24:15.20,0:24:16.78,Main-207-,,0,0,0,,‫– גם אני!\N‫– גם אני!
Dialogue: 0,0:24:16.78,0:24:18.40,Main-207-,,0,0,0,,‫כן!
Dialogue: 0,0:24:18.40,0:24:21.33,Main-207-,,0,0,0,,‫בואו ניצור מדינת חלומות ממש כאן!
Dialogue: 0,0:24:21.33,0:24:23.64,Main-207-,,0,0,0,,‫גם אני אעשה כמיטב יכולתי, אמא!
Dialogue: 0,0:24:23.64,0:24:26.72,Main-207-,,0,0,0,,‫את ילדה טובה, לינלין.
Dialogue: 0,0:24:27.28,0:24:28.60,Main-207-,,0,0,0,,‫כן!
Dialogue: 0,0:24:28.60,0:24:33.95,Main-207-,,0,0,0,,‫אם היו מדינות כאלה,\N‫העולם היה מקום שלו הרבה יותר.
Dialogue: 0,0:24:33.95,0:24:38.61,Main-207-,,0,0,0,,‫כולם היו מצליחים למצוא אושר.
Dialogue: 0,0:24:41.24,0:24:45.45,Main-207-,,0,0,0,,‫החלום של אמא היה החלום שלי!
Dialogue: 0,0:24:45.90,0:24:50.08,Main-207-,,0,0,0,,‫שלום? זה החלום שלך, לינלין?
Dialogue: 0,0:24:50.08,0:24:56.75,Main-207-,,0,0,0,,‫כן! אני הולכת לבנות מדינה\N‫שאמא תאהב!
Dialogue: 0,0:25:10.32,0:25:13.14,Main-207-,,0,0,0,,‫למה שלא תפסיקי לבכות כבר?
Dialogue: 0,0:25:13.14,0:25:17.73,Main-207-,,0,0,0,,‫הי, הי, הי! רוצה לראות את הקסם של אמא!
Dialogue: 0,0:25:17.73,0:25:18.74,Main-207-,,0,0,0,,‫קסם?
Dialogue: 0,0:25:18.74,0:25:22.95,Main-207-,,0,0,0,,‫כן, היא הייתה טובה בתעלולי קסם.
Dialogue: 0,0:25:22.95,0:25:26.12,Main-207-,,0,0,0,,‫אני חושבת שהיא שמה את הידיים כך...
Dialogue: 0,0:25:28.62,0:25:30.87,Main-207-,,0,0,0,,‫ואז...
Dialogue: 0,0:25:35.68,0:25:37.46,Musical,,0,0,0,,{\fad(150,150)}♪ Flower, flower! ♪
Dialogue: 0,0:25:37.46,0:25:38.84,Musical,,0,0,0,,{\fad(150,150)}♪ Flower, flower! ♪
Dialogue: 0,0:25:38.84,0:25:42.70,Main-207-,,0,0,0,,‫מה?! זה התעלול שאמא הייתה עושה!\N‫למה?!
Dialogue: 0,0:25:39.38,0:25:41.09,Musical,,0,0,0,,{\an8\fad(150,150)}♪ Flower, flower! ♪
Dialogue: 0,0:25:41.09,0:25:42.72,Musical,,0,0,0,,{\an8\fad(150,150)}♪ Flower, flower! ♪
Dialogue: 0,0:25:42.70,0:25:44.38,Main-207-,,0,0,0,,‫איך אני מסוגלת לעשות את זה?!
Dialogue: 0,0:25:42.72,0:25:44.38,Musical,,0,0,0,,{\an8\fad(150,150)}♪ Flower, flower! ♪
Dialogue: 0,0:25:44.38,0:25:46.18,Musical,,0,0,0,,{\fad(150,150)}♪ Flower, flower! ♪
Dialogue: 0,0:25:46.18,0:25:48.01,Musical,,0,0,0,,{\fad(150,150)}♪ Flower, flower! ♪
Dialogue: 0,0:25:48.01,0:25:49.88,Musical,,0,0,0,,{\fad(150,150)}♪ Flower, flower! ♪
Dialogue: 0,0:25:49.89,0:25:51.64,Musical,,0,0,0,,{\fad(150,150)}♪ Flower, flower! ♪
Dialogue: 0,0:25:49.20,0:25:50.85,Musical,,0,0,0,,{\fad(150,150)}♪ Earth! ♪
Dialogue: 0,0:25:51.64,0:25:53.28,Musical,,0,0,0,,{\fad(150,150)}♪ Flower, flower! ♪
Dialogue: 0,0:25:53.27,0:25:55.04,Musical,,0,0,0,,{\fad(150,150)}♪ Flower, flower! Flower... ♪
Dialogue: 0,0:25:51.64,0:25:53.77,Musical,,0,0,0,,{\fad(150,150)}♪ Earth! ♪
Dialogue: 0,0:25:56.94,0:26:01.44,Main-207-,,0,0,0,,‫מה ה...\N‫האם זו כוח של פרי השטן?
Dialogue: 0,0:26:01.44,0:26:02.74,Musical,,0,0,0,,{\fad(150,150)}♪ Flower, flower! ♪
Dialogue: 0,0:26:02.74,0:26:04.32,Musical,,0,0,0,,{\fad(150,150)}♪ Flower, flower! ♪
Dialogue: 0,0:26:04.32,0:26:06.06,Musical,,0,0,0,,{\fad(150,150)}♪ Flower, flower! ♪
