Dialogue: 0,0:00:00.00,0:00:05.00,Main-207-,,0,0,0,,{\an8}‫תרגום לעברית — That One Gerbil
Dialogue: 0,0:01:34.82,0:01:38.11,Main-207-,,0,0,0,,‫תעוף...
Dialogue: 0,0:01:38.11,0:01:41.62,Main-207-,,0,0,0,,‫עד קצה העולם החדש!
Dialogue: 0,0:01:42.77,0:01:45.33,Main-207-,,0,0,0,,{\fad(150,150)}‫פגז!
Dialogue: 0,0:02:34.11,0:02:38.05,Main-207-,,0,0,0,,‫מאמא, גברת סמות'י מ\N‫שלוש המפקדות המתוקות הגיעה!
Dialogue: 0,0:02:44.05,0:02:46.05,Main-207-,,0,0,0,,‫בסדר.
Dialogue: 0,0:02:46.05,0:02:49.66,Main-207-,,0,0,0,,‫המפקד המתוק קטקורי\N‫יגיע בקרוב גם הוא!
Dialogue: 0,0:02:49.66,0:02:53.90,Main-207-,,0,0,0,,‫אוי, עבר זמן מאז ש\N‫כולם התאספו יחד!
Dialogue: 0,0:02:54.37,0:02:57.82,Main-207-,,0,0,0,,‫מה עם קראקר?\N‫הוא כבר חזר הביתה?
Dialogue: 0,0:02:57.82,0:03:01.71,Main-207-,,0,0,0,,‫אני בטוחה שהוא יחזור בקרוב\N‫עם הראש של כובע הקש כמתנה!
Dialogue: 0,0:03:01.71,0:03:04.08,Main-207-,,0,0,0,,‫אני כבר לא יכולה לחכות!
Dialogue: 0,0:03:18.02,0:03:20.17,Main-207-,,0,0,0,,‫הממ? זה...?
Dialogue: 0,0:03:29.13,0:03:30.77,Main-207-,,0,0,0,,‫מה קרה?
Dialogue: 0,0:03:40.40,0:03:41.87,Main-207-,,0,0,0,,‫מה זה?!
Dialogue: 0,0:03:47.08,0:03:48.70,Main-207-,,0,0,0,,‫אח גדול!
Dialogue: 0,0:03:51.03,0:03:52.54,Main-207-,,0,0,0,,‫אח גדול!
Dialogue: 0,0:03:52.54,0:03:54.25,Main-207-,,0,0,0,,‫אח גדול קראקר!
Dialogue: 0,0:03:54.25,0:03:58.00,Main-207-,,0,0,0,,‫זה לא ייתכן!\N‫הוא אחד משלושת המפקדות המתוקות שלנו!
Dialogue: 0,0:03:58.00,0:04:02.17,Main-207-,,0,0,3,,‫מי עשה את זה?! אני אהרוג את הנבל הזה!
Dialogue: 0,0:04:02.52,0:04:05.56,Main-207-,,0,0,3,,‫מאיפה הוא עף?!
Dialogue: 0,0:04:05.56,0:04:07.38,Main-207-,,0,0,3,,‫אני חושב שהוא הלך ליער
Dialogue: 0,0:04:07.38,0:04:11.14,Main-207-,,0,0,3,,‫כדי לסדר את לופי כובע הקש אמש.
Dialogue: 0,0:04:11.48,0:04:13.14,Main-207-,,0,0,0,,‫אז זה אומר...
Dialogue: 0,0:04:15.60,0:04:19.07,Main-207-,,0,0,0,,‫לופי כובע הקש חייב להיות כאן בסביבה!
Dialogue: 0,0:04:20.94,0:04:24.03,Main-207-,,0,0,0,,‫תוציאו התראת חירום!
Dialogue: 0,0:04:28.95,0:04:30.51,Main-207-,,0,0,0,,‫פינוי!
Dialogue: 0,0:04:30.51,0:04:31.68,Main-207-,,0,0,0,,‫מה קרה?!
Dialogue: 0,0:04:31.68,0:04:34.83,Main-207-,,0,0,0,,‫המפקד המתוק קראקר הובס!
Dialogue: 0,0:04:34.83,0:04:35.83,Main-207-,,0,0,0,,‫מה?!
Dialogue: 0,0:04:53.26,0:04:55.39,Main-207-,,0,0,0,,‫לופי! אתה בסדר?!
Dialogue: 0,0:04:55.39,0:04:58.60,Main-207-,,0,0,0,,‫אכלתי ביסקוויטים בשביל חיים שלמים...
Dialogue: 0,0:04:58.60,0:05:01.50,Main-207-,,0,0,0,,‫אבל התכווצת חזרה הרבה.
Dialogue: 0,0:05:02.27,0:05:05.38,Main-207-,,0,0,0,,‫גיר ארבע לוקח כל כך הרבה אנרגיה.
Dialogue: 0,0:05:08.54,0:05:09.58,Main-207-,,0,0,0,,‫פאונד!
Dialogue: 0,0:05:10.07,0:05:12.10,Main-207-,,0,0,0,,‫איפה היית?!
Dialogue: 0,0:05:12.10,0:05:17.58,Main-207-,,0,0,0,,‫טוב, אני מצטער שברחתי.\N‫חשבתי שאתה הולך להפסיד.
Dialogue: 0,0:05:17.58,0:05:19.50,Main-207-,,0,0,0,,‫אתה די כנה!
Dialogue: 0,0:05:19.50,0:05:23.75,Main-207-,,0,0,0,,‫כי הבן אדם הזה היה \N‫אחד משלושת המפקדות המתוקות...
Dialogue: 0,0:05:23.75,0:05:25.13,Main-207-,,0,0,0,,‫טוב...
Dialogue: 0,0:05:29.39,0:05:33.40,Main-207-,,0,0,0,,‫בכל מקרה, ניצחנו!
Dialogue: 0,0:05:33.40,0:05:35.10,Main-207-,,0,0,0,,‫עשינו את זה! עשינו את זה!
Dialogue: 0,0:05:35.43,0:05:37.44,Main-207-,,0,0,0,,‫יאי! יאי!
Dialogue: 0,0:05:39.72,0:05:44.28,Main-207-,,0,0,0,,‫תתעוררו!\N‫הכנו אחד מקציני הקיסר הבכירים!
Dialogue: 0,0:05:45.11,0:05:47.53,Main-207-,,0,0,0,,‫אני... אפילו לא יכול לזוז...
Dialogue: 0,0:05:47.53,0:05:50.91,Main-207-,,0,0,0,,‫מה עשינו...
Dialogue: 0,0:05:50.91,0:05:55.29,Main-207-,,0,0,0,,‫עזרנו להם להביס את השר קראקר...
Dialogue: 0,0:05:56.63,0:06:02.59,Main-207-,,0,0,0,,‫כולם יודעים שאנחנו ה-Homies\N‫לא יכולים להתנגד לכוח של כרטיס הויבר של מאמא!
Dialogue: 0,0:06:03.19,0:06:10.18,Main-207-,,0,0,0,,‫לכן אפילו ילדי מאמא\N‫לא מורשים לשאת אחד!
Dialogue: 0,0:06:10.51,0:06:13.02,Main-207-,,0,0,0,,‫למה יש לך אחד?!
Dialogue: 0,0:06:13.02,0:06:14.33,Main-207-,,0,0,0,,‫זה נכון?
Dialogue: 0,0:06:15.14,0:06:17.98,Main-207-,,0,0,0,,‫אז הדבר הזה די יקר.
Dialogue: 0,0:06:17.98,0:06:21.43,Main-207-,,0,0,0,,‫אבל אתה בצרות גדולות.
Dialogue: 0,0:06:21.43,0:06:22.23,Main-207-,,0,0,0,,‫למה?
Dialogue: 0,0:06:25.28,0:06:29.53,Main-207-,,0,0,0,,‫כשהמפקד המתוק סנאק הובס,
Dialogue: 0,0:06:31.62,0:06:35.49,Main-207-,,0,0,0,,‫הצי הנקמני של קראקר\N‫הכהה את הים...
Dialogue: 0,0:06:36.02,0:06:38.78,Main-207-,,0,0,0,,‫ולינלין הכועסת יצרה סופה.
Dialogue: 0,0:06:41.29,0:06:46.51,Main-207-,,0,0,0,,‫שמעתי שהיא טבעה את ספינת האויב \N‫בהרף עין!
Dialogue: 0,0:06:46.98,0:06:48.01,Main-207-,,0,0,0,,‫סופה?
Dialogue: 0,0:06:48.01,0:06:51.37,Main-207-,,0,0,0,,‫לינלין תמיד מלווה\N‫באלמנטים של מזג האוויר.
Dialogue: 0,0:06:51.37,0:06:52.34,Main-207-,,0,0,0,,‫מזג אוויר?
Dialogue: 0,0:06:52.34,0:06:55.46,Main-207-,,0,0,0,,‫ביד שמאל שלה, זאוס, ענן רעמים!
Dialogue: 0,0:06:57.27,0:07:00.81,Main-207-,,0,0,0,,‫ביד ימין שלה, פרומתאוס, שמש!
Dialogue: 0,0:07:02.15,0:07:06.43,Main-207-,,0,0,0,,‫כשהיא מתרגזת, שום דבר לא יכול לעצור אותה.
Dialogue: 0,0:07:08.07,0:07:12.91,Main-207-,,0,0,0,,‫לפני שהיא תשמע על זה,\N‫תברח!
Dialogue: 0,0:07:14.83,0:07:17.45,Main-207-,,0,0,0,,‫לא אכפת לי אם היא תתרגז!
Dialogue: 0,0:07:17.45,0:07:18.70,Main-207-,,0,0,0,,‫מה?!
Dialogue: 0,0:07:21.29,0:07:25.92,Main-207-,,0,0,0,,‫אני זו שרוצה להתרגז!\N‫קודם כל, הטיפש סאנג'י...
Dialogue: 0,0:07:26.13,0:07:29.38,Note,,0,0,0,,"To my buds, I've gotta see a woman.\NI'll be back. –Sanji"
Dialogue: 0,0:07:26.84,0:07:29.97,Main-207-,,0,0,0,,‫הוא עזב פתאום, השאיר פתק!
Dialogue: 0,0:07:29.97,0:07:31.97,Main-207-,,0,0,0,,‫הכל בלי לספר לנו למה!
Dialogue: 0,0:07:34.85,0:07:36.97,Flashbacks-207-,,0,0,0,,‫זו הבעיה שלי.
Dialogue: 0,0:07:37.31,0:07:39.23,Flashbacks-207-,,0,0,0,,‫אני בהחלט אחזור.
Dialogue: 0,0:07:41.10,0:07:44.06,Flashbacks-207-,,0,0,0,,‫תגידו להם שלום מצדי.
Dialogue: 0,0:07:44.06,0:07:47.38,Main-207-,,0,0,0,,‫הודות למפה של פודינג,\N‫הגענו עד כאן,
Dialogue: 0,0:07:47.38,0:07:49.74,Main-207-,,0,0,0,,‫אבל פקומס נעלם.
Dialogue: 0,0:07:49.74,0:07:53.04,Main-207-,,0,0,0,,‫ולמרות שפודינג אמרה\N‫שהיא תביא את סאנג'י,
Dialogue: 0,0:07:53.04,0:07:57.03,Main-207-,,0,0,0,,‫לא היה אף אחד\N‫בנקודת המפגש.
Dialogue: 0,0:07:57.03,0:08:00.70,Main-207-,,0,0,0,,‫בזבזנו הרבה זמן \N‫כשהיינו אבודים ביער!
Dialogue: 0,0:08:01.39,0:08:06.92,Main-207-,,0,0,0,,‫כשהם יתחתנו,\N‫סאנג'י יהפוך לכפוף של ביג מום, נכון?!
Dialogue: 0,0:08:08.13,0:08:10.85,Main-207-,,0,0,0,,‫חייבים לזוז!
Dialogue: 0,0:08:12.01,0:08:14.89,Main-207-,,0,0,0,,‫כן! מתי החתונה?
Dialogue: 0,0:08:14.89,0:08:17.26,Main-207-,,0,0,0,,‫קראקר אמר שהיום הוינסמוקים יהיו
Dialogue: 0,0:08:17.26,0:08:19.54,Main-207-,,0,0,0,,‫בטירה שבה תתקיים החתונה.
Dialogue: 0,0:08:20.69,0:08:23.90,Main-207-,,0,0,0,,‫מה השעה עכשיו? חייבים לעצור אותם!
Dialogue: 0,0:08:23.90,0:08:28.23,Main-207-,,0,0,0,,‫א-אתה רציני?\N‫אם לא תברח, אתה באמת...
Dialogue: 0,0:08:28.23,0:08:30.19,Main-207-,,0,0,0,,‫אני לא הולך לברוח!
Dialogue: 0,0:08:38.56,0:08:39.79,Main-207-,,0,0,0,,‫היי, עץ!
Dialogue: 0,0:08:42.48,0:08:44.99,Main-207-,,0,0,0,,‫אתה יודע איפה הטירה, נכון?!
Dialogue: 0,0:08:44.99,0:08:45.96,Main-207-,,0,0,0,,‫טוב...
Dialogue: 0,0:08:45.96,0:08:48.00,Main-207-,,0,0,0,,‫תקח אותי לטירה!
Dialogue: 0,0:08:48.00,0:08:49.75,Main-207-,,0,0,0,,‫בשום אופן–
Dialogue: 0,0:08:53.24,0:08:57.41,Main-207-,,0,0,0,,‫אנחנו הולכים להחזיר את סאנג'י בכל מחיר!
Dialogue: 0,0:09:20.71,0:09:22.92,Main-207-,,0,0,0,,{\i1}‫נאמי, את שומעת אותי?!{\i}
Dialogue: 0,0:09:22.92,0:09:23.83,Main-207-,,0,0,0,,‫צ'ופר!
Dialogue: 0,0:09:23.83,0:09:25.12,Main-207-,,0,0,0,,‫מה שלומכם?
Dialogue: 0,0:09:25.12,0:09:29.36,Main-207-,,0,0,0,,{\i1}‫אנחנו בסדר! אם הדברים יסתדרו, \N‫נראה אתכם וקבוצת ברוק–{\i}
Dialogue: 0,0:09:29.36,0:09:30.17,Main-207-,,0,0,0,,{\i1}‫מה?{\i}
Dialogue: 0,0:09:31.29,0:09:33.58,Main-207-,,0,0,0,,‫זה לא נראה בסדר! צ'ופר?
Dialogue: 0,0:09:33.58,0:09:37.07,Main-207-,,0,0,0,,{\i1}‫בכל מקרה, אי אפשר להציל אותנו מבחוץ!{\i}
Dialogue: 0,0:09:37.07,0:09:38.13,Main-207-,,0,0,0,,{\i1}‫פשוט תמשיכו–{\i0}
Dialogue: 0,0:09:38.96,0:09:40.08,Main-207-,,0,0,0,,‫צ'ופר?!
Dialogue: 0,0:09:40.08,0:09:43.30,Main-207-,,0,0,0,,{\i1}‫נאמי, אל תדאגי! אנחנו בסדר–{\i}
Dialogue: 0,0:09:44.20,0:09:45.91,Main-207-,,0,0,0,,‫איך אני לא אדאג?
Dialogue: 0,0:09:45.91,0:09:49.47,Main-207-,,0,0,0,,‫נכון, אנחנו הולכים לטירה\N‫למצוא את סאנג'י-{\i1}קון{\fs10} {\r}!
Dialogue: 0,0:09:49.47,0:09:50.61,Main-207-,,0,0,0,,{\i1}‫בסדר!{\i}
Dialogue: 0,0:09:50.61,0:09:54.28,Main-207-,,0,0,0,,{\i1}‫ברגע שתצילו את סאנג'י,\N‫תעדכנו אותנו דרך המראה הזו שו–{\i}
Dialogue: 0,0:09:55.18,0:09:56.28,Main-207-,,0,0,0,,‫היא נשברה!
Dialogue: 0,0:09:56.28,0:09:58.99,Main-207-,,0,0,0,,‫היי, צ'ופר?! קרוט?!
Dialogue: 0,0:09:59.60,0:10:02.58,Main-207-,,0,0,0,,‫היא הפכה למראה רגילה.\N‫הם בסדר?
Dialogue: 0,0:10:07.87,0:10:09.83,Main-207-,,0,0,0,,‫הוא נהיה קטן יותר מקודם?!
Dialogue: 0,0:10:13.50,0:10:14.55,Main-207-,,0,0,0,,‫מה?
Dialogue: 0,0:10:14.55,0:10:16.20,Main-207-,,0,0,0,,‫מה קורה?!
Dialogue: 0,0:10:17.71,0:10:18.77,Main-207-,,0,0,0,,‫וואו...
Dialogue: 0,0:10:23.13,0:10:27.51,Main-207-,,0,0,0,,‫הוא כמעט חזר לגודל הרגיל!\N‫האם זה אנושי?!
Dialogue: 0,0:10:27.51,0:10:29.27,Main-207-,,0,0,0,,‫בשר...
Dialogue: 0,0:10:28.56,0:10:29.27,Secondary-207-,,0,0,0,,‫בשר?!
Dialogue: 0,0:10:30.92,0:10:32.30,Main-207-,,0,0,0,,‫היי, ילדה צעירה.
Dialogue: 0,0:10:33.58,0:10:34.86,Main-207-,,0,0,0,,‫את בת מזל.
Dialogue: 0,0:10:34.86,0:10:35.99,Main-207-,,0,0,0,,‫למה?
Dialogue: 0,0:10:35.99,0:10:37.12,Main-207-,,0,0,0,,‫הנה הם.
Dialogue: 0,0:10:42.11,0:10:44.45,Main-207-,,0,0,0,,‫זה גרמה 66.
Dialogue: 0,0:10:46.85,0:10:48.46,Main-207-,,0,0,0,,‫אתה יכול לראות את סאנג'י?
Dialogue: 0,0:10:49.29,0:10:50.75,Main-207-,,0,0,0,,‫זה זה?!
Dialogue: 0,0:10:51.79,0:10:55.05,Main-207-,,0,0,0,,‫היי, סאנג'י!
Dialogue: 0,0:10:55.05,0:10:58.42,Main-207-,,0,0,0,,‫הוד מעלתך, \N‫משהו מתקרב אלינו.
Dialogue: 0,0:11:00.01,0:11:02.93,Main-207-,,0,0,0,,‫עבר זמן מה!
Dialogue: 0,0:11:02.93,0:11:07.44,Main-207-,,0,0,0,,‫מה?! הטיפש הזה הגיע עד כאן\N‫לשטח של ביג מום?!
Dialogue: 0,0:11:09.13,0:11:12.46,Main-207-,,0,0,0,,‫מה העץ הגדול מאחוריו?!\N‫הוא רץ!
Dialogue: 0,0:11:12.46,0:11:14.40,Main-207-,,0,0,0,,‫היי!
Dialogue: 0,0:11:14.40,0:11:16.72,Main-207-,,0,0,0,,‫סאנג'י-{\i1}קון{\fs10} {\r}!
Dialogue: 0,0:11:16.72,0:11:19.35,Main-207-,,0,0,0,,‫שמח שהגענו בזמן!
Dialogue: 0,0:11:19.35,0:11:21.74,Main-207-,,0,0,0,,‫חשבתי שלא אראה אותך שוב!
Dialogue: 0,0:11:22.35,0:11:25.26,Main-207-,,0,0,0,,‫למה הם... כאן?
Dialogue: 0,0:11:25.70,0:11:29.19,Main-207-,,0,0,0,,‫זה לופי כובע הקש?
Dialogue: 0,0:11:29.19,0:11:32.65,Main-207-,,0,0,0,,‫היי! באנו לאסוף אותך!
Dialogue: 0,0:11:32.65,0:11:33.91,Main-207-,,0,0,0,,‫סאנג'י!
Dialogue: 0,0:11:33.91,0:11:36.42,Main-207-,,0,0,0,,‫עצור, טיפש!\N‫הקליקואוץ' יתהפך!
Dialogue: 0,0:11:36.71,0:11:38.17,Main-207-,,0,0,0,,‫בוא נלך, סאנג'י!
Dialogue: 0,0:11:38.17,0:11:41.86,Main-207-,,0,0,0,,‫אמרת בפתק שתחזור,\N‫אבל לא רציתי לחכות.
Dialogue: 0,0:11:44.71,0:11:47.47,Flashbacks-207-,,0,0,0,,‫משתה!
Dialogue: 0,0:11:49.84,0:11:52.30,Main-207-,,0,0,0,,‫רציתי לבוא לבד, אבל...
Dialogue: 0,0:11:52.30,0:11:55.11,Flashbacks-207-,,0,0,0,,‫אמרת שהידיים שלך חשובות לך.
Dialogue: 0,0:11:55.44,0:11:59.55,Flashbacks-207-,,0,0,0,,‫אם תנסה לברוח מהאי הזה,\N‫הידיים שלך יתפוצצו!
Dialogue: 0,0:12:03.03,0:12:06.41,Flashbacks-207-,,0,0,0,,‫אם מישהו דוחה את ההזמנה של מאמא...
Dialogue: 0,0:12:07.64,0:12:10.87,Main-207-,,0,0,0,,‫אז זורו והשאר \N‫חייבים להגיע לואנו.
Dialogue: 0,0:12:11.17,0:12:14.83,Flashbacks-207-,,0,0,0,,‫...רוצים שנחתוך לו את הראש.
Dialogue: 0,0:12:15.90,0:12:19.53,Main-207-,,0,0,0,,‫לכן נאמי, צ'ופר, ברוק ואני \N‫באנו לאסוף אותך. ו...
Dialogue: 0,0:12:19.53,0:12:24.06,Flashbacks-207-,,0,0,0,,‫אתה קורבן, סאנג'י.\N‫אני לא השתניתי.
Dialogue: 0,0:12:24.06,0:12:28.64,Flashbacks-207-,,0,0,0,,‫...אם אי פעם תכשל להיות גבר אמיתי, \N‫אני אשחט את עצמי!
Dialogue: 0,0:12:29.51,0:12:30.97,Flashbacks-207-,,0,0,0,,‫סאנג'י, אני רעב!
Dialogue: 0,0:12:31.46,0:12:34.92,Flashbacks-207-,,0,0,0,,‫אני לא רואה בך בן שלי אפילו לא קצת!
Dialogue: 0,0:12:34.92,0:12:37.51,Flashbacks-207-,,0,0,0,,‫ככה הורה מודה בטעות שלו!
Dialogue: 0,0:12:37.51,0:12:39.94,Flashbacks-207-,,0,0,0,,‫אני לא רוצה שאף אחד ידע על בושתי.
Dialogue: 0,0:12:38.98,0:12:39.94,Secondary-207-,,0,0,0,,‫סאנג'י!
Dialogue: 0,0:12:44.22,0:12:46.97,Flashbacks-207-,,0,0,0,,‫היי, סאנג'י!
Dialogue: 0,0:12:48.56,0:12:51.69,Flashbacks-207-,,0,0,0,,‫אל תתקרר.
Dialogue: 0,0:12:53.40,0:12:55.62,Main-207-,,0,0,0,,‫תראה, לא היה לי ברירה, אז...
Dialogue: 0,0:12:59.88,0:13:02.55,Main-207-,,0,0,0,,‫היי! מה אתה עושה, סאנג'י-{\i1}קון{\fs12} {\r}?!
Dialogue: 0,0:13:06.50,0:13:09.68,Main-207-,,0,0,0,,‫תסתלק מפניי, \N‫פיראט פחות ממאום!
Dialogue: 0,0:13:13.13,0:13:16.77,Main-207-,,0,0,0,,‫שמי הוא וינסמוק סאנג'י.
Dialogue: 0,0:13:18.10,0:13:19.49,Main-207-,,0,0,0,,‫אני נסיך...
Dialogue: 0,0:13:20.59,0:13:22.11,Main-207-,,0,0,0,,‫של גרמה!
Dialogue: 0,0:13:22.74,0:13:25.26,Main-207-,,0,0,0,,‫אני מצטער שהסתרתי את זה.
Dialogue: 0,0:13:25.26,0:13:28.28,Main-207-,,0,0,0,,‫חשבתי שזה יביא אותך לעצב.
Dialogue: 0,0:13:28.93,0:13:33.29,Main-207-,,0,0,0,,‫ההבדל במעמד שלנו\N‫לא יכול להיות ברור יותר.
Dialogue: 0,0:13:33.29,0:13:38.50,Main-207-,,0,0,0,,‫אם אשאר כאן, אוכל לבזבז כסף\N‫ולהשתמש בחיילים ובמשרתים כרצוני.
Dialogue: 0,0:13:39.11,0:13:43.40,Main-207-,,0,0,0,,‫לחזור לספינה העלובה ההיא\N‫איתך ועם החברים שלך...
Dialogue: 0,0:13:44.12,0:13:49.68,Main-207-,,0,0,0,,‫או להישאר כאן,\N‫להתחתן עם הבת היפה של ביג מום.
Dialogue: 0,0:13:49.68,0:13:54.80,Main-207-,,0,0,0,,‫די ברור מה חיים יותר מאושרים.
Dialogue: 0,0:13:54.80,0:13:57.84,Main-207-,,0,0,0,,‫אל תיקח את הפתק ברצינות.
Dialogue: 0,0:13:57.84,0:14:00.08,Main-207-,,0,0,0,,‫אני לא אחזור איתכם!
Dialogue: 0,0:14:00.08,0:14:04.90,Main-207-,,0,0,0,,‫אני לא מאמין שבאתם עד לכאן.\N‫תודה על הטרחה.
Dialogue: 0,0:14:06.56,0:14:10.24,Main-207-,,0,0,0,,‫תסתלקו מכאן... \N‫כבר שכחתי את השם שלך.
Dialogue: 0,0:14:10.24,0:14:14.12,Main-207-,,0,0,0,,‫שיגעון! על מה אתה מדבר?!\N‫אני לא משתכנע!
Dialogue: 0,0:14:14.98,0:14:17.65,Main-207-,,0,0,0,,‫בסדר, אני אעזור לך לגרש אותם.
Dialogue: 0,0:14:17.65,0:14:18.90,Main-207-,,0,0,0,,‫שב בצד!
Dialogue: 0,0:14:21.24,0:14:22.72,Main-207-,,0,0,0,,‫אני...
Dialogue: 0,0:14:23.38,0:14:24.76,Main-207-,,0,0,0,,‫אשלח אותם!
Dialogue: 0,0:14:34.89,0:14:37.85,Main-207-,,0,0,0,,‫מה הכוונה לשלוח אותנו, סאנג'י?
Dialogue: 0,0:14:37.85,0:14:38.94,Main-207-,,0,0,0,,‫תארזו.
Dialogue: 0,0:14:39.55,0:14:41.66,Main-207-,,0,0,0,,‫אין משמעות אחרת.
Dialogue: 0,0:14:44.29,0:14:47.33,Main-207-,,0,0,0,,‫אני לא יודע מה גרם לכם לבוא,
Dialogue: 0,0:14:47.33,0:14:50.73,Main-207-,,0,0,0,,‫אבל אני מעריך\N‫שטרחתם.
Dialogue: 0,0:14:51.53,0:14:56.53,Main-207-,,0,0,0,,‫אמור כך, אם באמת חשבתם עלי, \N‫הייתם צריכים לעשות בדיוק ההפך.
Dialogue: 0,0:14:57.09,0:15:00.06,Main-207-,,0,0,0,,‫במקום להיות איתכם\N‫שאתם עניים וחלשים,
Dialogue: 0,0:15:00.06,0:15:04.04,Main-207-,,0,0,0,,‫עדיף להיות חלק\N‫מהפיראטים של ביג מום, העשירים והחזקים.
Dialogue: 0,0:15:04.98,0:15:06.92,Main-207-,,0,0,0,,‫אהיה יותר מאושר.
Dialogue: 0,0:15:08.30,0:15:10.51,Main-207-,,0,0,0,,‫להיות כנה, אני לא בטוח
Dialogue: 0,0:15:10.51,0:15:13.72,Main-207-,,0,0,0,,‫שתהפוך למלך הפיראטים.
Dialogue: 0,0:15:13.72,0:15:17.25,Main-207-,,0,0,0,,‫זה פשוט טבע אנושי\N‫לקפוץ על עגלת הזוכים.
Dialogue: 0,0:15:17.86,0:15:21.98,Main-207-,,0,0,0,,‫תפסיק לצחוק, סאנג'י-{\i1}קון{\fs10} {\r}!\N‫על מה אתה מדבר?!
Dialogue: 0,0:15:24.58,0:15:27.90,Main-207-,,0,0,0,,‫אז כל הזמן הזה,
Dialogue: 0,0:15:28.58,0:15:30.90,Main-207-,,0,0,0,,‫הטעית אותי.
Dialogue: 0,0:15:31.75,0:15:33.60,Main-207-,,0,0,0,,‫כן, נכון.
Dialogue: 0,0:15:35.22,0:15:37.42,Main-207-,,0,0,0,,‫למעשה, הסתכלתי עליך מלמעלה.
Dialogue: 0,0:15:40.79,0:15:43.42,Main-207-,,0,0,0,,‫מה הזוהר הזה? להבה?!
Dialogue: 0,0:15:45.02,0:15:47.50,Main-207-,,0,0,0,,‫זה יהיה כיף לצפות.
Dialogue: 0,0:15:49.13,0:15:53.30,Main-207-,,0,0,0,,‫אני מניח שלא ציפית לזה,\N‫אז קשה לקבל.
Dialogue: 0,0:15:53.75,0:15:56.93,Main-207-,,0,0,0,,‫אני אוכיח לך. תתכונן.
Dialogue: 0,0:15:58.86,0:16:01.06,Main-207-,,0,0,0,,{\fad(150,150)}‫דיאבל ז'אמב...
Dialogue: 0,0:16:01.06,0:16:02.23,Main-207-,,0,0,0,,‫לא, סאנג'י-{\i1}קון{\fs10} {\r}!
Dialogue: 0,0:16:08.96,0:16:11.76,Main-207-,,0,0,0,,{\fad(150,150)}‫ז'ואה שוט!
Dialogue: 0,0:16:40.68,0:16:42.43,Main-207-,,0,0,0,,‫לופי! אתה מדמם!
Dialogue: 0,0:16:43.19,0:16:46.15,Main-207-,,0,0,0,,‫סאנג'י-{\i1}קון{\i}, האם באמת...
Dialogue: 0,0:16:50.91,0:16:52.44,Main-207-,,0,0,0,,‫תתכוננו להילחם.
Dialogue: 0,0:16:53.12,0:16:56.22,Main-207-,,0,0,0,,‫תשתמש בהאקי שלך או שתמות.
Dialogue: 0,0:16:57.14,0:17:00.66,Main-207-,,0,0,0,,‫אני רק רוצה לדבר איתך.\N‫למה אני צריך האקי?
Dialogue: 0,0:17:09.75,0:17:11.36,Main-207-,,0,0,0,,‫אני...
Dialogue: 0,0:17:11.36,0:17:12.92,Main-207-,,0,0,0,,‫לא הולך להילחם איתך!
Dialogue: 0,0:17:19.64,0:17:21.14,Main-207-,,0,0,0,,‫אז...
Dialogue: 0,0:17:22.31,0:17:23.81,Main-207-,,0,0,0,,‫תסתלק!
Dialogue: 0,0:17:26.92,0:17:29.69,Main-207-,,0,0,0,,‫אני גם לא הולך לעשות את זה!
Dialogue: 0,0:17:31.20,0:17:32.69,Main-207-,,0,0,0,,‫תמיד היית...
Dialogue: 0,0:17:33.05,0:17:36.07,Main-207-,,0,0,0,,‫אגואיסט!
Dialogue: 0,0:17:54.40,0:17:56.01,Flashbacks-207-,,0,0,0,,‫היי אתה, טבח!
Dialogue: 0,0:17:56.85,0:17:59.57,Flashbacks-207-,,0,0,0,,‫הצטרף לצוות שלי!
Dialogue: 0,0:17:59.57,0:18:02.36,Flashbacks-207-,,0,0,0,,‫תהיה הטבח על הספינה הפיראטית שלי!
Dialogue: 0,0:18:03.97,0:18:06.15,Main-207-,,0,0,0,,‫בבקשה תפסיק, סאנג'י-{\i1}קון{\fs10} {\r}!
Dialogue: 0,0:18:06.89,0:18:09.90,Main-207-,,0,0,0,,‫באנו רק לאסוף אותך!
Dialogue: 0,0:18:09.90,0:18:11.44,Main-207-,,0,0,0,,‫לופי...
Dialogue: 0,0:18:12.48,0:18:17.65,Main-207-,,0,0,0,,‫נלחם נגד הקצין הבכיר שלהם כל הלילה\N‫כדי להגיע עד לכאן!
Dialogue: 0,0:18:17.65,0:18:19.02,Main-207-,,0,0,0,,‫אז הגוף שלו–
Dialogue: 0,0:18:19.02,0:18:20.47,Main-207-,,0,0,0,,‫תפסיקי, נאמי!
Dialogue: 0,0:18:21.53,0:18:23.17,Main-207-,,0,0,0,,‫אל תתערבי בזה!
Dialogue: 0,0:18:23.79,0:18:24.87,Main-207-,,0,0,0,,‫זה...
Dialogue: 0,0:18:25.88,0:18:27.49,Main-207-,,0,0,0,,‫דו קרב!
Dialogue: 0,0:18:31.88,0:18:34.05,Main-207-,,0,0,0,,‫אתה קורא לזה דו קרב?!
Dialogue: 0,0:18:39.97,0:18:40.97,Main-207-,,0,0,0,,‫סאנג'י-{\i1}קון{\fs10} {\r}!
Dialogue: 0,0:19:09.83,0:19:13.73,Main-207-,,0,0,0,,‫תסתלק מפניי עכשיו!
Dialogue: 0,0:19:19.80,0:19:20.91,Main-207-,,0,0,0,,‫לופי!
Dialogue: 0,0:19:20.91,0:19:22.22,Main-207-,,0,0,0,,‫תסתלק!
Dialogue: 0,0:19:22.89,0:19:24.51,Main-207-,,0,0,0,,‫תסתלק!
Dialogue: 0,0:19:24.51,0:19:27.26,Main-207-,,0,0,0,,‫תעלם מפניי...
Dialogue: 0,0:19:28.18,0:19:30.34,Main-207-,,0,0,0,,‫עכשיו!
Dialogue: 0,0:19:53.51,0:19:55.17,Main-207-,,0,0,0,,‫אני מסרב!
Dialogue: 0,0:20:18.72,0:20:20.03,Main-207-,,0,0,0,,‫לופי!
Dialogue: 0,0:20:51.10,0:20:52.43,Main-207-,,0,0,0,,‫סאנג'י-{\i1}קון{\fs10} {\r}!
Dialogue: 0,0:20:56.27,0:20:57.61,Main-207-,,0,0,0,,‫יאללה!
Dialogue: 0,0:21:14.27,0:21:17.29,Main-207-,,0,0,0,,‫סאנג'י-{\i1}קון{\i}... בבקשה תפסיק...
Dialogue: 0,0:21:29.68,0:21:32.62,Main-207-,,0,0,0,,‫מספיק! תפסיק, סאנג'י-{\i1}קון{\fs10} {\r}!
Dialogue: 0,0:21:32.62,0:21:34.68,Main-207-,,0,0,0,,‫נלך!
Dialogue: 0,0:21:41.86,0:21:43.44,Main-207-,,0,0,0,,‫לא!
Dialogue: 0,0:21:46.47,0:21:48.41,Flashbacks-207-,,0,0,0,,‫אתה טבח טוב,
Dialogue: 0,0:21:48.78,0:21:50.91,Flashbacks-207-,,0,0,0,,‫אז נהיה פיראטים ביחד!
Dialogue: 0,0:21:55.67,0:21:59.07,Main-207-,,0,0,0,,{\fad(150,150)}‫קונקאסה!
Dialogue: 0,0:22:17.72,0:22:20.40,Main-207-,,0,0,0,,‫לופי! לופי!
Dialogue: 0,0:22:23.73,0:22:25.70,Main-207-,,0,0,0,,‫איזו עוצמה...
Dialogue: 0,0:22:25.70,0:22:28.40,Main-207-,,0,0,0,,‫בסוף, הוא וינסמוק.
Dialogue: 0,0:22:35.37,0:22:36.63,Main-207-,,0,0,0,,‫לופי!
Dialogue: 0,0:22:36.63,0:22:40.13,Main-207-,,0,0,0,,‫לופי! לופי! היי! אל תיעלם!
Dialogue: 0,0:22:40.13,0:22:42.16,Main-207-,,0,0,0,,‫לופי! לופי!
Dialogue: 0,0:22:52.26,0:22:54.53,Main-207-,,0,0,0,,‫היי, סאנג'י!
Dialogue: 0,0:23:00.80,0:23:02.08,Main-207-,,0,0,0,,‫להתראות!
Dialogue: 0,0:23:02.72,0:23:03.52,Main-207-,,0,0,0,,‫סליחה...
Dialogue: 0,0:23:03.52,0:23:05.86,Main-207-,,0,0,0,,‫לא היינו צריכים לעשות את זה!
Dialogue: 0,0:23:05.86,0:23:08.90,Main-207-,,0,0,0,,‫אוי! בחורה עם אופי! כמה חם!
Dialogue: 0,0:23:18.44,0:23:22.00,Main-207-,,0,0,0,,‫הקשרים המיותרים\N‫סוף סוף נקטעו.
Dialogue: 0,0:23:22.89,0:23:24.37,Main-207-,,0,0,0,,‫תודה שחיכיתם.
Dialogue: 0,0:23:25.44,0:23:27.46,Main-207-,,0,0,0,,‫– נלך.\N‫– כן, אדוני.
Dialogue: 0,0:23:36.42,0:23:37.58,Main-207-,,0,0,0,,‫לופי!
Dialogue: 0,0:23:42.35,0:23:44.42,Main-207-,,0,0,0,,‫רגע!
Dialogue: 0,0:23:44.42,0:23:46.87,Main-207-,,0,0,0,,‫סאנג'י!
Dialogue: 0,0:23:52.64,0:23:55.50,Main-207-,,0,0,0,,‫"פיראט פחות ממאום"?!
Dialogue: 0,0:23:55.50,0:23:58.62,Main-207-,,0,0,0,,‫אני יודע שאתה לא \N‫באמת רוצה לומר את הדברים האלה!
Dialogue: 0,0:23:58.62,0:24:00.94,Main-207-,,0,0,0,,‫תפסיק לשקר!
Dialogue: 0,0:24:00.94,0:24:05.29,Main-207-,,0,0,0,,‫חשבת שתוכל \N‫לשלוח אותי בקלות כזאת?!
Dialogue: 0,0:24:05.29,0:24:07.46,Main-207-,,0,0,0,,‫שיגעון!
Dialogue: 0,0:24:07.46,0:24:11.47,Main-207-,,0,0,0,,‫לא משנה כמה פעמים תבעט בי,
Dialogue: 0,0:24:12.27,0:24:13.95,Main-207-,,0,0,0,,‫אתה זה...
Dialogue: 0,0:24:16.12,0:24:18.28,Main-207-,,0,0,0,,‫שנפגע!
Dialogue: 0,0:24:27.94,0:24:32.05,Main-207-,,0,0,0,,‫לופי! למה?!\N‫לא משנה הסיבה, הוא לא יכול לעשות את זה–
Dialogue: 0,0:24:32.05,0:24:33.61,Main-207-,,0,0,0,,‫שתוק!
Dialogue: 0,0:24:34.22,0:24:36.07,Main-207-,,0,0,0,,‫האם נפסיק, סאנג'י?
Dialogue: 0,0:24:37.90,0:24:39.58,Main-207-,,0,0,0,,‫תמשיכו.
Dialogue: 0,0:24:47.28,0:24:48.71,Flashbacks-207-,,0,0,0,,‫היי...
Dialogue: 0,0:24:49.38,0:24:52.00,Flashbacks-207-,,0,0,0,,‫שמעת על האול בלו?!
Dialogue: 0,0:24:52.00,0:24:54.99,Flashbacks-207-,,0,0,0,,‫הים הזה עצמו הוא נס!
Dialogue: 0,0:24:54.99,0:24:56.68,Flashbacks-207-,,0,0,0,,‫בים הזה...
Dialogue: 0,0:24:59.25,0:25:01.21,Main-207-,,0,0,0,,‫המסע שלנו...
Dialogue: 0,0:25:02.06,0:25:04.21,Main-207-,,0,0,0,,‫עוד לא נגמר!
Dialogue: 0,0:25:06.21,0:25:09.65,Main-207-,,0,0,0,,‫אני אמתין כאן!
Dialogue: 0,0:25:09.65,0:25:14.67,Main-207-,,0,0,0,,‫אם לא תחזור, אני אהיה כאן...
Dialogue: 0,0:25:14.67,0:25:16.82,Main-207-,,0,0,0,,‫ומת מרעב!
Dialogue: 0,0:25:17.72,0:25:22.12,Main-207-,,0,0,0,,‫אתה הטבח של הספינה שלי!
Dialogue: 0,0:25:22.12,0:25:25.69,Flashbacks-207-,,0,0,0,,‫הוא שוב הכין אוכל לחולדות!
Dialogue: 0,0:25:26.88,0:25:31.83,Main-207-,,0,0,0,,‫אני לא אוכל שום דבר\N‫חוץ ממה שאתה מבשל!
Dialogue: 0,0:25:34.59,0:25:38.87,Main-207-,,0,0,0,,‫גם אם ארעב \N‫או חניתות ירדו עלי כגשם,
Dialogue: 0,0:25:38.87,0:25:43.19,Main-207-,,0,0,0,,‫אישאר כאן ואחכה לך!
Dialogue: 0,0:25:58.10,0:26:02.52,Main-207-,,0,0,0,,‫תחזור בטוח, סאנג'י!
Dialogue: 0,0:26:03.12,0:26:07.37,Main-207-,,0,0,0,,‫בלעדיך, אני...
Dialogue: 0,0:26:07.94,0:26:12.77,Main-207-,,0,0,0,,‫אני לא יכול להיות מלך הפיראטים!
