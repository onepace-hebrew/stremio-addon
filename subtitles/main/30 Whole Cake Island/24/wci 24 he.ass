Dialogue: 0,0:00:00.00,0:00:05.00,Main-207-,,0,0,0,,{\an8}‫תרגום לעברית — That One Gerbil
Dialogue: 0,0:01:37.34,0:01:41.25,Main-207-,,0,0,0,,‫כוחות בנות ברית!\N‫בואו נסתתר בטירה בינתיים!
Dialogue: 0,0:01:41.25,0:01:42.92,Main-207-,,0,0,0,,‫בסדר, מהר!
Dialogue: 0,0:01:42.92,0:01:44.65,Main-207-,,0,0,0,,‫כן, אני רוצה להיכנס!
Dialogue: 0,0:01:44.65,0:01:47.92,Main-207-,,0,0,0,,‫פיראטי פייר טנק! כסו עליהם!
Dialogue: 0,0:01:47.92,0:01:49.25,Main-207-,,0,0,0,,‫– {\i1}רֶרוֹ{\fs10} {\r}!\N‫– כן, אדוני!
Dialogue: 0,0:01:51.36,0:01:52.69,Main-207-,,0,0,0,,‫לעזאזל!
Dialogue: 0,0:02:01.98,0:02:05.33,Thoughts-207-,,0,0,0,,‫בֶּגֶה! ראיתי את זה במו עיניי!
Dialogue: 0,0:02:05.33,0:02:08.21,Thoughts-207-,,0,0,0,,‫אני לא מאמין שתכננת\N‫לחסל את מאמא!
Dialogue: 0,0:02:08.21,0:02:11.76,Thoughts-207-,,0,0,0,,‫האם זאת הייתה התוכנית שלו מהתחלה?!
Dialogue: 0,0:02:13.01,0:02:15.51,Main-207-,,0,0,0,,‫היכנסו לטירה-{\i1}רֶרוֹ{\fs10} {\r}!
Dialogue: 0,0:02:15.51,0:02:18.62,Main-207-,,0,0,0,,{\fad(150,150)}‫טחנה: הכנת תותח!
Dialogue: 0,0:02:21.34,0:02:23.69,Main-207-,,0,0,0,,{\fad(150,150)}‫ירי תותח!
Dialogue: 0,0:02:26.06,0:02:28.26,Main-207-,,0,0,0,,‫כל כך מגניב!
Dialogue: 0,0:02:28.26,0:02:30.99,Main-207-,,0,0,0,,‫זה רובוט! טירת רובוט!
Dialogue: 0,0:02:30.99,0:02:33.13,Thoughts-207-,,0,0,0,,‫איך אפשר להתרגש בזמן כזה?!
Dialogue: 0,0:02:33.53,0:02:36.97,Thoughts-207-,,0,0,0,,‫כמה זמן נוכל להחזיק מעמד?
Dialogue: 0,0:02:41.84,0:02:44.14,Thoughts-207-,,0,0,0,,‫זה הורס לי את עורית האוזן!
Dialogue: 0,0:02:48.93,0:02:50.05,Main-207-,,0,0,0,,{\i1}‫מוֹצ'י{\fs18} {\r}?
Dialogue: 0,0:03:03.28,0:03:04.13,Thoughts-207-,,0,0,0,,‫האם זה...
Dialogue: 0,0:03:04.13,0:03:06.70,Thoughts-207-,,0,0,0,,‫קופסת הטאמאטה?!
Dialogue: 0,0:03:09.97,0:03:11.13,Thoughts-207-,,0,0,0,,‫יופי!
Dialogue: 0,0:03:11.13,0:03:13.77,Thoughts-207-,,0,0,0,,‫מ-מה לעזאזל זה?
Dialogue: 0,0:03:18.08,0:03:22.18,Thoughts-207-,,0,0,0,,‫מי מעז לבלבל את הגאסטינו הגדול?!
Dialogue: 0,0:03:30.06,0:03:31.69,Main-207-,,0,0,0,,‫אח גדול!
Dialogue: 0,0:03:31.69,0:03:33.79,Thoughts-207-,,0,0,0,,‫הוא הולך להרוג אותי!
Dialogue: 0,0:03:38.33,0:03:42.40,Thoughts-207-,,0,0,0,,‫אח גדול! תודה לך!
Dialogue: 0,0:03:44.49,0:03:46.14,Thoughts-207-,,0,0,0,,‫בואו נלך!
Dialogue: 0,0:03:49.17,0:03:51.14,Main-207-,,0,0,0,,‫לא אתן לך ללכת!
Dialogue: 0,0:03:53.88,0:03:56.82,Main-207-,,0,0,0,,‫כסו עליהם-{\i1}רֶרוֹ{\fs10} {\r}! מהר-{\i1}רֶרוֹ{\fs10} {\r}!
Dialogue: 0,0:04:05.25,0:04:06.99,Main-207-,,0,0,0,,‫נאמי!
Dialogue: 0,0:04:06.99,0:04:09.86,Thoughts-207-,,0,0,0,,‫אמעך אותך עד מוות!
Dialogue: 0,0:04:09.86,0:04:11.06,Thoughts-207-,,0,0,0,,‫נאמי-{\i1}סאן{\fs10} {\r}!
Dialogue: 0,0:04:11.06,0:04:12.36,Main-207-,,0,0,0,,‫נאמי!
Dialogue: 0,0:04:13.83,0:04:16.77,Thoughts-207-,,0,0,0,,‫נלחם בך!
Dialogue: 0,0:04:22.57,0:04:24.51,Thoughts-207-,,0,0,0,,‫אוי-אוץ'!
Dialogue: 0,0:04:25.18,0:04:28.45,Main-207-,,0,0,0,,‫אוי, אוי! זה חם!
Dialogue: 0,0:04:27.00,0:04:28.46,SecondaryThought-207-,,0,0,0,,You won't get away now!
Dialogue: 0,0:04:28.46,0:04:30.08,Main-207-,,0,0,0,,‫צ'וברו!
Dialogue: 0,0:04:33.09,0:04:35.12,Main-207-,,0,0,0,,‫ג'יני!
Dialogue: 0,0:05:19.23,0:05:23.07,Main-207-,,0,0,0,,‫קדימה, גֶרמה 66!
Dialogue: 0,0:06:37.84,0:06:40.86,Main-207-,,0,0,0,,‫ממזרים מעצבנים!
Dialogue: 0,0:06:43.18,0:06:45.68,Main-207-,,0,0,0,,‫כולכם, שרפו עד מוות!
Dialogue: 0,0:06:54.19,0:06:56.26,Main-207-,,0,0,0,,‫ז-זה...?!
Dialogue: 0,0:07:14.38,0:07:16.62,Thoughts-207-,,0,0,0,,‫המדע של גֶרמה.
Dialogue: 0,0:07:16.62,0:07:21.72,Thoughts-207-,,0,0,0,,‫אז כך נראה שריון הזיכרון שלהם!\N‫הוא אפילו עמיד לאש!
Dialogue: 0,0:07:21.72,0:07:26.06,Thoughts-207-,,0,0,0,,‫אשתק אותם שוב עם הסוכרייה שלי!
Dialogue: 0,0:07:26.86,0:07:29.03,Main-207-,,0,0,0,,‫גל סוכרייה!{\fad(150,150)}
Dialogue: 0,0:08:00.05,0:08:02.79,Main-207-,,0,0,0,,‫פרעושים מעצבנים!
Dialogue: 0,0:08:17.86,0:08:22.01,Main-207-,,0,0,0,,‫אתה גדול מאוד,\N‫אבל זה לא אומר שאתה חזק.
Dialogue: 0,0:09:05.49,0:09:06.73,Thoughts-207-,,0,0,0,,‫נאמי-{\i1}סאן{\fs10} {\r}!
Dialogue: 0,0:09:07.97,0:09:10.20,Thoughts-207-,,0,0,0,,‫אתם בסדר?!
Dialogue: 0,0:09:10.20,0:09:11.36,Thoughts-207-,,0,0,0,,‫אני כן!
Dialogue: 0,0:09:12.21,0:09:13.39,Thoughts-207-,,0,0,0,,‫סאנג'י-{\i1}קון{\fs10} {\r}!
Dialogue: 0,0:09:13.39,0:09:15.77,Thoughts-207-,,0,0,0,,‫שמח שאת בסדר, נאמי-{\i1}סאן{\fs10} {\r}!
Dialogue: 0,0:09:18.38,0:09:20.44,Main-207-,,0,0,0,,{\fad(150,150)}‫גום-גום...
Dialogue: 0,0:09:21.20,0:09:23.28,Main-207-,,0,0,0,,{\fad(150,150)}‫שוט ג'ט!
Dialogue: 0,0:09:23.28,0:09:24.60,Main-207-,,0,0,0,,‫לופי!
Dialogue: 0,0:09:24.60,0:09:27.45,Thoughts-207-,,0,0,0,,‫– מהרו!\N‫– לכאן!
Dialogue: 0,0:09:28.68,0:09:31.72,Main-207-,,0,0,0,,‫כדאי שנסוג גם אנחנו-{\i1}רֶרוֹ{\fs10} {\r}!
Dialogue: 0,0:09:49.81,0:09:53.81,Thoughts-207-,,0,0,0,,‫הנה, הנה, זאת קופסת הטאמאטה, אוצר אגדי נסתר.
Dialogue: 0,0:09:53.81,0:09:58.52,Thoughts-207-,,0,0,0,,‫אף אחד לא יראה אותי כל כך רחוק מהפעולה!\N‫אני אוהב את הכאוס הנוכחי!
Dialogue: 0,0:09:58.52,0:10:03.55,Thoughts-207-,,0,0,0,,‫אנצל את ההזדמנות הזאת להחליף את מה שבפנים...
Dialogue: 0,0:10:43.96,0:10:46.12,Thoughts-207-,,0,0,0,,‫זאת ההזדמנות האחרונה שלנו!
Dialogue: 0,0:10:48.54,0:10:50.63,Thoughts-207-,,0,0,0,,{\fad(150,150)}‫ירי תותח!
Dialogue: 0,0:10:56.83,0:10:58.14,Thoughts-207-,,0,0,0,,‫לעזאזל!
Dialogue: 0,0:10:58.54,0:11:00.40,Thoughts-207-,,0,0,0,,{\fad(150,150)}‫חומת סוכרייה!
Dialogue: 0,0:11:01.08,0:11:02.84,Thoughts-207-,,0,0,0,,‫פֶּרוֹספֶּרוֹ!
Dialogue: 0,0:11:02.84,0:11:05.25,Thoughts-207-,,0,0,0,,‫אוי, זה כואב...
Dialogue: 0,0:11:05.25,0:11:08.31,Thoughts-207-,,0,0,0,,‫אז גֶרמה גם עובדת אתכם?
Dialogue: 0,0:11:09.09,0:11:12.38,Thoughts-207-,,0,0,0,,‫אני מקווה שאתם ממזרים מוכנים\N‫למה שעומד לבוא לכם.
Dialogue: 0,0:11:12.38,0:11:15.85,Thoughts-207-,,0,0,0,,‫לא תצחקו עוד הרבה!
Dialogue: 0,0:11:24.10,0:11:26.64,Thoughts-207-,,0,0,0,,{\fad(150,150)}‫טחנה: תנועה!
Dialogue: 0,0:11:44.05,0:11:48.05,Thoughts-207-,,0,0,0,,‫נירה בגבה\N‫עד שנאזל מתחמושת!
Dialogue: 0,0:11:49.22,0:11:51.69,Main-207-,,0,0,0,,‫הגיע הזמן למות, ביג מאם!
Dialogue: 0,0:11:52.70,0:11:53.43,Main-207-,,0,0,0,,{\fad(150,150)}‫תותח...
Dialogue: 0,0:11:54.59,0:11:55.93,Main-207-,,0,0,0,,‫ירי!{\fad(150,150)}
Dialogue: 0,0:11:58.68,0:12:00.37,Thoughts-207-,,0,0,0,,‫מה קרה עכשיו?!
Dialogue: 0,0:12:01.15,0:12:05.51,Main-207-,,0,0,0,,‫אבא, התותחים בצד שמאל שלנו נהרסו!
Dialogue: 0,0:12:05.51,0:12:09.07,Main-207-,,0,0,0,,‫והשאר\N‫נתקעו עם {\i1}מוֹצ'י{\fs15} {\r}!
Dialogue: 0,0:12:09.07,0:12:11.58,Main-207-,,0,0,0,,‫אנחנו לא יכולים לירות יותר!
Dialogue: 0,0:12:15.45,0:12:18.02,Thoughts-207-,,0,0,0,,‫ק-קָטָקוּרי!
Dialogue: 0,0:12:22.49,0:12:26.02,Main-207-,,0,0,0,,{\i1}‫יש לי חדשות רעות לכל מי שבטירה...{\i0}
Dialogue: 0,0:12:39.69,0:12:43.98,Main-207-,,0,0,0,,{\i1}‫הגפיים של ביג פאתר כלואות תחת סוכרייה!{\i0}
Dialogue: 0,0:12:45.41,0:12:48.78,Main-207-,,0,0,0,,{\i1}‫אנחנו לא יכולים להזיז אותו יותר!{\i0}
Dialogue: 0,0:12:50.41,0:12:55.44,Main-207-,,0,0,0,,{\i1}‫אנחנו מוקפים על ידי צוות הפיראטים של הקיסרית ביג מאם{\i0}
Dialogue: 0,0:12:55.44,0:13:00.99,Main-207-,,0,0,0,,{\i1}‫ועכשיו עלינו להתבצר\N‫בטירה תחת מצור!{\i0}
Dialogue: 0,0:13:02.08,0:13:04.22,Main-207-,,0,0,0,,‫לא...
Dialogue: 0,0:13:20.91,0:13:23.78,Thoughts-207-,,0,0,0,,‫כל מי שיצא יימות.
Dialogue: 0,0:13:25.98,0:13:28.78,Thoughts-207-,,0,0,0,,‫פשוט צאו כבר!
Dialogue: 0,0:13:30.11,0:13:33.19,Main-207-,,0,0,0,,‫איך יכולת לתת להם לנצל אותך כך?
Dialogue: 0,0:13:33.19,0:13:35.86,Main-207-,,0,0,0,,‫א-אני הקורבן כאן, אח גדול!
Dialogue: 0,0:13:35.86,0:13:39.10,Main-207-,,0,0,0,,‫פשוט מהרו והשמידו\N‫כל אחד ואחד מהם!
Dialogue: 0,0:13:41.37,0:13:45.10,Thoughts-207-,,0,0,0,,‫רעל?\N‫האישה הזאת מאוד מטרידה...
Dialogue: 0,0:14:02.39,0:14:03.76,Main-207-,,0,0,0,,‫הנה אתה!
Dialogue: 0,0:14:03.76,0:14:07.81,Main-207-,,0,0,0,,‫אתה מדהים, בֶּגֶה!\N‫אתה יכול להפוך לטירה ענקית!
Dialogue: 0,0:14:07.81,0:14:09.79,Main-207-,,0,0,0,,‫פרי הטירה-טירה כל כך מגניב!
Dialogue: 0,0:14:09.79,0:14:13.67,Main-207-,,0,0,0,,‫זה לא הזמן לשבחים!\N‫תחשוב על המצב שאנחנו בו!
Dialogue: 0,0:14:13.67,0:14:14.83,Main-207-,,0,0,0,,‫לעזאזל...
Dialogue: 0,0:14:14.83,0:14:18.60,Main-207-,,0,0,0,,‫תכננו את ההתנקשות הזאת מעל שנה,
Dialogue: 0,0:14:18.60,0:14:20.54,Main-207-,,0,0,0,,‫והיא נגמרה בכישלון!
Dialogue: 0,0:14:20.54,0:14:24.92,Main-207-,,0,0,0,,‫מעולם לא נכשלנו בהתנקשות...
Dialogue: 0,0:14:25.79,0:14:29.70,Main-207-,,0,0,0,,‫בסופו של דבר, קיסר הוכח\N‫שהוא מעבר ליכולות שלנו...
Dialogue: 0,0:14:29.70,0:14:31.88,Main-207-,,0,0,0,,‫מה עושים עכשיו?
Dialogue: 0,0:14:31.88,0:14:36.62,Main-207-,,0,0,0,,‫אין לנו הרבה זמן.\N‫הנה למה.
Dialogue: 0,0:14:36.62,0:14:39.96,Main-207-,,0,0,0,,‫תקשיבו טוב, חבר'ה!
Dialogue: 0,0:14:39.96,0:14:43.60,Main-207-,,0,0,0,,{\i1}‫אני{\i0} הטירה הזאת.\N‫היא חזקה, אבל לא בלתי מנוצחת.
Dialogue: 0,0:14:43.60,0:14:48.87,Main-207-,,0,0,0,,‫אם הטירה תיהרס, אני מת. \N‫מה שאומר שהטירה נעלמת,
Dialogue: 0,0:14:48.87,0:14:52.86,Main-207-,,0,0,0,,‫ואז כולכם תושלכו החוצה\N‫להיות טרף לאותם מפלצות!
Dialogue: 0,0:14:52.86,0:14:54.34,Main-207-,,0,0,0,,‫טרף?!
Dialogue: 0,0:15:08.35,0:15:11.26,Main-207-,,0,0,0,,‫לעולם לא אסלח להם...
Dialogue: 0,0:15:13.66,0:15:14.83,Main-207-,,0,0,0,,‫מאמא!
Dialogue: 0,0:15:16.69,0:15:19.83,Main-207-,,0,0,0,,‫אני מרגיש את כעסה של מאמא...
Dialogue: 0,0:15:31.01,0:15:35.35,Main-207-,,0,0,0,,‫גיהינום שם בחוץ, וגיהינום כאן בפנים.
Dialogue: 0,0:15:35.35,0:15:37.68,Main-207-,,0,0,0,,‫אנחנו במצב קשה מאוד!
Dialogue: 0,0:15:37.68,0:15:42.05,Main-207-,,0,0,0,,‫אל תאשים אותי, בֶּגֶה! המשגרים האלה היו בעלי טכנולוגיה מתקדמת ברמה עולמית...
Dialogue: 0,0:15:48.59,0:15:50.83,Main-207-,,0,0,0,,‫– מ-מה היה זה?\N‫– אבא!
Dialogue: 0,0:15:50.83,0:15:52.58,Main-207-,,0,0,0,,‫הי, בֶּגֶה! מה קרה?!
Dialogue: 0,0:15:52.58,0:15:54.63,Main-207-,,0,0,0,,‫מותק, אתה בסדר?!
Dialogue: 0,0:15:58.14,0:15:59.54,Main-207-,,0,0,0,,‫אולי זה...
Dialogue: 0,0:16:00.57,0:16:01.94,Main-207-,,0,0,0,,‫תסתכל בחוץ!
Dialogue: 0,0:16:01.94,0:16:03.31,Main-207-,,0,0,0,,‫מה?
Dialogue: 0,0:16:03.31,0:16:05.02,Main-207-,,0,0,0,,‫בחוץ?
Dialogue: 0,0:16:10.82,0:16:12.78,Main-207-,,0,0,0,,‫ממזרים!
Dialogue: 0,0:16:12.78,0:16:14.95,Main-207-,,0,0,0,,‫צאו!
Dialogue: 0,0:16:16.95,0:16:19.03,Main-207-,,0,0,0,,‫בֶּגֶה!
Dialogue: 0,0:16:19.03,0:16:21.06,Main-207-,,0,0,0,,‫כובע קש!
Dialogue: 0,0:16:22.33,0:16:24.20,Main-207-,,0,0,0,,‫אני פוחד!
Dialogue: 0,0:16:24.20,0:16:26.62,Main-207-,,0,0,0,,‫היא מסתכלת עלינו!
Dialogue: 0,0:16:27.81,0:16:31.98,Main-207-,,0,0,0,,‫ביג מאם התאוששה!
Dialogue: 0,0:16:41.08,0:16:44.25,Main-207-,,0,0,0,,‫כולכם, צאו מהטירה!
Dialogue: 0,0:16:44.25,0:16:46.68,Main-207-,,0,0,0,,‫תראו את עצמכם, פחדנים!
Dialogue: 0,0:16:49.32,0:16:51.16,Main-207-,,0,0,0,,‫מותק!
Dialogue: 0,0:16:51.16,0:16:52.56,Main-207-,,0,0,0,,‫אבא!
Dialogue: 0,0:16:52.56,0:16:55.83,Main-207-,,0,0,0,,‫אז בגדת בי?
Dialogue: 0,0:16:55.83,0:16:57.54,Main-207-,,0,0,0,,‫בֶּגֶה!
Dialogue: 0,0:16:59.75,0:17:03.09,Main-207-,,0,0,0,,‫מותק! הישאר איתי!
Dialogue: 0,0:17:05.00,0:17:08.84,Main-207-,,0,0,0,,‫אני פוחד!
Dialogue: 0,0:17:08.84,0:17:12.94,Main-207-,,0,0,0,,‫צא, בֶּגֶה! כובע קש!
Dialogue: 0,0:17:16.35,0:17:17.33,Main-207-,,0,0,0,,‫בֶּגֶה!
Dialogue: 0,0:17:17.93,0:17:19.89,Main-207-,,0,0,0,,‫תחזיק את פֶּז!
Dialogue: 0,0:17:26.02,0:17:27.96,Main-207-,,0,0,0,,‫צאו!
Dialogue: 0,0:17:27.96,0:17:30.19,Main-207-,,0,0,0,,‫רגע!
Dialogue: 0,0:17:30.19,0:17:34.20,Main-207-,,0,0,0,,‫מאמא! זאת אני!\N‫בֶּגֶה הוא בעלי! יש לנו ילד יחד!
Dialogue: 0,0:17:34.20,0:17:36.70,Main-207-,,0,0,0,,‫בבקשה, סלחי לו ותני לנו ללכת!
Dialogue: 0,0:17:36.70,0:17:38.79,Main-207-,,0,0,0,,‫שיפוֹן!
Dialogue: 0,0:17:39.62,0:17:43.21,Main-207-,,0,0,0,,‫את עדיין נראית בדיוק כמו לוֹלָה!
Dialogue: 0,0:17:44.28,0:17:45.28,Main-207-,,0,0,0,,‫היא עומדת לתקוף!
Dialogue: 0,0:17:45.28,0:17:46.28,Main-207-,,0,0,0,,‫תיזהרי!
Dialogue: 0,0:17:46.28,0:17:47.51,Main-207-,,0,0,0,,‫תתרחקי, שיפוֹן!
Dialogue: 0,0:17:47.51,0:17:48.65,Main-207-,,0,0,0,,‫גברת!
Dialogue: 0,0:17:48.65,0:17:50.68,Main-207-,,0,0,0,,‫מאמא! בבקשה!
Dialogue: 0,0:17:51.05,0:17:55.55,Main-207-,,0,0,0,,‫אמרתי לך לא להראות את הפנים האלה כאן!
Dialogue: 0,0:18:02.44,0:18:04.22,Main-207-,,0,0,0,,‫בקושי ניצלנו...
Dialogue: 0,0:18:04.22,0:18:05.43,Main-207-,,0,0,0,,‫את בסדר?
Dialogue: 0,0:18:05.43,0:18:07.17,Main-207-,,0,0,0,,‫גברת!
Dialogue: 0,0:18:07.17,0:18:11.17,Main-207-,,0,0,0,,‫גם את מעורבת בתכנית ההתנקשות, שיפוֹן?!
Dialogue: 0,0:18:11.17,0:18:14.48,Main-207-,,0,0,0,,‫לא תחיי כדי לאכול את החטיפים של מחר,\N‫זה בטוח!
Dialogue: 0,0:18:14.48,0:18:15.81,Main-207-,,0,0,0,,‫מאמא!
Dialogue: 0,0:18:19.01,0:18:24.38,Main-207-,,0,0,0,,‫אם היא תהרוס את הטירה ובֶּגֶה ימות,\N‫כולם יופיעו ממש מולנו!
Dialogue: 0,0:18:24.38,0:18:26.37,Main-207-,,0,0,0,,‫אל תתנו לאף אחד מהם לברוח!
Dialogue: 0,0:18:26.37,0:18:30.19,Main-207-,,0,0,0,,‫פיראטי פייר טנק... צוות כובעי הקש...
Dialogue: 0,0:18:30.19,0:18:33.43,Main-207-,,0,0,0,,‫ובנוסף, ג'ינביי וגֶרמה 66!
Dialogue: 0,0:18:33.43,0:18:37.66,Main-207-,,0,0,0,,‫הם הרסו את החתונה\N‫ואת מסיבת התה!
Dialogue: 0,0:18:37.66,0:18:40.55,Main-207-,,0,0,0,,‫אני לא מאמין שהם העריכו אותנו בצורה כה נמוכה.
Dialogue: 0,0:18:40.55,0:18:43.74,Main-207-,,0,0,0,,‫אנחנו צריכים לסחוט אותם\N‫ולהפוך אותם לדוגמה לעולם.
Dialogue: 0,0:18:43.74,0:18:46.10,Main-207-,,0,0,0,,‫צאו!
Dialogue: 0,0:18:47.91,0:18:49.65,Main-207-,,0,0,0,,‫בֶּגֶה!
Dialogue: 0,0:18:50.11,0:18:51.78,Main-207-,,0,0,0,,‫מותק!
Dialogue: 0,0:18:55.16,0:18:56.65,Main-207-,,0,0,0,,‫אתה בסדר?
Dialogue: 0,0:18:56.65,0:18:59.72,Main-207-,,0,0,0,,‫לעזאזל עם השקית הזקנה הזאת!
Dialogue: 0,0:19:01.95,0:19:06.84,Main-207-,,0,0,0,,‫ביג פאתר יכול לספוג פגיעת תותח\N‫ללא שריטה,
Dialogue: 0,0:19:06.84,0:19:09.06,Main-207-,,0,0,0,,‫אבל הוא לא יכול להגן מפניה!
Dialogue: 0,0:19:09.06,0:19:12.30,Main-207-,,0,0,0,,‫אני חייב לצאת לשם ולשבור לה את הפנים!
Dialogue: 0,0:19:12.30,0:19:13.50,Main-207-,,0,0,0,,‫לא, לופי!
Dialogue: 0,0:19:13.50,0:19:14.71,Main-207-,,0,0,0,,‫צ'ופר, תאחוז בו!
Dialogue: 0,0:19:14.71,0:19:16.03,Main-207-,,0,0,0,,‫בסדר!
Dialogue: 0,0:19:19.68,0:19:22.74,Main-207-,,0,0,0,,‫מה?! הי! תשחרר אותי!
Dialogue: 0,0:19:22.74,0:19:24.89,Main-207-,,0,0,0,,‫הי, צ'ופר! תשחרר אותי!
Dialogue: 0,0:19:24.89,0:19:28.10,Main-207-,,0,0,0,,‫לופי! אל תתלהב יותר מדי!
Dialogue: 0,0:19:28.10,0:19:32.82,Main-207-,,0,0,0,,‫באנו להחזיר את סאנג'י-{\i1}קון{\i} בחזרה,\N‫זוכר?!
Dialogue: 0,0:19:32.82,0:19:35.60,Main-207-,,0,0,0,,‫השגנו את עותקי הפּוֹנֶגליפ שהיינו צריכים,
Dialogue: 0,0:19:35.60,0:19:39.09,Main-207-,,0,0,0,,‫ואפילו עזרנו לסאנג'י-{\i1}קון{\i} להציל את משפחתו!
Dialogue: 0,0:19:39.09,0:19:42.56,Main-207-,,0,0,0,,‫השלמנו את המשימה שלנו!
Dialogue: 0,0:19:42.56,0:19:47.10,Main-207-,,0,0,0,,‫במקום להילחם, תעזור לנו\N‫לחשוב על תוכנית בריחה!
Dialogue: 0,0:19:47.10,0:19:52.00,Main-207-,,0,0,0,,‫אם היינו מתכוונים להילחם בה, היינו מביאים\N‫את זורו והשאר! נכון?!
Dialogue: 0,0:19:52.00,0:19:54.97,Main-207-,,0,0,0,,‫לופי-{\i1}סאן{\i}, נאמי-{\i1}סאן{\i} צודקת.
Dialogue: 0,0:19:54.97,0:19:59.61,Main-207-,,0,0,0,,‫הגענו עד כה\N‫כי באנו בקבוצה כל כך קטנה.
Dialogue: 0,0:19:59.61,0:20:03.85,Main-207-,,0,0,0,,‫בואו נברח ונתאחד\N‫עם זורו-{\i1}סאן{\i} והשאר בואנו!
Dialogue: 0,0:20:07.90,0:20:09.32,Main-207-,,0,0,0,,‫בֶּגֶה!
Dialogue: 0,0:20:09.32,0:20:10.47,Main-207-,,0,0,0,,‫אבא!
Dialogue: 0,0:20:10.47,0:20:12.36,Main-207-,,0,0,0,,‫בֶּגֶה!
Dialogue: 0,0:20:14.59,0:20:16.53,Main-207-,,0,0,0,,‫הנה! בֶּגֶה הוא...
Dialogue: 0,0:20:17.24,0:20:19.43,Main-207-,,0,0,0,,‫מה אנחנו עושים אז?!
Dialogue: 0,0:20:19.43,0:20:22.74,Main-207-,,0,0,0,,‫בֶּגֶה מסכן את חייו בשבילנו!
Dialogue: 0,0:20:28.91,0:20:31.08,Main-207-,,0,0,0,,‫לעזאזל...
Dialogue: 0,0:20:31.08,0:20:34.91,Main-207-,,0,0,0,,‫התוכניות שלי נהרסו לגמרי...
Dialogue: 0,0:20:35.61,0:20:39.37,Main-207-,,0,0,0,,‫אז אני בהחלט לא מוכן לשבת בחיבוק ידיים\N‫בזמן שכולכם נהנים מהצלחתכם!
Dialogue: 0,0:20:39.37,0:20:44.50,Main-207-,,0,0,0,,‫רגע, בֶּגֶה-{\i1}סאן{\fs10} {\r}!\N‫אתה לא יכול להוריד אותנו איתך!
Dialogue: 0,0:20:44.50,0:20:46.70,Main-207-,,0,0,0,,‫עשיתי את מה שהיה עלי לעשות!
Dialogue: 0,0:20:46.70,0:20:49.55,Main-207-,,0,0,0,,‫תחזיר לי את הלב שלי עכשיו!
Dialogue: 0,0:20:50.34,0:20:52.63,Main-207-,,0,0,0,,‫להוריד אתכם...?
Dialogue: 0,0:20:52.63,0:20:55.10,Main-207-,,0,0,0,,‫לא רעיון רע.
Dialogue: 0,0:20:55.51,0:20:59.31,Main-207-,,0,0,0,,‫כמו שאמרתי מהתחלה,\N‫לא אכפת לי מה יקרה לאף אחד מכם!
Dialogue: 0,0:21:09.53,0:21:11.19,Main-207-,,0,0,0,,‫אבל...
Dialogue: 0,0:21:11.19,0:21:15.78,Main-207-,,0,0,0,,‫הכפופים היקרים שלי...
Dialogue: 0,0:21:15.78,0:21:18.24,Main-207-,,0,0,0,,‫ואשתי האהובה ובני נמצאים כאן.
Dialogue: 0,0:21:21.10,0:21:25.03,Main-207-,,0,0,0,,‫ואין שום דרך שאתן להם למות!
Dialogue: 0,0:21:25.03,0:21:26.46,Main-207-,,0,0,0,,‫מותק!
Dialogue: 0,0:21:26.46,0:21:28.93,Main-207-,,0,0,0,,‫אבא!
Dialogue: 0,0:21:33.20,0:21:34.06,Main-207-,,0,0,0,,‫בֶּגֶה!
Dialogue: 0,0:21:38.40,0:21:41.71,Main-207-,,0,0,0,,‫יש רק דרך אחת...
Dialogue: 0,0:21:43.95,0:21:46.61,Main-207-,,0,0,0,,‫לוודא שכולם שורדים!
Dialogue: 0,0:21:46.61,0:21:47.74,Main-207-,,0,0,0,,‫רק אחת?!
Dialogue: 0,0:21:47.74,0:21:49.39,Main-207-,,0,0,0,,‫מה זה?!
Dialogue: 0,0:21:53.14,0:21:55.89,Main-207-,,0,0,0,,‫צאו!
Dialogue: 0,0:21:55.89,0:21:58.69,Main-207-,,0,0,0,,‫אני הולך להרוס אותה!
Dialogue: 0,0:22:00.67,0:22:03.07,Main-207-,,0,0,0,,‫היא לא תחזיק הרבה יותר...
Dialogue: 0,0:22:03.07,0:22:06.11,Main-207-,,0,0,0,,‫היו מוכנים לתקוף בכל רגע...
Dialogue: 0,0:22:07.07,0:22:09.51,Main-207-,,0,0,0,,‫אני יכול לרסק אותם עם זה!
Dialogue: 0,0:22:09.51,0:22:11.74,Main-207-,,0,0,0,,‫בואו נסיים עם...
Dialogue: 0,0:22:12.06,0:22:13.91,Main-207-,,0,0,0,,‫כל אחד ואחד מהם!
Dialogue: 0,0:22:16.61,0:22:21.42,Main-207-,,0,0,0,,‫מהרו ובואו!\N‫ואז אכלוא את כולכם בממד הראי שלי!
Dialogue: 0,0:22:24.86,0:22:28.53,Main-207-,,0,0,0,,‫הדרך היחידה לשרוד... זאת...
Dialogue: 0,0:22:28.53,0:22:35.23,Main-207-,,0,0,0,,‫החדר הזה בתוך ביג פאתר...\N‫הוא בעצם בתוך גופי.
Dialogue: 0,0:22:36.79,0:22:37.34,Main-207-,,0,0,0,,‫הי!
Dialogue: 0,0:22:37.34,0:22:39.60,Main-207-,,0,0,0,,‫אל תיפנקו!
Dialogue: 0,0:22:41.64,0:22:44.64,Main-207-,,0,0,0,,‫לא משנה כמה יתקפו אותי...
Dialogue: 0,0:22:45.26,0:22:49.47,Main-207-,,0,0,0,,‫אם ביג פאתר יטה או ייפול,
Dialogue: 0,0:22:50.02,0:22:53.82,Main-207-,,0,0,0,,‫רק אני אפגע.
Dialogue: 0,0:22:53.82,0:22:58.23,Main-207-,,0,0,0,,‫כל עוד אתם כאן,\N‫לא תינזקו כלל.
Dialogue: 0,0:22:58.23,0:23:02.95,Main-207-,,0,0,0,,‫– כשחושבים על זה...\N‫– רק בֶּגֶה-{\i1}סאן{\i} סובל.
Dialogue: 0,0:23:04.60,0:23:07.53,Main-207-,,0,0,0,,‫אנחנו שומעים את קולה של ביג מאם...
Dialogue: 0,0:23:09.50,0:23:12.27,Main-207-,,0,0,0,,‫אבל כאן בפנים עדיין שקט.
Dialogue: 0,0:23:15.42,0:23:17.49,Main-207-,,0,0,0,,‫נכון...
Dialogue: 0,0:23:17.49,0:23:22.71,Main-207-,,0,0,0,,‫וזה לא ישתנה גם\N‫אם אחזור לצורת האדם שלי.
Dialogue: 0,0:23:22.71,0:23:27.57,Main-207-,,0,0,0,,‫תקשיבו... אני הולך לחזור להיות אדם\N‫כשכולכם עדיין בפנים!
Dialogue: 0,0:23:27.57,0:23:32.16,Main-207-,,0,0,0,,‫ואז, סֵיזָר יאסוף אותי ויטיס אותנו לבטחה!
Dialogue: 0,0:23:32.16,0:23:36.26,Main-207-,,0,0,0,,‫אם הכל ייצא כשורה, נצא מהבלגן הזה.
Dialogue: 0,0:23:37.76,0:23:41.80,Main-207-,,0,0,0,,‫הי! איך אתה מעז לסכן את חיי\N‫מבלי לשאול אותי, ממזר!
Dialogue: 0,0:23:41.80,0:23:44.04,Main-207-,,0,0,0,,‫זאת משימת התאבדות!
Dialogue: 0,0:23:44.04,0:23:49.60,Main-207-,,0,0,0,,‫הם ימלאו אותנו עופרת ברגע שנצא! לתוכנית הזאת אין סיכוי להצלחה!
Dialogue: 0,0:23:49.60,0:23:51.74,Main-207-,,0,0,0,,‫רבים מהם משתמשים בהאקי שריון!
Dialogue: 0,0:23:51.74,0:23:54.61,Main-207-,,0,0,0,,‫גם אם אהפוך לגז,\N‫לא אוכל להתגונן מפניהם!
Dialogue: 0,0:23:54.61,0:23:56.98,Main-207-,,0,0,0,,‫תן לי לשאול אותך משהו.
Dialogue: 0,0:23:58.45,0:23:59.69,Main-207-,,0,0,0,,‫סאנג'י,
Dialogue: 0,0:24:02.23,0:24:04.78,Main-207-,,0,0,0,,‫למה הצלת אותנו?
Dialogue: 0,0:24:06.44,0:24:11.43,Main-207-,,0,0,0,,‫אנחנו האויבים שלך שנפלנו ישר לתוך המלכודת שלהם!
Dialogue: 0,0:24:14.93,0:24:18.81,Main-207-,,0,0,0,,‫כי אבא שלי היה עצוב...
Dialogue: 0,0:24:19.97,0:24:24.04,Main-207-,,0,0,0,,‫אם הייתי עדיין אחוז בשנאה מילדותי...
Dialogue: 0,0:24:26.86,0:24:28.55,Flashbacks-207-,,0,0,0,,‫תוציאו אותי!
Dialogue: 0,0:24:28.55,0:24:31.38,Flashbacks-207-,,0,0,0,,‫אבא! סליחה!
Dialogue: 0,0:24:32.42,0:24:36.49,Flashbacks-207-,,0,0,0,,‫סליחה שנולדתי חלש!
Dialogue: 0,0:24:36.49,0:24:42.79,Flashbacks-207-,,0,0,0,,‫עזור לי, אבא!
Dialogue: 0,0:24:45.76,0:24:49.08,Main-207-,,0,0,0,,‫הוא היה נדהם\N‫שהפכתי לאיש כה קטן
Dialogue: 0,0:24:49.08,0:24:53.57,Main-207-,,0,0,0,,‫שאשחק על מות בני משפחתי בדם.
Dialogue: 0,0:24:53.57,0:24:58.14,Flashbacks-207-,,0,0,0,,‫אל תתקרר.
Dialogue: 0,0:24:58.14,0:25:01.76,Main-207-,,0,0,0,,‫אני לא רוצה לחיות חיים שבהם אהיה מתוסכל מדי
Dialogue: 0,0:25:01.76,0:25:03.82,Main-207-,,0,0,0,,‫להביט בו!
Dialogue: 0,0:25:08.38,0:25:12.39,Flashbacks-207-,,0,0,0,,‫אל תודה אף פעם שאני אביך...
Dialogue: 0,0:25:12.39,0:25:17.02,Flashbacks-207-,,0,0,0,,‫לאף אחד, אפילו לא לאדם אחד!
Dialogue: 0,0:25:20.90,0:25:25.11,Flashbacks-207-,,0,0,0,,‫אני לא רוצה שאף אחד\N‫יידע על הבושה שלי!
Dialogue: 0,0:25:25.57,0:25:27.77,Flashbacks-207-,,0,0,0,,‫מובן לך?
Dialogue: 0,0:25:31.21,0:25:33.11,Main-207-,,0,0,0,,‫לפני שלוש עשרה שנה,
Dialogue: 0,0:25:33.11,0:25:38.55,Main-207-,,0,0,0,,‫ברחתי מגֶרמה, וויינסמוק סאנג'י מת בים.
Dialogue: 0,0:25:38.55,0:25:41.29,Main-207-,,0,0,0,,‫וזה מה שרצית.
Dialogue: 0,0:25:52.93,0:25:55.23,Main-207-,,0,0,0,,‫אז תודה בזה!
Dialogue: 0,0:25:55.97,0:26:00.60,Main-207-,,0,0,0,,‫אתה לא אבא שלי, ויינסמוק ג'אדג'!
Dialogue: 0,0:26:01.37,0:26:04.40,Main-207-,,0,0,0,,‫אל תראה את פניך אצלנו יותר!
Dialogue: 0,0:26:28.40,0:26:30.67,Main-207-,,0,0,0,,‫אני מבין.
Dialogue: 0,0:26:30.67,0:26:33.01,Main-207-,,0,0,0,,‫אז אתן לך את מילתי...
Dialogue: 0,0:26:33.01,0:26:35.27,Main-207-,,0,0,0,,‫לעולם לא אתקרב אליך...
Dialogue: 0,0:26:35.27,0:26:38.34,Main-207-,,0,0,0,,‫או לאיסט בלו שוב!
Dialogue: 0,0:26:45.35,0:26:47.92,Main-207-,,0,0,0,,‫כבר עשיתי את חלקי!
Dialogue: 0,0:26:47.92,0:26:50.49,Main-207-,,0,0,0,,‫זה לא היה חלק מהעסקה!
Dialogue: 0,0:26:50.49,0:26:55.02,Main-207-,,0,0,0,,‫אם לא תעשה את זה, אתה ממילא תמות, סֵיזָר!
Dialogue: 0,0:26:56.83,0:26:58.90,Main-207-,,0,0,0,,‫פתח את השער!
Dialogue: 0,0:27:00.36,0:27:05.02,Main-207-,,0,0,0,,‫גאנג בֶּגֶה! עד שסֵיזָר קלאון\N‫ייקח אותך לבטחה דרך האוויר,
Dialogue: 0,0:27:05.02,0:27:08.02,Main-207-,,0,0,0,,‫גֶרמה תשמש כשומרת שלך!
Dialogue: 0,0:27:08.02,0:27:09.57,Main-207-,,0,0,0,,‫ר-רגע!
Dialogue: 0,0:27:09.57,0:27:12.30,Main-207-,,0,0,0,,‫מי נתן לך את הזכות\N‫להחליט מה אני צריך לעשות?!
Dialogue: 0,0:27:12.30,0:27:15.88,Main-207-,,0,0,0,,‫הגישה הנחרצת שלך לא השתנתה, ג'אדג'!
Dialogue: 0,0:27:18.35,0:27:22.05,Main-207-,,0,0,0,,‫אה, נכון... גֶרמה יכולה גם לעוף.
Dialogue: 0,0:27:22.05,0:27:23.95,Main-207-,,0,0,0,,‫אז... נשאיר אותך מאחור.
Dialogue: 0,0:27:23.95,0:27:25.42,Main-207-,,0,0,0,,‫זה לא יהיה בעיה.
Dialogue: 0,0:27:27.86,0:27:30.86,Main-207-,,0,0,0,,‫בסדר, אם אנחנו מנסים לקנות זמן, אני...
Dialogue: 0,0:27:31.43,0:27:34.40,Main-207-,,0,0,0,,‫אין צורך, לופי.
Dialogue: 0,0:27:33.36,0:27:34.39,Secondary-207-,,0,0,0,,‫אבל...
Dialogue: 0,0:27:56.59,0:28:00.46,Main-207-,,0,0,0,,‫אני לא צריך עזרה מכישלון!
Dialogue: 0,0:28:02.75,0:28:05.92,Main-207-,,0,0,0,,‫כך הם רוצים לכפר על מעשיהם.
Dialogue: 0,0:28:07.26,0:28:09.30,Main-207-,,0,0,0,,‫רגע, רגע! וואו-וואו!
Dialogue: 0,0:28:09.30,0:28:12.30,Main-207-,,0,0,0,,‫מעולם לא אמרתי שאעזור, טיפשים!
Dialogue: 0,0:28:12.70,0:28:14.34,Main-207-,,0,0,0,,‫סֵיזָר!
Dialogue: 0,0:28:14.34,0:28:16.31,Main-207-,,0,0,0,,‫שתוק ועשה את זה!
Dialogue: 0,0:28:16.31,0:28:18.88,Main-207-,,0,0,0,,‫אוי!
Dialogue: 0,0:28:18.88,0:28:20.95,Main-207-,,0,0,0,,‫תשלם על זה!
Dialogue: 0,0:28:24.42,0:28:27.65,Main-207-,,0,0,0,,‫צאו כבר!
Dialogue: 0,0:28:27.65,0:28:29.19,Main-207-,,0,0,0,,‫בֶּגֶה!
Dialogue: 0,0:28:38.21,0:28:41.41,Main-207-,,0,0,0,,‫גֶרמה! התחילו לתקוף!
