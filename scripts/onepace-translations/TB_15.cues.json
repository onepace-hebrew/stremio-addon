[
 {
  "i": 0,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Let's travel all through the worldwide seas,"
 },
 {
  "i": 1,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 2,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 3,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 4,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "We were able to escape from the set course"
 },
 {
  "i": 5,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "along the boundary between sky and sea."
 },
 {
  "i": 6,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now we're rowing our way"
 },
 {
  "i": 7,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "to a hidden adventure at the dark bottom of the sea."
 },
 {
  "i": 8,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Doesn't it sound fun just thinking about it?"
 },
 {
  "i": 9,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Let's travel all through the worldwide seas,"
 },
 {
  "i": 10,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 11,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 12,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 13,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "That feeling we had when we set sail"
 },
 {
  "i": 14,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "is something I'll never forget."
 },
 {
  "i": 15,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Because of that"
 },
 {
  "i": 16,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "nothing will be able to scare me..."
 },
 {
  "i": 17,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now, as the trip approaches, our racing heartbeats"
 },
 {
  "i": 18,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "engrave a rhythm of adventure in our shy hearts."
 },
 {
  "i": 19,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Get all the treasures"
 },
 {
  "i": 20,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 21,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 22,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "making a splash..."
 },
 {
  "i": 23,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Fill your empty heart with dreams."
 },
 {
  "i": 24,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Spread your wings."
 },
 {
  "i": 25,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you color your heart with the blowing wind"
 },
 {
  "i": 26,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "you will move on."
 },
 {
  "i": 27,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Get all the treasures"
 },
 {
  "i": 28,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 29,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 30,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "making a splash..."
 },
 {
  "i": 31,
  "style": "Title",
  "name": "",
  "text": "{\\fad(1000,0)}Clash!\\NThe Titanic Battle Against Zombie 900!"
 },
 {
  "i": 32,
  "style": "Main",
  "name": "Oz",
  "text": "They don't have a wanted poster."
 },
 {
  "i": 33,
  "style": "Main",
  "name": "Oz",
  "text": "Which means the ones remaining are..."
 },
 {
  "i": 34,
  "style": "Main",
  "name": "Oz",
  "text": "That straw hat from before..."
 },
 {
  "i": 35,
  "style": "Main",
  "name": "Oz",
  "text": "An orange woman..."
 },
 {
  "i": 36,
  "style": "Main",
  "name": "Oz",
  "text": "And a cool hero."
 },
 {
  "i": 37,
  "style": "Main",
  "name": "Oz",
  "text": "I'm missing three people."
 },
 {
  "i": 38,
  "style": "Main",
  "name": "Oz",
  "text": "Where could they be?"
 },
 {
  "i": 39,
  "style": "Main",
  "name": "Zombie",
  "text": "She's awake."
 },
 {
  "i": 40,
  "style": "Main",
  "name": "Pelona",
  "text": "Stop!"
 },
 {
  "i": 41,
  "style": "Main",
  "name": "Pelona",
  "text": "I hate cockroaches! Get them off!"
 },
 {
  "i": 42,
  "style": "Main",
  "name": "Pelona",
  "text": "Not cockroaches!"
 },
 {
  "i": 43,
  "style": "Secondary",
  "name": "Zombie",
  "text": "Perona-sama."
 },
 {
  "i": 44,
  "style": "Secondary",
  "name": "Zombie",
  "text": "Perona-sama."
 },
 {
  "i": 45,
  "style": "Secondary",
  "name": "Zombie",
  "text": "Please calm down!"
 },
 {
  "i": 46,
  "style": "Secondary",
  "name": "Zombie",
  "text": "There's no such thing!"
 },
 {
  "i": 47,
  "style": "Main",
  "name": "Pelona",
  "text": "Where am I?"
 },
 {
  "i": 48,
  "style": "Main",
  "name": "Zombie",
  "text": "The enemy is no longer here."
 },
 {
  "i": 49,
  "style": "Main",
  "name": "Zombie",
  "text": "You were unconscious."
 },
 {
  "i": 50,
  "style": "Main",
  "name": "Zombie",
  "text": "What happened?"
 },
 {
  "i": 51,
  "style": "Main",
  "name": "Zombie",
  "text": "And to you of all people."
 },
 {
  "i": 52,
  "style": "Main",
  "name": "Pelona",
  "text": "What happened to the mansion?!"
 },
 {
  "i": 53,
  "style": "Main",
  "name": "Pelona",
  "text": "Was this the pirates' doing?!"
 },
 {
  "i": 54,
  "style": "Main",
  "name": "Zombie",
  "text": "The pirates caused a lot of trouble, but..."
 },
 {
  "i": 55,
  "style": "Main",
  "name": "Zombie",
  "text": "These are the traces of Oars' mindless rampage."
 },
 {
  "i": 56,
  "style": "Main",
  "name": "Pelona",
  "text": "Oars?"
 },
 {
  "i": 57,
  "style": "Main",
  "name": "Zombie",
  "text": "And, according to our reports, Oars annihilated all the Zombie Generals."
 },
 {
  "i": 58,
  "style": "Main",
  "name": "Pelona",
  "text": "The ultimate army?!"
 },
 {
  "i": 59,
  "style": "Main",
  "name": "Pelona",
  "text": "Is Oars out of control?!"
 },
 {
  "i": 60,
  "style": "Main",
  "name": "Zombie",
  "text": "Well, that's-"
 },
 {
  "i": 61,
  "style": "Main",
  "name": "Pelona",
  "text": "Guys!"
 },
 {
  "i": 62,
  "style": "Main",
  "name": "Zombie",
  "text": "Brothers!"
 },
 {
  "i": 63,
  "style": "Main",
  "name": "Oz",
  "text": "Woman!"
 },
 {
  "i": 64,
  "style": "Main",
  "name": "Pelona",
  "text": "O-Oars?"
 },
 {
  "i": 65,
  "style": "Main",
  "name": "Zombie",
  "text": "B-By the way, it seems Hogback-sama got trampled..."
 },
 {
  "i": 66,
  "style": "Main",
  "name": "Pelona",
  "text": "What?!"
 },
 {
  "i": 67,
  "style": "Main",
  "name": "Oz",
  "text": "No woman here?"
 },
 {
  "i": 68,
  "style": "Main",
  "name": "Oz",
  "text": "Woman!"
 },
 {
  "i": 69,
  "style": "Main",
  "name": "Pelona",
  "text": "Woman?"
 },
 {
  "i": 70,
  "style": "Main",
  "name": "Pelona",
  "text": "This is bad, I have to get out of here!"
 },
 {
  "i": 71,
  "style": "Main",
  "name": "Pelona",
  "text": "Thriller Bark is being destroyed by Oars and the pirates!"
 },
 {
  "i": 72,
  "style": "Main",
  "name": "Pelona",
  "text": "Quickly! Gather the provisions and treasures!"
 },
 {
  "i": 73,
  "style": "Main",
  "name": "Pelona",
  "text": "Once you've put them on their pirate ship, we're outta here!"
 },
 {
  "i": 74,
  "style": "Main",
  "name": "Zombie",
  "text": "Their?"
 },
 {
  "i": 75,
  "style": "Main",
  "name": "Pelona",
  "text": "The Straw Hats'!"
 },
 {
  "i": 76,
  "style": "Main",
  "name": "Pelona",
  "text": "We will escape on their ship!"
 },
 {
  "i": 77,
  "style": "Main",
  "name": "Pelona",
  "text": "Quickly!"
 },
 {
  "i": 78,
  "style": "Main",
  "name": "Zombie",
  "text": "Yes, immediately!"
 },
 {
  "i": 79,
  "style": "Captions",
  "name": "Sign",
  "text": "{\\fad(600,0)}Meanwhile, in an empty room."
 },
 {
  "i": 80,
  "style": "Main",
  "name": "Zombie",
  "text": "Now, the vow kiss."
 },
 {
  "i": 81,
  "style": "Main",
  "name": "Nami",
  "text": "What?!"
 },
 {
  "i": 82,
  "style": "Main",
  "name": "Nami",
  "text": "W-W-W-Wait!"
 },
 {
  "i": 83,
  "style": "Main",
  "name": "Nami",
  "text": "What's this?!"
 },
 {
  "i": 84,
  "style": "Main",
  "name": "Nami",
  "text": "No! Stop!"
 },
 {
  "i": 85,
  "style": "Main",
  "name": "Absalom",
  "text": "You're awake?"
 },
 {
  "i": 86,
  "style": "Main",
  "name": "Absalom",
  "text": "Give up, then!"
 },
 {
  "i": 87,
  "style": "Main",
  "name": "Absalom",
  "text": "Once I kiss you, you will become my wife."
 },
 {
  "i": 88,
  "style": "Main",
  "name": "Nami",
  "text": "I said no! You invisible, perverted beast!"
 },
 {
  "i": 89,
  "style": "Main",
  "name": "Nami",
  "text": "I still wanna go on adventures!"
 },
 {
  "i": 90,
  "style": "Main",
  "name": "Absalom",
  "text": "Be quiet and accept it!"
 },
 {
  "i": 91,
  "style": "Main",
  "name": "Absalom",
  "text": "You will become the Graveyard King's wife! The Graveyard Queen!"
 },
 {
  "i": 92,
  "style": "Main",
  "name": "Nami",
  "text": "No! What is that?!"
 },
 {
  "i": 93,
  "style": "Main",
  "name": "Lola",
  "text": "Curse you, Namizou!"
 },
 {
  "i": 94,
  "style": "Main",
  "name": "Nami",
  "text": "Lo-"
 },
 {
  "i": 95,
  "style": "Main",
  "name": "Absalom",
  "text": "Lola!"
 },
 {
  "i": 96,
  "style": "Main",
  "name": "Lola",
  "text": "Namizou..."
 },
 {
  "i": 97,
  "style": "Main",
  "name": "Lola",
  "text": "You!"
 },
 {
  "i": 98,
  "style": "Main",
  "name": "Lola",
  "text": "How could you betray me?"
 },
 {
  "i": 99,
  "style": "Main",
  "name": "Lola",
  "text": "That speech back then about supporting me was nothing but a lie!"
 },
 {
  "i": 100,
  "style": "Main",
  "name": "Lola",
  "text": "What support?! You were trying to steal Ab-sama from me!"
 },
 {
  "i": 101,
  "style": "Main",
  "name": "Lola",
  "text": "What kind of friend are you?!"
 },
 {
  "i": 102,
  "style": "Main",
  "name": "Nami",
  "text": "W-Wait a minute, Lola!"
 },
 {
  "i": 103,
  "style": "Main",
  "name": "Nami",
  "text": "I was unconscious all this time."
 },
 {
  "i": 104,
  "style": "Main",
  "name": "Nami",
  "text": "I don't know what's-"
 },
 {
  "i": 105,
  "style": "Main",
  "name": "Nami",
  "text": "A wedding dress?"
 },
 {
  "i": 106,
  "style": "Main",
  "name": "Nami",
  "text": "Why am I wearing this?"
 },
 {
  "i": 107,
  "style": "Main",
  "name": "Nami",
  "text": "It's beautiful."
 },
 {
  "i": 108,
  "style": "Main",
  "name": "Lola",
  "text": "It's not beautiful, you traitor!"
 },
 {
  "i": 109,
  "style": "Main",
  "name": "Nami",
  "text": "Wait! This is a misunderstanding!"
 },
 {
  "i": 110,
  "style": "Main",
  "name": "Absalom",
  "text": "Dammit, Lola!"
 },
 {
  "i": 111,
  "style": "Main",
  "name": "Absalom",
  "text": "Not only did you interrupt my wedding, but you are trying to harm my bride!"
 },
 {
  "i": 112,
  "style": "Main",
  "name": "Lola",
  "text": "Shut up and marry me!"
 },
 {
  "i": 113,
  "style": "Main",
  "name": "Absalom",
  "text": "Hell no!"
 },
 {
  "i": 114,
  "style": "Main",
  "name": "Lola",
  "text": "Ab-sama, you have no idea, do you?"
 },
 {
  "i": 115,
  "style": "Main",
  "name": "Lola",
  "text": "This woman's real name is Namizou!"
 },
 {
  "i": 116,
  "style": "Main",
  "name": "Lola",
  "text": "And she is actually a man!"
 },
 {
  "i": 117,
  "style": "Main",
  "name": "Absalom",
  "text": "What?!"
 },
 {
  "i": 118,
  "style": "Main",
  "name": "Absalom",
  "text": "That's impossible!"
 },
 {
  "i": 119,
  "style": "Thoughts",
  "name": "Nami",
  "text": "I did say that..."
 },
 {
  "i": 120,
  "style": "Main",
  "name": "Absalom",
  "text": "But, at the bathroom I certainly..."
 },
 {
  "i": 121,
  "style": "Main",
  "name": "Lola",
  "text": "Disappear, Namizou!"
 },
 {
  "i": 122,
  "style": "Main",
  "name": "Nami",
  "text": "Stop, Lola!"
 },
 {
  "i": 123,
  "style": "Main",
  "name": "Absalom",
  "text": "Hey, stop already, Lola!"
 },
 {
  "i": 124,
  "style": "Thoughts",
  "name": "Nami",
  "text": "Is she missing...?!"
 },
 {
  "i": 125,
  "style": "Main",
  "name": "Lola",
  "text": "Namizou."
 },
 {
  "i": 126,
  "style": "Main",
  "name": "Nami",
  "text": "Lola."
 },
 {
  "i": 127,
  "style": "Main",
  "name": "Lola",
  "text": "Escape, Namizou."
 },
 {
  "i": 128,
  "style": "Main",
  "name": "Lola",
  "text": "I'll keep him busy."
 },
 {
  "i": 129,
  "style": "Main",
  "name": "Lola",
  "text": "I'm here to save you, my friend!"
 },
 {
  "i": 130,
  "style": "Main",
  "name": "Nami",
  "text": "Lola!"
 },
 {
  "i": 131,
  "style": "Main",
  "name": "Lola",
  "text": "Ab-sama!"
 },
 {
  "i": 132,
  "style": "Main",
  "name": "Lola",
  "text": "Now that you know the truth, Absalom, forget about her and marry me instead!"
 },
 {
  "i": 133,
  "style": "Main",
  "name": "Nami",
  "text": "Lola..."
 },
 {
  "i": 134,
  "style": "Main",
  "name": "Absalom",
  "text": "My bride is escaping!"
 },
 {
  "i": 135,
  "style": "Main",
  "name": "Lola",
  "text": "I am your bride!"
 },
 {
  "i": 136,
  "style": "Main",
  "name": "Absalom",
  "text": "There's no doubt she's a woman, Lola."
 },
 {
  "i": 137,
  "style": "Main",
  "name": "Absalom",
  "text": "Get out of my way!"
 },
 {
  "i": 138,
  "style": "Main",
  "name": "Nami",
  "text": "Lola!"
 },
 {
  "i": 139,
  "style": "Main",
  "name": "Absalom",
  "text": "Meddling zombie..."
 },
 {
  "i": 140,
  "style": "Main",
  "name": "Absalom",
  "text": "You made me waste my strength."
 },
 {
  "i": 141,
  "style": "Main",
  "name": "Absalom",
  "text": "Very smart..."
 },
 {
  "i": 142,
  "style": "Main",
  "name": "Absalom",
  "text": "You stopped running."
 },
 {
  "i": 143,
  "style": "Main",
  "name": "Absalom",
  "text": "Either way..."
 },
 {
  "i": 144,
  "style": "Main",
  "name": "Absalom",
  "text": "You can't get away from me."
 },
 {
  "i": 145,
  "style": "Main",
  "name": "Absalom",
  "text": "I'm an invisible man."
 },
 {
  "i": 146,
  "style": "Main",
  "name": "Nami",
  "text": "{\\fad(150,150)}Thunder Charge!"
 },
 {
  "i": 147,
  "style": "Main",
  "name": "Nami",
  "text": "How dare you!"
 },
 {
  "i": 148,
  "style": "Flashbacks",
  "name": "Lola",
  "text": "I'm here to save you, my friend!"
 },
 {
  "i": 149,
  "style": "Main",
  "name": "Nami",
  "text": "How dare you hurt Lola!"
 },
 {
  "i": 150,
  "style": "Main",
  "name": "Absalom",
  "text": "That's it! Come straight into my arms!"
 },
 {
  "i": 151,
  "style": "Main",
  "name": "Nami",
  "text": "{\\fad(150,150)}Swing Arm!"
 },
 {
  "i": 152,
  "style": "Main",
  "name": "Nami",
  "text": "It won't hurt you anyway!"
 },
 {
  "i": 153,
  "style": "Main",
  "name": "Nami",
  "text": "I'm aware of that!"
 },
 {
  "i": 154,
  "style": "Main",
  "name": "Nami",
  "text": "How come?"
 },
 {
  "i": 155,
  "style": "Main",
  "name": "Nami",
  "text": "Back on the bridge, he didn't feel it."
 },
 {
  "i": 156,
  "style": "Thoughts",
  "name": "Zombie",
  "text": "Figures... He already exerted himself when he fought that man."
 },
 {
  "i": 157,
  "style": "Thoughts",
  "name": "Zombie",
  "text": "That must be it."
 },
 {
  "i": 158,
  "style": "Main",
  "name": "Nami",
  "text": "Well, it doesn't matter."
 },
 {
  "i": 159,
  "style": "Main",
  "name": "Nami",
  "text": "I won!"
 },
 {
  "i": 160,
  "style": "Main",
  "name": "Nami",
  "text": "I must have hit a weak spot!"
 },
 {
  "i": 161,
  "style": "Main",
  "name": "Nami",
  "text": "Lola!"
 },
 {
  "i": 162,
  "style": "Main",
  "name": "Nami",
  "text": "Are you alright?"
 },
 {
  "i": 163,
  "style": "Main",
  "name": "Nami",
  "text": "Hang in there!"
 },
 {
  "i": 164,
  "style": "Main",
  "name": "Nami",
  "text": "Thank you for coming to save me!"
 },
 {
  "i": 165,
  "style": "Main",
  "name": "Lola",
  "text": "Why are you thanking me, Namizou?"
 },
 {
  "i": 166,
  "style": "Main",
  "name": "Lola",
  "text": "We're friends."
 },
 {
  "i": 167,
  "style": "Main",
  "name": "Nami",
  "text": "But... Back then, I was scared of you, so I lied..."
 },
 {
  "i": 168,
  "style": "Main",
  "name": "Nami",
  "text": "I'm sorry."
 },
 {
  "i": 169,
  "style": "Main",
  "name": "Nami",
  "text": "I'm actually a woman."
 },
 {
  "i": 170,
  "style": "Main",
  "name": "Lola",
  "text": "Silly you."
 },
 {
  "i": 171,
  "style": "Main",
  "name": "Lola",
  "text": "I knew."
 },
 {
  "i": 172,
  "style": "Main",
  "name": "Nami",
  "text": "Lola."
 },
 {
  "i": 173,
  "style": "Main",
  "name": "Lola",
  "text": "More importantly! Ab-sama is off-guard right now!"
 },
 {
  "i": 174,
  "style": "Main",
  "name": "Lola",
  "text": "You shall be my husband now, Absalom!"
 },
 {
  "i": 175,
  "style": "Main",
  "name": "Oz",
  "text": "Are you here?!"
 },
 {
  "i": 176,
  "style": "Main",
  "name": "Oz",
  "text": "Come out, Straw Hat!"
 },
 {
  "i": 177,
  "style": "Main",
  "name": "Oz",
  "text": "Woman!"
 },
 {
  "i": 178,
  "style": "Main",
  "name": "Oz",
  "text": "Cool hero!"
 },
 {
  "i": 179,
  "style": "Main",
  "name": "Sanji",
  "text": "What was his name?"
 },
 {
  "i": 180,
  "style": "Main",
  "name": "Chopper",
  "text": "Let's see..."
 },
 {
  "i": 181,
  "style": "Main",
  "name": "Zoro",
  "text": "I'm sure it was Ross."
 },
 {
  "i": 182,
  "style": "Main",
  "name": "Usopp",
  "text": "No, you got it wrong."
 },
 {
  "i": 183,
  "style": "Main",
  "name": "Usopp",
  "text": "It ended with... \"rs\"."
 },
 {
  "i": 184,
  "style": "Main",
  "name": "Chopper",
  "text": "Fuse."
 },
 {
  "i": 185,
  "style": "Main",
  "name": "Usopp",
  "text": "Whoa, that's a wild guess."
 },
 {
  "i": 186,
  "style": "Main",
  "name": "Sanji",
  "text": "Uars?"
 },
 {
  "i": 187,
  "style": "Main",
  "name": "Usopp",
  "text": "Something's still missing..."
 },
 {
  "i": 188,
  "style": "Main",
  "name": "Robin",
  "text": "Oars."
 },
 {
  "i": 189,
  "style": "Main",
  "name": "All",
  "text": "That's it!"
 },
 {
  "i": 190,
  "style": "Main",
  "name": "Brook",
  "text": "Excuse me... I'm sorry, but my body..."
 },
 {
  "i": 191,
  "style": "Main",
  "name": "Franky",
  "text": "Yeah, don't worry."
 },
 {
  "i": 192,
  "style": "Main",
  "name": "Franky",
  "text": "Can you still move?"
 },
 {
  "i": 193,
  "style": "Main",
  "name": "Brook",
  "text": "Yes."
 },
 {
  "i": 194,
  "style": "Main",
  "name": "Franky",
  "text": "Then step aside."
 },
 {
  "i": 195,
  "style": "Main",
  "name": "Sanji",
  "text": "Hey, Oars!"
 },
 {
  "i": 196,
  "style": "Main",
  "name": "Sanji",
  "text": "If you have Luffy's shadow inside of you..."
 },
 {
  "i": 197,
  "style": "Main",
  "name": "Sanji",
  "text": "Then you should already know that you should never..."
 },
 {
  "i": 198,
  "style": "Main",
  "name": "Sanji",
  "text": "underestimate your crewmates' strength."
 },
 {
  "i": 199,
  "style": "Main",
  "name": "Oz",
  "text": "You're a sturdy bunch, little pirates."
 },
 {
  "i": 200,
  "style": "Main",
  "name": "Zoro",
  "text": "I have a proposal for you all..."
 },
 {
  "i": 201,
  "style": "Main",
  "name": "Zoro",
  "text": "How about we flip this guy over?"
 },
 {
  "i": 202,
  "style": "Main",
  "name": "Sanji",
  "text": "I see."
 },
 {
  "i": 203,
  "style": "Main",
  "name": "Sanji",
  "text": "That would certainly be nice."
 },
 {
  "i": 204,
  "style": "Main",
  "name": "Usopp",
  "text": "W-Wait a minute!"
 },
 {
  "i": 205,
  "style": "Main",
  "name": "Usopp",
  "text": "F-Flip over?!"
 },
 {
  "i": 206,
  "style": "Main",
  "name": "Usopp",
  "text": "This huge thing?!"
 },
 {
  "i": 207,
  "style": "Main",
  "name": "Zoro",
  "text": "However, with this enormous size, Luffy's attacks are more impressive."
 },
 {
  "i": 208,
  "style": "Main",
  "name": "Robin",
  "text": "But he doesn't look like a \"Pirate King\" in the least."
 },
 {
  "i": 209,
  "style": "Main",
  "name": "Franky",
  "text": "How shall we strike?"
 },
 {
  "i": 210,
  "style": "Main",
  "name": "Franky",
  "text": "There are countless ways to do it."
 },
 {
  "i": 211,
  "style": "Main",
  "name": "Chopper",
  "text": "He must have a weakness."
 },
 {
  "i": 212,
  "style": "Main",
  "name": "Sanji",
  "text": "When you're catching a big fish, the most common tactic is to weaken it bit by bit."
 },
 {
  "i": 213,
  "style": "Main",
  "name": "Usopp",
  "text": "If that's the plan, then I am..."
 },
 {
  "i": 214,
  "style": "Main",
  "name": "Usopp",
  "text": "Too scared."
 },
 {
  "i": 215,
  "style": "Main",
  "name": "Oz",
  "text": "I'll squash you!"
 },
 {
  "i": 216,
  "style": "Main",
  "name": "Zoro",
  "text": "Here he comes!"
 },
 {
  "i": 217,
  "style": "Main",
  "name": "Oz",
  "text": "{\\fad(150,150)}Rubber..."
 },
 {
  "i": 218,
  "style": "Main",
  "name": "Oz",
  "text": "{\\fad(150,150)}Butt Slam!"
 },
 {
  "i": 219,
  "style": "Main",
  "name": "Usopp",
  "text": "What kind of attack is that!?"
 },
 {
  "i": 220,
  "style": "Main",
  "name": "Franky",
  "text": "Scatter!"
 },
 {
  "i": 221,
  "style": "Main",
  "name": "Oz",
  "text": "{\\fad(150,150)}Scythe!"
 },
 {
  "i": 222,
  "style": "Main",
  "name": "Franky",
  "text": "Bastard."
 },
 {
  "i": 223,
  "style": "Main",
  "name": "Franky",
  "text": "In that case, I will show you..."
 },
 {
  "i": 224,
  "style": "Main",
  "name": "Franky",
  "text": "Our combined power!"
 },
 {
  "i": 225,
  "style": "Main",
  "name": "Franky",
  "text": "You two!"
 },
 {
  "i": 226,
  "style": "Main",
  "name": "Franky",
  "text": "Let's do it!"
 },
 {
  "i": 227,
  "style": "Main",
  "name": "Franky",
  "text": "Tactics Fifteen!"
 },
 {
  "i": 228,
  "style": "Main",
  "name": "Usopp",
  "text": "What?!"
 },
 {
  "i": 229,
  "style": "Main",
  "name": "Chopper",
  "text": "No way..."
 },
 {
  "i": 230,
  "style": "Main",
  "name": "Chopper",
  "text": "Are we gonna use \"that\" here?!"
 },
 {
  "i": 231,
  "style": "Main",
  "name": "Franky",
  "text": "Zoro!"
 },
 {
  "i": 232,
  "style": "Main",
  "name": "Franky",
  "text": "Curly!"
 },
 {
  "i": 233,
  "style": "Main",
  "name": "Franky",
  "text": "Stand by!"
 },
 {
  "i": 234,
  "style": "Main",
  "name": "Franky",
  "text": "Just hold my legs!"
 },
 {
  "i": 235,
  "style": "Main",
  "name": "Sanji",
  "text": "What is he up to?"
 },
 {
  "i": 236,
  "style": "Main",
  "name": "Franky",
  "text": "Here we go!"
 },
 {
  "i": 237,
  "style": "Main",
  "name": "Chopper",
  "text": "{\\fad(150,150)}Pirates Docking 6..."
 },
 {
  "i": 238,
  "style": "Main",
  "name": "Usopp",
  "text": "{\\fad(150,150)}Giant Robot Warrior..."
 },
 {
  "i": 239,
  "style": "Main",
  "name": "Franky",
  "text": "{\\fad(150,150)}Big Emperor!"
 },
 {
  "i": 240,
  "style": "Main",
  "name": "Chopper",
  "text": "Wait a minute, Franky!"
 },
 {
  "i": 241,
  "style": "Main",
  "name": "Chopper",
  "text": "The left arm hasn't docked yet!"
 },
 {
  "i": 242,
  "style": "Main",
  "name": "Franky",
  "text": "What?!"
 },
 {
  "i": 243,
  "style": "Main",
  "name": "Franky",
  "text": "Hey, what're you waiting for, Nico Robin?!"
 },
 {
  "i": 244,
  "style": "Main",
  "name": "Franky",
  "text": "Hurry up and dock onto my left arm!"
 },
 {
  "i": 245,
  "style": "Main",
  "name": "Chopper",
  "text": "Robin, hurry!"
 },
 {
  "i": 246,
  "style": "Main",
  "name": "Usopp",
  "text": "Come, Robin!"
 },
 {
  "i": 247,
  "style": "Main",
  "name": "Usopp",
  "text": "Do it like me!"
 },
 {
  "i": 248,
  "style": "Main",
  "name": "Robin",
  "text": "For a person, that's shameful."
 },
 {
  "i": 249,
  "style": "Main",
  "name": "Oz",
  "text": "Why did you stop?"
 },
 {
  "i": 250,
  "style": "Main",
  "name": "Sanji",
  "text": "Why're you shocked as well?!"
 },
 {
  "i": 251,
  "style": "Main",
  "name": "Oz",
  "text": "I was starting to get excited."
 },
 {
  "i": 252,
  "style": "Main",
  "name": "Oz",
  "text": "Do it!"
 },
 {
  "i": 253,
  "style": "Main",
  "name": "Oz",
  "text": "The docking!"
 },
 {
  "i": 254,
  "style": "Main",
  "name": "Zoro",
  "text": "How absurd! I can't believe they made me do such a thing."
 },
 {
  "i": 255,
  "style": "Main",
  "name": "Zoro",
  "text": "No, forget it happened."
 },
 {
  "i": 256,
  "style": "Main",
  "name": "Franky",
  "text": "Robin, if you had joined, we would've completed the Robot Warrior, Big Emperor!"
 },
 {
  "i": 257,
  "style": "Main",
  "name": "Chopper",
  "text": "I never thought you'd betray us! Never!"
 },
 {
  "i": 258,
  "style": "Main",
  "name": "Usopp",
  "text": "Luffy would have done it!"
 },
 {
  "i": 259,
  "style": "Main",
  "name": "Robin",
  "text": "Don't ever ask me again..."
 },
 {
  "i": 260,
  "style": "Main",
  "name": "Robin",
  "text": "to do your docking."
 },
 {
  "i": 261,
  "style": "Main",
  "name": "Franky",
  "text": "Payback time, you bastard!"
 },
 {
  "i": 262,
  "style": "Main",
  "name": "Zoro",
  "text": "Franky!"
 },
 {
  "i": 263,
  "style": "Main",
  "name": "Zoro",
  "text": "I'm gonna borrow this huge thing!"
 },
 {
  "i": 264,
  "style": "Main",
  "name": "Franky",
  "text": "You! That's my Heavy Nunchaku!"
 },
 {
  "i": 265,
  "style": "Main",
  "name": "Franky",
  "text": "It can't be helped,"
 },
 {
  "i": 266,
  "style": "Main",
  "name": "Franky",
  "text": "I'll lend it to you!"
 },
 {
  "i": 267,
  "style": "Main",
  "name": "Sanji",
  "text": "You bastard."
 },
 {
  "i": 268,
  "style": "Main",
  "name": "Sanji",
  "text": "I have to hurry and go re-rescue Nami-san!"
 },
 {
  "i": 269,
  "style": "Main",
  "name": "Oz",
  "text": "You?"
 },
 {
  "i": 270,
  "style": "Main",
  "name": "Zoro",
  "text": "Robin!"
 },
 {
  "i": 271,
  "style": "Main",
  "name": "Zoro",
  "text": "Once I reach his left arm, you take care of the joint!"
 },
 {
  "i": 272,
  "style": "Main",
  "name": "Robin",
  "text": "Understood."
 },
 {
  "i": 273,
  "style": "Main",
  "name": "Zombie",
  "text": "Perona-sama!"
 },
 {
  "i": 274,
  "style": "Main",
  "name": "Zombie",
  "text": "The fridge is already full!"
 },
 {
  "i": 275,
  "style": "Main",
  "name": "Zombie",
  "text": "Nothing else will fit."
 },
 {
  "i": 276,
  "style": "Main",
  "name": "Pelona",
  "text": "There's still the pantry, isn't there?"
 },
 {
  "i": 277,
  "style": "Main",
  "name": "Zombie",
  "text": "Roger."
 },
 {
  "i": 278,
  "style": "Main",
  "name": "Pelona",
  "text": "Hurry with the treasure!"
 },
 {
  "i": 279,
  "style": "Main",
  "name": "Pelona",
  "text": "Load the rest of it!"
 },
 {
  "i": 280,
  "style": "Main",
  "name": "Zombies",
  "text": "{\\i1}Roger!"
 },
 {
  "i": 281,
  "style": "Main",
  "name": "Usopp",
  "text": "Take this!"
 },
 {
  "i": 282,
  "style": "Main",
  "name": "Usopp",
  "text": "{\\fad(150,150)}Deadly Special Oil Star!"
 },
 {
  "i": 283,
  "style": "Main",
  "name": "Usopp",
  "text": "{\\fad(150,150)\\pos(555,702)}Tri"
 },
 {
  "i": 284,
  "style": "Main",
  "name": "Usopp",
  "text": "{\\fad(150,150)\\pos(605,702)}ple"
 },
 {
  "i": 285,
  "style": "Main",
  "name": "Usopp",
  "text": "{\\fad(150,150)\\pos(697,702)}Shot!"
 },
 {
  "i": 286,
  "style": "Main",
  "name": "Zoro",
  "text": "Hey, curly eyebrow!"
 },
 {
  "i": 287,
  "style": "Main",
  "name": "Zoro",
  "text": "Throw me!"
 },
 {
  "i": 288,
  "style": "Main",
  "name": "Sanji",
  "text": "Carrying such huge thing...?"
 },
 {
  "i": 289,
  "style": "Main",
  "name": "Zoro",
  "text": "It's okay if you can't handle it!"
 },
 {
  "i": 290,
  "style": "Main",
  "name": "Sanji",
  "text": "Bastard!"
 },
 {
  "i": 291,
  "style": "Main",
  "name": "Sanji",
  "text": "Of course I can, idiot!"
 },
 {
  "i": 292,
  "style": "Main",
  "name": "Sanji",
  "text": "{\\fad(150,150)}Armée de l'Air..."
 },
 {
  "i": 293,
  "style": "Note",
  "name": "Note",
  "text": "{\\fad(150,150)}Air Army"
 },
 {
  "i": 294,
  "style": "Main",
  "name": "Sanji",
  "text": "{\\fad(150,150)}Power Shoot!"
 },
 {
  "i": 295,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(150,150)}Great Sword Strike!"
 },
 {
  "i": 296,
  "style": "Main",
  "name": "Robin",
  "text": "{\\fad(150,150)}Cien Fleur..."
 },
 {
  "i": 297,
  "style": "Note",
  "name": "Note",
  "text": "{\\fad(150,150)}One Hundred Flowers"
 },
 {
  "i": 298,
  "style": "Main",
  "name": "Robin",
  "text": "{\\fad(150,150)}Big Tree!"
 },
 {
  "i": 299,
  "style": "Main",
  "name": "Oz",
  "text": "W-What?"
 },
 {
  "i": 300,
  "style": "Main",
  "name": "Oz",
  "text": "D-Dangerous... I'm falling! I'm falling!"
 },
 {
  "i": 301,
  "style": "Main",
  "name": "Franky",
  "text": "Behold!"
 },
 {
  "i": 302,
  "style": "Main",
  "name": "Franky",
  "text": "My super instant-made mid-air stairs!"
 },
 {
  "i": 303,
  "style": "Main",
  "name": "Franky",
  "text": "{\\fad(150,150)}Franky Skywalk!"
 },
 {
  "i": 304,
  "style": "Main",
  "name": "Franky",
  "text": "But... this foothold won't last much longer!"
 },
 {
  "i": 305,
  "style": "Main",
  "name": "Franky",
  "text": "Let's go already, Chopper!"
 },
 {
  "i": 306,
  "style": "Main",
  "name": "Chopper",
  "text": "Ok!"
 },
 {
  "i": 307,
  "style": "Main",
  "name": "Both",
  "text": "{\\fad(150,150)}Super..."
 },
 {
  "i": 308,
  "style": "Main",
  "name": "Both",
  "text": "{\\fad(150,150)}Frapper..."
 },
 {
  "i": 309,
  "style": "Main",
  "name": "Both",
  "text": "{\\fad(150,150)}Gong!"
 },
 {
  "i": 310,
  "style": "Main",
  "name": "Chopper",
  "text": "Regardless of size, the human body always has the same weak spots."
 },
 {
  "i": 311,
  "style": "Main",
  "name": "Chopper",
  "text": "Hitting your jaw will shake your brain a bit."
 },
 {
  "i": 312,
  "style": "Main",
  "name": "Sanji",
  "text": "Now your only support is that single leg..."
 },
 {
  "i": 313,
  "style": "Main",
  "name": "Sanji",
  "text": "Monster Luffy."
 },
 {
  "i": 314,
  "style": "Main",
  "name": "Sanji",
  "text": "{\\fad(150,150)}Anti-Manner..."
 },
 {
  "i": 315,
  "style": "Main",
  "name": "Sanji",
  "text": "{\\fad(150,150)}Kick..."
 },
 {
  "i": 316,
  "style": "Main",
  "name": "Sanji",
  "text": "{\\fad(150,150)}Course!"
 },
 {
  "i": 317,
  "style": "Main",
  "name": "Zoro",
  "text": "Completely flipped that monster over."
 },
 {
  "i": 318,
  "style": "Main",
  "name": "Franky",
  "text": "Alright! Go down!"
 },
 {
  "i": 319,
  "style": "Main",
  "name": "Sanji",
  "text": "One down."
 },
 {
  "i": 320,
  "style": "Main",
  "name": "Zombie",
  "text": "Hey, hey! This doesn't look like a mansion anymore."
 },
 {
  "i": 321,
  "style": "Main",
  "name": "Zombie",
  "text": "What are those moves?!"
 },
 {
  "i": 322,
  "style": "Main",
  "name": "Zombie",
  "text": "Acrobatics?!"
 },
 {
  "i": 323,
  "style": "Main",
  "name": "Zombie",
  "text": "C-Could it be that..."
 },
 {
  "i": 324,
  "style": "Main",
  "name": "Zombie",
  "text": "Someone flipped him over?"
 },
 {
  "i": 325,
  "style": "Main",
  "name": "Zombie",
  "text": "C'mon, use your head."
 },
 {
  "i": 326,
  "style": "Main",
  "name": "Zombie",
  "text": "Not even an army of one thousand men would be capable of such a thing."
 },
 {
  "i": 327,
  "style": "Main",
  "name": "Lola",
  "text": "I'll be fine, Namizou."
 },
 {
  "i": 328,
  "style": "Main",
  "name": "Lola",
  "text": "You go ahead and escape."
 },
 {
  "i": 329,
  "style": "Main",
  "name": "Lola",
  "text": "Let me explain the current situation."
 },
 {
  "i": 330,
  "style": "Main",
  "name": "Nami",
  "text": "Lola..."
 },
 {
  "i": 331,
  "style": "Main",
  "name": "Lola",
  "text": "That friend of yours, Strawhat Luffy..."
 },
 {
  "i": 332,
  "style": "Main",
  "name": "Lola",
  "text": "The Special Zombie who holds his shadow is rampaging all over the island."
 },
 {
  "i": 333,
  "style": "Main",
  "name": "Nami",
  "text": "It's the zombie we saw at that freezer room."
 },
 {
  "i": 334,
  "style": "Main",
  "name": "Nami",
  "text": "How troublesome!"
 },
 {
  "i": 335,
  "style": "Main",
  "name": "Nami",
  "text": "How are we gonna take Luffy's shadow back from that monster?!"
 },
 {
  "i": 336,
  "style": "Main",
  "name": "Nami",
  "text": "But..."
 },
 {
  "i": 337,
  "style": "Main",
  "name": "Nami",
  "text": "There's no way I'm going back empty-handed after going through this nightmare!"
 },
 {
  "i": 338,
  "style": "Main",
  "name": "Nami",
  "text": "There it is!"
 },
 {
  "i": 339,
  "style": "Main",
  "name": "Nami",
  "text": "And it's not locked!"
 },
 {
  "i": 340,
  "style": "Main",
  "name": "Oz",
  "text": "Why, you bastards..."
 },
 {
  "i": 341,
  "style": "Main",
  "name": "Oz",
  "text": "I've had enough of you!"
 },
 {
  "i": 342,
  "style": "Main",
  "name": "Oz",
