עזאזל!"},{"i":160,"he":"לא הוגן לעשות ערימה של מתים חיים!"},{"i":161,"he":"לא הוגן!"},{"i":162,"he":"אנחנו רק ניקח את הצל שלך, אחי."},{"i":163,"he":"לעזאזל, עזוב אותי!"},{"i":164,"he":"לעזאזל!"},{"i":165,"he":"היי, יש שם מישהו!"},{"i":166,"he":"הם מטהרים את האחרים!"},{"i":167,"he":"תוריד את הידיים המלוכלכות שלך..."},{"i":168,"he":"מעל האחים הקטנים שלי!"},{"i":169,"he":"מי הבחורים האלה?!"},{"i":170,"he":"הם מסוכנים ביותר!"},{"i":171,"he":"א...!"},{"i":172,"he":"אח גדול!"},{"i":173,"he":"רובין!"},{"i":174,"he":"לא הגענו בזמן?"},{"i":175,"he":"אחד חסר."},{"i":176,"he":"אוסופ."},{"i":177,"he":"צ'ופר."},{"i":178,"he":"אתם פצועים?"},{"i":179,"he":"בלתי אפשרי!"},{"i":180,"he":"חוץ מהמזמזם, הופיעו עוד מנוולים\\Nשמכירים את נקודת התורפה שלנו!"},{"i":181,"he":"זה נורא!"},{"i":182,"he":"\"אנחנו לא יכולים למות\" היה המשפט שלנו,\\Nאני לא רוצה לחיות בפחד מהשמדה!"},{"i":183,"he":"שמעתי שאת מי שהצללים שלהם נלקחו\\Nלוקחים מעבר למדרגות הארוכות האלה."},{"i":184,"he":"נכון, לופי הועבר דרך כאן!"},{"i":185,"he":"רדפנו אחריו, אבל אז נאמי...!"},{"i":186,"he":"מעניין אם נאמי בסדר..."},{"i":187,"he":"הוא לא רצה להשמיד אותה.\\Nבטוח נחזור כדי להציל אותה!"},{"i":188,"he":"אגב..."},{"i":189,"he":"אותה נהמה מפלצתית שהגיעה מלמעלה..."},{"i":190,"he":"מה זה היה?"},{"i":191,"he":"כן, הלכנו לשם אחרי ששמענו אותה."},{"i":192,"he":"זה היה הקול של לופי..."},{"i":193,"he":"נספר לכם כל מה שראינו."},{"i":194,"he":"בכל אופן... קרה משהו נורא!"},{"i":195,"he":"תמשיכו להביא עוד!"},{"i":196,"he":"הוא עוד לא קיבל מספיק!"},{"i":197,"he":"כמה הזומבי המיוחד יכול לאכול?!"},{"i":198,"he":"הוא יאכל את כל המזון של האי!"},{"i":199,"he":"איזו תיאבון מדהים."},{"i":200,"he":"קומאשי, למה החבאת את הפיראטים האלה?!"},{"i":201,"he":"אבל... זה..."},{"i":202,"he":"תפסיק לדבר, זה לא חמוד!"},{"i":203,"he":"סליחה, כרישה קטנה."},{"i":204,"he":"אני לא מכיר אותך ובכל זאת את מאכילה אותי."},{"i":205,"he":"למרות שזה טעים נורא וזה לא מספיק."},{"i":206,"he":"ארור אתה, זומבי מיוחד!"},{"i":207,"he":"אל תהיה כל כך חצוף!"},{"i":208,"he":"מי לדעתך גורם לנו, הזומבים, לזוז?!"},{"i":209,"he":"איך אתה בכלל יכול להתלונן\\Nבפני שליט ת'רילר בארק?!"},{"i":210,"he":"האדון יום אחד יהפוך לשליט הים הזה-"},{"i":211,"he":"אנחנו ממש מצטערים!"},{"i":212,"he":"הבחור הזה אמר את כל זה!"},{"i":213,"he":"אתה, אל תלשין על החברים שלך!"},{"i":214,"he":"תקשיב, אורס."},{"i":215,"he":"לפני 500 שנה היית נבל ענק\\Nשהשאיר מאחוריו אינספור אגדות."},{"i":216,"he":"ועכשיו הוקמת לתחייה כדי להפוך\\Nלמשרת שלי בימינו."},{"i":217,"he":"משרת?"},{"i":218,"he":"אני לא רוצה את זה."},{"i":219,"he":"יש לי חלום."},{"i":220,"he":"מעולם לא ראיתי זומבי חצוף כל כך!"},{"i":221,"he":"צפוף ומשעמם פה."},{"i":222,"he":"אני הולך לצאת החוצה לרגע."},{"i":223,"he":"אולי אצא לים ואסתובב בעולם."},{"i":224,"he":"יוצא לטיול?!"},{"i":225,"he":"טמבל שכמוך, זה בלתי אפשרי."},{"i":226,"he":"המקפיא המיוחד הזה עשוי מפלדה\\Nצפופה במיוחד והוא אטום לחלוטין."},{"i":227,"he":"לא תצליח לשרוט אותו אפילו במע-"},{"i":228,"he":"גומי..."},{"i":229,"he":"אקדח!"},{"i":230,"he":"ה-היי! רגע!"},{"i":231,"he":"זה נורא, אורס ברח!"},{"i":232,"he":"מוזר..."},{"i":233,"he":"הייתה לי הרגשה שהיד שלי תימתח\\Nאבל... טוב, לא משנה."},{"i":234,"he":"אני אהיה... מלך הפיראטים!"},{"i":235,"he":"בדיוק כמו אז..."},{"i":236,"he":"תתחנן \"לא האפרו\", \"לא האפרו\"...\\Nבסוף תתחנן בפניי לחייך בלי בושה שוב."},{"i":237,"he":"לא!"},{"i":238,"he":"זה לא יקרה ככה!"},{"i":239,"he":"אין טעם."},{"i":240,"he":"גם אם אאזור אומץ ואחתוך אותם,\\Nהזומבים המפחידים האלה ממשיכים לקום!"},{"i":241,"he":"בטח יש להם חולשה."},{"i":242,"he":"בקצב הזה, גם אם אמצא את הזומבי שלי,\\Nלא יהיה שום דבר שאוכל לעשות."},{"i":243,"he":"יותר מהכל, הפרצופים של הזומבים\\Nפשוט מפחידים מדי!"},{"i":244,"he":"אחד משלנו טוהר!"},{"i":245,"he":"מה קרה?!"},{"i":246,"he":"הוא היה רעב ואכל דג מלוח על האש."},{"i":247,"he":"אידיוט, הוא היה חדש."},{"i":248,"he":"זו בטח החולשה של הזומבים!"},{"i":249,"he":"אתה! אתה השלד שאת הצל שלו\\Nגנבנו לפני כמה ימים."},{"i":250,"he":"איך חזרת לכאן?"},{"i":251,"he":"תענה לשאלה שלי!"},{"i":252,"he":"לאיזה זומבי יש את הצל שלי?"},{"i":253,"he":"אם לא תענה, אפזר דגים בכל רחבי האי!"},{"i":254,"he":"דגים...?"},{"i":255,"he":"ואיך זה אמור להשפיע עליי?"},{"i":256,"he":"זה..."},{"i":257,"he":"אין מצב..."},{"i":258,"he":"אבל, אני לא חושב שזה יכול להיות מלח..."},{"i":259,"he":"מלח...?"},{"i":260,"he":"ו-ואיך מ-מלח א-אמור לעזור בכלל?!"},{"i":261,"he":"זה מלח!"},{"i":262,"he":"זומבים ממש ממש מפחידים בסופו של דבר."},{"i":263,"he":"זה אפילו יותר גרוע בלילה."},{"i":264,"he":"מה, זה היה רק חרגול."},{"i":265,"he":"הוא הפחיד אותי."},{"i":266,"he":"ובכל זאת, זה אפילו יותר מסוכן כשהשמש\\Nזורחת, וקל שהאויב ימצא אותי."},{"i":267,"he":"זהו זה!"},{"i":268,"he":"לשיר!"},{"i":269,"he":"כשמפחדים צריך לשיר שיר כדי להסיח את הדעת!"},{"i":270,"he":"אוכל לטהר אותם אם לא אסתכל\\Nבפרצופים שלהם, במהירות השלד שלי."},{"i":271,"he":"ואז, בטוח אמצא את הצל שלי!"},{"i":272,"he":"מה זה השיר הזה?"},{"i":273,"he":"מישהו מזמזם."},{"i":274,"he":"מי זה?!"},{"i":275,"he":"מה קרה?!"},{"i":276,"he":"על מה כל המהומה באי?!"},{"i":277,"he":"יש לוחם עם פרצוף מפחיד\\Nשמופיע כששומעים זמזום בחושך!"},{"i":278,"he":"הוא מסתובב ומנסה למצוא את הצל שלו!"},{"i":279,"he":"הוא כבר השמיד את רוב זומבי החיילים!"},{"i":280,"he":"בבקשה תעשה משהו!"},{"i":281,"he":"גברת פרונה, יש צרה..."},{"i":282,"he":"שתוק!"},{"i":283,"he":"אל תעיר אותי, קומאשי..."},{"i":284,"he":"בבקשה תתעוררי..."},{"i":285,"he":"סוף סוף נפגשנו."},{"i":286,"he":"מה זה הכוח הזה?"},{"i":287,"he":"זה לא הזומבי שלי...?"},{"i":288,"he":"אני בכלל לא מצליח לעמוד בקצב שלו!"},{"i":289,"he":"למרות שיש לנו אותו סגנון חרב!"},{"i":290,"he":"תוותר."},{"i":291,"he":"לא משנה כמה פעמים תנסה, זה יהיה אותו דבר."},{"i":292,"he":"אם תנסה לזוז מהר יותר,\\Nאחתוך לך את האפרו המגוחך הזה."},{"i":293,"he":"ב-בבקשה אל!"},{"i":294,"he":"בבקשה אל תיגע באפרו!"},{"i":295,"he":"בבקשה!"},{"i":296,"he":"איך אתה לא יודע?!"},{"i":297,"he":"אם אתה הצל שלי, אז איך אתה\\Nלא יודע כמה האפרו הזה חשוב?"},{"i":298,"he":"מאחר שהגוף שלי כבר לא מזדקן,\\Nהוא לעולם לא יצמח שוב!"},{"i":299,"he":"אתה שואל למה?"},{"i":300,"he":"שכחתי הכל לגבי הימים שלי איתך."},{"i":301,"he":"כרגע, אני מציית רק\\Nלאדון מוריה ולאדון אבסלום!"},{"i":302,"he":"שלד שמוקיר את האפרו שלו\\Nהוא לא יותר מבדיחה בעיניי!"},{"i":303,"he":"תפסיק!"},{"i":304,"he":"לא האפרו!"},{"i":305,"he":"לא האפרו!"},{"i":306,"he":"לא האפרו!"},{"i":307,"he":"לא האפרו!"},{"i":308,"he":"איזה מראה עלוב, אדוני לשעבר."},{"i":309,"he":"אני מצטער... הפסדתי..."},{"i":310,"he":"בבקשה תן לי ללכת..."},{"i":311,"he":"אעזוב את האי הזה מיד."},{"i":312,"he":"אז, תסתלק מהעיניים שלי."},{"i":313,"he":"זה יהיה מטריד בשבילי אם תמות."},{"i":314,"he":"זה היה מראה מעורר רחמים."},{"i":315,"he":"תגיד מה שאתה רוצה."},{"i":316,"he":"חמש השנים האחרונות..."},{"i":317,"he":"רק בשביל הרגע הזה...!"},{"i":318,"he":"התחזקתי!"},{"i":319,"he":"אדון אבסלום."},{"i":320,"he":"הכל מוכן לטקס?"},{"i":321,"he":"בכל רגע שתרצה."},{"i":322,"he":"איזו כלה יפהפייה!"},{"i":323,"he":"נתחיל את הטקס מיד."},{"i":324,"he":"תלבישו אותה בשמלה ותביאו אותה לאולם הטקסים."},{"i":325,"he":"כן, מיד."},{"i":326,"he":"מפלצת גדולה מענקים?!"},{"i":327,"he":"כן..."},{"i":328,"he":"הרעש והשאגה המדהימים האלה היו מעשה ידיו."},{"i":329,"he":"אני יכול רק לתאר לעצמי שזה\\Nהזומבי של לופי שואג ומשתולל."},{"i":330,"he":"בואו נמהר!"},{"i":331,"he":"היי, תראו!"},{"i":332,"he":"הנה הסאני!"},{"i":333,"he":"אני מבין..."},{"i":334,"he":"אם תלכו ישר למעלה תמצאו את החדר של הבוס."},{"i":335,"he":"המדרגות האלה משמשות לפריקה?"},{"i":336,"he":"היי!"},{"i":337,"he":"כל המקום הפוך!"},{"i":338,"he":"אין ספק שזה מעשה ידי הזומבים."},{"i":339,"he":"מלא בעקבות בוציות."},{"i":340,"he":"אז, הם אולי עדיין שם..."},{"i":341,"he":"אכן בלגן שלם."},{"i":342,"he":"כמעט שלא נשאר כלום."},{"i":343,"he":"יש כאן זומבי כלשהו...?"},{"i":344,"he":"קודם כל, איפה הם יכולים להיות...?"},{"i":345,"he":"אני לא רואה אותם."},{"i":346,"he":"היי!"},{"i":347,"he":"לופי!"},{"i":348,"he":"זורו!"},{"i":349,"he":"סאנג'י!"},{"i":350,"he":"היי, הם בחדר האוכל!"},{"i":351,"he":"שלושתם!"},{"i":352,"he":"הזומבים שינו להם לגמרי את המראה."},{"i":353,"he":"מעורר רחמים."},{"i":354,"he":"תתעוררו!"},{"i":355,"he":"זה לא הזמן לתנומה!"},{"i":356,"he":"יש לנו בעיות רציניות!"},{"i":357,"he":"הם עדיין ישנים."},{"i":358,"he":"הם הרגישו משהו בכלל?"},{"i":359,"he":"אין מה לעשות."},{"i":360,"he":"היי, תזוזו אחורה, אני הולך להשתמש בבזוקה."},{"i":361,"he":"לא, זה בסדר."},{"i":362,"he":"אומנית חרב יפהפייה הביאה הרבה בשר!"},{"i":363,"he":"יפהפייה?"},{"i":364,"he":"בשר?"},{"i":365,"he":"אומנית חרב?"},{"i":366,"he":"הם חסרי תקנה!"}]