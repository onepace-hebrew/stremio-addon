 {
  "i": 6,
  "style": "OP11 Lyrics",
  "name": "",
  "text": "Until I can reach the sky,"
 },
 {
  "i": 7,
  "style": "OP11 Lyrics",
  "name": "",
  "text": "I believe, until the next tomorrow, hey"
 },
 {
  "i": 8,
  "style": "OP11 Lyrics",
  "name": "",
  "text": "Chasing and being chased on top of Mobius' ring."
 },
 {
  "i": 9,
  "style": "OP11 Lyrics",
  "name": "",
  "text": "Getting closer and facing forward, hey I want to share your style."
 },
 {
  "i": 10,
  "style": "OP11 Lyrics",
  "name": "",
  "text": "It begins, it expands, this flavor that exceeds imagination"
 },
 {
  "i": 11,
  "style": "OP11 Lyrics",
  "name": "",
  "text": "I feel so good throughout my body, I will become free, oh yeah"
 },
 {
  "i": 12,
  "style": "OP11 Lyrics",
  "name": "",
  "text": "Share the music, even if it's far."
 },
 {
  "i": 13,
  "style": "OP11 Lyrics",
  "name": "",
  "text": "Share the one dream, by telling each other."
 },
 {
  "i": 14,
  "style": "OP11 Lyrics",
  "name": "",
  "text": "Share the good times and laugh."
 },
 {
  "i": 15,
  "style": "OP11 Lyrics",
  "name": "",
  "text": "I'll keep going until I can reach the sky."
 },
 {
  "i": 16,
  "style": "OP11 Lyrics",
  "name": "",
  "text": "Let's overcome it now, I believe in the next tomorrow yeah yeah..."
 },
 {
  "i": 17,
  "style": "OP11 Lyrics",
  "name": "",
  "text": "You were waiting there on the other side of the invisible wall."
 },
 {
  "i": 18,
  "style": "OP11 Lyrics",
  "name": "",
  "text": "I'll be there soon, I believe in one world yeah yeah..."
 },
 {
  "i": 19,
  "style": "Main",
  "name": "Brook",
  "text": "I have reached my limit! I have a muscle cramp!"
 },
 {
  "i": 20,
  "style": "Title",
  "name": "",
  "text": "{\\fad(1800,0)}Duval's Tragedy"
 },
 {
  "i": 21,
  "style": "Main",
  "name": "Brook",
  "text": "Though I do not have any muscles to have a cramp in!"
 },
 {
  "i": 22,
  "style": "Main",
  "name": "Zoro",
  "text": "Brook, you're pretty enthusiastic, huh?"
 },
 {
  "i": 23,
  "style": "Main",
  "name": "Zoro",
  "text": "You took out quite a few of the Flying Fish."
 },
 {
  "i": 24,
  "style": "Main",
  "name": "Brook",
  "text": "I am glad to have been of help!"
 },
 {
  "i": 25,
  "style": "Main",
  "name": "Brook",
  "text": "But please... let me rest for a while..."
 },
 {
  "i": 26,
  "style": "Main",
  "name": "Brook",
  "text": "Zoro-san..."
 },
 {
  "i": 27,
  "style": "Main",
  "name": "Brook",
  "text": "It looks like you're still hurt..."
 },
 {
  "i": 28,
  "style": "Main",
  "name": "Zoro",
  "text": "I won't let these fish beat me! Don't worry about it!"
 },
 {
  "i": 29,
  "style": "Thoughts",
  "name": "Hachi",
  "text": "You let down your guard, Roronoa!"
 },
 {
  "i": 30,
  "style": "Main",
  "name": "Hachi",
  "text": "{\\fad(150,150)}Six-Sword Style..."
 },
 {
  "i": 31,
  "style": "Main",
  "name": "Hachi",
  "text": "{\\fad(150,150)}Octopus-Arm Danger!"
 },
 {
  "i": 32,
  "style": "Main",
  "name": "Zoro",
  "text": "You saved me, huh?"
 },
 {
  "i": 33,
  "style": "Main",
  "name": "Hachi",
  "text": "That's right! You guys were spacing out and all..."
 },
 {
  "i": 34,
  "style": "Main",
  "name": "Camie",
  "text": "Hacchin! You were really cool!"
 },
 {
  "i": 35,
  "style": "Main",
  "name": "Pappag",
  "text": "Just what I'd expect from you, Hachi!"
 },
 {
  "i": 36,
  "style": "Main",
  "name": "Hachi",
  "text": "Really?"
 },
 {
  "i": 37,
  "style": "Main",
  "name": "Rider",
  "text": "Die, fishman!"
 },
 {
  "i": 38,
  "style": "Main",
  "name": "Brook",
  "text": "Right! Excuse me!"
 },
 {
  "i": 39,
  "style": "Main",
  "name": "Hachi",
  "text": "I thought I was gonna die! Thanks!"
 },
 {
  "i": 40,
  "style": "Main",
  "name": "Zoro",
  "text": "I told you to watch yourself, didn't I?"
 },
 {
  "i": 41,
  "style": "Main",
  "name": "Riders",
  "text": "Don't take them on one by one... Get in formation!"
 },
 {
  "i": 42,
  "style": "Hentai",
  "name": "Text-bubble",
  "text": "{\\frz22\\pos(778,594)}Formation (Hentai)"
 },
 {
