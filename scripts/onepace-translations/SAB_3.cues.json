  "text": "{\\frz339\\pos(790,126)}Pervert\\N(Hentai)"
 },
 {
  "i": 45,
  "style": "Main",
  "name": "Franky",
  "text": "You called?"
 },
 {
  "i": 46,
  "style": "Main",
  "name": "Riders",
  "text": "Attack in flying formation!"
 },
 {
  "i": 47,
  "style": "Hentai",
  "name": "Text-bubbles",
  "text": "{\\frz25\\fs38\\pos(958,436)}Formation (Hentai)"
 },
 {
  "i": 48,
  "style": "Hentai",
