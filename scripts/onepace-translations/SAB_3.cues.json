  "text": "{\\fad(150,150)}Teeth"
 },
 {
  "i": 397,
  "style": "Main",
  "name": "",
  "text": "{\\fad(150,150)}Menton"
 },
 {
  "i": 398,
  "style": "Note",
  "name": "",
  "text": "{\\fad(150,150)}Jaw"
 },
 {
  "i": 399,
  "style": "Main",
  "name": "",
  "text": "Please, stop it..."
 },
 {
  "i": 400,
  "style": "Main",
  "name": "",
  "text": "{\\fad(150,150)}Parage Shot!"
 },
 {
  "i": 401,
  "style": "Note",
  "name": "",
  "text": "{\\fad(150,150)}Trimming Shot"
 },
 {
  "i": 402,
  "style": "Main",
  "name": "",
  "text": "Taste the classiness of my finishing attack, and end your misery."
 },
 {
  "i": 403,
  "style": "Main",
  "name": "",
  "text": "You shitty bastard."
 }
]