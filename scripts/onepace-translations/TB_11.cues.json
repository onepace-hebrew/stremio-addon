[
 {
  "i": 0,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}Let's travel all through the worldwide seas,"
 },
 {
  "i": 1,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 2,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 3,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 4,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "We were able to escape from the set course"
 },
 {
  "i": 5,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "along the boundary between sky and sea."
 },
 {
  "i": 6,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now we're rowing our way"
 },
 {
  "i": 7,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "to a hidden adventure at the dark bottom of the sea."
 },
 {
  "i": 8,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Doesn't it sound fun just thinking about it?"
 },
 {
  "i": 9,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Let's travel all through the worldwide seas,"
 },
 {
  "i": 10,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 11,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 12,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 13,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "That feeling we had when we set sail"
 },
 {
  "i": 14,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "is something I'll never forget."
 },
 {
  "i": 15,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Because of that"
 },
 {
  "i": 16,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "nothing will be able to scare me..."
 },
 {
  "i": 17,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now, as the trip approaches, our racing heartbeats"
 },
 {
  "i": 18,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "engrave a rhythm of adventure in our shy hearts."
 },
 {
  "i": 19,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}Get all the treasures"
 },
 {
  "i": 20,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 21,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 22,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(50,50)}making a splash..."
 },
 {
  "i": 23,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Fill your empty heart with dreams."
 },
 {
  "i": 24,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Spread your wings."
 },
 {
  "i": 25,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you color your heart with the blowing wind"
 },
 {
  "i": 26,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "you will move on."
 },
 {
  "i": 27,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(50,0)}Get all the treasures"
 },
 {
  "i": 28,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 29,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 30,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "making a splash..."
 },
 {
  "i": 31,
  "style": "Title",
  "name": "",
  "text": "{\\fad(2000,2000)}A Stolen Dream! Sanji vs. Absalom"
 },
 {
  "i": 32,
  "style": "Main",
  "name": "Luffy",
  "text": "W-What's going on?"
 },
 {
  "i": 33,
  "style": "Main",
  "name": "Luffy",
  "text": "That's one amazing tremor!"
 },
 {
  "i": 34,
  "style": "Main",
  "name": "Moriah",
  "text": "The ship could be caught in some weird current..."
 },
 {
  "i": 35,
  "style": "Main",
  "name": "Moriah",
  "text": "It's probably your fault."
 },
 {
  "i": 36,
  "style": "Main",
  "name": "Moria",
  "text": "Now then, what business do you have here?"
 },
 {
  "i": 37,
  "style": "Main",
  "name": "Moria",
  "text": "Why did you come?"
 },
 {
  "i": 38,
  "style": "Main",
  "name": "Luffy",
  "text": "Yeah, you ripped off my shadow a while ago."
 },
 {
  "i": 39,
  "style": "Main",
  "name": "Luffy",
  "text": "I want it back."
 },
 {
  "i": 40,
  "style": "Main",
  "name": "Luffy",
  "text": "Also Zoro's,"
 },
 {
  "i": 41,
  "style": "Main",
  "name": "Luffy",
  "text": "and Sanji's,"
 },
 {
  "i": 42,
  "style": "Main",
  "name": "Luffy",
  "text": "and Brook's,"
 },
 {
  "i": 43,
  "style": "Main",
  "name": "Luffy",
  "text": "and the zombie old man's."
 },
 {
  "i": 44,
  "style": "Main",
  "name": "Luffy",
  "text": "All of them!"
 },
 {
  "i": 45,
  "style": "Main",
  "name": "Moriah",
  "text": "Quite a greedy guy."
 },
 {
  "i": 46,
  "style": "Main",
  "name": "Moriah",
  "text": "And what're you planning on doing?"
 },
 {
  "i": 47,
  "style": "Main",
  "name": "Luffy",
  "text": "I'll kick your ass!"
 },
 {
  "i": 48,
  "style": "Main",
  "name": "Moriah",
  "text": "Kick my ass?"
 },
 {
  "i": 49,
  "style": "Main",
  "name": "Luffy",
  "text": "Yeah, that's right."
 },
 {
  "i": 50,
  "style": "Main",
  "name": "Moriah",
  "text": "If you defeat or kill me, that would just leave the zombies without their master."
 },
 {
  "i": 51,
  "style": "Main",
  "name": "Moriah",
  "text": "The shadows won't come out."
 },
 {
  "i": 52,
  "style": "Main",
  "name": "Moria",
  "text": "My devil fruit ability is to rule over the shadows."
 },
 {
  "i": 53,
  "style": "Main",
  "name": "Moria",
  "text": "In order for your wish to be granted, this is what you do..."
 },
 {
  "i": 54,
  "style": "Main",
  "name": "Moria",
  "text": "The current owners of the shadows must hear me give the order, \"Go back to your Master.\""
 },
 {
  "i": 55,
  "style": "Main",
  "name": "Luffy",
  "text": "Just by doing that, every shadow will return?"
 },
 {
  "i": 56,
  "style": "Main",
  "name": "Moriah",
  "text": "That's right! Simple, isn't it?"
 },
 {
  "i": 57,
  "style": "Main",
  "name": "Moriah",
  "text": "You can weaken me to the point of doing so, but..."
 },
 {
  "i": 58,
  "style": "Main",
  "name": "Moriah",
  "text": "With your current strength I seriously doubt you can even touch me."
 },
 {
  "i": 59,
  "style": "Main",
  "name": "Luffy",
  "text": "Alright."
 },
 {
  "i": 60,
  "style": "Main",
  "name": "Luffy",
  "text": "{\\fad(150,150)}Rubber..."
 },
 {
  "i": 61,
  "style": "Main",
  "name": "Luffy",
  "text": "{\\fad(150,150)}Pistol!"
 },
 {
  "i": 62,
  "style": "Main",
  "name": "Luffy",
  "text": "A shadow?"
 },
 {
  "i": 63,
  "style": "Main",
  "name": "Moriah",
  "text": "Let's see you win..."
 },
 {
  "i": 64,
  "style": "Main",
  "name": "Moriah",
  "text": "Against my clone,"
 },
 {
  "i": 65,
  "style": "Main",
  "name": "Moriah",
  "text": "Doppelman!"
 },
 {
  "i": 66,
  "style": "Main",
  "name": "Moriah",
  "text": "Long ago, I too was overconfident in my abilities and ambition."
 },
 {
  "i": 67,
  "style": "Main",
  "name": "Moriah",
  "text": "Until I finally realized the need to have many more subordinates."
 },
 {
  "i": 68,
  "style": "Main",
  "name": "Luffy",
  "text": "Who is this guy?"
 },
 {
  "i": 69,
  "style": "Main",
  "name": "Luffy",
  "text": "Hey! Move!"
 },
 {
  "i": 70,
  "style": "Main",
  "name": "Moriah",
  "text": "I don't have to move a finger."
 },
 {
  "i": 71,
  "style": "Main",
  "name": "Moria",
  "text": "Other people's efforts will make me Pirate King."
 },
 {
  "i": 72,
  "style": "Main",
  "name": "Luffy",
  "text": "I'm gonna be the Pirate King!"
 },
 {
  "i": 73,
  "style": "Main",
  "name": "Moriah",
  "text": "Your zombie said the same."
 },
 {
  "i": 74,
  "style": "Flashbacks",
  "name": "Oars",
  "text": "I'm gonna be the Pirate King!"
 },
 {
  "i": 75,
  "style": "Main",
  "name": "Moriah",
  "text": "As expected from the shadow and body. Despite the difference in size,"
 },
 {
  "i": 76,
  "style": "Main",
  "name": "Moriah",
  "text": "He still reflects the strong will of its former master."
 },
 {
  "i": 77,
  "style": "Main",
  "name": "Moriah",
  "text": "But it won't be for long."
 },
 {
  "i": 78,
  "style": "Main",
  "name": "Moriah",
  "text": "Once he loses all memories of being you, he'll fully become my loyal zombie."
 },
 {
  "i": 79,
  "style": "Main",
  "name": "Moriah",
  "text": "Regardless of how strong the will is, every zombie will end up showing absolute loyalty!"
 },
 {
  "i": 80,
  "style": "Main",
  "name": "Luffy",
  "text": "I'm taking it back now!"
 },
 {
  "i": 81,
  "style": "Main",
  "name": "Luffy",
  "text": "{\\fad(150,150)}Rubber..."
 },
 {
  "i": 82,
  "style": "Main",
  "name": "Moria",
  "text": "{\\fad(150,150)}Brick Bat!"
 },
 {
  "i": 83,
  "style": "Main",
  "name": "Luffy",
  "text": "{\\fad(150,150)}Gatling!"
 },
 {
  "i": 84,
  "style": "Main",
  "name": "Luffy",
  "text": "Damn! They're protecting him!"
 },
 {
  "i": 85,
  "style": "Main",
  "name": "Luffy",
  "text": "I can't hit him!"
 },
 {
  "i": 86,
  "style": "Main",
  "name": "Moriah",
  "text": "Don't worry, they won't suck your blood."
 },
 {
  "i": 87,
  "style": "Main",
  "name": "Moriah",
  "text": "Kick my ass?"
 },
 {
  "i": 88,
  "style": "Main",
  "name": "Moriah",
  "text": "Don't make me laugh."
 },
 {
  "i": 89,
  "style": "Main",
  "name": "Luffy",
  "text": "Let go of me!"
 },
 {
  "i": 90,
  "style": "Main",
  "name": "Moriah",
  "text": "An inexperienced youngster always underestimates everyone else, and gets ridiculed in the end."
 },
 {
  "i": 91,
  "style": "Main",
  "name": "Luffy",
  "text": "You bastard! I'm through with you!"
 },
 {
  "i": 92,
  "style": "Main",
  "name": "Luffy",
  "text": "{\\fad(150,150)}Rubber..."
 },
 {
  "i": 93,
  "style": "Main",
  "name": "Moria",
  "text": "What? He jumped down..."
 },
 {
  "i": 94,
  "style": "Main",
  "name": "Moria",
  "text": "Are you running away?"
 },
 {
  "i": 95,
  "style": "Main",
  "name": "Luffy",
  "text": "{\\fad(150,150)}Stamp!"
 },
 {
  "i": 96,
  "style": "Main",
  "name": "Moriah",
  "text": "That hurt, stupid brat!"
 },
 {
  "i": 97,
  "style": "Main",
  "name": "Luffy",
  "text": "Look!"
 },
 {
  "i": 98,
  "style": "Main",
  "name": "Luffy",
  "text": "I did touch you after all, giant leek!"
 },
 {
  "i": 99,
  "style": "Main",
  "name": "Sanji",
  "text": "Skip, skip, skip..."
 },
 {
  "i": 100,
  "style": "Main",
  "name": "Sanji",
  "text": "Get your..."
 },
 {
  "i": 101,
  "style": "Main",
  "name": "Sanji",
  "text": "hands off Nami-san!"
 },
 {
  "i": 102,
  "style": "Main",
  "name": "Sanji",
  "text": "Sorry for the delay, Nami-san."
 },
 {
  "i": 103,
  "style": "Main",
  "name": "Sanji",
  "text": "Your knight is here."
 },
 {
  "i": 104,
  "style": "Main",
  "name": "Sanji",
  "text": "Is this..."
 },
 {
  "i": 105,
  "style": "Main",
  "name": "Sanji",
  "text": "A Goddess?"
 },
 {
  "i": 106,
  "style": "Main",
  "name": "Sanji",
  "text": "Ah, no, it's Nami-san..."
 },
 {
  "i": 107,
  "style": "Main",
  "name": "Sanji",
  "text": "Definitely Nami-san."
 },
 {
  "i": 108,
  "style": "Main",
  "name": "Sanji",
  "text": "Without a doubt."
 },
 {
  "i": 109,
  "style": "Main",
  "name": "Sanji",
  "text": "Ah, that surprised me..."
 },
 {
  "i": 110,
  "style": "Main",
  "name": "Sanji",
  "text": "Such beauty can be tricky."
 },
 {
  "i": 111,
  "style": "Main",
  "name": "Sanji",
  "text": "For a second I thought I rescued a fairy by accident."
 },
 {
  "i": 112,
  "style": "Secondary",
  "name": "Absalom",
  "text": "Geez..."
 },
 {
  "i": 113,
  "style": "Secondary",
  "name": "Absalom",
  "text": "What're you blabbering on about?"
 },
 {
  "i": 114,
  "style": "Main",
  "name": "Absalom",
  "text": "You're one of the crew members who was on the ship, aren't you?"
 },
 {
  "i": 115,
  "style": "Main",
  "name": "Absalom",
  "text": "A-An angel?!"
 },
 {
  "i": 116,
  "style": "Main",
  "name": "Absalom",
  "text": "Ah, no, no, it's a human."
 },
 {
  "i": 117,
  "style": "Main",
  "name": "Absalom",
  "text": "No doubt about it."
 },
 {
  "i": 118,
  "style": "Main",
  "name": "Absalom",
  "text": "That got me."
 },
 {
  "i": 119,
  "style": "Main",
  "name": "Sanji",
  "text": "I don't blame you."
 },
 {
  "i": 120,
  "style": "Main",
  "name": "Sanji",
  "text": "Not in the least."
 },
 {
  "i": 121,
  "style": "Main",
  "name": "Sanji",
  "text": "Seeing Nami-san dressed in this snow white color is confusing."
 },
 {
  "i": 122,
  "style": "Main",
  "name": "Absalom",
  "text": "Absolutely right!"
 },
 {
  "i": 123,
  "style": "Main",
  "name": "Zombie",
  "text": "What's with those two?"
 },
 {
  "i": 124,
  "style": "Secondary",
  "name": "Absalom",
  "text": "We're thinking alike."
 },
 {
  "i": 125,
  "style": "Main",
  "name": "Absalom",
  "text": "Curse you, pirate!"
 },
 {
  "i": 126,
  "style": "Main",
  "name": "Absalom",
  "text": "I've no reason to get along with you!"
 },
 {
  "i": 127,
  "style": "Main",
  "name": "Sanji",
  "text": "Hey!"
 },
 {
  "i": 128,
  "style": "Main",
  "name": "Sanji",
  "text": "That could've hit Nami-san."
 },
 {
  "i": 129,
  "style": "Main",
  "name": "Sanji",
  "text": "You should avoid attacking recklessly in a lady's presence."
 },
 {
  "i": 130,
  "style": "Main",
  "name": "Absalom",
  "text": "Good job avoiding that."
 },
 {
  "i": 131,
  "style": "Main",
  "name": "Absalom",
  "text": "It seems you no longer have your shadow."
 },
 {
  "i": 132,
  "style": "Main",
  "name": "Absalom",
  "text": "Come to think of it, there was this newbie zombie who had a strange attachment to that woman."
 },
 {
  "i": 133,
  "style": "Main",
  "name": "Absalom",
  "text": "A rebel zombie with some ego still left in him."
 },
 {
  "i": 134,
  "style": "Main",
  "name": "Absalom",
  "text": "That was probably your zombie."
 },
 {
  "i": 135,
  "style": "Main",
  "name": "Absalom",
  "text": "The fact that he wasn't included among the General Zombies must mean that his real body is weak."
 },
 {
  "i": 136,
  "style": "Main",
  "name": "Absalom",
  "text": "That overconfident penguin was actually pretty weak."
 },
 {
  "i": 137,
  "style": "Main",
  "name": "Absalom",
  "text": "It's so absurd..."
 },
 {
  "i": 138,
  "style": "Main",
  "name": "Absalom",
  "text": "for a pathetic underling to pick a fight with me, a monster and commander of the General Zombies!"
 },
 {
  "i": 139,
  "style": "Main",
  "name": "Sanji",
  "text": "A-A nymph?!"
 },
 {
  "i": 140,
  "style": "Main",
  "name": "Sanji",
  "text": "That surprised me..."
 },
 {
  "i": 141,
  "style": "Main",
  "name": "Sanji",
  "text": "I thought it was a nymph for a second."
 },
 {
  "i": 142,
  "style": "Main",
  "name": "Absalom",
  "text": "Now, I don't wanna get rough..."
 },
 {
  "i": 143,
  "style": "Main",
  "name": "Absalom",
  "text": "Leave that woman with me and go back to your life in the shadows."
 },
 {
  "i": 144,
  "style": "Main",
  "name": "Absalom",
  "text": "I'm busy right now..."
 },
 {
  "i": 145,
  "style": "Main",
  "name": "Absalom",
  "text": "My strongest underlings were annihilated by your stupid captain's zombie."
 },
 {
  "i": 146,
  "style": "Main",
  "name": "Absalom",
  "text": "And before that, I couldn't even give my bride the vow kiss..."
 },
 {
  "i": 147,
  "style": "Main",
  "name": "Absalom",
  "text": "Don't you get it?"
 },
 {
  "i": 148,
  "style": "Main",
  "name": "Absalom",
  "text": "I'm terribly irritated right now."
 },
 {
  "i": 149,
  "style": "Main",
  "name": "Absalom",
  "text": "I have no time to deal with amateurs like y-"
 },
 {
  "i": 150,
  "style": "Main",
  "name": "Sanji",
  "text": "Shut up, you Carnival-beast-face man!"
 },
 {
  "i": 151,
  "style": "Main",
  "name": "Zombie",
  "text": "Absalom-sama!"
 },
 {
  "i": 152,
  "style": "Main",
  "name": "Zombie",
  "text": "No way!"
 },
 {
  "i": 153,
  "style": "Main",
  "name": "Zombie",
  "text": "He sent that 300 kilogram body flying in an instant!"
 },
 {
  "i": 154,
  "style": "Main",
  "name": "Sanji",
  "text": "You must be the invisible man Usopp spoke of."
 },
 {
  "i": 155,
  "style": "Thoughts",
  "name": "Absalom",
  "text": "What's with that kick?!"
 },
 {
  "i": 156,
  "style": "Thoughts",
  "name": "Absalom",
  "text": "Hogback improved my body with the power of the wild, and yet he blew me away..."
 },
 {
  "i": 157,
  "style": "Main",
  "name": "Absalom",
  "text": "{\\fad(150,150)}Hands of the Dead!"
 },
 {
  "i": 158,
  "style": "Thoughts",
  "name": "Absalom",
  "text": "What's the meaning of this?!"
 },
 {
  "i": 159,
  "style": "Thoughts",
  "name": "Absalom",
  "text": "Did he know what I was about to do?!"
 },
 {
  "i": 160,
  "style": "Main",
  "name": "Sanji",
  "text": "{\\fad(150,150)}Basse Côte!"
 },
 {
  "i": 161,
  "style": "Note",
  "name": "Sanji",
  "text": "{\\fad(150,150)}Lower Rib"
 },
 {
  "i": 162,
  "style": "Main",
  "name": "Sanji",
  "text": "{\\fad(150,150)}Longe!"
 },
 {
  "i": 163,
  "style": "Note",
  "name": "Sanji",
  "text": "{\\fad(150,150)}Loin"
 },
 {
  "i": 164,
  "style": "Main",
  "name": "Sanji",
  "text": "You're that wild beast who licked Robin-chan on the Sunny, aren't you?!"
 },
 {
  "i": 165,
  "style": "Flashbacks",
  "name": "Robin",
  "text": "Something grabbed me...!"
 },
 {
  "i": 166,
  "style": "Main",
  "name": "Sanji",
  "text": "You're the one who saw Nami-san completely naked in the bathroom, aren't you?"
 },
 {
  "i": 167,
  "style": "Flashbacks",
  "name": "Absalom",
  "text": "You'll be my bride."
 },
 {
  "i": 168,
  "style": "Main",
