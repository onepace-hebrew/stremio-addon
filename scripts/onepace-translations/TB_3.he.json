[{"i":0,"he":"בואו נשוט בכל ימי העולם,"},{"i":1,"he":"ונרים את קריאת הקרב שלנו."},{"i":2,"he":"אם החלטתם, תנו לאות היציאה"},{"i":3,"he":"להדהד."},{"i":4,"he":"הצלחנו לחמוק מהמסלול שנקבע"},{"i":5,"he":"לאורך הגבול שבין השמיים לים."},{"i":6,"he":"עכשיו אנחנו חותרים בדרכנו"},{"i":7,"he":"אל הרפתקה נסתרת במעמקי הים האפלים."},{"i":8,"he":"לא נשמע כיף רק לחשוב על זה?"},{"i":9,"he":"בואו נשוט בכל ימי העולם,"},{"i":10,"he":"ונרים את קריאת הקרב שלנו."},{"i":11,"he":"אם החלטתם, תנו לאות היציאה"},{"i":12,"he":"להדהד."},{"i":13,"he":"את התחושה שהייתה לנו כשהפלגנו"},{"i":14,"he":"לעולם לא אשכח."},{"i":15,"he":"בזכותה"},{"i":16,"he":"שום דבר לא יוכל להפחיד אותי..."},{"i":17,"he":"עכשיו, כשהמסע מתקרב, פעימות הלב הדוהרות"},{"i":18,"he":"חורתות קצב של הרפתקה בלבבותינו הביישנים."},{"i":19,"he":"אספו את כל האוצרות"},{"i":20,"he":"תוך כדי צחוק רם."},{"i":21,"he":"חלקו את כולם במסיבה גדולה"},{"i":22,"he":"ועשו רעש..."},{"i":23,"he":"מלאו את הלב הריק שלכם בחלומות."},{"i":24,"he":"פרשו כנפיים."},{"i":25,"he":"אם תצבעו את הלב ברוח הנושבת"},{"i":26,"he":"תמשיכו הלאה."},{"i":27,"he":"אספו את כל האוצרות"},{"i":28,"he":"תוך כדי צחוק רם."},{"i":29,"he":"חלקו את כולם במסיבה גדולה"},{"i":30,"he":"ועשו רעש..."},{"i":31,"he":"האיש הבלתי נראה\\Nוסוד האחוזה!"},{"i":32,"he":"אנחנו פיר-"},{"i":33,"he":"כלומר, מלחים!"},{"i":34,"he":"טיילנו ואיבדנו את הדרך!"},{"i":35,"he":"בבקשה תנו לנו להיכנס!"},{"i":36,"he":"יש מישהו בבית?"},{"i":37,"he":"מוזר, הפנים נראים כמו מנהרה."},{"i":38,"he":"אני רואה חצר מהצד השני."},{"i":39,"he":"סליחה על ההפרעה!"},{"i":40,"he":"אתה חושב שהוא לא בבית?"},{"i":41,"he":"זה לא יהיה טוב."},{"i":42,"he":"אם נחזור, הזומבים יתפסו אותנו."},{"i":43,"he":"תראו, אור נדלק עכשיו!"},{"i":44,"he":"האמת, זה יותר כמו זרקור."},{"i":45,"he":"הוא מאיר על הבאר הזו..."},{"i":46,"he":"ברוכים הבאים."},{"i":47,"he":"אחת, שתיים, שלוש."},{"i":48,"he":"מ-מה?"},{"i":49,"he":"ארבע, חמש."},{"i":50,"he":"א-אאוץ'!"},{"i":51,"he":"היא תוקפת אותנו עם צלחות!"},{"i":52,"he":"שש, שבע."},{"i":53,"he":"אאוץ', את מכוונת רק אלי?!"},{"i":54,"he":"כן, נכון."},{"i":55,"he":"אסור לך להיכנס לאחוזה."},{"i":56,"he":"שניכם שם יכולים להיכנס."},{"i":57,"he":"הא? למה?"},{"i":58,"he":"אתה לא הולך לשום מקום!"},{"i":59,"he":"שמונה, תשע!"},{"i":60,"he":"למה?"},{"i":61,"he":"תפסיקי, מספיק!"},{"i":62,"he":"מה?"},{"i":63,"he":"בבקשה בלי עוד דברים מפחידים!"},{"i":64,"he":"יש שם עוד מישהו?"},{"i":65,"he":"את לא יכולה לעשות חריגה אחת, סינדרי?"},{"i":66,"he":"אני מצטער שהפחדתי אתכם ככה."},{"i":67,"he":"מזמן, כדי לבחון את אהבת ארוסה העשיר,"},{"i":68,"he":"האישה הזו שברה את כל\\Nצלחות החרסינה היקרות שלו,"},{"i":69,"he":"גורשה וניהלה חיים אומללים."},{"i":70,"he":"המשרתת שונאת הצלחות שלי, סינדרי."},{"i":71,"he":"טוב... שיהיה."},{"i":72,"he":"ועוד לא הצגתי את עצמי..."},{"i":73,"he":"{\\fad(1000,0)}אדון האחוזה (מנתח גאון)\\Nד\"ר הוגבק"},{"i":74,"he":"אני הד\"ר הוגבק המהולל בכל העולם!"},{"i":75,"he":"ואני גאון."},{"i":76,"he":"עשר!"},{"i":77,"he":"אוסופ!"},{"i":78,"he":"ר-רגע, סינדרי!"},{"i":79,"he":"אמרתי לך להפסיק עם זה!"},{"i":80,"he":"את אמורה להקשיב למה שיש לי להגיד!"},{"i":81,"he":"הלוואי שהצלחות יעלמו מהעולם הזה."},{"i":82,"he":"אני מבין!"},{"i":83,"he":"אני באמת מבין, אבל עכשיו אני מנסה לדבר!"},{"i":84,"he":"צ'ופר..."},{"i":85,"he":"זה הבחור שרצית ל..."},{"i":86,"he":"ד-ד\"ר הוגבק, זה באמת הוא!"},{"i":87,"he":"הוא נראה קצת אידיוט."},{"i":88,"he":"תפסיקי, נאמי!"},{"i":89,"he":"טוב, נמשיך עם זה בפנים."},{"i":90,"he":"נעשה חריגה ונרשה לכל השלושה להיכנס."},{"i":91,"he":"אז ברוכים הבאים."},{"i":92,"he":"נ-נכון, היכנסו."},{"i":93,"he":"אני לא מבין למה אני לא יכולתי להיכנס..."},{"i":94,"he":"אבל בכל מקרה, בואו נלך."},{"i":95,"he":"כן, זה לפחות עדיף על הזומבים."},{"i":96,"he":"היי, אני עדיין...!"},{"i":97,"he":"אני... עדיין כאן..."},{"i":98,"he":"אשמח לקבל אתכם באחוזה שלי!"},{"i":99,"he":"אתם כל כך מלוכלכים!"},{"i":100,"he":"למה אתם כאן?"},{"i":101,"he":"טוב, יש המון סיבות..."},{"i":102,"he":"ראשית..."},{"i":103,"he":"אני רוצה לדבר איתך אחר כך!"},{"i":104,"he":"תקפו אותנו זומבים בבית הקברות, וברחנו לכאן!"},{"i":105,"he":"זומבים?"},{"i":106,"he":"ראינו כאן עוד המון יצורים לא ייאמנו!"},{"i":107,"he":"מה הקטע של המקום הזה?"},{"i":108,"he":"אתה גר כאן, אתה אמור לדעת!"},{"i":109,"he":"הו, תקפו אתכם?"},{"i":110,"he":"אני שמח שהגעתם לכאן בשלום."},{"i":111,"he":"זה נהדר."},{"i":112,"he":"ולשאלתכם, הנה התשובה שלי:"},{"i":113,"he":"אני גר כאן כי אני לא יודע מה הם הדברים האלו."},{"i":114,"he":"אז אתה כאן כדי לחקור את הזומבים, דוקטור?!"},{"i":115,"he":"ברור!"},{"i":116,"he":"לבני אדם יש פחד נורא מזומבים."},{"i":117,"he":"אבל אם נסתכל על זה כאנשים\\Nשחוזרים מהמתים במקום..."},{"i":118,"he":"אז זה לא בדיוק חיי הנצח\\Nשכל בני האדם שואפים אליהם?"},{"i":119,"he":"לכל אחד יש יקיר אחד או שניים\\Nשמתו ושהוא מתגעגע לראות שוב..."},{"i":120,"he":"עם המדע הרפואי, אנחנו מסוגלים לשלוט\\Nבמי שחי ומי שמת, בלי לפחד מהאלים!"},{"i":121,"he":"מהסיבה הזו יצאתי לגלות כדי להתחיל\\Nאת המחקר שלי באי המסתורי הזה."},{"i":122,"he":"ב-באמת?"},{"i":123,"he":"אבל אם תצליח, יהיו המון אנשים שיהיו מאושרים!"},{"i":124,"he":"אני אעודד אותך, ד\"ר הוגבק!"},{"i":125,"he":"הו, תודה, ד\"ר צ'ופר."},{"i":126,"he":"ג-גם אם אתה קורא לי דוקטור,\\Nזה לא משמח אותי, חתיכת חרא!"},{"i":127,"he":"אפשר לקבל את החתימה שלך?"},{"i":128,"he":"הו, בטח."},{"i":129,"he":"לד\"ר צ'ופר,"},{"i":130,"he":"ואחר כך, אפשר לראות את המעבדה שלך?"},{"i":131,"he":"לעולם אל תעז אפילו להציץ במעבדה שלי...!"},{"i":132,"he":"הו, סינדרי, את לא יכולה לפחות\\Nלשים את הפודינג על צלחת?"},{"i":133,"he":"או שאין טעם בכלל לבקש?!"},{"i":134,"he":"הלוואי שכל הצלחות ייעלמו."},{"i":135,"he":"טוב, אל דאגה, אנחנו שומרים את\\Nהמפה נקייה בדיוק למקרים כאלו!"},{"i":136,"he":"אז בואו נאכל!"},{"i":137,"he":"אתה יכול לפחות להשתמש בכפית!"},{"i":138,"he":"הו! זה ממש מתוק וטעים!"},{"i":139,"he":"הכנתי את האמבטיה."},{"i":140,"he":"אתם כולכם מלוכלכים, אז אתם יכולים להשתמש בה."},{"i":141,"he":"אה כן, זקן!"},{"i":142,"he":"כל זה בסדר, אבל..."},{"i":143,"he":"לא ראית במקרה שלד מוזר עובר כאן, נכון?"},{"i":144,"he":"ש-שלד?"},{"i":145,"he":"כן."},{"i":146,"he":"יש לו אפרו, הוא ממש גבוה..."},{"i":147,"he":"הוא ממש קל..."},{"i":148,"he":"טוב, אני מניח שזה מוזר\\Nמספיק להיות שלד שמהלך ומדבר."},{"i":149,"he":"אתה יודע משהו על זה?"},{"i":150,"he":"לא, אני לא."},{"i":151,"he":"באמת?"},{"i":152,"he":"טוב, שיהיה."},{"i":153,"he":"הם מתכוונים לבחור ההוא?"},{"i":154,"he":"לא... זה לא יכול להיות..."},{"i":155,"he":"האמבטיה של האחוזה"},{"i":156,"he":"אין לי באמת שום עניין לראות\\Nנשים אנושיות עירומות..."},{"i":157,"he":"אבל אני כן רוצה להציץ במעבדה של ד\"ר הוגבק."},{"i":158,"he":"אבל באמת, נאמי,"},{"i":159,"he":"למה אנחנו צריכים לשמור עלייך ככה?"},{"i":160,"he":"אם את כל כך מפוחדת, יכולת לוותר על האמבטיה!"},{"i":161,"he":"אתם יודעים, אחרי שזומבים תפסו\\Nאתכם ככה, ממש לא אכפת לכם."},{"i":162,"he":"אתם מטונפים!"},{"i":163,"he":"אנחנו פשוט נתלכלך שוב!"},{"i":164,"he":"כן!"},{"i":165,"he":"הלילה, אנחנו עוזבים."},{"i":166,"he":"מה אתה, טי-"},{"i":167,"he":"אמרו לנו שאנחנו יכולים ללון פה."},{"i":168,"he":"אתם יודעים מה יכול לקרות\\Nלנו אם נצא החוצה הלילה?!"},{"i":169,"he":"בכל מקרה, אנחנו לא הולכים לשום מקום אחר."},{"i":170,"he":"לופי והאחרים יבואו ויצילו אותנו."},{"i":171,"he":"אוקיי?"},{"i":172,"he":"אני מסכים!"},{"i":173,"he":"אני לא רוצה לחזור החוצה לשם!"},{"i":174,"he":"אני לא אוהב את היער הזה, ולא את הקברים!"},{"i":175,"he":"הפנים זהים לחוץ."},{"i":176,"he":"הסתכלתם טוב מסביב?"},{"i":177,"he":"אם אני לא טועה,"},{"i":178,"he":"המסדרונות והחדרים מלאים."},{"i":179,"he":"האחוזה הזו מלאה בזומבים."},{"i":180,"he":"א-איפה הם?!"},{"i":181,"he":"אבל הכי חשוד מכולם זה הוגבק עצמו."},{"i":182,"he":"הוא בהחלט משקר."},{"i":183,"he":"אם באמת לא היה לו שום קשר\\Nלזומבים כמו שהוא אומר,"},{"i":184,"he":"למה שהוא יגור באחוזה שמלאה בהם?"},{"i":185,"he":"מ-מה איתך, צ'ופר?"},{"i":186,"he":"אם זה באמת נכון, אז..."},{"i":187,"he":"לא..."},{"i":188,"he":"אז בינתיים, פשוט נעמיד\\Nפנים שאנחנו לא יודעים,"},{"i":189,"he":"ונעזוב הלילה."},{"i":190,"he":"ובכן, ובכן, איזו בחורה ערמומית."},{"i":191,"he":"מה?"},{"i":192,"he":"אוסופ, צ'ופר, אחד מכם אמר משהו?"},{"i":193,"he":"אני לא אמרתי כלום."},{"i":194,"he":"היי, בדיוק הפלצתי!"},{"i":195,"he":"איכס, מגעיל, אוסופ!"},{"i":196,"he":"אני אוסופו!"},{"i":197,"he":"חתיכת...!"},{"i":198,"he":"מה קורה?"},{"i":199,"he":"אין כאן אף אחד...!"},{"i":200,"he":"בהשוואה לאישה ההיא על הספינה..."},{"i":201,"he":"את הרבה יותר חלשה - יותר הטיפוס שלי."},{"i":202,"he":"יש כאן מישהו...!"},{"i":203,"he":"אוסופ, צ'ו-"},{"i":204,"he":"את... תהיי הכלה שלי."},{"i":205,"he":"היי נאמי, מה קרה?"},{"i":206,"he":"אתה מריח את הפלוץ של אוסופ גם כאן?"},{"i":207,"he":"תודה רבה!"},{"i":208,"he":"אתה מודה לה?"},{"i":209,"he":"צאו..."},{"i":210,"he":"טמבל, תעזור לי...!"},{"i":211,"he":"ארור שכמותך...!"},{"i":212,"he":"אוסופ, צ'ופר, הצילו!"},{"i":213,"he":"יש כאן מישהו!"},{"i":214,"he":"היא צודקת, אני מריח את זה!"},{"i":215,"he":"עדיין?"},{"i":216,"he":"סליחה!"},{"i":217,"he":"לא הפלוץ, אדם!"},{"i":218,"he":"הוא יוצא דרך החלון!"},{"i":219,"he":"איך החלון עושה את זה לבד?"},{"i":220,"he":"מה בורח?"},{"i":221,"he":"{\\fad(150,150)}כוכב אבק שריפה קטלני!"},{"i":222,"he":"מעניין אם הוא הצליח לברוח..."},{"i":223,"he":"הוא שמע את כל השיחה שלנו..."},{"i":224,"he":"ה-היי, נאמי, מה בדיוק קרה?"},{"i":225,"he":"אני לא מבין!"},{"i":226,"he":"הוא היה כאן כל הזמן..."},{"i":227,"he":"איש בלתי נראה."},{"i":228,"he":"{\\fad(380,600)}בינתיים... בת'אוזנד סאני\\Nלופי והאחרים"},{"i":229,"he":"לא טוב."},{"i":230,"he":"לא משנה מה נעשה, אנחנו לא מצליחים לצאת."},{"i":231,"he":"מקורי העכביש הענק הזה..."},{"i":232,"he":"הספינה של השלד ההוא תקועה\\Nגם היא, בדיוק כמו הסאני."},{"i":233,"he":"וגם המיני מרי שאוסופ\\Nוהאחרים נסעו בו תקוע כאן."},{"i":234,"he":"עם השער הקדמי ככה, זה\\Nכמעט כאילו הוא קורא לך."},{"i":235,"he":"לעזאזל."},{"i":236,"he":"אני כמעט רואה את כל הרוחות\\Nהקטנות מזמינות אותנו פנימה."},{"i":237,"he":"על מה אתה ממלמל שם, זורו?"},{"i":238,"he":"אתה צריך לבוא גם!"},{"i":239,"he":"אם תישאר כאן פשוט תשתעמם."},{"i":240,"he":"בוא נלך!"},{"i":241,"he":"אתה אפילו יכול לחלוק קצת מהבנטו שלי!"},{"i":242,"he":"למה פתאום יש מדרגות?"},{"i":243,"he":"כי זו הכניסה!"},{"i":244,"