[
 {
  "i": 0,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}Let's travel all through the worldwide seas,"
 },
 {
  "i": 1,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 2,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 3,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 4,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "We were able to escape from the set course"
 },
 {
  "i": 5,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "along the boundary between sky and sea."
 },
 {
  "i": 6,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now we're rowing our way"
 },
 {
  "i": 7,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "to a hidden adventure at the dark bottom of the sea."
 },
 {
  "i": 8,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Doesn't it sound fun just thinking about it?"
 },
 {
  "i": 9,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Let's travel all through the worldwide seas,"
 },
 {
  "i": 10,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 11,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 12,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 13,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "That feeling we had when we set sail"
 },
 {
  "i": 14,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "is something I'll never forget."
 },
 {
  "i": 15,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Because of that"
 },
 {
  "i": 16,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "nothing will be able to scare me..."
 },
 {
  "i": 17,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now, as the trip approaches, our racing heartbeats"
 },
 {
  "i": 18,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "engrave a rhythm of adventure in our shy hearts."
 },
 {
  "i": 19,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}Get all the treasures"
 },
 {
  "i": 20,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 21,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 22,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(50,50)}making a splash..."
 },
 {
  "i": 23,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Fill your empty heart with dreams."
 },
 {
  "i": 24,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Spread your wings."
 },
 {
  "i": 25,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you color your heart with the blowing wind"
 },
 {
  "i": 26,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "you will move on."
 },
 {
  "i": 27,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(50,0)}Get all the treasures"
 },
 {
  "i": 28,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 29,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 30,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "making a splash..."
 },
 {
  "i": 31,
  "style": "Title",
  "name": "",
  "text": "{\\fad(2000,2000)}Already Negative!\\NUsopp's Courageous Stand!"
 },
 {
  "i": 32,
  "style": "Captions",
  "name": "",
  "text": "{\\fad(170,0)}Within Thriller Bark: The Mast Mansion"
 },
 {
  "i": 33,
  "style": "Captions small",
  "name": "Sign",
  "text": "{\\pos(164,160)}Moriah's Dance Hall"
 },
 {
  "i": 34,
  "style": "Captions small",
  "name": "Sign",
  "text": "{\\pos(114,468)}Perona's room"
 },
 {
  "i": 35,
  "style": "Main",
  "name": "Chopper",
  "text": "Usopp and Sanji fell below..."
 },
 {
  "i": 36,
  "style": "Main",
  "name": "Chopper",
  "text": "Are we just gonna leave them?"
 },
 {
  "i": 37,
  "style": "Main",
  "name": "Luffy",
  "text": "Yeah!"
 },
 {
  "i": 38,
  "style": "Main",
  "name": "Luffy",
  "text": "They'll be fine."
 },
 {
  "i": 39,
  "style": "Main",
  "name": "Luffy",
  "text": "Anyway, we gotta find Moriah before he moves."
 },
 {
  "i": 40,
  "style": "Main",
  "name": "Luffy",
  "text": "As soon as we find that giant leek I'll beat the hell out of him!"
 },
 {
  "i": 41,
  "style": "Main",
  "name": "Chopper",
  "text": "Got it!"
 },
 {
  "i": 42,
  "style": "Main",
  "name": "Chopper",
  "text": "That's the fastest way to solve all this trouble."
 },
 {
  "i": 43,
  "style": "Main",
  "name": "Chopper",
  "text": "That's the entrance to the Dance Hall, where Luffy's shadow was taken!"
 },
 {
  "i": 44,
  "style": "Main",
  "name": "Chopper",
  "text": "And we last saw Moriah in the freezer room which is beyond it."
 },
 {
  "i": 45,
  "style": "Main",
  "name": "Luffy",
  "text": "Alright!"
 },
 {
  "i": 46,
  "style": "Main",
  "name": "Hogback",
  "text": "You!"
 },
 {
  "i": 47,
  "style": "Main",
  "name": "Hogback",
  "text": "Did you defeat Perona?!"
 },
 {
  "i": 48,
  "style": "Main",
  "name": "Chopper",
  "text": "Hogback!"
 },
 {
  "i": 49,
  "style": "Main",
  "name": "Hogback",
  "text": "What's with this reindeer?"
 },
 {
  "i": 50,
  "style": "Main",
  "name": "Robin",
  "text": "Is that Dr. Hogback?"
 },
 {
  "i": 51,
  "style": "Main",
  "name": "Luffy",
  "text": "He's the guy who was with Moria."
 },
 {
  "i": 52,
  "style": "Main",
  "name": "Luffy",
  "text": "Should I kick this guy's ass too?!"
 },
 {
  "i": 53,
  "style": "Main",
  "name": "Hogback",
  "text": "W-Wait a minute!"
 },
 {
  "i": 54,
  "style": "Main",
  "name": "Chopper",
  "text": "Wait, Luffy!"
 },
 {
  "i": 55,
  "style": "Main",
  "name": "Chopper",
  "text": "Why don't you leave this guy to me?"
 },
 {
  "i": 56,
  "style": "Main",
  "name": "Chopper",
  "text": "That's the doorway there, isn't it?"
 },
 {
  "i": 57,
  "style": "Main",
  "name": "Chopper",
  "text": "That's the freezer room."
 },
 {
  "i": 58,
  "style": "Main",
  "name": "Chopper",
  "text": "Go ahead!"
 },
 {
  "i": 59,
  "style": "Main",
  "name": "Luffy",
  "text": "Alright! I got it!"
 },
 {
  "i": 60,
  "style": "Main",
  "name": "Hogback",
  "text": "Such a lack of manners, going to meet Moriah-sama without notice!"
 },
 {
  "i": 61,
  "style": "Main",
  "name": "Hogback",
  "text": "Cindry-chan! Get him!"
 },
 {
  "i": 62,
  "style": "Main",
  "name": "Cindry",
  "text": "Yes..."
 },
 {
  "i": 63,
  "style": "Main",
  "name": "Cindry",
  "text": "One!"
 },
 {
  "i": 64,
  "style": "Main",
  "name": "Cindry",
  "text": "Two!"
 },
 {
  "i": 65,
  "style": "Main",
  "name": "Luffy",
  "text": "What?! Plates?"
 },
 {
  "i": 66,
  "style": "Main",
  "name": "Cindry",
  "text": "Thr-"
 },
 {
  "i": 67,
  "style": "Main",
  "name": "Hogback",
  "text": "What's wrong, Cindry-chan?!"
 },
 {
  "i": 68,
  "style": "Main",
  "name": "Robin",
  "text": "Go ahead, Luffy."
 },
 {
  "i": 69,
  "style": "Main",
  "name": "Luffy",
  "text": "Thanks, Robin!"
 },
 {
  "i": 70,
  "style": "Main",
  "name": "Hogback",
  "text": "Wait, Straw Hat!"
 },
 {
  "i": 71,
  "style": "Main",
  "name": "Chopper",
  "text": "Hogback!"
 },
 {
  "i": 72,
  "style": "Main",
  "name": "Chopper",
  "text": "I'm disappointed in you!"
 },
 {
  "i": 73,
  "style": "Main",
  "name": "Chopper",
  "text": "I won't accept you as a doctor!"
 },
 {
  "i": 74,
  "style": "Main",
  "name": "Hogback",
  "text": "I couldn't recognize you, Dr. Chopper!"
 },
 {
  "i": 75,
  "style": "Main",
  "name": "Hogback",
  "text": "So you were a Zoan type user all along..."
 },
 {
  "i": 76,
  "style": "Main",
  "name": "Hogback",
  "text": "No wonder I thought you were a strange creature."
 },
 {
  "i": 77,
  "style": "Main",
  "name": "Hogback",
  "text": "I have no idea how you avoided being carried through Perona's Garden, but..."
 },
 {
  "i": 78,
  "style": "Main",
  "name": "Hogback",
  "text": "You won't be escaping this time."
 },
 {
  "i": 79,
  "style": "Main",
  "name": "Hogback",
  "text": "I'll take your shadow!"
 },
 {
  "i": 80,
  "style": "Main",
  "name": "Hogback",
  "text": "No..."
 },
 {
  "i": 81,
  "style": "Main",
  "name": "Hogback",
  "text": "Better yet..."
 },
 {
  "i": 82,
  "style": "Main",
  "name": "Hogback",
  "text": "How about I kill you here and turn you into a marionette?"
 },
 {
  "i": 83,
  "style": "Main",
  "name": "Hogback",
  "text": "They will do it."
 },
 {
  "i": 84,
  "style": "Main",
  "name": "Luffy",
  "text": "This passage is incredibly long!"
 },
 {
  "i": 85,
  "style": "Main",
  "name": "Luffy",
  "text": "Alright! I'm out!"
 },
 {
  "i": 86,
  "style": "Main",
  "name": "Luffy",
  "text": "What's this place?"
 },
 {
  "i": 87,
  "style": "Main",
  "name": "Luffy",
  "text": "Found you!"
 },
 {
  "i": 88,
  "style": "Main",
  "name": "Moriah",
  "text": "Yo!"
 },
 {
  "i": 89,
  "style": "Main",
  "name": "Moriah",
  "text": "It's just you..."
 },
 {
  "i": 90,
  "style": "Main",
  "name": "Franky",
  "text": "What's with this hugeness?!"
 },
 {
  "i": 91,
  "style": "Main",
  "name": "Franky",
  "text": "Is this some sort of archdemon?!"
 },
 {
  "i": 92,
  "style": "Main",
  "name": "Franky",
  "text": "I've never seen a giant like this!"
 },
 {
  "i": 93,
  "style": "Main",
  "name": "Franky",
  "text": "Is this a zombie?"
 },
 {
  "i": 94,
  "style": "Main",
  "name": "Sanji",
  "text": "Is this..."
 },
 {
  "i": 95,
  "style": "Main",
  "name": "Sanji",
  "text": "Luffy?"
 },
 {
  "i": 96,
  "style": "Main",
  "name": "Usopp",
  "text": "No use!"
 },
 {
  "i": 97,
  "style": "Main",
  "name": "Usopp",
  "text": "It's all over!"
 },
 {
  "i": 98,
  "style": "Main",
  "name": "Usopp",
  "text": "It came to kill us!"
 },
 {
  "i": 99,
  "style": "Main",
  "name": "Usopp",
  "text": "What is he planning to do?!"
 },
 {
  "i": 100,
  "style": "Main",
  "name": "Oars",
  "text": "This looks good."
 },
 {
  "i": 101,
  "style": "Main",
  "name": "Oars",
  "text": "Alright! Now I'm all set!"
 },
 {
  "i": 102,
  "style": "Main",
  "name": "Oars",
  "text": "I'll definitely be the Pirate King!"
 },
 {
  "i": 103,
  "style": "Main",
  "name": "Oars",
  "text": "I was kinda surprised when the building collapsed."
 },
 {
  "i": 104,
  "style": "Main",
  "name": "Usopp",
  "text": "W-What?"
 },
 {
  "i": 105,
  "style": "Main",
  "name": "Usopp",
  "text": "He didn't even notice us?!"
 },
 {
  "i": 106,
  "style": "Main",
  "name": "Zoro",
  "text": "That thing's speech sure resembles Luffy's..."
 },
 {
  "i": 107,
  "style": "Main",
  "name": "Zoro",
  "text": "Luffy's power certainly is dangerous when embedded in a body like that."
 },
 {
  "i": 108,
  "style": "Main",
  "name": "Usopp",
  "text": "Let's just..."
 },
 {
  "i": 109,
  "style": "Main",
  "name": "Usopp",
  "text": "Forget your shadows..."
 },
 {
  "i": 110,
  "style": "Main",
  "name": "Both",
  "text": "Of course not!"
 },
 {
  "i": 111,
  "style": "Main",
  "name": "Sanji",
  "text": "Even if we give up our shadows, we haven't saved Nami-san yet!"
 },
 {
  "i": 112,
  "style": "Main",
  "name": "Sanji",
  "text": "Pull it together!"
 },
 {
  "i": 113,
  "style": "Main",
  "name": "Sanji",
  "text": "In any case, getting past here is the problem..."
 },
 {
  "i": 114,
  "style": "Main",
  "name": "Sanji",
  "text": "It seems Usopp and I fell along with the stairs, but..."
 },
 {
  "i": 115,
  "style": "Main",
  "name": "Sanji",
  "text": "Even if we try to change our route..."
 },
 {
  "i": 116,
  "style": "Main",
  "name": "Sanji",
  "text": "This bridge has collapsed and we can no longer go to that mast-like mansion."
 },
 {
  "i": 117,
  "style": "Main",
  "name": "Zoro",
  "text": "Jumping isn't an option either..."
 },
 {
  "i": 118,
  "style": "Main",
  "name": "Usopp",
  "text": "Our shortcut has turned into a detour infested with zombies..."
 },
 {
  "i": 119,
  "style": "Main",
  "name": "Franky",
  "text": "Hang on thirty more seconds!"
 },
 {
  "i": 120,
  "style": "Main",
  "name": "Franky",
  "text": "I'm not sure about this ornament."
 },
 {
  "i": 121,
  "style": "Main",
  "name": "All",
  "text": "He built a bridge!"
 },
 {
  "i": 122,
  "style": "Main",
  "name": "Franky",
  "text": "All this rubble and wood is more than enough to build a bridge or two."
 },
 {
  "i": 123,
  "style": "Main",
  "name": "Usopp",
  "text": "But despite this being an emergency, you gave it a lot of detail."
 },
 {
  "i": 124,
  "style": "Main",
  "name": "Franky",
  "text": "You expect me to make a shoddy job?!"
 },
 {
  "i": 125,
  "style": "Main",
  "name": "Sanji",
  "text": "No, this is just fine."
 },
 {
  "i": 126,
  "style": "Main",
  "name": "Sanji",
  "text": "Anyway, you saved us. Let's go!"
 },
 {
  "i": 127,
  "style": "Main",
  "name": "Sanji",
  "text": "What's wrong with this room?"
 },
 {
  "i": 128,
  "style": "Main",
  "name": "Zoro",
  "text": "Quite the eye-catching type of room."
 },
 {
  "i": 129,
  "style": "Main",
  "name": "Perona",
  "text": "I planned on having the zombies on the stairs and bridge make you their prey."
 },
 {
  "i": 130,
  "style": "Main",
  "name": "Perona",
  "text": "I didn't think Oars would fall down."
 },
 {
  "i": 131,
  "style": "Main",
  "name": "Perona",
  "text": "What a nosy nuisance."
 },
 {
  "i": 132,
  "style": "Main",
  "name": "Zoro",
  "text": "Those ghosts...!"
 },
 {
  "i": 133,
  "style": "Main",
  "name": "Zoro",
  "text": "Is she... the one controlling them?"
 },
 {
  "i": 134,
  "style": "Main",
  "name": "Zoro",
  "text": "Who the hell is she?!"
 },
 {
  "i": 135,
  "style": "Main",
  "name": "Perona",
  "text": "By now, you must be aware of how terrible these ghosts are!"
 },
 {
  "i": 136,
  "style": "Main",
  "name": "Perona",
  "text": "Thanks to the Hollow Fruit I'm a ghost woman, capable of creating ghosts at will!"
 },
 {
  "i": 137,
  "style": "Main",
  "name": "Perona",
  "text": "These ghosts are branches of myself."
 },
 {
  "i": 138,
  "style": "Main",
  "name": "Perona",
  "text": "They empty people's hearts."
 },
 {
  "i": 139,
  "style": "Main",
  "name": "Perona",
  "text": "This is it for you all!"
 },
 {
  "i": 140,
  "style": "Main",
  "name": "Sanji",
  "text": "I can't believe those troublesome ghosts are being controlled by that cutie-chan!"
 },
 {
  "i": 141,
  "style": "Main",
  "name": "Usopp",
  "text": "No time for that!"
 },
 {
  "i": 142,
  "style": "Main",
  "name": "Usopp",
  "text": "If we get hit by those things, we'll be done for sure!"
 },
 {
  "i": 143,
  "style": "Main",
  "name": "Franky",
  "text": "There's no choice but to run!"
 },
 {
  "i": 144,
  "style": "Main",
  "name": "Zoro",
  "text": "They're certainly dangerous!"
 },
 {
  "i": 145,
  "style": "Main",
  "name": "Perona",
  "text": "{\\fad(150,150)}Negative Hollow!"
 },
 {
  "i": 146,
  "style": "Main",
  "name": "Sanji",
  "text": "My existence is worth less than a maggot's..."
 },
 {
  "i": 147,
  "style": "Main",
  "name": "Franky",
  "text": "You're right..."
 },
 {
  "i": 148,
  "style": "Main",
  "name": "Franky",
  "text": "I wish I were born a stray dog..."
 },
 {
  "i": 149,
  "style": "Main",
  "name": "Zoro",
  "text": "I don't deserve to walk on the same ground as all of you..."
 },
 {
  "i": 150,
  "style": "Main",
  "name": "Usopp",
  "text": "It's all... over..."
 },
 {
  "i": 151,
  "style": "Main",
  "name": "Perona",
  "text": "Seize them."
 },
 {
  "i": 152,
  "style": "Main",
  "name": "Perona",
  "text": "How simple."
 },
 {
  "i": 153,
  "style": "Main",
  "name": "Perona",
  "text": "Only the ones above remain."
 },
 {
  "i": 154,
  "style": "Main",
  "name": "Usopp",
  "text": "{{\\fad(150,150)}Riot Shot: Salt Star!"
 },
 {
  "i": 155,
  "style": "Main",
  "name": "Perona",
  "text": "Who is it?!"
 },
 {
  "i": 156,
  "style": "Main",
  "name": "Usopp",
  "text": "I won't let you..."
 },
 {
  "i": 157,
  "style": "Main",
  "name": "Usopp",
  "text": "Lay a hand on my crew!"
 },
 {
  "i": 158,
  "style": "Main",
  "name": "Perona",
  "text": "Damn!"
 },
 {
  "i": 159,
  "style": "Main",
  "name": "Perona",
  "text": "So he just pretended he was hit?"
 },
 {
  "i": 160,
  "style": "Main",
  "name": "Perona",
  "text": "{{\\fad(150,150)}Negative Hollow!"
 },
 {
  "i": 161,
  "style": "Main",
  "name": "Perona",
  "text": "What?!"
 },
 {
  "i": 162,
  "style": "Main",
  "name": "Usopp",
  "text": "My name is..."
 },
 {
  "i": 163,
  "style": "Main",
  "name": "Usopp",
  "text": "Captain Usopp."
 },
 {
  "i": 164,
  "style": "Main",
  "name": "Perona",
  "text": "Why?!"
 },
 {
  "i": 165,
  "style": "Main",
  "name": "Perona",
  "text": "Why isn't it affecting you?!"
 },
 {
  "i": 166,
  "style": "Main",
  "name": "Perona",
  "text": "The ghost hit you!"
 },
 {
  "i": 167,
  "style": "Main",
  "name": "Perona",
  "text": "What kind of trick did you use?!"
 },
 {
  "i": 168,
  "style": "Main",
  "name": "Usopp",
  "text": "It is no trick..."
 },
 {
  "i": 169,
  "style": "Main",
  "name": "Usopp",
  "text": "I've always been...!"
 },
 {
  "i": 170,
  "style": "Main",
  "name": "Usopp",
  "text": "Negative!"
 },
 {
  "i": 171,
  "style": "Main",
  "name": "Zombie",
  "text": "He's immune to the ghost's negative power!"
 },
 {
  "i": 172,
  "style": "Main",
  "name": "Zombie",
  "text": "What an incredible man!"
 },
 {
  "i": 173,
  "style": "Thoughts",
  "name": "Perona",
  "text": "That's not possible..."
 },
 {
  "i": 174,
  "style": "Thoughts",
  "name": "Perona",
  "text": "There's no way a man immune to the negative hollow can exist!"
 },
 {
  "i": 175,
  "style": "Thoughts",
  "name": "Perona",
  "text": "People cling to life."
 },
 {
  "i": 176,
  "style": "Thoughts",
  "name": "Perona",
  "text": "That fact alone allows them to keep moving forward, and yet..."
 },
 {
  "i": 177,
  "style": "Thoughts",
  "name": "Perona",
  "text": "And yet... this man..."
 },
 {
  "i": 178,
  "style": "Main",
  "name": "All",
  "text": "{\\i1}Do your best!"
 },
 {
  "i": 179,
  "style": "Main",
  "name": "Note",
  "text": "{\\move(246,106,698,432,8,1093)}Do your best!!"
 },
 {
  "i": 180,
  "style": "Main",
  "name": "Note",
  "text": "{\\move(1074,128,1078,486,6,1674)}Fight!!"
 },
 {
  "i": 181,
  "style": "Main",
  "name": "Note",
  "text": "{\\move(56,494,440,567,8,1051)}Live!!!"
 },
 {
  "i": 182,
  "style": "Main",
  "name": "Usopp",
  "text": "Don't cheer me now!"
 },
 {
  "i": 183,
  "style": "Secondary",
  "name": "All",
  "text": "{\\i1}Do your best!"
 },
 {
  "i": 184,
  "style": "Main",
  "name": "Usopp",
  "text": "Come on, snap out of it already!"
 },
 {
  "i": 185,
  "style": "Main",
  "name": "Usopp",
  "text": "Let's hurry and go rescue Nami and Brook!"
 },
 {
  "i": 186,
  "style": "Main",
  "name": "Usopp",
  "text": "You can't..."
 },
 {
  "i": 187,
  "style": "Main",
  "name": "Usopp",
  "text": "You can't expect to beat her with your inferior abilities."
 },
 {
  "i": 188,
  "style": "Main",
  "name": "Usopp",
  "text": "I'll take care of her!"
 },
 {
  "i": 189,
  "style": "Main",
  "name": "Sanji",
  "text": "What's this reliant sensation...?"
 },
 {
  "i": 190,
  "style": "Main",
  "name": "Zoro",
  "text": "He wasn't affected...?"
 },
 {
  "i": 191,
  "style": "Main",
  "name": "Perona",
  "text": "Curse you!"
 },
 {
  "i": 192,
  "style": "Main",
  "name": "Usopp",
  "text": "But... take care of the zombies around her!"
 },
 {
  "i": 193,
  "style": "Main",
  "name": "Usopp",
  "text": "God knows I can't beat them! I'd certainly die-"
 },
 {
  "i": 194,
  "style": "Main",
  "name": "Sanji",
  "text": "We'll leave it all to you!"
 },
 {
  "i": 195,
  "style": "Main",
  "name": "Usopp",
  "text": "What? Ah!"
 },
 {
  "i": 196,
  "style": "Main",
  "name": "Usopp",
  "text": "No-!"
 },
 {
  "i": 197,
  "style": "Main",
  "name": "Usopp",
  "text": "That's not-!"
 },
 {
  "i": 198,
  "style": "Main",
  "name": "Usopp",
  "text": "Wait a-!"
 },
 {
  "i": 199,
  "style": "Main",
  "name": "Usopp",
  "text": "I didn't-! I was-!"
 },
 {
  "i": 200,
  "style": "Main",
  "name": "Usopp",
  "text": "Wait a minute!"
 },
 {
  "i": 201,
  "style": "Main",
  "name": "Usopp",
  "text": "Wait!"
 },
 {
  "i": 202,
  "style": "Main",
  "name": "Zombie",
  "text": "Groom Absalom..."
 },
 {
  "i": 203,
  "style": "Main",
  "name": "Zombie",
  "text": "Do you take Nami as your wife, in sickness and health, to love and to cherish until death do you part?"
 },
 {
  "i": 204,
  "style": "Main",
  "name": "Absalom",
  "text": "I do!"
 },
 {
  "i": 205,
  "style": "Main",
  "name": "Zombie",
  "text": "And, Bride Nami..."
 },
 {
  "i": 206,
  "style": "Main",
  "name": "Zombie",
  "text": "Do you vow to love Absalom for all eternity?"
 },
 {
  "i": 207,
  "style": "Main",
  "name": "Zombie",
  "text": "Yes! I sure do!"
 },
 {
  "i": 208,
  "style": "Main",
  "name": "Zombie",
  "text": "I really love Ab-sama!"
 },
 {
  "i": 209,
  "style": "Main",
  "name": "Zombie",
  "text": "You may kiss the bride now."
 },
 {
  "i": 210,
  "style": "Main",
  "name": "Perona",
  "text": "No matter how you look at it, it's still impossible!"
 },
 {
  "i": 211,
  "style": "Main",
  "name": "Perona",
  "text": "With this simultaneous attack, you'll lose your will to live for good!"
 },
 {
  "i": 212,
  "style": "Main",
  "name": "Perona",
  "text": "{{\\fad(150,150)}Fourfold Negative Attack..."
 },
 {
  "i": 213,
  "style": "Main",
  "name": "Perona",
  "text": "{{\\fad(150,150)}Negative Hollows!"
 },
 {
  "i": 214,
  "style": "Main",
  "name": "Wild Zombie",
  "text": "They got him!"
 },
 {
  "i": 215,
  "style": "Main",
  "name": "Wild Zombie",
  "text": "The four of them completely passed through him!"
 },
 {
  "i": 216,
  "style": "Main",
  "name": "Wild Zombie",
  "text": "Ever since the creation of Thriller Bark..."
 },
 {
  "i": 217,
  "style": "Main",
  "name": "Wild Zombie",
  "text": "There hasn't been anyone immune to the ghosts' depressing pow-"
 },
 {
  "i": 218,
  "style": "Main",
  "name": "Wild Zombie",
  "text": "The negative ghosts...!"
 },
 {
  "i": 219,
  "style": "Main",
  "name": "Wild Zombie",
  "text": "Have gone negative!"
 },
 {
  "i": 220,
  "style": "Main",
  "name": "Perona",
  "text": "Kumashi, sorry for everything..."
 },
 {
  "i": 221,
  "style": "Main",
  "name": "Wild Zombie",
  "text": "Even Perona-sama was affected!"
 },
 {
  "i": 222,
  "style": "Main",
  "name": "Wild Zombie",
  "text": "Is that guy a holy man?!"
 },
 {
  "i": 223,
  "style": "Main",
  "name": "Wild Zombie",
  "text": "He's a holy man, isn't he?!"
 },
 {
  "i": 224,
  "style": "Main",
  "name": "Usopp",
  "text": "Listen well, all of you..."
 },
 {
  "i": 225,
  "style": "Main",
  "name": "Usopp",
  "text": "When it comes to thinking negative..."
 },
 {
  "i": 226,
  "style": "Main",
  "name": "Usopp",
  "text": "There's no one who can surpass me!"
 },
 {
  "i": 227,
  "style": "Main",
  "name": "Wild Zombie",
  "text": "Such confidence in something so useless!"
 },
 {
  "i": 228,
  "style": "Captions",
  "name": "Sign",
  "text": "{\\fad(280,0)}Perona's Wonder Garden"
 },
 {
  "i": 229,
  "style": "Main",
  "name": "Zoro",
  "text": "Who'd have thought Usopp's negativity would be useful in such a place."
 },
 {
  "i": 230,
  "style": "Main",
  "name": "Franky",
  "text": "If he hadn't been there, we'd be dead by now."
 },
 {
  "i": 231,
  "style": "Main",
  "name": "Zoro",
  "text": "What a terrifying ability he has."
 },
 {
  "i": 232,
  "style": "Main",
  "name": "Sanji",
  "text": "I'll leave you here and head to where Nami-san is."
 },
 {
  "i": 233,
  "style": "Main",
  "name": "Franky",
  "text": "Got it!"
 },
 {
  "i": 234,
  "style": "Main",
  "name": "Franky",
  "text": "Give it all you got!"
 },
 {
  "i": 235,
  "style": "Main",
  "name": "Sanji",
  "text": "Of course!"
 },
 {
  "i": 236,
  "style": "Main",
  "name": "Sanji",
  "text": "I'm the will-o'-wisp of love!"
 },
 {
  "i": 237,
  "style": "Main",
  "name": "Sanji",
  "text": "Nami-swan!"
 },
 {
  "i": 238,
  "style": "Main",
  "name": "Sanji",
  "text": "You won't be someone else's bride!"
 },
 {
  "i": 239,
  "style": "Main",
  "name": "Zoro",
  "text": "He jumped..."
 },
 {
  "i": 240,
  "style": "Main",
  "name": "Zoro",
  "text": "Is he even aware of how high we are?"
 },
 {
  "i": 241,
  "style": "Main",
  "name": "Franky",
  "text": "Well..."
 },
 {
  "i": 242,
  "style": "Main",
  "name": "Franky",
  "text": "The more your tension rises, the less pain you feel."
 },
 {
  "i": 243,
  "style": "Main",
  "name": "Franky",
  "text": "Anyway, we're heading to the top floor of that mansion!"
 },
 {
  "i": 244,
  "style": "Main",
  "name": "Zoro",
  "text": "Alright!"
 },
 {
  "i": 245,
  "style": "Main",
  "name": "Franky",
  "text": "The skeleton must be there!"
 },
 {
  "i": 246,
  "style": "Main",
  "name": "Ryuma",
  "text": "Just like the phoenix..."
 },
 {
  "i": 247,
  "style": "Main",
  "name": "Ryuma",
  "text": "Then again, more like a zombie."
 },
 {
  "i": 248,
  "style": "Main",
  "name": "Ryuma",
  "text": "You shouldn't be able to stand anymore."
 },
 {
  "i": 249,
  "style": "Main",
  "name": "Ryuma",
  "text": "It is time I stop your movements for good."
 },
 {
  "i": 250,
  "style": "Main",
  "name": "Ryuma",
  "text": "So you never show up again to reclaim your shadow."
 },
 {
  "i": 251,
  "style": "Main",
  "name": "Ryuma",
  "text": "Would you like me to finish you off with my special \"Arrow Notch Slash\"?"
 },
 {
  "i": 252,
  "style": "Main",
  "name": "Brook",
  "text": "You know nothing."
 },
 {
  "i": 253,
  "style": "Main",
  "name": "Brook",
  "text": "Don't use that name!"
 },
 {
  "i": 254,
  "style": "Main",
  "name": "Brook",
  "text": "The name of the quick slash technique..."
 },
 {
  "i": 255,
  "style": "Main",
  "name": "Brook",
  "text": "from the Surprise Attack Squad of the kingdom I came from is..."
 },
 {
  "i": 256,
  "style": "Note",
  "name": "Brook",
  "text": "Requiem: Type of song sung during funerals\\NBanderole: Horizontal fencing attack or banner"
 },
 {
  "i": 257,
  "style": "Main",
  "name": "Brook",
  "text": "Requiem la Banderole."
 },
 {
  "i": 258,
  "style": "Main",
  "name": "Brook",
  "text": "And the alias my comrades gave to that sword technique, which they praised so much is..."
 },
 {
  "i": 259,
  "style": "Main",
  "name": "Brook",
  "text": "Three-Pace Hum: Notch Slash!"
 },
 {
  "i": 260,
  "style": "Main",
  "name": "Brook",
  "text": "Although you have my personality and skills, you've lost my memories and humanity."
 },
 {
  "i": 261,
  "style": "Main",
  "name": "Brook",
  "text": "So you have no right to use that name!"
 },
 {
  "i": 262,
  "style": "Main",
  "name": "Ryuma",
  "text": "If you're the real one as you imply..."
 },
 {
  "i": 263,
  "style": "Main",
  "name": "Ryuma",
  "text": "Then try to overcome my fake sword skills!"
 },
 {
  "i": 264,
  "style": "Main",
  "name": "Ryuma",
  "text": "This is your last chance..."
 },
 {
  "i": 265,
  "style": "Main",
  "name": "Both",
  "text": "{\\fad(150,150)}Three-Pace Hum..."
 },
 {
  "i": 266,
  "style": "Main",
  "name": "Ryuma",
  "text": "{\\fad(150,150)}Notch Slash!"
 },
 {
  "i": 267,
  "style": "Thoughts",
  "name": "Brook",
  "text": "Laboon!"
 },
 {
  "i": 268,
  "style": "Thoughts",
  "name": "Brook",
  "text": "More than anything, I'd like to apologize to you..."
 },
 {
  "i": 269,
  "style": "Thoughts",
  "name": "Brook",
  "text": "It has been fifty long years in this dark sea..."
 },
 {
  "i": 270,
  "style": "Thoughts",
  "name": "Brook",
  "text": "And yet..."
 },
 {
  "i": 271,
  "style": "Thoughts",
  "name": "Brook",
  "text": "There was no point in staying alive after all..."
 },
 {
  "i": 272,
  "style": "Thoughts",
  "name": "Brook",
  "text": "So lonely..."
 },
 {
  "i": 273,
  "style": "Thoughts",
  "name": "Brook",
  "text": "My life has been..."
 },
 {
  "i": 274,
  "style": "Thoughts",
  "name": "Brook",
  "text": "So lonely..."
 },
 {
  "i": 275,
  "style": "Main",
  "name": "Ryuma",
  "text": "First..."
 },
 {
  "i": 276,
  "style": "Main",
  "name": "Ryuma",
  "text": "Obviously, I'll get rid of that afro."
 },
 {
  "i": 277,
  "style": "Main",
  "name": "Ryuma",
  "text": "What?!"
 },
 {
  "i": 278,
  "style": "Main",
  "name": "Ryuma",
  "text": "The mansion is shaking...!"
 },
 {
  "i": 279,
  "style": "Main",
  "name": "Franky",
  "text": "Hey! What's with this shaking?!"
 },
 {
  "i": 280,
  "style": "Main",
  "name": "Zoro",
  "text": "Who knows..."
 },
 {
  "i": 281,
  "style": "Main",
  "name": "Zoro",
  "text": "Maybe an earthquake?"
 },
 {
  "i": 282,
  "style": "Main",
  "name": "Franky",
  "text": "Is this the laboratory?!"
 },
 {
  "i": 283,
  "style": "Main",
  "name": "Franky",
  "text": "Found him!"
 },
 {
  "i": 284,
  "style": "Main",
  "name": "Franky",
  "text": "Hey! Skeleton!"
 },
 {
  "i": 285,
  "style": "Main",
  "name": "Franky",
  "text": "You've been beaten up pretty badly."
 },
 {
  "i": 286,
  "style": "Main",
  "name": "Franky",
  "text": "Are you still in this world?!"
 },
 {
  "i": 287,
  "style": "Main",
  "name": "Franky",
  "text": "Are you alive?!"
 },
 {
  "i": 288,
  "style": "Main",
  "name": "Brooke",
  "text": "Y-You..."
 },
 {
  "i": 289,
  "style": "Main",
  "name": "Brooke",
  "text": "Why are you here...?"
 },
 {
  "i": 290,
  "style": "Main",
  "name": "Ryuuma",
  "text": "Pathetic..."
 },
 {
  "i": 291,
  "style": "Main",
  "name": "Ryuuma",
  "text": "Pitying the loser after his defeat!"
 },
 {
  "i": 292,
  "style": "Main",
  "name": "Zoro",
  "text": "Hold on a second!"
 },
 {
  "i": 293,
  "style": "Main",
  "name": "Zoro",
  "text": "Are you..."
 },
 {
  "i": 294,
  "style": "Main",
  "name": "Zoro",
  "text": "The legendary samurai who is rumored to have sliced a dragon long ago?"
 },
 {
  "i": 295,
  "style": "Main",
  "name": "Zoro",
  "text": "I wanted to meet you."
 },
 {
  "i": 296,
  "style": "Main",
  "name": "",
  "text": "Kiss! Kiss! Kiss! Kiss!"
 },
 {
  "i": 297,
  "style": "Main",
  "name": "Absalom",
  "text": "Hey! Wait a minute!"
 },
 {
  "i": 298,
  "style": "Main",
  "name": "Absalom",
  "text": "What's this shaking?!"
 },
 {
  "i": 299,
  "style": "Main",
  "name": "Absalom",
  "text": "I can't kiss my bride!{\\fs30 I'm pretty sure that Absalom says the word Shikai ( eternity or something) probably related to the wedding-kiss, I didn't hear the word hanayome (bride) check please}"
 },
 {
  "i": 300,
  "style": "Main",
  "name": "Zombie General",
  "text": "Absalom-sama!"
 },
 {
  "i": 301,
  "style": "Main",
  "name": "Absalom",
  "text": "What?!"
 },
 {
  "i": 302,
  "style": "Main",
  "name": "Absalom",
  "text": "Did you find anything?!"
 },
 {
  "i": 303,
  "style": "Main",
  "name": "Zombie general",
  "text": "This giant ship, Thriller Bark, is being sucked into a weird current!"
 },
 {
  "i": 304,
  "style": "Main",
  "name": "Zombie general",
  "text": "The whole island is shaking!"
 },
 {
  "i": 305,
  "style": "Main",
  "name": "Absalom",
  "text": "How did this happen?!"
 },
 {
  "i": 306,
  "style": "Main",
  "name": "Zombie general",
  "text": "It seems like... the Special Zombie is messing with the rudder."
 },
 {
  "i": 307,
  "style": "Main",
  "name": "Absalom",
  "text": "What?!"
 },
 {
  "i": 308,
  "style": "Main",
  "name": "Oars",
  "text": "It's moving! Moving!"
 },
 {
  "i": 309,
  "style": "Main",
  "name": "Absalom",
  "text": "General Zombies!"
 },
 {
  "i": 310,
  "style": "Main",
  "name": "Absalom",
  "text": "Set out immediately!"
 },
 {
  "i": 311,
  "style": "Main",
  "name": "Absalom",
  "text": "Stop Oars!"
 },
 {
  "i": 312,
  "style": "Main",
  "name": "",
  "text": "{\\i1}Roger!"
 },
 {
  "i": 313,
  "style": "Main",
  "name": "Zombie general",
  "text": "Oars!"
 },
 {
  "i": 314,
  "style": "Main",
  "name": "Zombie general",
  "text": "That's as far as you go, Special Zombie Oars."
 },
 {
  "i": 315,
  "style": "Main",
  "name": "Zombie general",
  "text": "Start cutting at his legs!"
 },
 {
  "i": 316,
  "style": "Main",
  "name": "Zombie general",
  "text": "Where's Oars?"
 },
 {
  "i": 317,
  "style": "Main",
  "name": "Zombie general",
  "text": "He's gone."
 },
 {
  "i": 318,
  "style": "Main",
  "name": "Zombie general",
  "text": "Being so huge..."
 },
 {
  "i": 319,
  "style": "Main",
  "name": "Zombie general",
  "text": "How can he move so swiftly?"
 },
 {
  "i": 320,
  "style": "Main",
  "name": "Zombie general",
  "text": "Found him!"
 },
 {
  "i": 321,
  "style": "Main",
  "name": "Zombie general",
  "text": "Above!"
 },
 {
  "i": 322,
  "style": "Main",
  "name": "Oars",
  "text": "{\\fad(150,150)}Rubber..."
 },
 {
  "i": 323,
  "style": "Main",
  "name": "Oars",
  "text": "{\\fad(150,150)}(Even though I'm not rubber...)"
 },
 {
  "i": 324,
  "style": "Main",
  "name": "Oars",
  "text": "{\\fad(150,150)}Gatling!"
 },
 {
  "i": 325,
  "style": "Main",
  "name": "Oars",
  "text": "Don't interfere with my adventure!"
 },
 {
  "i": 326,
  "style": "Main",
  "name": "Absalom",
  "text": "Annihilated?!"
 },
 {
  "i": 327,
  "style": "Main",
  "name": "Absalom",
  "text": "The ones who came from here?!"
 },
 {
  "i": 328,
  "style": "Main",
  "name": "Zombie",
  "text": "Y-Yes..."
 },
 {
  "i": 329,
  "style": "Main",
  "name": "Zombie",
  "text": "Everyone was crushed..."
 },
 {
  "i": 330,
  "style": "Main",
  "name": "Absalom",
  "text": "They're the ultimate Zombie Army of this island!"
 },
 {
  "i": 331,
  "style": "Main",
  "name": "Absalom",
  "text": "They're the General Zombies!"
 },
 {
  "i": 332,
  "style": "Main",
  "name": "Zombie",
  "text": "Yes, in a blink of an eye..."
 },
 {
  "i": 333,
  "style": "Main",
  "name": "Absalom",
  "text": "Impossible..."
 },
 {
  "i": 334,
  "style": "Main",
  "name": "Absalom",
