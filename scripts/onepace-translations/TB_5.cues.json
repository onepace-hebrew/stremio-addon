[
 {
  "i": 0,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}Let's travel all through the worldwide seas,"
 },
 {
  "i": 1,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 2,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 3,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 4,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "We were able to escape from the set course"
 },
 {
  "i": 5,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "along the boundary between sky and sea."
 },
 {
  "i": 6,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now we're rowing our way"
 },
 {
  "i": 7,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "to a hidden adventure at the dark bottom of the sea."
 },
 {
  "i": 8,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Doesn't it sound fun just thinking about it?"
 },
 {
  "i": 9,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Let's travel all through the worldwide seas,"
 },
 {
  "i": 10,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 11,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 12,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 13,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}That feeling we had when we set sail"
 },
 {
  "i": 14,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "is something I'll never forget."
 },
 {
  "i": 15,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Because of that"
 },
 {
  "i": 16,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "nothing will be able to scare me..."
 },
 {
  "i": 17,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now, as the trip approaches, our racing heartbeats"
 },
 {
  "i": 18,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "engrave a rhythm of adventure in our shy hearts."
 },
 {
  "i": 19,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}Get all the treasures"
 },
 {
  "i": 20,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 21,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 22,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(50,50)}making a splash..."
 },
 {
  "i": 23,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Fill your empty heart with dreams."
 },
 {
  "i": 24,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Spread your wings."
 },
 {
  "i": 25,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you color your heart with the blowing wind"
 },
 {
  "i": 26,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "you will move on."
 },
 {
  "i": 27,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Get all the treasures"
 },
 {
  "i": 28,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 29,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 30,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "making a splash..."
 },
 {
  "i": 31,
  "style": "Title",
  "name": "",
  "text": "{\\fad(1800,2000)}Perona's Wonder Garden and\\Nthe Charge of the General Zombies!"
 },
 {
  "i": 32,
  "style": "Main",
  "name": "Absalom",
  "text": "No matter where they try to run, track them down and drag them here!"
 },
 {
  "i": 33,
  "style": "Main",
  "name": "Absalom",
  "text": "No one can match the Zombie Generals!"
 },
 {
  "i": 34,
  "style": "Main",
  "name": "Absalom",
  "text": "Hey, stop wasting time, Captain John."
 },
 {
  "i": 35,
  "style": "Main",
  "name": "Absalom",
  "text": "You're really not living up to your lifetime's infamous reputation."
 },
 {
  "i": 36,
  "style": "Main",
  "name": "John",
  "text": "Okay, okay. I'm going."
 },
 {
  "i": 37,
  "style": "Main",
  "name": "Absalom",
  "text": "Geez... he never changes..."
 },
 {
  "i": 38,
  "style": "Main",
  "name": "Lola",
  "text": "Ab-sama..."
 },
 {
  "i": 39,
  "style": "Main",
  "name": "Lola",
  "text": "Marry me!"
 },
 {
  "i": 40,
  "style": "Main",
  "name": "Absalom",
  "text": "Lola!"
 },
 {
  "i": 41,
  "style": "Main",
  "name": "Absalom",
  "text": "You...! Go and fight this instant!"
 },
 {
  "i": 42,
  "style": "Main",
  "name": "Absalom",
  "text": "I'm your commander here!"
 },
 {
  "i": 43,
  "style": "Main",
  "name": "Lola",
  "text": "Then, marry me."
 },
 {
  "i": 44,
  "style": "Main",
  "name": "Absalom",
  "text": "Why would I?!"
 },
 {
  "i": 45,
  "style": "Main",
  "name": "Absalom",
  "text": "Lola... what're you...?!"
 },
 {
  "i": 46,
  "style": "Main",
  "name": "Absalom",
  "text": "Aren't you gonna listen to the Grave Ab-sama orders?!"
 },
 {
  "i": 47,
  "style": "Main",
  "name": "Lola",
  "text": "Then, marry me!"
 },
 {
  "i": 48,
  "style": "Main",
  "name": "Absalom",
  "text": "Stop joking!"
 },
 {
  "i": 49,
  "style": "Main",
  "name": "Absalom",
  "text": "I'm a human!"
 },
 {
  "i": 50,
  "style": "Main",
  "name": "Absalom",
  "text": "I need to have a human bride!"
 },
 {
  "i": 51,
  "style": "Main",
  "name": "Absalom",
  "text": "Hey, Lola... think about it."
 },
 {
  "i": 52,
  "style": "Main",
  "name": "Absalom",
  "text": "You're a female warthog zombie."
 },
 {
  "i": 53,
  "style": "Main",
  "name": "Absalom",
  "text": "You're dead and rotting!"
 },
 {
  "i": 54,
  "style": "Main",
  "name": "Absalom",
  "text": "Stop it!"
 },
 {
  "i": 55,
  "style": "Main",
  "name": "Absalom",
  "text": "Hey, what a terrifying method!"
 },
 {
  "i": 56,
  "style": "Main",
  "name": "Absalom",
  "text": "Isn't that a marriage certificate?!"
 },
 {
  "i": 57,
  "style": "Main",
  "name": "Absalom",
  "text": "To think you're forcing me to marry you!"
 },
 {
  "i": 58,
  "style": "Main",
  "name": "Lola",
  "text": "I can't resist that wild muzzle of yours."
 },
 {
  "i": 59,
  "style": "Main",
  "name": "Lola",
  "text": "Absalom, give me your finger."
 },
 {
  "i": 60,
  "style": "Main",
  "name": "Lola",
  "text": "I love you!"
 },
 {
  "i": 61,
  "style": "Main",
  "name": "Absalom",
  "text": "Don't mess around!"
 },
 {
  "i": 62,
  "style": "Main",
  "name": "Absalom",
  "text": "I don't wanna spend my days being haunted by a dead animal!"
 },
 {
  "i": 63,
  "style": "Main",
  "name": "Lola",
  "text": "{\\fad(150,150)}Bridal Arts..."
 },
 {
  "i": 64,
  "style": "Main",
  "name": "Lola",
  "text": "{\\fad(150,150)}Oath Kiss!"
 },
 {
  "i": 65,
  "style": "Main",
  "name": "Absalom",
  "text": "Wait, Lola!"
 },
 {
  "i": 66,
  "style": "Main",
  "name": "Absalom",
  "text": "Listen carefully."
 },
 {
  "i": 67,
  "style": "Main",
  "name": "Absalom",
  "text": "I've already..."
 },
 {
  "i": 68,
  "style": "Main",
  "name": "Absalom",
  "text": "I've already chosen the woman who'll be my bride!"
 },
 {
  "i": 69,
  "style": "Main",
  "name": "Absalom",
  "text": "She certainly has a strong temper, but she's a weak, flesh and blood woman in the end!"
 },
 {
  "i": 70,
  "style": "Main",
  "name": "Lola",
  "text": "You'll fail again anyways."
 },
 {
  "i": 71,
  "style": "Main",
  "name": "Absalom",
  "text": "Idiot, look!"
 },
 {
  "i": 72,
  "style": "Main",
  "name": "Absalom",
  "text": "She's one of the pirates who landed on this island, perfectly suited to become this handsome man's bride."
 },
 {
  "i": 73,
  "style": "Main",
  "name": "Lola",
  "text": "I won't let it happen!"
 },
 {
  "i": 74,
  "style": "Main",
  "name": "Lola",
  "text": "That woman..."
 },
 {
  "i": 75,
  "style": "Main",
  "name": "Lola",
  "text": "I'll get rid of her!"
 },
 {
  "i": 76,
  "style": "Main",
  "name": "Absalom",
  "text": "Wait!"
 },
 {
  "i": 77,
  "style": "Main",
  "name": "Absalom",
  "text": "Lola!"
 },
 {
  "i": 78,
  "style": "Main",
  "name": "Perona",
  "text": "Hey, Kumashi!"
 },
 {
  "i": 79,
  "style": "Main",
  "name": "Perona",
  "text": "Kumashi!"
 },
 {
  "i": 80,
  "style": "Main",
  "name": "Perona",
  "text": "The Risky Brothers are bringing a coffin here."
 },
 {
  "i": 81,
  "style": "Main",
  "name": "Perona",
  "text": "When you receive it, send it to the master's Dance Hall!"
 },
 {
  "i": 82,
  "style": "Main",
  "name": "Perona",
  "text": "Is that clear?"
 },
 {
  "i": 83,
  "style": "Main",
  "name": "Perona",
  "text": "Is that clear or not?!"
 },
 {
  "i": 84,
  "style": "Main",
  "name": "Kumashi",
  "text": "Yes..."
 },
 {
  "i": 85,
  "style": "Main",
  "name": "Perona",
  "text": "Don't answer, it's not cute!"
 },
 {
  "i": 86,
  "style": "Main",
  "name": "Perona",
  "text": "From now on, I'll be commanding the treasure collecting group toward the ship."
 },
 {
  "i": 87,
  "style": "Main",
  "name": "Perona",
  "text": "If anything happens, come and tell me, got it?"
 },
 {
  "i": 88,
  "style": "Main",
  "name": "Perona",
  "text": "That's it, when you don't say anything, you're so cute!"
 },
 {
  "i": 89,
  "style": "Main",
  "name": "Kumashi",
  "text": "H-Have a nice trip..."
 },
 {
  "i": 90,
  "style": "Main",
  "name": "Perona",
  "text": "You! You talked just now!"
 },
 {
  "i": 91,
  "style": "Main",
  "name": "Squirrel",
  "text": "Take it there! Take it there! To the master's lair!"
 },
 {
  "i": 92,
  "style": "Main",
  "name": "Squirrel",
  "text": "Oh no! We dropped it!"
 },
 {
  "i": 93,
  "style": "Main",
  "name": "Squirrel",
  "text": "Oh no! We broke it!"
 },
 {
  "i": 94,
  "style": "Main",
  "name": "Squirrel",
  "text": "The delivery for our master!"
 },
 {
  "i": 95,
  "style": "Main",
  "name": "Squirrel",
  "text": "The coffin opened up!"
 },
 {
  "i": 96,
  "style": "Main",
  "name": "Chopper",
  "text": "Where am I?"
 },
 {
  "i": 97,
  "style": "Main",
  "name": "Squirrel",
  "text": "He's awake!"
 },
 {
  "i": 98,
  "style": "Main",
  "name": "Squirrel",
  "text": "Damn it!"
 },
 {
  "i": 99,
  "style": "Main",
  "name": "Squirrel",
  "text": "Hurry and hit him! Beat him to death!"
 },
 {
  "i": 100,
  "style": "Main",
  "name": "Squirrel",
  "text": "Killing is bad!"
 },
 {
  "i": 101,
  "style": "Main",
  "name": "Squirrel",
  "text": "Then, half-kill!"
 },
 {
  "i": 102,
  "style": "Main",
  "name": "Squirrel",
  "text": "Half-kill!"
 },
 {
  "i": 103,
  "style": "Main",
  "name": "Chopper",
  "text": "Usopp!"
 },
 {
  "i": 104,
  "style": "Main",
  "name": "Chopper",
  "text": "Nami!"
 },
 {
  "i": 105,
  "style": "Main",
  "name": "Chopper",
  "text": "Hey, hang in there!"
 },
 {
  "i": 106,
  "style": "Main",
  "name": "Chopper",
  "text": "Wake up!"
 },
 {
  "i": 107,
  "style": "Main",
  "name": "Usopp",
  "text": "The samurai... certainly..."
 },
 {
  "i": 108,
  "style": "Main",
  "name": "Usopp",
  "text": "Did he strike us with the back of the blade?"
 },
 {
  "i": 109,
  "style": "Main",
  "name": "Nami",
  "text": "It seems it was raining here."
 },
 {
  "i": 110,
  "style": "Main",
  "name": "Nami",
  "text": "The ground is a little wet."
 },
 {
  "i": 111,
  "style": "Main",
  "name": "Nami",
  "text": "Where are we?"
 },
 {
  "i": 112,
  "style": "Main",
  "name": "Chopper",
  "text": "I don't know, but..."
 },
 {
  "i": 113,
  "style": "Main",
  "name": "Chopper",
  "text": "Just now those squirrels were carrying us to be delivered in that coffin."
 },
 {
  "i": 114,
  "style": "Main",
  "name": "Usopp",
  "text": "Isn't this an iron coffin?!"
 },
 {
  "i": 115,
  "style": "Main",
  "name": "Squirrel",
  "text": "Oh no, those three are awake!"
 },
 {
  "i": 116,
  "style": "Main",
  "name": "Squirrel",
  "text": "This is bad. Call our comrades!"
 },
 {
  "i": 117,
  "style": "Main",
  "name": "Nami",
  "text": "It looks like... we're currently behind the mansion."
 },
 {
  "i": 118,
  "style": "Main",
  "name": "Nami",
  "text": "Hogback's laboratory was on the top floor."
 },
 {
  "i": 119,
  "style": "Main",
  "name": "Nami",
  "text": "They've already carried us a long way it seems."
 },
 {
  "i": 120,
  "style": "Main",
  "name": "Chopper",
  "text": "Hey, look behind you!"
 },
 {
  "i": 121,
  "style": "Main",
  "name": "Chopper",
  "text": "There's a sturdy building on the opposite side!"
 },
 {
  "i": 122,
  "style": "Main",
  "name": "Usopp",
  "text": "What's that?"
 },
 {
  "i": 123,
  "style": "Main",
  "name": "Usopp",
  "text": "There was such a huge building behind the mansion all this time?"
 },
 {
  "i": 124,
  "style": "Main",
  "name": "Nami",
  "text": "I've figured out where we are!"
 },
 {
  "i": 125,
  "style": "Main",
  "name": "Usopp",
  "text": "What is it?"
 },
 {
  "i": 126,
  "style": "Main",
  "name": "Usopp",
  "text": "What do you mean?"
 },
 {
  "i": 127,
  "style": "Main",
  "name": "Nami",
  "text": "We're on the passage that connects the mansion to that huge building."
 },
 {
  "i": 128,
  "style": "Main",
  "name": "Usopp",
  "text": "Passage?"
 },
 {
  "i": 129,
  "style": "Main",
  "name": "Usopp",
  "text": "It's so wide, almost like a forest."
 },
 {
  "i": 130,
  "style": "Main",
  "name": "Usopp",
  "text": "Even if it's been made a forest, they were carrying our coffin here while we were unconscious."
 },
 {
  "i": 131,
  "style": "Main",
  "name": "Usopp",
  "text": "That means, they had to have been carrying us to that building."
 },
 {
  "i": 132,
  "style": "Main",
  "name": "Nami",
  "text": "That's probably the place where zombies are made."
 },
 {
  "i": 133,
  "style": "Main",
  "name": "Chopper",
  "text": "I'm glad we woke up!"
 },
 {
  "i": 134,
  "style": "Main",
  "name": "Chopper",
  "text": "Let's run!"
 },
 {
  "i": 135,
  "style": "Main",
  "name": "Usopp",
  "text": "That's right! Let's run, right away!"
 },
 {
  "i": 136,
  "style": "Main",
  "name": "Nami",
  "text": "Wait a minute!"
 },
 {
  "i": 137,
  "style": "Main",
  "name": "Nami",
  "text": "We didn't get any treasure because we got scared and started running around screaming..."
 },
 {
  "i": 138,
  "style": "Main",
  "name": "Nami",
  "text": "Is that alright?"
 },
 {
  "i": 139,
  "style": "Main",
  "name": "Usopp",
  "text": "What're you thinking, idiot?!"
 },
 {
  "i": 140,
  "style": "Main",
  "name": "Chopper",
  "text": "My \"Something is wrong\"-sensor is having a huge response!"
 },
 {
  "i": 141,
  "style": "Main",
  "name": "Usopp",
  "text": "Let's just run away, Nami!"
 },
 {
  "i": 142,
  "style": "Main",
  "name": "Chopper",
  "text": "That's right! That's right!"
 },
 {
  "i": 143,
  "style": "Main",
  "name": "",
  "text": "Let's run! Let's run!"
 },
 {
  "i": 144,
  "style": "Thoughts",
  "name": "Nami",
  "text": "I clearly remember what the zombie said back then."
 },
 {
  "i": 145,
  "style": "Flashbacks",
  "name": "Zombie",
  "text": "What a shame!"
 },
 {
  "i": 146,
  "style": "Flashbacks",
  "name": "Zombie",
  "text": "The treasure storehouse isn't here!"
 },
 {
  "i": 147,
  "style": "Main",
  "name": "Usopp",
  "text": "Stop thinking useless stuff, let's run!"
 },
 {
  "i": 148,
  "style": "Main",
  "name": "Chopper",
  "text": "Let's run, Nami!"
 },
 {
  "i": 149,
  "style": "Main",
  "name": "Nami",
  "text": "How stupid!"
 },
 {
  "i": 150,
  "style": "Main",
  "name": "Nami",
  "text": "I finally understand! I was just too scared at the time!"
 },
 {
  "i": 151,
  "style": "Main",
  "name": "Both",
  "text": "Weird looking eyes!"
 },
 {
  "i": 152,
  "style": "Main",
  "name": "Nami",
  "text": "Then, where do we run?"
 },
 {
  "i": 153,
  "style": "Main",
  "name": "Nami",
  "text": "Forward?"
 },
 {
  "i": 154,
  "style": "Main",
  "name": "Nami",
  "text": "Back?"
 },
 {
  "i": 155,
  "style": "Main",
  "name": "Usopp",
  "text": "That's one hard decision."
 },
 {
  "i": 156,
  "style": "Main",
  "name": "Usopp",
  "text": "If we go back to the mansion, we'll most likely run into that samurai again."
 },
 {
  "i": 157,
  "style": "Main",
  "name": "Chopper",
  "text": "But, we might run into scarier guys if we head forward."
 },
 {
  "i": 158,
  "style": "Main",
  "name": "Nami",
  "text": "What're these little animals?"
 },
 {
  "i": 159,
  "style": "Main",
  "name": "Nami",
  "text": "Penguins?"
 },
 {
  "i": 160,
  "style": "Main",
  "name": "Penguin 1",
  "text": "Numbers!"
 },
 {
  "i": 161,
  "style": "Main",
  "name": "Penguin 1",
  "text": "One!"
 },
 {
  "i": 162,
  "style": "Main",
  "name": "Penguin 2",
  "text": "Two!"
 },
 {
  "i": 163,
  "style": "Main",
  "name": "Sanji-pen",
  "text": "Three!"
 },
 {
  "i": 164,
  "style": "Thoughts",
  "name": "NUC",
  "text": "No..."
 },
 {
  "i": 165,
  "style": "Main",
  "name": "Penguin 1",
  "text": "Greetings, we're...!"
 },
 {
  "i": 166,
  "style": "Main",
  "name": "Penguin 2",
  "text": "The Penguin Zombie Combi-"
 },
 {
  "i": 167,
  "style": "Main",
  "name": "Penguin 2",
  "text": "Ah, I got it wrong."
 },
 {
  "i": 168,
  "style": "Main",
  "name": "Sanji-pen",
  "text": "Trio! We're a trio!"
 },
 {
  "i": 169,
  "style": "Main",
  "name": "Sanji-pen",
  "text": "I'm the new guy!"
 },
 {
  "i": 170,
  "style": "Main",
  "name": "Usopp",
  "text": "Like we care about that kinda member info!"
 },
 {
  "i": 171,
  "style": "Main",
  "name": "Penguin 1",
  "text": "And behind you all are..."
 },
 {
  "i": 172,
  "style": "Main",
  "name": "All",
  "text": "No way..."
 },
 {
  "i": 173,
  "style": "Main",
  "name": "Penguin 1",
  "text": "Our comrades, the Wild Zombies!"
 },
 {
  "i": 174,
  "style": "Main",
  "name": "Zombies",
  "text": "Welcome to Perona-sama's Wonder Garden!"
 },
 {
  "i": 175,
  "style": "Main",
  "name": "All",
  "text": "More strange creatures came out!"
 },
 {
  "i": 176,
  "style": "Main",
  "name": "Koala",
  "text": "Alright then, let's get 'em!"
 },
 {
  "i": 177,
  "style": "Main",
  "name": "Chopper",
  "text": "Usopp!"
 },
 {
  "i": 178,
  "style": "Main",
  "name": "Chopper",
  "text": "Fire!"
 },
 {
  "i": 179,
  "style": "Main",
  "name": "Chopper",
  "text": "Fire?"
 },
 {
  "i": 180,
  "style": "Main",
  "name": "Chopper",
  "text": "Use fire! These guys are zombies!"
 },
 {
  "i": 181,
  "style": "Main",
  "name": "Usopp",
  "text": "{\\fad(150,0)}Deadly..."
 },
 {
  "i": 182,
  "style": "Main",
  "name": "Chopper",
  "text": "Usopp!"
 },
 {
  "i": 183,
  "style": "Main",
  "name": "Nami",
  "text": "Chopper!"
 },
 {
  "i": 184,
  "style": "Main",
  "name": "Nami",
  "text": "Watch out, behind you!"
 },
 {
  "i": 185,
  "style": "Main",
  "name": "Nami",
  "text": "Usopp..."
 },
 {
  "i": 186,
  "style": "Main",
  "name": "Nami",
  "text": "Chopper..."
 },
 {
  "i": 187,
  "style": "Main",
  "name": "Hippo",
  "text": "You're in the same situation!"
 },
 {
  "i": 188,
  "style": "Main",
  "name": "Sanji-pen",
  "text": "Stop!"
 },
 {
  "i": 189,
  "style": "Main",
  "name": "Zombie",
  "text": "Bastard! What're you doing to your comrade!"
 },
 {
  "i": 190,
  "style": "Main",
  "name": "Zombie",
  "text": "Your enemy is that woman!"
 },
 {
  "i": 191,
  "style": "Main",
  "name": "Zombie",
  "text": "She's the one you should beat!"
 },
 {
  "i": 192,
  "style": "Main",
  "name": "Sanji-pen",
  "text": "I have no idea who this lady might be or where she came from..."
 },
 {
  "i": 193,
  "style": "Main",
  "name": "Sanji-pen",
  "text": "But even if it goes against master's orders..."
 },
 {
  "i": 194,
  "style": "Main",
  "name": "Sanji-pen",
  "text": "Even if I die..."
 },
 {
  "i": 195,
  "style": "Main",
  "name": "Sanji-pen",
  "text": "I won't hurt a woman!"
 },
 {
  "i": 196,
  "style": "Main",
  "name": "Sanji-pen",
  "text": "If you've a problem with that, bring it on!"
 },
 {
  "i": 197,
  "style": "Main",
  "name": "Sanji-pen",
  "text": "Damn Zombies!"
 },
 {
  "i": 198,
  "style": "Main",
  "name": "Luffy",
  "text": "Hey! What's wrong?!"
 },
 {
  "i": 199,
  "style": "Main",
  "name": "Luffy",
  "text": "Hey Piglet!"
 },
 {
  "i": 200,
  "style": "Main",
  "name": "Luffy",
  "text": "You did something again, didn't you?!"
 },
 {
  "i": 201,
  "style": "Main",
  "name": "Luffy",
  "text": "Spit it out!"
 },
 {
  "i": 202,
  "style": "Main",
  "name": "Pig",
  "text": "I told you from the start that I don't know anything."
 },
 {
  "i": 203,
  "style": "Main",
  "name": "Franky",
  "text": "And you're laughing now."
 },
 {
  "i": 204,
  "style": "Main",
  "name": "Franky",
  "text": "What an obvious fella."
 },
 {
  "i": 205,
  "style": "Main",
  "name": "Robin",
  "text": "How strange..."
 },
 {
  "i": 206,
  "style": "Main",
  "name": "Robin",
  "text": "Not even a scream."
 },
 {
  "i": 207,
  "style": "Main",
  "name": "Robin",
  "text": "I wonder if they were strangled to death..."
 },
 {
  "i": 208,
  "style": "Main",
  "name": "Franky",
  "text": "Why is your train of thought always so dark?!"
 },
 {
  "i": 209,
  "style": "Main",
  "name": "Luffy",
  "text": "How weird..."
 },
 {
  "i": 210,
  "style": "Main",
  "name": "Luffy",
  "text": "Even Zoro's disappeared."
 },
 {
  "i": 211,
  "style": "Main",
  "name": "Luffy",
  "text": "Where did they go?!"
 },
 {
  "i": 212,
  "style": "Main",
  "name": "Luffy",
  "text": "It can't be helped with Zoro and Sanji!"
 },
 {
  "i": 213,
  "style": "Main",
  "name": "Franky",
  "text": "What're you doing at a time like this?!"
 },
 {
  "i": 214,
  "style": "Main",
  "name": "Luffy",
  "text": "Hey! I found the armor lying in there!"
 },
 {
  "i": 215,
  "style": "Main",
  "name": "Luffy",
  "text": "Isn't it a man's romance to wear it?!"
 },
 {
  "i": 216,
  "style": "Main",
  "name": "Franky",
  "text": "No way!"
 },
 {
  "i": 217,
  "style": "Main",
  "name": "Franky",
  "text": "R-Romance?!"
 },
 {
  "i": 218,
  "style": "Main",
  "name": "Franky",
  "text": "Of course!"
 },
 {
  "i": 219,
  "style": "Main",
  "name": "Luffy",
  "text": "When you gained that iron body, did you change your heart to iron as well?"
 },
 {
  "i": 220,
  "style": "Main",
  "name": "Franky",
  "text": "Please forgive me!"
 },
 {
  "i": 221,
  "style": "Main",
  "name": "Franky",
  "text": "I never intended to go so far as to change my heart to iron!"
 },
 {
  "i": 222,
  "style": "Main",
  "name": "Franky",
  "text": "When you lose something important, a foreboding wind blows through your heart."
 },
 {
  "i": 223,
  "style": "Main",
  "name": "Franky",
  "text": "Please listen..."
 },
 {
  "i": 224,
  "style": "Main",
  "name": "Franky",
  "text": "\"The Heart of a Steely Cyborg Traveler\""
 },
 {
  "i": 225,
  "style": "Main",
  "name": "Pig",
  "text": "Are these guys aware of the current situation?"
 },
 {
  "i": 226,
  "style": "Main",
  "name": "Robin",
  "text": "Hey."
 },
 {
  "i": 227,
  "style": "Main",
  "name": "Robin",
  "text": "We've come to a large hall."
 },
 {
  "i": 228,
  "style": "Main",
  "name": "Luffy",
  "text": "Really?"
 },
 {
  "i": 229,
  "style": "Main",
  "name": "Luffy",
  "text": "Robin, are Usopp and the others there?!"
 },
 {
  "i": 230,
  "style": "Main",
  "name": "Robin",
  "text": "I don't think so."
 },
 {
  "i": 231,
  "style": "Main",
  "name": "Robin",
  "text": "This hall's interior looks like the outside..."
 },
 {
  "i": 232,
  "style": "Main",
  "name": "Luffy",
  "text": "What's with this place?!"
 },
 {
  "i": 233,
  "style": "Main",
  "name": "Franky",
  "text": "It's as if it were an arena."
 },
 {
  "i": 234,
  "style": "Main",
  "name": "Pig",
  "text": "It's not that simple."
 },
 {
  "i": 235,
  "style": "Main",
  "name": "Pig",
  "text": "You better resign yourselves."
 },
 {
  "i": 236,
  "style": "Main",
  "name": "Pig",
  "text": "It's impossible for you to escape from here!"
 },
 {
  "i": 237,
  "style": "Main",
  "name": "Luffy",
  "text": "Franky!"
 },
 {
  "i": 238,
  "style": "Main",
  "name": "Robin",
  "text": "Who is it?!"
 },
 {
  "i": 239,
  "style": "Main",
  "name": "Luffy",
  "text": "A moving suit of armor!"
 },
 {
  "i": 240,
  "style": "Main",
  "name": "Robin",
  "text": "No doubt it's a zombie."
 },
 {
  "i": 241,
  "style": "Main",
  "name": "Robin",
  "text": "It's moving even with those spears in its body."
 },
 {
  "i": 242,
  "style": "Main",
  "name": "Franky",
  "text": "Just 'cause zombies are well equipped..."
 },
 {
  "i": 243,
  "style": "Main",
  "name": "Franky",
  "text": "I won't be scared...!"
 },
 {
  "i": 244,
  "style": "Main",
  "name": "Franky",
  "text": "{\\fad(150,150)}Strong Right!"
 },
 {
  "i": 245,
  "style": "Main",
  "name": "Franky",
  "text": "The wall was...!"
 },
 {
  "i": 246,
  "style": "Main",
  "name": "Franky",
  "text": "Since it uses fencing..."
 },
 {
  "i": 247,
  "style": "Main",
  "name": "Franky",
  "text": "{\\fad(150,150)}Weapons Left!"
 },
 {
  "i": 248,
  "style": "Main",
  "name": "Luffy",
  "text": "Franky was...!"
 },
 {
  "i": 249,
  "style": "Main",
  "name": "Franky",
  "text": "It'll take more than that to kill me!"
 },
 {
  "i": 250,
  "style": "Main",
  "name": "Franky",
  "text": "Especially for a corpse like you!"
 },
 {
  "i": 251,
  "style": "Main",
  "name": "Luffy",
  "text": "He's still getting up."
 },
 {
  "i": 252,
  "style": "Main",
  "name": "Franky",
  "text": "The latch won't open."
 },
 {
  "i": 253,
  "style": "Main",
  "name": "Franky",
  "text": "He's completely different from the zombies we've seen so far."
 },
 {
  "i": 254,
  "style": "Main",
  "name": "Pig",
  "text": "Soon you'll understand!"
 },
 {
  "i": 255,
  "style": "Main",
  "name": "Pig",
  "text": "That's what makes them really terrifying!"
 },
 {
  "i": 256,
  "style": "Main",
  "name": "Luffy",
  "text": "That guy, speaking from that far!"
 },
 {
  "i": 257,
  "style": "Main",
  "name": "Pig",
  "text": "They don't feel pain!"
 },
 {
  "i": 258,
  "style": "Main",
  "name": "Pig",
  "text": "Every single one of those armed General Zombies made a name for themselves in battle."
 },
 {
  "i": 259,
  "style": "Main",
  "name": "Pig",
  "text": "They're unbending warriors!"
 },
 {
  "i": 260,
  "style": "Main",
  "name": "Pig",
  "text": "The leader of a country's knights who turned into a brutal criminal."
 },
 {
  "i": 261,
  "style": "Main",
  "name": "Pig",
  "text": "A legendary samurai, a pirate, a gunslinger!"
 },
 {
  "i": 262,
  "style": "Main",
  "name": "Pig",
  "text": "Imagine those men after they've become invulnerable!"
 },
 {
  "i": 263,
  "style": "Main",
  "name": "Pig",
  "text": "There's no way someone like you could beat them!"
 },
 {
  "i": 264,
  "style": "Main",
  "name": "Pig",
  "text": "Even now your friends are in peril!"
 },
 {
  "i": 265,
  "style": "Main",
  "name": "Pig",
  "text": "Serves you right!"
 },
 {
  "i": 266,
  "style": "Main",
  "name": "Luffy",
  "text": "You bastard!"
 },
 {
  "i": 267,
  "style": "Main",
  "name": "Pig",
  "text": "Wall zombie!"
 },
 {
  "i": 268,
  "style": "Main",
  "name": "Wall-zombie",
  "text": "Got it!"
 },
 {
  "i": 269,
  "style": "Main",
  "name": "Luffy",
  "text": "He's closed off the path!"
 },
 {
  "i": 270,
  "style": "Main",
  "name": "Robin",
  "text": "That's not the only path that was closed."
 },
 {
  "i": 271,
  "style": "Main",
  "name": "Franky",
  "text": "Speaking from my experience..."
 },
 {
  "i": 272,
  "style": "Main",
  "name": "Franky",
  "text": "This will be more than just tough."
 },
 {
  "i": 273,
  "style": "Main",
  "name": "Luffy",
  "text": "It's full of armor!"
 },
 {
  "i": 274,
  "style": "Main",
  "name": "Franky",
  "text": "There's no point in fighting them one by one, as our attacks don't harm them."
 },
 {
  "i": 275,
  "style": "Main",
  "name": "Franky",
  "text": "And we'll just be overwhelmed if we try to face them all straight on."
 },
 {
  "i": 276,
  "style": "Main",
  "name": "Luffy",
  "text": "I see."
 },
 {
  "i": 277,
  "style": "Main",
  "name": "Luffy",
  "text": "You're right, it's not like this is our last battle."
 },
 {
  "i": 278,
  "style": "Main",
  "name": "Robin",
  "text": "If we run straight ahead from this hall, we'll probably reach the courtyard."
 },
 {
  "i": 279,
  "style": "Main",
  "name": "Luffy",
  "text": "Alright! Then, the three of us will meet up in there."
 },
 {
  "i": 280,
  "style": "Main",
  "name": "Luffy",
  "text": "Be careful not to let anyone else disappear."
 },
 {
  "i": 281,
  "style": "Main",
  "name": "Robin",
  "text": "Of course."
 },
 {
  "i": 282,
  "style": "Main",
  "name": "Zombie",
  "text": "Get 'em!"
 },
 {
  "i": 283,
  "style": "Main",
  "name": "Luffy",
  "text": "Let's go!"
 },
 {
  "i": 284,
  "style": "Main",
  "name": "Luffy",
  "text": "Move!"
 },
 {
  "i": 285,
  "style": "Main",
  "name": "Jigorou",
  "text": "{\\fad(150,150)}Phoenix of the Thirty-six Earthly Desires!"
 },
 {
  "i": 286,
  "style": "Main",
  "name": "Luffy",
  "text": "This technique...!"
 },
 {
  "i": 287,
  "style": "Main",
  "name": "Luffy",
  "text": "Zoro!"
 },
 {
  "i": 288,
  "style": "Main",
  "name": "Jigorou",
  "text": "A scar on the back is a shame for a warrior!"
 },
 {
  "i": 289,
  "style": "Main",
  "name": "Jigorou",
  "text": "Yet I'm covered with scars!"
 },
 {
  "i": 290,
  "style": "Main",
  "name": "Luffy",
  "text": "Who're you?"
 },
 {
  "i": 291,
  "style": "Main",
  "name": "Luffy",
  "text": "I thought you were Zoro."
 },
 {
  "i": 292,
  "style": "Main",
  "name": "Jigorou",
  "text": "My name is Jigoro!"
 },
 {
  "i": 293,
  "style": "Main",
  "name": "Luffy",
  "text": "You're exactly like him!"
 },
 {
  "i": 294,
  "style": "Main",
  "name": "Franky",
  "text": "This is what you use against zombies!"
 },
 {
  "i": 295,
  "style": "Main",
  "name": "Franky",
  "text": "{\\fad(150,150)}Fresh Fire!"
 },
 {
  "i": 296,
  "style": "Main",
  "name": "Zombie",
  "text": "Prepare the buckets!"
 },
 {
  "i": 297,
  "style": "Main",
  "name": "Franky",
  "text": "What?!"
 },
 {
  "i": 298,
  "style": "Main",
  "name": "Robin",
  "text": "{\\fad(150,150)}Once Fleur!"
 },
 {
  "i": 299,
  "style": "Note",
  "name": "Robin",
  "text": "{\\fad(150,150)}Eleven flowers"
 },
 {
  "i": 300,
  "style": "Main",
  "name": "Robin",
  "text": "{\\fad(150,150)}Slam!"
 },
 {
  "i": 301,
  "style": "Main",
  "name": "Robin",
  "text": "Where's Luffy?!"
 },
 {
  "i": 302,
  "style": "Main",
  "name": "Franky",
  "text": "It seems he hasn't come out yet."
 },
 {
  "i": 303,
  "style": "Main",
  "name": "Franky",
  "text": "Even if we went back, it'd be hard to find that idiot because he's wearing that armor!"
 },
 {
  "i": 304,
  "style": "Main",
  "name": "Franky",
  "text": "Could he have disappeared as well?!"
 },
 {
  "i": 305,
  "style": "Main",
  "name": "Robin",
  "text": "But we can't patiently wait for him."
 },
 {
  "i": 306,
  "style": "Main",
  "name": "Robin",
  "text": "The zombies will be here in no time!"
 },
 {
  "i": 307,
  "style": "Main",
  "name": "Franky",
  "text": "Hey! Straw Hat!"
 },
 {
  "i": 308,
  "style": "Main",
  "name": "Luffy",
  "text": "That hurt, bastard! Let me out!"
 },
 {
  "i": 309,
  "style": "Main",
  "name": "Franky",
  "text": "What the...?"
 },
 {
  "i": 310,
  "style": "Secondary",
  "name": "Luffy",
  "text": "Bastards, let me out, damn it!"
 },
 {
  "i": 311,
  "style": "Main",
  "name": "Luffy",
  "text": "It's not fun, damn it!"
 },
 {
  "i": 312,
  "style": "Main",
  "name": "Luffy",
  "text": "Open the lid!"
 },
 {
  "i": 313,
  "style": "Main",
  "name": "Franky",
  "text": "A-A coffin?!"
 },
 {
  "i": 314,
  "style": "Main",
  "name": "Luffy",
  "text": "Let me out immediately!"
 },
 {
  "i": 315,
  "style": "Main",
  "name": "Luffy",
  "text": "Let me out, I'll kick your ass!"
 },
 {
  "i": 316,
  "style": "Main",
  "name": "Robin",
  "text": "That voice just now...!"
 },
 {
  "i": 317,
  "style": "Main",
  "name": "Luffy",
  "text": "Let me out!"
 },
 {
  "i": 318,
  "style": "Main",
  "name": "Luffy",
  "text": "Hey, I'm telling you to let me out!"
 },
 {
  "i": 319,
  "style": "Main",
  "name": "Robin",
  "text": "Luffy!"
 },
 {
  "i": 320,
  "style": "Main",
  "name": "Franky",
  "text": "No way...!"
 },
 {
  "i": 321,
  "style": "Main",
  "name": "Franky",
  "text": "Is Straw Hat inside of that thing?!"
 },
 {
  "i": 322,
  "style": "Main",
  "name": "Franky",
  "text": "After him, Nico Robin!"
 },
 {
  "i": 323,
  "style": "Main",
  "name": "Franky",
  "text": "What the hell is he doing?!"
 },
 {
  "i": 324,
  "style": "Main",
  "name": "Franky",
  "text": "He let himself get caught!"
 },
 {
  "i": 325,
  "style": "Main",
  "name": "Franky",
  "text": "Straw Hat!"
 },
 {
  "i": 326,
  "style": "Main",
  "name": "Spider",
  "text": "You're not following him!"
 },
 {
  "i": 327,
  "style": "Main",
  "name": "Spider",
  "text": "Hey, hey! Monkey! Monkey! Monkey!"
 },
 {
  "i": 328,
  "style": "Main",
  "name": "Spider",
  "text": "I'm the widely rumored Spider Monkey!"
 },
 {
  "i": 329,
  "style": "Main",
  "name": "Robin",
  "text": "A gigantic spider!"
 },
 {
  "i": 330,
  "style": "Main",
  "name": "Franky",
  "text": "This thing's size exceeds that of average insects! It's a monstrous spider!"
 },
 {
  "i": 331,
  "style": "Main",
  "name": "Luffy",
  "text": "Let me out I tell you, idiot!"
 },
 {
  "i": 332,
  "style": "Main",
  "name": "Luffy",
  "text": "Open the li-"
 },
 {
  "i": 333,
  "style": "Main",
  "name": "Spider",
  "text": "Ah! Another one."
 },
 {
  "i": 334,
  "style": "Main",
  "name": "Franky",
  "text": "Damn, the coffin...!"
 },
 {
  "i": 335,
  "style": "Main",
  "name": "Franky",
  "text": "Bastard, what're you gonna do with him?!"
 },
 {
  "i": 336,
  "style": "Main",
  "name": "Spider",
  "text": "Don't worry."
 },
 {
  "i": 337,
  "style": "Main",
  "name": "Spider",
  "text": "Whatever happens to him, you will also learn firsthand."
 },
