[
 {
  "i": 0,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}Let's travel all through the worldwide seas,"
 },
 {
  "i": 1,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 2,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 3,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 4,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "We were able to escape from the set course"
 },
 {
  "i": 5,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "along the boundary between sky and sea."
 },
 {
  "i": 6,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now we're rowing our way"
 },
 {
  "i": 7,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "to a hidden adventure at the dark bottom of the sea."
 },
 {
  "i": 8,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Doesn't it sound fun just thinking about it?"
 },
 {
  "i": 9,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Let's travel all through the worldwide seas,"
 },
 {
  "i": 10,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 11,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 12,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 13,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}That feeling we had when we set sail"
 },
 {
  "i": 14,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "is something I'll never forget."
 },
 {
  "i": 15,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Because of that"
 },
 {
  "i": 16,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "nothing will be able to scare me..."
 },
 {
  "i": 17,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now, as the trip approaches, our racing heartbeats"
 },
 {
  "i": 18,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "engrave a rhythm of adventure in our shy hearts."
 },
 {
  "i": 19,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}Get all the treasures"
 },
 {
  "i": 20,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 21,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 22,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(50,50)}making a splash..."
 },
 {
  "i": 23,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Fill your empty heart with dreams."
 },
 {
  "i": 24,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Spread your wings."
 },
 {
  "i": 25,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you color your heart with the blowing wind"
 },
 {
  "i": 26,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "you will move on."
 },
 {
  "i": 27,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Get all the treasures"
 },
 {
  "i": 28,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 29,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 30,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "making a splash..."
 },
 {
  "i": 31,
  "style": "Title",
  "name": "Title",
  "text": "{\\fad(1700,2000)}Oars' Awakening and\\NBrook vs. Ryuma!"
 },
 {
  "i": 32,
  "style": "Main",
  "name": "Moria",
  "text": "Let's get started!"
 },
 {
  "i": 33,
  "style": "Thoughts",
  "name": "Usopp",
  "text": "W-What's this...?"
 },
 {
  "i": 34,
  "style": "Thoughts",
  "name": "Usopp",
  "text": "A-A giant's corpse...?"
 },
 {
  "i": 35,
  "style": "Thoughts",
  "name": "Usopp",
  "text": "Even for a giant it's too big!"
 },
 {
  "i": 36,
  "style": "Main",
  "name": "Nami",
  "text": "Don't make a sound, Chopper."
 },
 {
  "i": 37,
  "style": "Main",
  "name": "Moria",
  "text": "Calm down, Straw Hat Luffy's Shadow."
 },
 {
  "i": 38,
  "style": "Main",
  "name": "Moria",
  "text": "I'm your new master."
 },
 {
  "i": 39,
  "style": "Main",
  "name": "Moria",
  "text": "You'll receive a new voice and body to live as a zombie from now on."
 },
 {
  "i": 40,
  "style": "Main",
  "name": "Moria",
  "text": "Forget every connection with your previous human body."
 },
 {
  "i": 41,
  "style": "Main",
  "name": "Moria",
  "text": "Submit to me and become my loyal soldier."
 },
 {
  "i": 42,
  "style": "Main",
  "name": "Moria",
  "text": "We have a deal then."
 },
 {
  "i": 43,
  "style": "Main",
  "name": "Hogback",
  "text": "Cindry-chan, you also entered a contract to forget your past existence..."
 },
 {
  "i": 44,
  "style": "Main",
  "name": "Hogback",
  "text": "So we should be able to eat with plates."
 },
 {
  "i": 45,
  "style": "Main",
  "name": "Cindry",
  "text": "It would be best if your knees were broken as well."
 },
 {
  "i": 46,
  "style": "Main",
  "name": "Hogback",
  "text": "Scary!"
 },
 {
  "i": 47,
  "style": "Main",
  "name": "Hogback",
  "text": "Cindry-chan, that threat was way too scary!"
 },
 {
  "i": 48,
  "style": "Main",
  "name": "Absalom",
  "text": "Cindry is really strict with Hogback."
 },
 {
  "i": 49,
  "style": "Main",
  "name": "Moria",
  "text": "Now, awake...!"
 },
 {
  "i": 50,
  "style": "Thoughts",
  "name": "Chopper",
  "text": "T-The shadow...!"
 },
 {
  "i": 51,
  "style": "Main",
  "name": "Moria",
  "text": "From your 500 year slumber!"
 },
 {
  "i": 52,
  "style": "Main",
  "name": "Nami",
  "text": "Luffy's shadow was..."
 },
 {
  "i": 53,
  "style": "Main",
  "name": "Absalom",
  "text": "It's in."
 },
 {
  "i": 54,
  "style": "Main",
  "name": "Nami",
  "text": "No! Don't yell!"
 },
 {
  "i": 55,
  "style": "Main",
  "name": "All",
  "text": "The corpse moved!"
 },
 {
  "i": 56,
  "style": "Main",
  "name": "Moria",
  "text": "What?"
 },
 {
  "i": 57,
  "style": "Main",
  "name": "Usopp",
  "text": "D-Damn it! We've been found!"
 },
 {
  "i": 58,
  "style": "Main",
  "name": "Nami",
  "text": "We screamed!"
 },
 {
  "i": 59,
  "style": "Main",
  "name": "Chopper",
  "text": "The demon has awakened!"
 },
 {
  "i": 60,
  "style": "Main",
  "name": "Perona",
  "text": "Hey, Kumashi!"
 },
 {
  "i": 61,
  "style": "Main",
  "name": "Perona",
  "text": "Don't tell me you've been hiding those pirates!"
 },
 {
  "i": 62,
  "style": "Main",
  "name": "Absalom",
  "text": "My bride!"
 },
 {
  "i": 63,
  "style": "Main",
  "name": "Absalom",
  "text": "Why's she here?!"
 },
 {
  "i": 64,
  "style": "Main",
  "name": "Hogback",
  "text": "Splendid!"
 },
 {
  "i": 65,
  "style": "Main",
  "name": "Hogback",
  "text": "What violence!"
 },
 {
  "i": 66,
  "style": "Main",
  "name": "Hogback",
  "text": "It's a masterpiece!"
 },
 {
  "i": 67,
  "style": "Main",
  "name": "Hogback",
  "text": "Truly a devil!"
 },
 {
  "i": 68,
  "style": "Main",
  "name": "Oars",
  "text": "Meat!"
 },
 {
  "i": 69,
  "style": "Main",
  "name": "Oars",
  "text": "I'm hungry!"
 },
 {
  "i": 70,
  "style": "Main",
  "name": "Absalom",
  "text": "Hey! Where did the pirates...? Where did my bride go?!"
 },
 {
  "i": 71,
  "style": "Main",
  "name": "Zombie",
  "text": "They ran at full speed!"
 },
 {
  "i": 72,
  "style": "Main",
  "name": "Zombie",
  "text": "They sure are fast!"
 },
 {
  "i": 73,
  "style": "Main",
  "name": "Absalom",
  "text": "You won't escape!"
 },
 {
  "i": 74,
  "style": "Main",
  "name": "Oars",
  "text": "Sanji, food!"
 },
 {
  "i": 75,
  "style": "Main",
  "name": "Oars",
  "text": "Who's this Sanji?"
 },
 {
  "i": 76,
  "style": "Main",
  "name": "Usopp",
  "text": "What happened...?"
 },
 {
  "i": 77,
  "style": "Main",
  "name": "Usopp",
  "text": "What happened just now?"
 },
 {
  "i": 78,
  "style": "Main",
  "name": "Chopper",
  "text": "It started moving as soon as Luffy's shadow was inserted!"
 },
 {
  "i": 79,
  "style": "Main",
  "name": "Nami",
  "text": "So that's how zombies work!"
 },
 {
  "i": 80,
  "style": "Main",
  "name": "Chopper",
  "text": "That was what Dr. Hogback meant by \"giving back life!\""
 },
 {
  "i": 81,
  "style": "Main",
  "name": "Usopp",
  "text": "That huge man's ability..."
 },
 {
  "i": 82,
  "style": "Main",
  "name": "Usopp",
  "text": "It's probably a devil fruit ability!"
 },
 {
  "i": 83,
  "style": "Main",
  "name": "Nami",
  "text": "The fact his first word was \"meat\" means..."
 },
 {
  "i": 84,
  "style": "Main",
  "name": "Nami",
  "text": "That giant monster without a doubt holds Luffy's personality."
 },
 {
  "i": 85,
  "style": "Main",
  "name": "Usopp",
  "text": "Ah, right."
 },
 {
  "i": 86,
  "style": "Main",
  "name": "Nami",
  "text": "Then, if I remember correctly..."
 },
 {
  "i": 87,
  "style": "Main",
  "name": "Nami",
  "text": "That Sanji-like penguin we met at the bridge..."
 },
 {
  "i": 88,
  "style": "Flashbacks",
  "name": "Inuppe",
  "text": "Even if I die..."
 },
 {
  "i": 89,
  "style": "Flashbacks",
  "name": "Inuppe",
  "text": "I won't hurt a lady!"
 },
 {
  "i": 90,
  "style": "Main",
  "name": "Usopp",
  "text": "I see!"
 },
 {
  "i": 91,
  "style": "Main",
  "name": "Usopp",
  "text": "Then, Sanji's shadow was embedded into it."
 },
 {
  "i": 92,
  "style": "Main",
  "name": "Nami",
  "text": "Most likely."
 },
 {
  "i": 93,
  "style": "Main",
  "name": "Usopp",
  "text": "So, the samurai who hit us with the back of the sword..."
 },
 {
  "i": 94,
  "style": "Main",
  "name": "Usopp",
  "text": "That's Brook!"
 },
 {
  "i": 95,
  "style": "Main",
  "name": "Usopp",
  "text": "Incredible!"
 },
 {
  "i": 96,
  "style": "Main",
  "name": "Chopper",
  "text": "So all those strange incidents were tied together."
 },
 {
  "i": 97,
  "style": "Main",
  "name": "Chopper",
  "text": "These terrible zombies are just a game to him!"
 },
 {
  "i": 98,
  "style": "Main",
  "name": "Chopper",
  "text": "He's just toying with people's lives!"
 },
 {
  "i": 99,
  "style": "Main",
  "name": "Chopper",
  "text": "What \"mankind dream\"...!"
 },
 {
  "i": 100,
  "style": "Main",
  "name": "Chopper",
  "text": "What \"bringing back the dead\"...!"
 },
 {
  "i": 101,
  "style": "Flashbacks",
  "name": "Chopper",
  "text": "Dr. Hogback is a great man!"
 },
 {
  "i": 102,
  "style": "Flashbacks",
  "name": "Chopper",
  "text": "I highly respect him!"
 },
 {
  "i": 103,
  "style": "Main",
  "name": "Chopper",
  "text": "He doesn't want to help anyone in the least!"
 },
 {
  "i": 104,
  "style": "Main",
  "name": "Chopper",
  "text": "He's just another villain!"
 },
 {
  "i": 105,
  "style": "Main",
  "name": "Nami",
  "text": "Chopper..."
 },
 {
  "i": 106,
  "style": "Main",
  "name": "Usopp",
  "text": "This isn't the time to be crying over that."
 },
 {
  "i": 107,
  "style": "Main",
  "name": "Usopp",
  "text": "Our friends are becoming victims of this zombie game!"
 },
 {
  "i": 108,
  "style": "Main",
  "name": "Usopp",
  "text": "Do you understand?"
 },
 {
  "i": 109,
  "style": "Main",
  "name": "Usopp",
  "text": "We have to save them!"
 },
 {
  "i": 110,
  "style": "Main",
  "name": "Usopp",
  "text": "Hurry up!"
 },
 {
  "i": 111,
  "style": "Main",
  "name": "Usopp",
  "text": "We're going to where Luffy's being transported!"
 },
 {
  "i": 112,
  "style": "Main",
  "name": "Nami",
  "text": "Yea, they said to \"take them back to the ship\"!"
 },
 {
  "i": 113,
  "style": "Main",
  "name": "Nami",
  "text": "I wonder if they meant the Sunny?"
 },
 {
  "i": 114,
  "style": "Main",
  "name": "Chopper",
  "text": "If the same thing happened to Zoro and Sanji..."
 },
 {
  "i": 115,
  "style": "Main",
  "name": "Chopper",
  "text": "They must be there as well!"
 },
 {
  "i": 116,
  "style": "Main",
  "name": "Nami",
  "text": "You're right!"
 },
 {
  "i": 117,
  "style": "Main",
  "name": "Usopp",
  "text": "Let's go help 'em!"
 },
 {
  "i": 118,
  "style": "Main",
  "name": "Nami",
  "text": "Usopp!"
 },
 {
  "i": 119,
  "style": "Main",
  "name": "Nami",
  "text": "Chopper!"
 },
 {
  "i": 120,
  "style": "Main",
  "name": "Nami",
  "text": "Are you okay?!"
 },
 {
  "i": 121,
  "style": "Main",
  "name": "Nami",
  "text": "What?"
 },
 {
  "i": 122,
  "style": "Main",
  "name": "Nami",
  "text": "It hurts, what're you-?!"
 },
 {
  "i": 123,
  "style": "Main",
  "name": "Nami",
  "text": "Let go of me!"
 },
 {
  "i": 124,
  "style": "Main",
  "name": "Nami",
  "text": "This guy...!"
 },
 {
  "i": 125,
  "style": "Main",
  "name": "Nami",
  "text": "What strength!"
 },
 {
  "i": 126,
  "style": "Main",
  "name": "Absalom",
  "text": "Are you done saying goodbye?"
 },
 {
  "i": 127,
  "style": "Main",
  "name": "Absalom",
  "text": "Today I'll marry this woman."
 },
 {
  "i": 128,
  "style": "Main",
  "name": "Usopp",
  "text": "Idiot..."
 },
 {
  "i": 129,
  "style": "Main",
  "name": "Usopp",
  "text": "For the manly Usopp, there's no point in living..."
 },
 {
  "i": 130,
  "style": "Main",
  "name": "Usopp",
  "text": "If he can't protect even one woman!"
 },
 {
  "i": 131,
  "style": "Main",
  "name": "Chopper",
  "text": "Usopp, that weapon...!"
 },
 {
  "i": 132,
  "style": "Main",
  "name": "Usopp",
  "text": "Take this!"
 },
 {
  "i": 133,
  "style": "Main",
  "name": "Usopp",
  "text": "{\\fad(100,100)}Six Chambered Viper Star!"
 },
 {
  "i": 134,
  "style": "Main",
  "name": "Chopper",
  "text": "He's disappearing again!"
 },
 {
  "i": 135,
  "style": "Main",
  "name": "Nami",
  "text": "What? Even me?"
 },
 {
  "i": 136,
  "style": "Main",
  "name": "Usopp",
  "text": "Nami disappeared too!"
 },
 {
  "i": 137,
  "style": "Main",
  "name": "Chopper",
  "text": "Nami!"
 },
 {
  "i": 138,
  "style": "Main",
  "name": "Chopper",
  "text": "Where are you?!"
 },
 {
  "i": 139,
  "style": "Main",
  "name": "Chopper",
  "text": "What?"
 },
 {
  "i": 140,
  "style": "Main",
  "name": "Chopper",
  "text": "Her scent is being erased by another smell!"
 },
 {
  "i": 141,
  "style": "Main",
  "name": "Nami",
  "text": "Help me!"
 },
 {
  "i": 142,
  "style": "Main",
  "name": "Nami",
  "text": "Usopp, Cho-!"
 },
 {
  "i": 143,
  "style": "Main",
  "name": "Usopp",
  "text": "Hey! Nami, what's wrong?!"
 },
 {
  "i": 144,
  "style": "Main",
  "name": "Usopp",
  "text": "Where are you?!"
 },
 {
  "i": 145,
  "style": "Main",
  "name": "Usopp",
  "text": "Answer me, Nami!"
 },
 {
  "i": 146,
  "style": "Main",
  "name": "Absalom",
  "text": "Zombies!"
 },
 {
  "i": 147,
  "style": "Main",
  "name": "Absalom",
  "text": "I'll leave them to you."
 },
 {
  "i": 148,
  "style": "Main",
  "name": "Absalom",
  "text": "Take those two to Moria-sama!"
 },
 {
  "i": 149,
  "style": "Main",
  "name": "Chopper",
  "text": "Huh?"
 },
 {
  "i": 150,
  "style": "Main",
  "name": "Usopp",
  "text": "Where's he talking from?!"
 },
 {
  "i": 151,
  "style": "Main",
  "name": "Usopp",
  "text": "What?! An armored zombie?!"
 },
 {
  "i": 152,
  "style": "Main",
  "name": "Usopp",
  "text": "More zombies are coming from below!"
 },
 {
  "i": 153,
  "style": "Main",
  "name": "Chopper",
  "text": "Zombies are coming from above too!"
 },
 {
  "i": 154,
  "style": "Main",
  "name": "Zombies",
  "text": "Hey, pirates...!"
 },
 {
  "i": 155,
  "style": "Main",
  "name": "Zombies",
  "text": "Hand over your shadows!"
 },
 {
  "i": 156,
  "style": "Main",
  "name": "Usopp",
  "text": "Don't get caught, they'll steal our shadows!"
 },
 {
  "i": 157,
  "style": "Main",
  "name": "Chopper",
  "text": "Y-Yea."
 },
 {
  "i": 158,
  "style": "Main",
  "name": "Chopper",
  "text": "There's also portrait zombies!"
 },
 {
  "i": 159,
  "style": "Main",
  "name": "Usopp",
  "text": "Damn!"
 },
 {
  "i": 160,
  "style": "Main",
  "name": "Usopp",
  "text": "It's unfair to make an undead dog-pile!"
 },
 {
  "i": 161,
  "style": "Main",
  "name": "Usopp",
  "text": "Unfair!"
 },
 {
  "i": 162,
  "style": "Main",
  "name": "Zombies",
  "text": "We're just gonna take your shadow, bro."
 },
 {
  "i": 163,
  "style": "Main",
  "name": "Chopper",
  "text": "Damn, let me go!"
 },
 {
  "i": 164,
  "style": "Main",
  "name": "Chopper",
  "text": "Damn!"
 },
 {
  "i": 165,
  "style": "Main",
  "name": "Zombies",
  "text": "Hey, someone's there!"
 },
 {
  "i": 166,
  "style": "Main",
  "name": "Zombies",
  "text": "They're purifying the others!"
 },
 {
  "i": 167,
  "style": "Main",
  "name": "Franky",
  "text": "Get your dirty hands off..."
 },
 {
  "i": 168,
  "style": "Main",
  "name": "Franky",
  "text": "My little brothers!"
 },
 {
  "i": 169,
  "style": "Main",
  "name": "Zombies",
  "text": "Who're these guys?!"
 },
 {
  "i": 170,
  "style": "Main",
  "name": "Zombies",
  "text": "They're extremely dangerous!"
 },
 {
  "i": 171,
  "style": "Main",
  "name": "Chopper",
  "text": "B...!"
 },
 {
  "i": 172,
  "style": "Main",
  "name": "Chopper",
  "text": "Big Bro!"
 },
 {
  "i": 173,
  "style": "Main",
  "name": "Usopp",
  "text": "Robin!"
 },
 {
  "i": 174,
  "style": "Main",
  "name": "Franky",
  "text": "Didn't we make it on time?"
 },
 {
  "i": 175,
  "style": "Main",
  "name": "Franky",
  "text": "There's one missing."
 },
 {
  "i": 176,
  "style": "Main",
  "name": "Robin",
  "text": "Usopp."
 },
 {
  "i": 177,
  "style": "Main",
  "name": "Robin",
  "text": "Chopper."
 },
 {
  "i": 178,
  "style": "Main",
  "name": "Robin",
  "text": "Are you hurt?"
 },
 {
  "i": 179,
  "style": "Main",
  "name": "Zombie",
  "text": "Impossible!"
 },
 {
  "i": 180,
  "style": "Main",
  "name": "Zombie",
  "text": "Aside from the Humming One, other bastards who know our weak point have appeared!"
 },
 {
  "i": 181,
  "style": "Main",
  "name": "Zombie",
  "text": "This is terrible!"
 },
 {
  "i": 182,
  "style": "Main",
  "name": "Zombie",
  "text": "\"We can't die\" was our catchphrase, I don't wanna spend my days in fear of annihilation!"
 },
 {
  "i": 183,
  "style": "Main",
  "name": "Robin",
  "text": "I heard that those whose shadows were taken are carried past these long stairs."
 },
 {
  "i": 184,
  "style": "Main",
  "name": "Usopp",
  "text": "That's right, Luffy was transported through here!"
 },
 {
  "i": 185,
  "style": "Main",
  "name": "Usopp",
  "text": "We were going after him, but then Nami...!"
 },
 {
  "i": 186,
  "style": "Main",
  "name": "Chopper",
  "text": "I wonder if Nami's okay..."
 },
 {
  "i": 187,
  "style": "Main",
  "name": "Usopp",
  "text": "It wasn't like he wanted to exterminate her. We'll definitely be back to rescue her!"
 },
 {
  "i": 188,
  "style": "Main",
  "name": "Robin",
  "text": "By the way..."
 },
 {
  "i": 189,
  "style": "Main",
  "name": "Robin",
  "text": "That monster-like growl coming from upstairs..."
 },
 {
  "i": 190,
  "style": "Main",
  "name": "Robin",
  "text": "What was it?"
 },
 {
  "i": 191,
  "style": "Main",
  "name": "Franky",
  "text": "Yeah, we went there after we heard it."
 },
 {
  "i": 192,
  "style": "Main",
  "name": "Usopp",
  "text": "That was Luffy's voice..."
 },
 {
  "i": 193,
  "style": "Main",
  "name": "Usopp",
  "text": "We'll tell you everything we witnessed."
 },
 {
  "i": 194,
  "style": "Main",
  "name": "Usopp",
  "text": "Anyway... something terrible has happened!"
 },
 {
  "i": 195,
  "style": "Main",
  "name": "Zombie",
  "text": "Keep delivering more!"
 },
 {
  "i": 196,
  "style": "Main",
  "name": "Zombie",
  "text": "He hasn't had enough yet!"
 },
 {
  "i": 197,
  "style": "Main",
  "name": "Zombie",
  "text": "How much can the Special Zombie eat?!"
 },
 {
  "i": 198,
  "style": "Main",
  "name": "Zombie",
  "text": "He's gonna eat the whole island's provisions!"
 },
 {
  "i": 199,
  "style": "Main",
  "name": "Moria",
  "text": "What an amazing appetite."
 },
 {
  "i": 200,
  "style": "Main",
  "name": "Perona",
  "text": "Kumashi, why were you hiding those pirates?!"
 },
 {
  "i": 201,
  "style": "Main",
  "name": "Bearsy",
  "text": "But... that's..."
 },
 {
  "i": 202,
  "style": "Main",
  "name": "Perona",
  "text": "Stop talking, it's un-cute!"
 },
 {
  "i": 203,
  "style": "Main",
  "name": "Oars",
  "text": "Sorry, tiny leek."
 },
 {
  "i": 204,
  "style": "Main",
  "name": "Oars",
  "text": "I don't know you and yet you're feeding me."
 },
 {
  "i": 205,
  "style": "Main",
  "name": "Oars",
  "text": "Even though it tastes terrible and isn't enough."
 },
 {
  "i": 206,
  "style": "Main",
  "name": "Zombie",
  "text": "Damn you Special Zombie!"
 },
 {
  "i": 207,
  "style": "Main",
  "name": "Zombie",
  "text": "Don't act so cheeky!"
 },
 {
  "i": 208,
  "style": "Main",
  "name": "Zombie",
  "text": "Who do you think makes us, zombies, move?!"
 },
 {
  "i": 209,
  "style": "Main",
  "name": "Zombie",
  "text": "How can you even complain to the ruler of Thriller Bark?!"
 },
 {
  "i": 210,
  "style": "Main",
  "name": "Zombie",
  "text": "The Master will someday become ruler of this sea-"
 },
 {
  "i": 211,
  "style": "Main",
  "name": "Zombie",
  "text": "We're really sorry!"
 },
 {
  "i": 212,
  "style": "Main",
  "name": "Zombie",
  "text": "This guy said all that!"
 },
 {
  "i": 213,
  "style": "Main",
  "name": "Zombie",
  "text": "You, don't sell out your friends!"
 },
 {
  "i": 214,
  "style": "Main",
  "name": "Moria",
  "text": "Listen, Oars."
 },
 {
  "i": 215,
  "style": "Main",
  "name": "Moria",
  "text": "500 years ago you were a huge villain who left numerous legends behind."
 },
 {
  "i": 216,
  "style": "Main",
  "name": "Moria",
  "text": "And now you've been resurrected to become my servant in this present day."
 },
 {
  "i": 217,
  "style": "Main",
  "name": "Oars",
  "text": "Servant?"
 },
 {
  "i": 218,
  "style": "Main",
  "name": "Oars",
  "text": "I don't want that."
 },
 {
  "i": 219,
  "style": "Main",
  "name": "Oars",
  "text": "I have a dream."
 },
 {
  "i": 220,
  "style": "Main",
  "name": "Zombie",
  "text": "I've never seen such an insolent zombie!"
 },
 {
  "i": 221,
  "style": "Main",
  "name": "Oars",
  "text": "It's cramped and boring here."
 },
 {
  "i": 222,
  "style": "Main",
  "name": "Oz",
  "text": "I'm gonna go outside for a bit."
 },
 {
  "i": 223,
  "style": "Main",
  "name": "Oz",
  "text": "Maybe go out to sea and go around the world."
 },
 {
  "i": 224,
  "style": "Main",
  "name": "Zombie",
  "text": "Going on a trip?!"
 },
 {
  "i": 225,
  "style": "Main",
  "name": "Zombie",
  "text": "You blockhead, that's impossible."
 },
 {
  "i": 226,
  "style": "Main",
  "name": "Zombie",
  "text": "This special freezer is made from super dense steel and it's completely sealed."
 },
 {
  "i": 227,
  "style": "Main",
  "name": "Zombie",
  "text": "You won't be able to scratch it in the leas-"
 },
 {
  "i": 228,
  "style": "Main",
  "name": "Oz",
  "text": "{\\fad(100,100)}Rubber..."
 },
 {
  "i": 229,
  "style": "Main",
  "name": "Oz",
  "text": "{\\fad(100,100)}Pistol!"
 },
 {
  "i": 230,
  "style": "Main",
  "name": "Zombie",
  "text": "H-Hey! Wait!"
 },
 {
  "i": 231,
  "style": "Main",
  "name": "Zombie",
  "text": "This is terrible, Oars has escaped!"
 },
 {
  "i": 232,
  "style": "Main",
  "name": "Oars",
  "text": "Strange..."
 },
 {
  "i": 233,
  "style": "Main",
  "name": "Oars",
  "text": "I had a feeling that my arm would stretch but... well, whatever."
 },
 {
  "i": 234,
  "style": "Main",
  "name": "Oz",
  "text": "I'm gonna be... the Pirate King!"
 },
 {
  "i": 235,
  "style": "Main",
  "name": "Ryuma",
  "text": "Just like then..."
 },
 {
  "i": 236,
  "style": "Main",
  "name": "Ryuuma",
  "text": "Pleading \"not the afro\", \"not the afro\"... You'll wind up shamelessly begging me for your life again."
 },
 {
  "i": 237,
  "style": "Main",
  "name": "Brookb",
  "text": "No!"
 },
 {
  "i": 238,
  "style": "Main",
  "name": "Brook",
  "text": "It won't go that way!"
 },
 {
  "i": 239,
  "style": "Thoughts",
  "name": "Brook",
  "text": "{\\i1}It's pointless.{\\i0}"
 },
 {
  "i": 240,
  "style": "Thoughts",
  "name": "Brook",
  "text": "{\\i1}Even if I muster my courage and cut them, those scary zombies keep getting up!{\\i0}"
 },
 {
  "i": 241,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "They definitely must have a weakness."
 },
 {
  "i": 242,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "At this rate, even if I find my own zombie, there wouldn't be anything I could do."
 },
 {
  "i": 243,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "More than anything, zombies' faces are just too scary!"
 },
 {
  "i": 244,
  "style": "Flashbacks",
  "name": "Zombie",
  "text": "One of ours was purified!"
 },
 {
  "i": 245,
  "style": "Flashbacks",
  "name": "Zombie",
  "text": "What happened?!"
 },
 {
  "i": 246,
  "style": "Flashbacks",
  "name": "Zombie",
  "text": "He was hungry and ate some salty grilled fish."
 },
 {
  "i": 247,
  "style": "Flashbacks",
  "name": "Zombie",
  "text": "Idiot, he was a newcomer."
 },
 {
  "i": 248,
  "style": "Thoughts",
  "name": "Brook",
  "text": "{\\i1}This must be the zombies' weakness!{\\i0}"
 },
 {
  "i": 249,
  "style": "Flashbacks",
  "name": "Hogback",
  "text": "You! You're the skeleton whose shadow we stole a few days ago."
 },
 {
  "i": 250,
  "style": "Flashbacks",
  "name": "Hogback",
  "text": "How did you get back here?"
 },
 {
  "i": 251,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "Answer my question!"
 },
 {
  "i": 252,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "Which zombie has my shadow?"
 },
 {
  "i": 253,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "If you don't answer, I'll scatter fish all over the island!"
 },
 {
  "i": 254,
  "style": "Flashbacks",
  "name": "Hogback",
  "text": "Fish...?"
 },
 {
  "i": 255,
  "style": "Flashbacks",
  "name": "Hogback",
  "text": "And how's that gonna affect me?"
 },
 {
  "i": 256,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "That's..."
 },
 {
  "i": 257,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "No way..."
 },
 {
  "i": 258,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "But, I don't think it could be salt..."
 },
 {
  "i": 259,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "Salt...?"
 },
 {
  "i": 260,
  "style": "Flashbacks",
  "name": "Hogback",
  "text": "A-And h-how is salt g-gonna do any good?!"
 },
 {
  "i": 261,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "It's salt!"
 },
 {
  "i": 262,
  "style": "Thoughts",
  "name": "Brook",
  "text": "{\\i1}Zombies are really, really scary after all.{\\i0}"
 },
 {
  "i": 263,
  "style": "Thoughts",
  "name": "Brook",
  "text": "{\\i1}It's even worse during the night.{\\i0}"
 },
 {
  "i": 264,
  "style": "Flashbacks",
  "name": "Brooke",
  "text": "What, it was just a grasshopper."
 },
 {
  "i": 265,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "It scared me."
 },
 {
  "i": 266,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "Nonetheless, it's even more dangerous when the sun is shining, and it's easy to be found by the enemy."
 },
 {
  "i": 267,
  "style": "Flashbacks",
  "name": "Brooke",
  "text": "That's it!"
 },
 {
  "i": 268,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "Sing!"
 },
 {
  "i": 269,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "When you're scared you should sing a song to take your mind off things!"
 },
 {
  "i": 270,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "I'll be able to purify them if I don't look at their faces by using my skeleton speed."
 },
 {
  "i": 271,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "Then, I'll definitely find my shadow!"
 },
 {
  "i": 272,
  "style": "Flashbacks",
  "name": "Zombie",
  "text": "What's this song?"
 },
 {
  "i": 273,
  "style": "Flashbacks",
  "name": "Zombie",
  "text": "Someone's humming."
 },
 {
  "i": 274,
  "style": "Flashbacks",
  "name": "Zombie",
  "text": "Who is it?!"
 },
 {
  "i": 275,
  "style": "Flashbacks",
  "name": "Absalom",
  "text": "What's wrong?!"
 },
 {
  "i": 276,
  "style": "Flashbacks",
  "name": "Absalom",
  "text": "What's all the ruckus on the island about?!"
 },
 {
  "i": 277,
  "style": "Flashbacks",
  "name": "Zombie",
  "text": "There's a warrior with a scary face who appears when you hear humming in the darkness!"
 },
 {
  "i": 278,
  "style": "Flashbacks",
  "name": "Zombie",
  "text": "He's going around trying to find his shadow!"
 },
 {
  "i": 279,
  "style": "Flashbacks",
  "name": "Zombie",
  "text": "He already annihilated most of the Soldier Zombies!"
 },
 {
  "i": 280,
  "style": "Flashbacks",
  "name": "Zombie",
  "text": "Please do something!"
 },
 {
  "i": 281,
  "style": "Flashbacks",
  "name": "Bearsy",
  "text": "Perona-sama, there's trouble..."
 },
 {
  "i": 282,
  "style": "Flashbacks",
  "name": "Perona",
  "text": "Shut up!"
 },
 {
  "i": 283,
  "style": "Flashbacks",
  "name": "Perona",
  "text": "Don't wake me, Kumashi..."
 },
 {
  "i": 284,
  "style": "Flashbacks",
  "name": "Bearsy",
  "text": "Please wake up..."
 },
 {
  "i": 285,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "We finally meet."
 },
 {
  "i": 286,
  "style": "Thoughts",
  "name": "Brook",
  "text": "{\\i1}What's with this strength?{\\i0}"
 },
 {
  "i": 287,
  "style": "Thoughts",
  "name": "Brook",
  "text": "{\\i1}Isn't this my zombie...?{\\i0}"
 },
 {
  "i": 288,
  "style": "Thoughts",
  "name": "Brooke",
  "text": "{\\i1}I can't keep up with him at all!{\\i0}"
 },
 {
  "i": 289,
  "style": "Thoughts",
  "name": "Brooke",
  "text": "{\\i1}Even though we share the same sword style!{\\i0}"
 },
 {
  "i": 290,
  "style": "Flashbacks",
  "name": "Ryuuma",
  "text": "Give up."
 },
 {
  "i": 291,
  "style": "Flashbacks",
  "name": "Ryuuma",
  "text": "Regardless of how many times you try, it'll be the same."
 },
 {
  "i": 292,
  "style": "Flashbacks",
  "name": "Ryuuma",
  "text": "If you try to move quicker, I'll cut off that ridiculous afro of yours."
 },
 {
  "i": 293,
  "style": "Flashbacks",
  "name": "Brooke",
  "text": "P-Please don't!"
 },
 {
  "i": 294,
  "style": "Flashbacks",
  "name": "Brooke",
  "text": "Please don't touch the afro!"
 },
 {
  "i": 295,
  "style": "Flashbacks",
  "name": "Brooke",
  "text": "Please!"
 },
 {
  "i": 296,
  "style": "Flashbacks",
  "name": "Brooke",
  "text": "Why don't you know?!"
 },
 {
  "i": 297,
  "style": "Flashbacks",
  "name": "Brooke",
  "text": "If you're my shadow, then why don't you know how important this afro is?"
 },
 {
  "i": 298,
  "style": "Flashbacks",
  "name": "Brooke",
  "text": "Since my body no longer ages, it'll never grow again!"
 },
 {
  "i": 299,
  "style": "Flashbacks",
  "name": "Ryuuma",
  "text": "Why, you ask?"
 },
 {
  "i": 300,
  "style": "Flashbacks",
  "name": "Ryuuma",
  "text": "I've forgotten everything about my days with you."
 },
 {
  "i": 301,
  "style": "Flashbacks",
  "name": "Ryuuma",
  "text": "Right now, I only obey Moriah-sama and Absalom-sama!"
 },
 {
  "i": 302,
  "style": "Flashbacks",
  "name": "Ryuuma",
  "text": "A skeleton who treasures his afro is nothing but a joke to me!"
 },
 {
  "i": 303,
  "style": "Flashbacks",
  "name": "Brook",
  "text": "Stop!"
 },
 {
  "i": 304,
  "style": "Flashbacks",
  "name": "Brooke",
  "text": "Not the afro!"
 },
 {
  "i": 305,
  "style": "Flashbacks",
  "name": "Brooke",
  "text": "Not the afro!"
 },
 {
  "i": 306,
  "style": "Flashbacks",
  "name": "Brooke",
  "text": "Not the afro!"
 },
 {
  "i": 307,
  "style": "Flashbacks",
  "name": "Brooke",
  "text": "Not the afro!"
 },
 {
  "i": 308,
  "style": "Flashbacks",
  "name": "Ryuuma",
  "text": "What a miserable look, my former master."
 },
 {
  "i": 309,
  "style": "Flashbacks",
  "name": "Brooke",
  "text": "I'm sorry... I've lost..."
 },
 {
  "i": 310,
  "style": "Flashbacks",
  "name": "Brooke",
  "text": "Please let me off..."
 },
 {
  "i": 311,
  "style": "Flashbacks",
  "name": "Brooke",
  "text": "I'll leave this island immediately."
 },
 {
  "i": 312,
  "style": "Flashbacks",
  "name": "Ryuuma",
  "text": "Then, get out of my sight."
 },
 {
  "i": 313,
  "style": "Flashbacks",
  "name": "Ryuuma",
  "text": "It'll be troublesome for me if you die."
 },
 {
  "i": 314,
  "style": "Main",
  "name": "Ryuuma",
  "text": "It was a pathetic sight."
 },
 {
  "i": 315,
  "style": "Main",
  "name": "Brooke",
  "text": "Say anything you want."
 },
 {
  "i": 316,
  "style": "Main",
  "name": "Brooke",
  "text": "These past five years..."
 },
 {
  "i": 317,
  "style": "Main",
  "name": "Brooke",
  "text": "Just for this moment...!"
 },
 {
  "i": 318,
  "style": "Main",
  "name": "Brooke",
  "text": "I became stronger!"
 },
 {
  "i": 319,
  "style": "Main",
  "name": "Zombie",
  "text": "Absalom-sama."
 },
 {
  "i": 320,
  "style": "Main",
  "name": "Absalom",
  "text": "Is everything ready for the ceremony?"
 },
 {
  "i": 321,
  "style": "Main",
  "name": "Zombie",
  "text": "Anytime you want."
 },
 {
  "i": 322,
  "style": "Main",
  "name": "Zombie",
  "text": "What a beautiful bride!"
 },
 {
  "i": 323,
  "style": "Main",
  "name": "Absalom",
  "text": "We'll start the ceremony immediately."
 },
 {
  "i": 324,
  "style": "Main",
  "name": "Absalom",
  "text": "Put her in a dress and bring her to the ceremonial hall."
 },
 {
  "i": 325,
  "style": "Main",
  "name": "Zombie",
  "text": "Yes, right away."
 },
 {
  "i": 326,
  "style": "Main",
  "name": "Franky",
  "text": "A monster bigger than giants?!"
 },
 {
  "i": 327,
  "style": "Main",
  "name": "Usopp",
  "text": "Yes..."
 },
 {
  "i": 328,
  "style": "Main",
  "name": "Usopp",
  "text": "That incredible noise and roar were his doing."
 },
 {
  "i": 329,
  "style": "Main",
  "name": "Usopp",
  "text": "I can only imagine that's Luffy's zombie roaring and rampaging."
 },
 {
  "i": 330,
  "style": "Main",
  "name": "Usopp",
  "text": "Let's hurry!"
 },
 {
  "i": 331,
  "style": "Main",
  "name": "Usopp",
  "text": "Hey, look!"
 },
 {
  "i": 332,
  "style": "Main",
  "name": "Usopp",
  "text": "There's the Sunny!"
 },
 {
  "i": 333,
  "style": "Main",
  "name": "Franky",
  "text": "I see..."
