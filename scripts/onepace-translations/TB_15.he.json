"},{"i":166,"he":"אנחנו חברות."},{"i":167,"he":"אבל... אז פחדתי ממך, אז שיקרתי..."},{"i":168,"he":"אני מצטערת."},{"i":169,"he":"אני באמת אישה."},{"i":170,"he":"טיפשונת שכמותך."},{"i":171,"he":"ידעתי."},{"i":172,"he":"לולה."},{"i":173,"he":"מה שיותר חשוב! אדון אב לא מוגן כרגע!"},{"i":174,"he":"אתה תהיה בעלי עכשיו, אבסלום!"},{"i":175,"he":"אתה כאן?!"},{"i":176,"he":"תצא החוצה, כובע קש!"},{"i":177,"he":"אישה!"},{"i":178,"he":"גיבור מגניב!"},{"i":179,"he":"איך קראו לו?"},{"i":180,"he":"בוא נראה..."},{"i":181,"he":"אני בטוח שזה היה רוס."},{"i":182,"he":"לא, טעית."},{"i":183,"he":"זה נגמר ב... \"רס\"."},{"i":184,"he":"פיוז."},{"i":185,"he":"וואו, זה ניחוש פרוע."},{"i":186,"he":"יואארס?"},{"i":187,"he":"עדיין חסר משהו..."},{"i":188,"he":"אורס."},{"i":189,"he":"זהו זה!"},{"i":190,"he":"סליחה... אני מצטער, אבל הגוף שלי..."},{"i":191,"he":"כן, אל תדאג."},{"i":192,"he":"אתה עדיין יכול לזוז?"},{"i":193,"he":"כן."},{"i":194,"he":"אז תזוז הצידה."},{"i":195,"he":"היי, אורס!"},{"i":196,"he":"אם הצל של לופי בתוכך..."},{"i":197,"he":"אז אתה כבר אמור לדעת שאסור לך אף פעם..."},{"i":198,"he":"לזלזל בכוח של חברי הצוות שלך."},{"i":199,"he":"אתם חבורה קשוחה, פיראטים קטנים."},{"i":200,"he":"יש לי הצעה לכולכם..."},{"i":201,"he":"מה דעתכם שנהפוך את הבחור הזה?"},{"i":202,"he":"אני מבין."},{"i":203,"he":"זה בהחלט יהיה נחמד."},{"i":204,"he":"ר-רגע אחד!"},{"i":205,"he":"ל-להפוך?!"},{"i":206,"he":"את הדבר הענק הזה?!"},{"i":207,"he":"אבל, עם הגודל העצום הזה,\\Nהמתקפות של לופי מרשימות יותר."},{"i":208,"he":"אבל הוא ממש לא נראה כמו \"מלך פיראטים\"."},{"i":209,"he":"איך נתקוף?"},{"i":210,"he":"יש אינסוף דרכים לעשות את זה."},{"i":211,"he":"בטח יש לו חולשה."},{"i":212,"he":"כשתופסים דג גדול, הטקטיקה הכי נפוצה\\Nהיא להחליש אותו לאט לאט."},{"i":213,"he":"אם זו התוכנית, אז אני..."},{"i":214,"he":"מפוחד מדי."},{"i":215,"he":"אני אמעך אתכם!"},{"i":216,"he":"הנה הוא בא!"},{"i":217,"he":"גומי..."},{"i":218,"he":"חבטת ישבן!"},{"i":219,"he":"איזו מין מתקפה זו?!"},{"i":220,"he":"תתפזרו!"},{"i":221,"he":"מגל!"},{"i":222,"he":"מנוול."},{"i":223,"he":"במקרה הזה, אני אראה לך..."},{"i":224,"he":"את הכוח המשולב שלנו!"},{"i":225,"he":"שניכם!"},{"i":226,"he":"בואו נעשה את זה!"},{"i":227,"he":"טקטיקה חמש-עשרה!"},{"i":228,"he":"מה?!"},{"i":229,"he":"אין מצב..."},{"i":230,"he":"אנחנו עומדים להשתמש ב\"זה\" כאן?!"},{"i":231,"he":"זורו!"},{"i":232,"he":"תלתל!"},{"i":233,"he":"תהיו מוכנים!"},{"i":234,"he":"פשוט תחזיקו לי את הרגליים!"},{"i":235,"he":"מה הוא זומם?"},{"i":236,"he":"קדימה!"},{"i":237,"he":"עגינת הפיראטים 6..."},{"i":238,"he":"לוחם הרובוט הענק..."},{"i":239,"he":"הקיסר הגדול!"},{"i":240,"he":"רגע אחד, פרנקי!"},{"i":241,"he":"היד השמאלית עוד לא נעגנה!"},{"i":242,"he":"מה?!"},{"i":243,"he":"היי, למה את מחכה, ניקו רובין?!"},{"i":244,"he":"תזדרזי ותיעגני ליד השמאלית שלי!"},{"i":245,"he":"רובין, מהר!"},{"i":246,"he":"בואי, רובין!"},{"i":247,"he":"תעשי כמוני!"},{"i":248,"he":"בשביל בן אדם, זה מביש."},{"i":249,"he":"למה הפסקתם?"},{"i":250,"he":"למה גם אתה בהלם?!"},{"i":251,"he":"התחלתי להתרגש."},{"i":252,"he":"תעשו את זה!"},{"i":253,"he":"את העגינה!"},{"i":254,"he":"איזה אבסורד! אני לא מאמין\\Nשהם גרמו לי לעשות דבר כזה."},{"i":255,"he":"לא, תשכחו שזה קרה."},{"i":256,"he":"רובין, אם היית מצטרפת, היינו משלימים\\Nאת לוחם הרובוט, הקיסר הגדול!"},{"i":257,"he":"מעולם לא חשבתי שתבגדי בנו! מעולם!"},{"i":258,"he":"לופי היה עושה את זה!"},{"i":259,"he":"אל תבקשו ממני שוב לעולם..."},{"i":260,"he":"לבצע את העגינה שלכם."},{"i":261,"he":"הגיע זמן הנקמה, מנוול!"},{"i":262,"he":"פרנקי!"},{"i":263,"he":"אני הולך לשאול את הדבר הענק הזה!"},{"i":264,"he":"אתה! זה הנונצ'אקו הכבד שלי!"},{"i":265,"he":"אין מה לעשות,"},{"i":266,"he":"אני אשאיל לך אותו!"},{"i":267,"he":"מנוול שכמוך."},{"i":268,"he":"אני חייב להזדרז וללכת\\Nלהציל מחדש את גברת נאמי!"},{"i":269,"he":"אתה?"},{"i":270,"he":"רובין!"},{"i":271,"he":"ברגע שאגיע ליד השמאלית שלו, תטפלי במפרק!"},{"i":272,"he":"הבנתי."},{"i":273,"he":"גברת פרונה!"},{"i":274,"he":"המקרר כבר מלא!"},{"i":275,"he":"שום דבר אחר לא ייכנס."},{"i":276,"he":"עוד יש את המזווה, לא?"},{"i":277,"he":"קיבלתי."},{"i":278,"he":"תזדרזו עם האוצר!"},{"i":279,"he":"תעמיסו את כל מה שנשאר!"},{"i":280,"he":"קיבלנו!"},{"i":281,"he":"תאכל את זה!"},{"i":282,"he":"כוכב שמן מיוחד קטלני!"},{"i":283,"he":"יריית"},{"i":284,"he":"משו"},{"i":285,"he":"לשת!"},{"i":286,"he":"היי, גבה מתולתלת!"},{"i":287,"he":"תזרוק אותי!"},{"i":288,"he":"לסחוב דבר ענק כזה...?"},{"i":289,"he":"זה בסדר אם אתה לא מסוגל!"},{"i":290,"he":"מנוול!"},{"i":291,"he":"ברור שאני מסוגל, אידיוט!"},{"i":292,"he":"ארמה דה ל'אר..."},{"i":293,"he":"צבא האוויר"},{"i":294,"he":"בעיטת עוצמה!"},{"i":295,"he":"מהלומת חרב אדירה!"},{"i":296,"he":"סיין פלר..."},{"i":297,"he":"מאה פרחים"},{"i":298,"he":"עץ ענק!"},{"i":299,"he":"מ-מה?"},{"i":300,"he":"מ-מסוכן... אני נופל! אני נופל!"},{"i":301,"he":"הביטו!"},{"i":302,"he":"המדרגות המיידיות שלי באוויר!"},{"i":303,"he":"פרנקי סקייווק!"},{"i":304,"he":"אבל... הדריכה הזו לא תחזיק עוד הרבה זמן!"},{"i":305,"he":"בוא נזוז כבר, צ'ופר!"},{"i":306,"he":"אוקי!"},{"i":307,"he":"סופר..."},{"i":308,"he":"פראפה..."},{"i":309,"he":"גונג!"},{"i":310,"he":"בלי קשר לגודל, לגוף האדם\\Nתמיד יש את אותן נקודות תורפה."},{"i":311,"he":"מכה בלסת תנער לך קצת את המוח."},{"i":312,"he":"עכשיו המשענת היחידה שלך\\Nהיא הרגל הבודדת הזו..."},{"i":313,"he":"לופי המפלצת."},{"i":314,"he":"חוסר נימוס..."},{"i":315,"he":"בעיטת..."},{"i":316,"he":"מסלול!"},{"i":317,"he":"הפך את המפלצת הזו לגמרי."},{"i":318,"he":"יופי! לך למטה!"},{"i":319,"he":"אחד למטה."},{"i":320,"he":"היי, היי! זה כבר לא נראה כמו אחוזה."},{"i":321,"he":"מה המהלכים האלה?!"},{"i":322,"he":"אקרובטיקה?!"},{"i":323,"he":"י-ייתכן ש..."},{"i":324,"he":"מישהו הפך אותו?"},{"i":325,"he":"נו, תשתמש בראש."},{"i":326,"he":"אפילו צבא של אלף איש לא היה מסוגל לדבר כזה."},{"i":327,"he":"אני אהיה בסדר, נאמיזו."},{"i":328,"he":"תמשיכי קדימה ותברחי."},{"i":329,"he":"תני לי להסביר את המצב הנוכחי."},{"i":330,"he":"לולה..."},{"i":331,"he":"החבר ההוא שלך, כובע הקש לופי..."},{"i":332,"he":"הזומבי המיוחד שמחזיק את הצל שלו\\Nמשתולל על פני כל האי."},{"i":333,"he":"זה הזומבי שראינו בחדר ההקפאה ההוא."},{"i":334,"he":"איזו צרה!"},{"i":335,"he":"איך נחזיר את הצל של לופי מהמפלצת הזו?!"},{"i":336,"he":"אבל..."},{"i":337,"he":"אין מצב שאני חוזרת בידיים ריקות\\Nאחרי שעברתי את הסיוט הזה!"},{"i":338,"he":"הנה זה!"},{"i":339,"he":"וזה לא נעול!"},{"i":340,"he":"מנוולים שכמוכם..."},{"i":341,"he":"נמאס לי מכם!"},{"i":342,"he":"אני אמחץ את כולכם!"},{"i":343,"he":"ממילא רק עקבתי אחרי אדון מוריה בשביל הכיף."},{"i":344,"he":"ברור שאני לא נשארת בסביבה\\Nאם החיים שלי בסכנה."},{"i":345,"he":"עכשיו, תזדרזו, כולכם!"},{"i":346,"he":"אנחנו צריכים להסתלק מכאן בהקדם האפשרי!"},{"i":347,"he":"כן."},{"i":348,"he":"יופי! תעמיסו את שאר האספקה!"},{"i":349,"he":"מי אתה?"},{"i":350,"he":"אתה לא זומבי, נכון?"},{"i":351,"he":"מה אתה עושה כאן?"},{"i":352,"he":"גוף ענק כזה..."},{"i":353,"he":"אתה נראה בדיוק כמו דוב."},{"i":354,"he":"דוב, הא?"},{"i":355,"he":"זו בדיוק התשובה הנכונה."},{"i":356,"he":"האם מוריה..."},{"i":357,"he":"נמצא כאן בסביבה?"}]