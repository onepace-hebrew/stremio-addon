 },
 {
  "i": 137,
  "style": "Note",
  "name": "",
  "text": "{\\fad(150,150)}Cherry Blossom Shoot"
 },
 {
  "i": 138,
  "style": "Main",
  "name": "Oz",
  "text": "You bastard!"
 },
 {
  "i": 139,
  "style": "Main",
  "name": "Oz",
  "text": "Why do you insist on attacking the same spot?!"
 },
 {
  "i": 140,
  "style": "Main",
