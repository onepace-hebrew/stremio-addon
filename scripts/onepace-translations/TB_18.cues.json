  "text": "Hey, Robin! Look out for the shadow behind you!"
 },
 {
  "i": 59,
  "style": "Main",
  "name": "Nami",
  "text": "What is Moriah doing here?!"
 },
 {
  "i": 60,
  "style": "Main",
  "name": "Moria",
  "text": "Pretty close."
 },
 {
  "i": 61,
  "style": "Main",
  "name": "Moria",
  "text": "But it's a shame for you,"
 },
 {
  "i": 62,
  "style": "Main",
  "name": "Moria",
  "text": "I can switch places with Doppelman any time I want."
 },
 {
  "i": 63,
  "style": "Main",
  "name": "Sanji",
  "text": "Switch places?"
 },
 {
  "i": 64,
  "style": "Main",
  "name": "Usopp",
  "text": "Then, the one over there is..."
 },
 {
  "i": 65,
  "style": "Main",
