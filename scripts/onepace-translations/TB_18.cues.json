 },
 {
  "i": 55,
  "style": "Main",
  "name": "Robin",
  "text": "{\\fad(150,150)}Clutch!"
 },
 {
  "i": 56,
  "style": "Main",
  "name": "Usopp",
  "text": "She did it!"
 },
 {
  "i": 57,
  "style": "Main",
  "name": "Nami",
  "text": "You're amazing, Robin!"
 },
 {
  "i": 58,
  "style": "Main",
