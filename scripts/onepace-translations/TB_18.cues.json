 {
  "i": 103,
  "style": "Main",
  "name": "Sanji",
  "text": "Chopper, what're you doing there?!"
 },
 {
  "i": 104,
  "style": "Main",
  "name": "Chopper",
  "text": "I was searching for Oars' cause of death five hundred years ago."
