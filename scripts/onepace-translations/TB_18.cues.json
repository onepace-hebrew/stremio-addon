 },
 {
  "i": 116,
  "style": "Main",
  "name": "Both",
  "text": "I can't believe we're losing to such an idiot!"
 },
 {
  "i": 117,
  "style": "Main",
  "name": "Chopper",
  "text": "Zombies may not feel pain, but the damage received remains."
 },
 {
  "i": 118,
  "style": "Main",
  "name": "Chopper",
  "text": "All of the attacks he's received have been accumulating!"
 },
 {
  "i": 119,
  "style": "Main",
  "name": "Chopper",
  "text": "If we get rid of this arm, his strength will be halved!"
 },
 {
  "i": 120,
  "style": "Main",
  "name": "Chopper",
  "text": "Anyway, aim for this spot{\\fscx250}-{\\r}"
 },
 {
  "i": 121,
  "style": "Main",
  "name": "Oz",
  "text": "Quit babbling, you tiny man on my shoulder!"
