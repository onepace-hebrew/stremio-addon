 {
  "i": 34,
  "style": "Main",
  "name": "Usopp",
  "text": "Good work, Robin!"
 },
 {
  "i": 35,
  "style": "Main",
  "name": "Moria",
  "text": "Is this how you intend to stop me?"
 },
 {
  "i": 36,
  "style": "Main",
  "name": "Moria",
  "text": "Such a pointless act."
 },
 {
  "i": 37,
  "style": "Main",
  "name": "Moria",
  "text": "{\\fad(150,150)}Brick Bat!"
 },
 {
  "i": 38,
  "style": "Main",
  "name": "Sanji",
  "text": "Robin-chan!"
 },
 {
  "i": 39,
  "style": "Main",
  "name": "Robin",
  "text": "{\\fad(150,150)}Veinte Fleur!"
 },
 {
  "i": 40,
  "style": "Note",
  "name": "Note",
  "text": "{\\fad(150,150)}Twenty Flowers"
 },
 {
  "i": 41,
  "style": "Main",
  "name": "Robin",
  "text": "{\\fad(150,150)}Calendula!"
 },
 {
  "i": 42,
  "style": "Note",
