  "i": 31,
  "style": "Title",
  "name": "",
  "text": "{\\fad(2000,2000)}The Crew's Annihilation!\\NOars vs. Nightmare Luffy"
 },
 {
  "i": 32,
  "style": "Main",
  "name": "Robin",
  "text": "{\\fad(150,150)}Hold!"
 },
 {
  "i": 33,
  "style": "Main",
  "name": "Moria",
  "text": "I can't{\\fscx250}-{\\r}"
