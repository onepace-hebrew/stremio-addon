  "text": "This hold of yours is quite effective!"
 },
 {
  "i": 48,
  "style": "Thoughts",
  "name": "Robin",
  "text": "I shouldn't pay attention to his shadow."
 },
 {
  "i": 49,
  "style": "Thoughts",
  "name": "Robin",
  "text": "If I bring down the body, the shadow will surely be annihilated as well."
 },
 {
  "i": 50,
  "style": "Main",
  "name": "Robin",
  "text": "{\\fad(150,150)}Cuatro Manos!"
 },
 {
  "i": 51,
