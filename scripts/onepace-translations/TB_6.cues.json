 {
  "i": 370,
  "style": "Main",
  "name": "Spider",
  "text": "These are my subordinates, the Spider Mice."
 },
 {
  "i": 371,
  "style": "Main",
  "name": "Spider",
  "text": "There are as many as 500 of them here on Thriller Bark."
 },
 {
  "i": 372,
  "style": "Main",
  "name": "Spider",
  "text": "We've never let even a single prey we've caught escape!"
 },
 {
  "i": 373,
  "style": "Main",
  "name": "Spider",
  "text": "We wait everywhere to ambush. From the darkness and blind spots we capture our enemy."
 },
 {
  "i": 374,
  "style": "Main",
  "name": "Spider",
  "text": "Our thread has been modified by Hogback-sama so that no human strength can tear it!"
 },
 {
  "i": 375,
  "style": "Main",
