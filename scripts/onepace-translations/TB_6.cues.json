[
 {
  "i": 0,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}Let's travel all through the worldwide seas,"
 },
 {
  "i": 1,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 2,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 3,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 4,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "We were able to escape from the set course"
 },
 {
  "i": 5,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "along the boundary between sky and sea."
 },
 {
  "i": 6,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now we're rowing our way"
 },
 {
  "i": 7,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "to a hidden adventure at the dark bottom of the sea."
 },
 {
  "i": 8,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Doesn't it sound fun just thinking about it?"
 },
 {
  "i": 9,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Let's travel all through the worldwide seas,"
 },
 {
  "i": 10,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 11,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 12,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 13,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}That feeling we had when we set sail"
 },
 {
  "i": 14,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "is something I'll never forget."
 },
 {
  "i": 15,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Because of that"
 },
 {
  "i": 16,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "nothing will be able to scare me..."
 },
 {
  "i": 17,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now, as the trip approaches, our racing heartbeats"
 },
 {
  "i": 18,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "engrave a rhythm of adventure in our shy hearts."
 },
 {
  "i": 19,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}Get all the treasures"
 },
 {
  "i": 20,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 21,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 22,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(50,50)}making a splash..."
 },
 {
  "i": 23,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Fill your empty heart with dreams."
 },
 {
  "i": 24,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Spread your wings."
 },
 {
  "i": 25,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you color your heart with the blowing wind"
 },
 {
  "i": 26,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "you will move on."
 },
 {
  "i": 27,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Get all the treasures"
 },
 {
  "i": 28,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 29,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 30,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "making a splash..."
 },
 {
  "i": 31,
  "style": "Title",
  "name": "",
  "text": "{\\fad(2000,2000}Number 900?!\\NLola's Pursuit and the Humming Swordsman"
 },
 {
  "i": 32,
  "style": "Main",
  "name": "Zombie",
  "text": "Hey, what're you doing newcomer?!"
 },
 {
  "i": 33,
  "style": "Main",
  "name": "Zombie",
  "text": "It's impossible for us, zombies, to betray our master's orders..."
 },
 {
  "i": 34,
  "style": "Main",
  "name": "Zombie",
  "text": "How come he's disobeying?!"
 },
 {
  "i": 35,
  "style": "Main",
  "name": "Zombie",
  "text": "Moreover, he's as powerful as a general grade!"
 },
 {
  "i": 36,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "Put simply, that unstoppable power..."
 },
 {
  "i": 37,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "The power to make the impossible possible..."
 },
 {
  "i": 38,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "The name of the hurricane that knocks down all obstacles is...!"
 },
 {
  "i": 39,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "Love!"
 },
 {
  "i": 40,
  "style": "Main",
  "name": "Nami",
  "text": "As I thought, all those ridiculous things that Dog Penguin is saying..."
 },
 {
  "i": 41,
  "style": "Main",
  "name": "Nami",
  "text": "Are almost like Sanji's."
 },
 {
  "i": 42,
  "style": "Main",
  "name": "Usopp",
  "text": "Hey, Dog Penguin!"
 },
 {
  "i": 43,
  "style": "Main",
  "name": "Usopp",
  "text": "Do you know something about Sanji?!"
 },
 {
  "i": 44,
  "style": "Main",
  "name": "Usopp",
  "text": "We're Sanji's friends, so..."
 },
 {
  "i": 45,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "Shut the hell up, pirates!"
 },
 {
  "i": 46,
  "style": "Secondary",
  "name": "Usopp",
  "text": "We're Sanji's friends, so..."
 },
 {
  "i": 47,
  "style": "Main",
  "name": "Usopp",
  "text": "He's our enemy after all!"
 },
 {
  "i": 48,
  "style": "Main",
  "name": "Usopp",
  "text": "What?"
 },
 {
  "i": 49,
  "style": "Main",
  "name": "Usopp",
  "text": "Now what?!"
 },
 {
  "i": 50,
  "style": "Main",
  "name": "Absalom",
  "text": "Wait, Lola!"
 },
 {
  "i": 51,
  "style": "Main",
  "name": "Both",
  "text": "A wild boar?"
 },
 {
  "i": 52,
  "style": "Main",
  "name": "Absalom",
  "text": "Hey!"
 },
 {
  "i": 53,
  "style": "Main",
  "name": "Absalom",
  "text": "Wait, Lola!"
 },
 {
  "i": 54,
  "style": "Main",
  "name": "Lola",
  "text": "Come and catch me!"
 },
 {
  "i": 55,
  "style": "Main",
  "name": "Nami",
  "text": "What?!"
 },
 {
  "i": 56,
  "style": "Main",
  "name": "Lola",
  "text": "I finally found you..."
 },
 {
  "i": 57,
  "style": "Main",
  "name": "Lola",
  "text": "Burglar Cat!"
 },
 {
  "i": 58,
  "style": "Main",
  "name": "Nami",
  "text": "Me?!"
 },
 {
  "i": 59,
  "style": "Main",
  "name": "Nami",
  "text": "W-Wait a minute!"
 },
 {
  "i": 60,
  "style": "Main",
  "name": "Nami",
  "text": "I haven't stolen anything yet!"
 },
 {
  "i": 61,
  "style": "Main",
  "name": "Lola",
  "text": "It's useless!"
 },
 {
  "i": 62,
  "style": "Main",
  "name": "Lola",
  "text": "I won't let you have Ab-sama!"
 },
 {
  "i": 63,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "Don't lay a hand on this lady."
 },
 {
  "i": 64,
  "style": "Main",
  "name": "Lola",
  "text": "Don't butt in!"
 },
 {
  "i": 65,
  "style": "Main",
  "name": "Usopp",
  "text": "Dog Penguin!"
 },
 {
  "i": 66,
  "style": "Main",
  "name": "Usopp",
  "text": "Why didn't he attack?!"
 },
 {
  "i": 67,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "Even if I die..."
 },
 {
  "i": 68,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "I'll never hurt a woman!"
 },
 {
  "i": 69,
  "style": "Main",
  "name": "Chopper",
  "text": "Amazing!"
 },
 {
  "i": 70,
  "style": "Main",
  "name": "Usopp",
  "text": "To figure out that thing was a woman, you sure are something!"
 },
 {
  "i": 71,
  "style": "Main",
  "name": "Nami",
  "text": "Usopp! Chopper!"
 },
 {
  "i": 72,
  "style": "Main",
  "name": "Absalom",
  "text": "I've got my bride!"
 },
 {
  "i": 73,
  "style": "Main",
  "name": "Both",
  "text": "Amazing, Nami is flying!"
 },
 {
  "i": 74,
  "style": "Main",
  "name": "Nami",
  "text": "Idiots, I'm being kidnapped!"
 },
 {
  "i": 75,
  "style": "Main",
  "name": "Chopper",
  "text": "By who?!"
 },
 {
  "i": 76,
  "style": "Main",
  "name": "Usopp",
  "text": "Wait!"
 },
 {
  "i": 77,
  "style": "Main",
  "name": "Absalom",
  "text": "Well then, we shall start the ceremony right away!"
 },
 {
  "i": 78,
  "style": "Main",
  "name": "Absalom",
  "text": "I've already made the preparations!"
 },
 {
  "i": 79,
  "style": "Main",
  "name": "Nami",
  "text": "Put me down!"
 },
 {
  "i": 80,
  "style": "Main",
  "name": "Nami",
  "text": "You're the invisible man who was in the bathroom, aren't you?!"
 },
 {
  "i": 81,
  "style": "Main",
  "name": "Usopp",
  "text": "Could that be for real?!"
 },
 {
  "i": 82,
  "style": "Main",
  "name": "Chopper",
  "text": "Nami!"
 },
 {
  "i": 83,
  "style": "Main",
  "name": "Absalom",
  "text": "I've evaluated you."
 },
 {
  "i": 84,
  "style": "Main",
  "name": "Absalom",
  "text": "You're most suitable to become my bride!"
 },
 {
  "i": 85,
  "style": "Main",
  "name": "Absalom",
  "text": "My name is Absalom!"
 },
 {
  "i": 86,
  "style": "Main",
  "name": "Absalom",
  "text": "It's the name of your future husband."
 },
 {
  "i": 87,
  "style": "Main",
  "name": "Absalom",
  "text": "Be sure to remember it!"
 },
 {
  "i": 88,
  "style": "Main",
  "name": "Nami",
  "text": "You've got some nerve spying on naked people!"
 },
 {
  "i": 89,
  "style": "Main",
  "name": "Nami",
  "text": "Keeping my body in shape everyday isn't something I do just to have some perverted beast spy on it!"
 },
 {
  "i": 90,
  "style": "Main",
  "name": "Nami",
  "text": "{\\fad(150,150)}Thunder Charge!"
 },
 {
  "i": 91,
  "style": "Main",
  "name": "Usopp",
  "text": "Nami!"
 },
 {
  "i": 92,
  "style": "Main",
  "name": "Usopp",
  "text": "Good job!"
 },
 {
  "i": 93,
  "style": "Main",
  "name": "Usopp",
  "text": "Let's just keep running!"
 },
 {
  "i": 94,
  "style": "Main",
  "name": "Usopp",
  "text": "We're getting outta this forest!"
 },
 {
  "i": 95,
  "style": "Main",
  "name": "Nami",
  "text": "What?!"
 },
 {
  "i": 96,
  "style": "Main",
  "name": "Nami",
  "text": "He hasn't fallen down!"
 },
 {
  "i": 97,
  "style": "Main",
  "name": "Usopp",
  "text": "He isn't just anyone, you can tell by looking at him!"
 },
 {
  "i": 98,
  "style": "Thoughts",
  "name": "Absalom",
  "text": "What... is this shock running through my body...?"
 },
 {
  "i": 99,
  "style": "Thoughts",
  "name": "Absalom",
  "text": "It's as if I had just been struck by a bolt of lightning!"
 },
 {
  "i": 100,
  "style": "Thoughts",
  "name": "Absalom",
  "text": "Perhaps... this is..."
 },
 {
  "i": 101,
  "style": "Thoughts",
  "name": "Absalom",
  "text": "Love?"
 },
 {
  "i": 102,
  "style": "Main",
  "name": "Lola",
  "text": "You won't get away from me!"
 },
 {
  "i": 103,
  "style": "Main",
  "name": "Zombies",
  "text": "Hey! This isn't time to stand without doing anything!"
 },
 {
  "i": 104,
  "style": "Main",
  "name": "Zombies",
  "text": "It is our job to capture those three!"
 },
 {
  "i": 105,
  "style": "Main",
  "name": "Zombies",
  "text": "You're right!"
 },
 {
  "i": 106,
  "style": "Main",
  "name": "Zombies",
  "text": "If we fail, Perona-sama's punishment awaits us!"
 },
 {
  "i": 107,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "No! They're going after that lady!"
 },
 {
  "i": 108,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "But, why am I protecting that girl?!"
 },
 {
  "i": 109,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "Moreover, I can't move...!"
 },
 {
  "i": 110,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "This body is too weak!"
 },
 {
  "i": 111,
  "style": "Main",
  "name": "Zombies",
  "text": "Hurry up and catch those three!"
 },
 {
  "i": 112,
  "style": "Main",
  "name": "Absalom",
  "text": "Wait, Wild Zombies!"
 },
 {
  "i": 113,
  "style": "Main",
  "name": "Absalom",
  "text": "Don't lay a hand on that woman!"
 },
 {
  "i": 114,
  "style": "Main",
  "name": "Zombies",
  "text": "Shut up, Perv-salom!"
 },
 {
  "i": 115,
  "style": "Main",
  "name": "Zombies",
  "text": "We receive orders from the master, but we're Perona-sama's subordinates!"
 },
 {
  "i": 116,
  "style": "Main",
  "name": "Absalom",
  "text": "I said wait!"
 },
 {
  "i": 117,
  "style": "Main",
  "name": "Absalom",
  "text": "I'm aware that you are Perona's underlings."
 },
 {
  "i": 118,
  "style": "Main",
  "name": "Absalom",
  "text": "However...!"
 },
 {
  "i": 119,
  "style": "Main",
  "name": "Absalom",
  "text": "You should still know not to make me angry."
 },
 {
  "i": 120,
  "style": "Main",
  "name": "Absalom",
  "text": "Don't push your luck."
 },
 {
  "i": 121,
  "style": "Main",
  "name": "Absalom",
  "text": "What do you want?!"
 },
 {
  "i": 122,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "I won't let you... go after that lady."
 },
 {
  "i": 123,
  "style": "Main",
  "name": "Zombies",
  "text": "H-Hey, newcomer, stop!"
 },
 {
  "i": 124,
  "style": "Main",
  "name": "Zombies",
  "text": "Don't anger Absalom!"
 },
 {
  "i": 125,
  "style": "Main",
  "name": "Lola",
  "text": "Wait, Burglar Cat!"
 },
 {
  "i": 126,
  "style": "Main",
  "name": "Usopp",
  "text": "Hey, Nami! She seems to be only after you!"
 },
 {
  "i": 127,
  "style": "Main",
  "name": "Nami",
  "text": "You're right! What did I do?!"
 },
 {
  "i": 128,
  "style": "Main",
  "name": "Usopp",
  "text": "Why don't we split into two groups and escape?"
 },
 {
  "i": 129,
  "style": "Main",
  "name": "Nami",
  "text": "You wanna leave me, cold-hearted monster?!"
 },
 {
  "i": 130,
  "style": "Main",
  "name": "Lola",
  "text": "Come here, damn it!"
 },
 {
  "i": 131,
  "style": "Main",
  "name": "Chopper",
  "text": "The wild boar is so scary!"
 },
 {
  "i": 132,
  "style": "Main",
  "name": "Franky",
  "text": "Could it be that they..."
 },
 {
  "i": 133,
  "style": "Flashbacks",
  "name": "Luffy",
  "text": "What're you bastards doing?!"
 },
 {
  "i": 134,
  "style": "Flashbacks",
  "name": "Luffy",
  "text": "Let me out!"
 },
 {
  "i": 135,
  "style": "Main",
  "name": "Franky",
  "text": "just like Straw Hat now, were drawn into the other side of the wall?"
 },
 {
  "i": 136,
  "style": "Main",
  "name": "Spider",
  "text": "Monkey! Monkey!"
 },
 {
  "i": 137,
  "style": "Main",
  "name": "Spider",
  "text": "And soon you'll share the same fate!"
 },
 {
  "i": 138,
  "style": "Main",
  "name": "Spider",
  "text": "You have invulnerable zombies coming from both sides."
 },
 {
  "i": 139,
  "style": "Main",
  "name": "Spider",
  "text": "Just give it up!"
 },
 {
  "i": 140,
  "style": "Main",
  "name": "Franky",
  "text": "I can't figure out whether you're a dumbass spider or a dumbass monkey, but..."
 },
 {
  "i": 141,
  "style": "Main",
  "name": "Franky",
  "text": "That huge spiderweb that the Sunny got caught in when we landed was your doing, wasn't it?"
 },
 {
  "i": 142,
  "style": "Main",
  "name": "Spider",
  "text": "That's right!"
 },
 {
  "i": 143,
  "style": "Main",
  "name": "Spider",
  "text": "All of your actions head right to Perona-sama's Ghost Network."
 },
 {
  "i": 144,
  "style": "Main",
  "name": "Robin",
  "text": "I wonder if those big ears also contribute to the info gathering."
 },
 {
  "i": 145,
  "style": "Main",
  "name": "Robin",
  "text": "They look like they could hear very well."
 },
 {
  "i": 146,
  "style": "Main",
  "name": "Spider",
  "text": "What did you say just now?"
 },
 {
  "i": 147,
  "style": "Main",
  "name": "Franky",
  "text": "Stop pretending!"
 },
 {
  "i": 148,
  "style": "Main",
  "name": "Franky",
  "text": "It's the worst case scenario."
 },
 {
  "i": 149,
  "style": "Main",
  "name": "Franky",
  "text": "We're completely surrounded."
 },
 {
  "i": 150,
  "style": "Main",
  "name": "Franky",
  "text": "It seems we urgently need a counter-measure."
 },
 {
  "i": 151,
  "style": "Main",
  "name": "Franky",
  "text": "Shall I take care of this?!"
 },
 {
  "i": 152,
  "style": "Main",
  "name": "Robin",
  "text": "Do as you wish."
 },
 {
  "i": 153,
  "style": "Main",
  "name": "Robin",
  "text": "I'll try to deal with it."
 },
 {
  "i": 154,
  "style": "Main",
  "name": "Franky",
  "text": "I'm pretty reliable actually."
 },
 {
  "i": 155,
  "style": "Main",
  "name": "Franky",
  "text": "Well then, let's get started!"
 },
 {
  "i": 156,
  "style": "Main",
  "name": "Spider",
  "text": "Wait! What're you gonna do?!"
 },
 {
  "i": 157,
  "style": "Secondary",
  "name": "Franky",
  "text": "{\\fad(150,150)}Coup de..."
 },
 {
  "i": 158,
  "style": "Main",
  "name": "Franky",
  "text": "{\\fad(150,150)}Vent!"
 },
 {
  "i": 159,
  "style": "Main",
  "name": "Spider",
  "text": "Wh...aaat?!"
 },
 {
  "i": 160,
  "style": "Main",
  "name": "Spider",
  "text": "You... destroyed the bridge?!"
 },
 {
  "i": 161,
  "style": "Main",
  "name": "Franky",
  "text": "Well, that's how it is."
 },
 {
  "i": 162,
  "style": "Main",
  "name": "Robin",
  "text": "As violent as always."
 },
 {
  "i": 163,
  "style": "Main",
  "name": "Robin",
  "text": "{\\fad(150,150)}Cien Fleur..."
 },
 {
  "i": 164,
  "style": "Note",
  "name": "Robin",
  "text": "{\\fad(150,150)}One Hundred Flowers"
 },
 {
  "i": 165,
  "style": "Main",
  "name": "Robin",
  "text": "{\\fad(150,150)}Wing!"
 },
 {
  "i": 166,
  "style": "Main",
  "name": "Franky",
  "text": "You! You can fly?!"
 },
 {
  "i": 167,
  "style": "Main",
  "name": "Robin",
  "text": "Yes, for about five seconds."
 },
 {
  "i": 168,
  "style": "Main",
  "name": "Franky",
  "text": "Too short!"
 },
 {
  "i": 169,
  "style": "Main",
  "name": "Franky",
  "text": "No... but it's long enough."
 },
 {
  "i": 170,
  "style": "Main",
  "name": "Franky",
  "text": "{\\fad(150,150)}Strong Right!"
 },
 {
  "i": 171,
  "style": "Main",
  "name": "Franky",
  "text": "Alright! Got it!"
 },
 {
  "i": 172,
  "style": "Main",
  "name": "Franky",
  "text": "Now if we can just make it to that entrance, we can follow Straw Hat!"
 },
 {
  "i": 173,
  "style": "Main",
  "name": "Robin",
  "text": "I'm sorry."
 },
 {
  "i": 174,
  "style": "Main",
  "name": "Robin",
  "text": "This is my limit."
 },
 {
  "i": 175,
  "style": "Main",
  "name": "Franky",
  "text": "Pulling arm!"
 },
 {
  "i": 176,
  "style": "Main",
  "name": "Robin",
  "text": "Everyone seems to have fallen into the courtyard."
 },
 {
  "i": 177,
  "style": "Main",
  "name": "Robin",
  "text": "This doesn't mean it's over, but..."
 },
 {
  "i": 178,
  "style": "Main",
  "name": "Robin",
  "text": "They won't follow us for now."
 },
 {
  "i": 179,
  "style": "Main",
  "name": "Robin",
  "text": "That went fairly well."
 },
 {
  "i": 180,
  "style": "Main",
  "name": "Franky",
  "text": "You bastard!"
 },
 {
  "i": 181,
  "style": "Main",
  "name": "Franky",
  "text": "How dare you use me as a stepping stone?!"
 },
 {
  "i": 182,
  "style": "Main",
  "name": "Spider",
  "text": "Damn you!"
 },
 {
  "i": 183,
  "style": "Main",
  "name": "Spider",
  "text": "This is unforgivable!"
 },
 {
  "i": 184,
  "style": "Main",
  "name": "Spider",
  "text": "I'm a spider!"
 },
 {
  "i": 185,
  "style": "Main",
  "name": "Spider",
  "text": "I'll get back there in no time!"
 },
 {
  "i": 186,
  "style": "Main",
  "name": "Zombie",
  "text": "What is... that?"
 },
 {
  "i": 187,
  "style": "Main",
  "name": "Franky",
  "text": "What the...?"
 },
 {
  "i": 188,
  "style": "Main",
  "name": "Franky",
  "text": "Is something... falling?"
 },
 {
  "i": 189,
  "style": "Main",
  "name": "Franky",
  "text": "No!"
 },
 {
  "i": 190,
  "style": "Main",
  "name": "Franky",
  "text": "Someone is coming!"
 },
 {
  "i": 191,
  "style": "Main",
  "name": "Brook",
  "text": "Only bones!"
 },
 {
  "i": 192,
  "style": "Main",
  "name": "Brook",
  "text": "Bone!"
 },
 {
  "i": 193,
  "style": "Main",
  "name": "Usopp",
  "text": "Hey, stop! Stop it!"
 },
 {
  "i": 194,
  "style": "Main",
  "name": "Usopp",
  "text": "Don't kill her! She's our friend!"
 },
 {
  "i": 195,
  "style": "Main",
  "name": "Chopper",
  "text": "Bastard!"
 },
 {
  "i": 196,
  "style": "Main",
  "name": "Chopper",
  "text": "Bastard, stop!"
 },
 {
  "i": 197,
  "style": "Main",
  "name": "Usopp",
  "text": "Hurry and escape, Nami!"
 },
 {
  "i": 198,
  "style": "Main",
  "name": "Lola",
  "text": "Absalom is gonna be my groom!"
 },
 {
  "i": 199,
  "style": "Main",
  "name": "Lola",
  "text": "Begone!"
 },
 {
  "i": 200,
  "style": "Main",
  "name": "Lola",
  "text": "Prepare to die!"
 },
 {
  "i": 201,
  "style": "Main",
  "name": "Nami",
  "text": "Wa-!"
 },
 {
  "i": 202,
  "style": "Main",
  "name": "Nami",
  "text": "Wait a minute!"
 },
 {
  "i": 203,
  "style": "Main",
  "name": "Nami",
  "text": "I-!"
 },
 {
  "i": 204,
  "style": "Main",
  "name": "Nami",
  "text": "I'm...!"
 },
 {
  "i": 205,
  "style": "Main",
  "name": "Nami",
  "text": "I'm actually a man!"
 },
 {
  "i": 206,
  "style": "Main",
  "name": "Usopp",
  "text": "Hey, hey."
 },
 {
  "i": 207,
  "style": "Main",
  "name": "Lola",
  "text": "Is that true?!"
 },
 {
  "i": 208,
  "style": "Main",
  "name": "Nami",
  "text": "That's right!"
 },
 {
  "i": 209,
  "style": "Main",
  "name": "Nami",
  "text": "It's a hobby of mine!"
 },
 {
  "i": 210,
  "style": "Main",
  "name": "Nami",
  "text": "It's no joke!"
 },
 {
  "i": 211,
  "style": "Main",
  "name": "Nami",
  "text": "Plus..."
 },
 {
  "i": 212,
  "style": "Main",
  "name": "Nami",
  "text": "You and that beast man are perfect for each other!"
 },
 {
  "i": 213,
  "style": "Main",
  "name": "Nami",
  "text": "I thought I could give you all my support!"
 },
 {
  "i": 214,
  "style": "Main",
  "name": "Lola",
  "text": "Really?!"
 },
 {
  "i": 215,
  "style": "Main",
  "name": "Nami",
  "text": "Really!"
 },
 {
  "i": 216,
  "style": "Main",
  "name": "Nami",
  "text": "It's no joke!"
 },
 {
  "i": 217,
  "style": "Main",
  "name": "Lola",
  "text": "No one has ever given me such supportive thoughts before."
 },
 {
  "i": 218,
  "style": "Main",
  "name": "Lola",
  "text": "You're the first person to ever have said such kind words to me."
 },
 {
  "i": 219,
  "style": "Main",
  "name": "Lola",
  "text": "I..."
 },
 {
  "i": 220,
  "style": "Main",
  "name": "Lola",
  "text": "I...!"
 },
 {
  "i": 221,
  "style": "Main",
  "name": "Nami",
  "text": "Raise your head, my friend."
 },
 {
  "i": 222,
  "style": "Main",
  "name": "Nami",
  "text": "This is called friendship."
 },
 {
  "i": 223,
  "style": "Main",
  "name": "Nami",
  "text": "My name is Namizou."
 },
 {
  "i": 224,
  "style": "Main",
  "name": "Nami",
  "text": "You may call me Nami."
 },
 {
  "i": 225,
  "style": "Main",
  "name": "Lola",
  "text": "Friendship...!"
 },
 {
  "i": 226,
  "style": "Main",
  "name": "Lola",
  "text": "Nami!"
 },
 {
  "i": 227,
  "style": "Main",
  "name": "Usopp",
  "text": "She fell for it!"
 },
 {
  "i": 228,
  "style": "Main",
  "name": "Nami",
  "text": "Of course you can't put his seal on while he's conscious."
 },
 {
  "i": 229,
  "style": "Main",
  "name": "Nami",
  "text": "If you do it while he's sleeping-"
 },
 {
  "i": 230,
  "style": "Main",
  "name": "Lola",
  "text": "Attack while he's sleeping?!"
 },
 {
  "i": 231,
  "style": "Main",
  "name": "Lola",
  "text": "Is that ok!? As a human being?!"
 },
 {
  "i": 232,
  "style": "Main",
  "name": "Nami",
  "text": "But, aren't you a zombie, Lola?"
 },
 {
  "i": 233,
  "style": "Main",
  "name": "Lola",
  "text": "That's mean! It's too low!"
 },
 {
  "i": 234,
  "style": "Main",
  "name": "Nami",
  "text": "It's alright as long as he's sleeping and doesn't notice."
 },
 {
  "i": 235,
  "style": "Main",
  "name": "Usopp",
  "text": "Hey, Namizou."
 },
 {
  "i": 236,
  "style": "Main",
  "name": "Usopp",
  "text": "Can we get out of here now?"
 },
 {
  "i": 237,
  "style": "Main",
  "name": "Nami",
  "text": "By the way, Lola..."
 },
 {
  "i": 238,
  "style": "Main",
  "name": "Nami",
  "text": "I dropped something earlier in the treasure storehouse..."
 },
 {
  "i": 239,
  "style": "Main",
  "name": "Nami",
  "text": "I want it back but, I can't remember the way. Can you tell me?"
 },
 {
  "i": 240,
  "style": "Main",
  "name": "Lola",
  "text": "Silly you."
 },
 {
  "i": 241,
  "style": "Main",
  "name": "Lola",
  "text": "But it's fine."
 },
 {
  "i": 242,
  "style": "Main",
  "name": "Lola",
  "text": "The closest way is right through Lady Perona's room over there."
 },
 {
  "i": 243,
  "style": "Main",
  "name": "Lola",
  "text": "Do you see it?"
 },
 {
  "i": 244,
  "style": "Main",
  "name": "Usopp",
  "text": "She's completely taken in... she's not gonna come out of it."
 },
 {
  "i": 245,
  "style": "Secondary",
  "name": "Lola",
  "text": "See that incredibly high tower over there?"
 },
 {
  "i": 246,
  "style": "Secondary",
  "name": "Lola",
  "text": "If you go straight that way you will come across the stairs that lead to it."
 },
 {
  "i": 247,
  "style": "Thoughts",
  "name": "Chopper",
  "text": "So Nami was a man all along..."
 },
 {
  "i": 248,
  "style": "Thoughts",
  "name": "Chopper",
  "text": "I always thought she acted kinda manly."
 },
 {
  "i": 249,
  "style": "Main",
  "name": "Usopp",
  "text": "Hey Nami, that guy has caught up to us."
 },
 {
  "i": 250,
  "style": "Main",
  "name": "Nami",
  "text": "Really?!"
 },
 {
  "i": 251,
  "style": "Main",
  "name": "Nami",
  "text": "Lola! Attack chance!"
 },
 {
  "i": 252,
  "style": "Main",
  "name": "Nami",
  "text": "I'll never meet him again, so you'll be fine!"
 },
 {
  "i": 253,
  "style": "Main",
  "name": "Nami",
  "text": "Do your best! You two will be the best couple!"
 },
 {
  "i": 254,
  "style": "Main",
  "name": "Lola",
  "text": "Thank you, Nami!"
 },
 {
  "i": 255,
  "style": "Main",
  "name": "Lola",
  "text": "I'm full of courage now!"
 },
 {
  "i": 256,
  "style": "Main",
  "name": "Lola",
  "text": "Absalom!"
 },
 {
  "i": 257,
  "style": "Main",
  "name": "Absalom",
  "text": "Lola!"
 },
 {
  "i": 258,
  "style": "Main",
  "name": "Nami",
  "text": "You two, this is our chance!"
 },
 {
  "i": 259,
  "style": "Main",
  "name": "Chopper",
  "text": "The wild boar didn't harm Nami after all."
 },
 {
  "i": 260,
  "style": "Main",
  "name": "Chopper",
  "text": "Nami, you're incredible!"
 },
 {
  "i": 261,
  "style": "Main",
  "name": "Nami",
  "text": "If you talk to her, you'll realize she's not so bad after all."
 },
 {
  "i": 262,
  "style": "Main",
  "name": "Usopp",
  "text": "You have a weird look again!"
 },
 {
  "i": 263,
  "style": "Main",
  "name": "Perona",
  "text": "Not a single treasure chest in the whole ship?!"
 },
 {
  "i": 264,
  "style": "Main",
  "name": "Zombie",
  "text": "Yes, there are some, but they're almost empty."
 },
 {
  "i": 265,
  "style": "Main",
  "name": "Zombie",
  "text": "All that's left is just a small amount of money."
 },
 {
  "i": 266,
  "style": "Main",
  "name": "Perona",
  "text": "I'm surprised that these two ships gave us almost no spoils."
 },
 {
  "i": 267,
  "style": "Main",
  "name": "Perona",
  "text": "Is this really the ship of the man who beat Crocodile?"
 },
 {
  "i": 268,
  "style": "Main",
  "name": "Perona",
  "text": "Well, it's fine."
 },
 {
  "i": 269,
  "style": "Main",
  "name": "Perona",
  "text": "Carry out some rations, if there are any."
 },
 {
  "i": 270,
  "style": "Main",
  "name": "Zombie",
  "text": "Yes."
 },
 {
  "i": 271,
  "style": "Main",
  "name": "Hildon",
  "text": "Perona-sama!"
 },
 {
  "i": 272,
  "style": "Main",
  "name": "Perona",
  "text": "Hildon."
 },
 {
  "i": 273,
  "style": "Main",
  "name": "Hildon",
  "text": "Moria-sama has summoned the Three Mystery Persons."
 },
 {
  "i": 274,
  "style": "Main",
  "name": "Perona",
  "text": "Master?"
 },
 {
  "i": 275,
  "style": "Main",
  "name": "Perona",
  "text": "What for?"
 },
 {
  "i": 276,
  "style": "Main",
  "name": "Hildon",
  "text": "It seems Straw Hat Luffy has been captured."
 },
 {
  "i": 277,
  "style": "Main",
  "name": "Hildon",
  "text": "It's time to awaken Number 900."
 },
 {
  "i": 278,
  "style": "Main",
  "name": "Perona",
  "text": "Number 900?!"
 },
 {
  "i": 279,
  "style": "Main",
  "name": "Perona",
  "text": "Are you serious?!"
 },
 {
  "i": 280,
  "style": "Main",
  "name": "Lola",
  "text": "Ab-sama!"
 },
 {
  "i": 281,
  "style": "Main",
  "name": "Lola",
  "text": "Absalom, you bastard! Come out and marry me!"
 },
 {
  "i": 282,
  "style": "Main",
  "name": "Lola",
  "text": "You disappeared and ran again, didn't you?!"
 },
 {
  "i": 283,
  "style": "Main",
  "name": "Absalom",
  "text": "Strange..."
 },
 {
  "i": 284,
  "style": "Main",
  "name": "Absalom",
  "text": "There's nowhere else they could have run to."
 },
 {
  "i": 285,
  "style": "Main",
  "name": "Absalom",
  "text": "Hey, Kumashi!"
 },
 {
  "i": 286,
  "style": "Main",
  "name": "Bearsy",
  "text": "Absalom-sama, I've got a problem..."
 },
 {
  "i": 287,
  "style": "Main",
  "name": "Bearsy",
  "text": "Something's bothering me..."
 },
 {
  "i": 288,
  "style": "Main",
  "name": "Absalom",
  "text": "Wait, my issues come first."
 },
 {
  "i": 289,
  "style": "Main",
  "name": "Absalom",
  "text": "Have three pirates come through here?"
 },
 {
  "i": 290,
  "style": "Main",
  "name": "Bearsy",
  "text": "That's..."
 },
 {
  "i": 291,
  "style": "Main",
  "name": "Perona",
  "text": "Absalom!"
 },
 {
  "i": 292,
  "style": "Main",
  "name": "Perona",
  "text": "What're you doing here?"
 },
 {
  "i": 293,
  "style": "Main",
  "name": "Perona",
  "text": "This is my room."
 },
 {
  "i": 294,
  "style": "Main",
  "name": "Absalom",
  "text": "Perona."
 },
 {
  "i": 295,
  "style": "Main",
  "name": "Bearsy",
  "text": "Welcome back, Perona-sama..."
 },
 {
  "i": 296,
  "style": "Main",
  "name": "Perona",
  "text": "Don't talk, Kumashi!"
 },
 {
  "i": 297,
  "style": "Main",
  "name": "Perona",
  "text": "How many times do I have to tell you?!"
 },
 {
  "i": 298,
  "style": "Main",
  "name": "Bearsy",
  "text": "But, there's something impo-"
 },
 {
  "i": 299,
  "style": "Main",
  "name": "Perona",
  "text": "Be quiet!"
 },
 {
  "i": 300,
  "style": "Main",
  "name": "Perona",
  "text": "Don't speak."
 },
 {
  "i": 301,
  "style": "Main",
  "name": "Absalom",
  "text": "You are as severe as ever with Kumashi..."
 },
 {
  "i": 302,
  "style": "Main",
  "name": "Absalom",
  "text": "Sevearsy."
 },
 {
  "i": 303,
  "style": "Main",
  "name": "Perona",
  "text": "Quiet, he's my subordinate."
 },
 {
  "i": 304,
  "style": "Main",
  "name": "Perona",
  "text": "More importantly, have you heard?"
 },
 {
  "i": 305,
  "style": "Main",
  "name": "Perona",
  "text": "Master is calling for us."
 },
 {
  "i": 306,
  "style": "Main",
  "name": "Absalom",
  "text": "Did something happen?"
 },
 {
  "i": 307,
  "style": "Main",
  "name": "Perona",
  "text": "Did something happen? I'll tell you what happened!"
 },
 {
  "i": 308,
  "style": "Main",
  "name": "Perona",
  "text": "Number 900 is gonna be awakened."
 },
 {
  "i": 309,
  "style": "Main",
  "name": "Absalom",
  "text": "The 900?!"
 },
 {
  "i": 310,
  "style": "Main",
  "name": "Absalom",
  "text": "Did he capture that 300 million man?!"
 },
 {
  "i": 311,
  "style": "Main",
  "name": "Nami",
  "text": "Somehow, we're still barely hiding from them."
 },
 {
  "i": 312,
  "style": "Secondary",
  "name": "Absalom",
  "text": "Did he capture that 300 million man?!"
 },
 {
  "i": 313,
  "style": "Main",
  "name": "Nami",
  "text": "It's a miracle."
 },
 {
  "i": 314,
  "style": "Main",
  "name": "Chopper",
  "text": "Then again, why're we hiding in such place?!"
 },
 {
  "i": 315,
  "style": "Main",
  "name": "Usopp",
  "text": "We had no choice!"
 },
 {
  "i": 316,
  "style": "Main",
  "name": "Usopp",
  "text": "I didn't think that beast man would catch up with us so fast!"
 },
 {
  "i": 317,
  "style": "Main",
  "name": "Usopp",
  "text": "Moreover, I don't think that guy's a zombie."
 },
 {
  "i": 318,
  "style": "Main",
  "name": "Usopp",
  "text": "We'll get outta here once we get the chance, alright?"
 },
 {
  "i": 319,
  "style": "Main",
  "name": "Hildon",
  "text": "Absalom-sama!"
 },
 {
  "i": 320,
  "style": "Main",
  "name": "Hildon",
  "text": "So you were here."
 },
 {
  "i": 321,
  "style": "Main",
  "name": "Hildon",
  "text": "I've brought interesting information."
 },
 {
  "i": 322,
  "style": "Main",
  "name": "Absalom",
  "text": "What is it?"
 },
 {
  "i": 323,
  "style": "Main",
  "name": "Hildon",
  "text": "There's another trespasser along with the pirates."
 },
 {
  "i": 324,
  "style": "Main",
  "name": "Absalom",
  "text": "Trespasser?"
 },
 {
  "i": 325,
  "style": "Main",
  "name": "Hildon",
  "text": "The \"Humming\" Chivalrous Swordsman."
 },
 {
  "i": 326,
  "style": "Main",
  "name": "Absalom",
  "text": "What?!"
 },
 {
  "i": 327,
  "style": "Main",
  "name": "Zombie",
  "text": "Someone... fell from the sky."
 },
 {
  "i": 328,
  "style": "Main",
  "name": "Franky",
  "text": "Hey, what was it that fell just now?"
 },
 {
  "i": 329,
  "style": "Main",
  "name": "Robin",
  "text": "Could it be..."
 },
 {
  "i": 330,
  "style": "Main",
  "name": "Franky",
  "text": "Well..."
 },
 {
  "i": 331,
  "style": "Main",
  "name": "Franky",
  "text": "I can tell by looking at the mark..."
 },
 {
  "i": 332,
  "style": "Main",
  "name": "Spider",
  "text": "That was a strange interruption, but you're not gonna get away from me."
 },
 {
  "i": 333,
  "style": "Main",
  "name": "Spider",
  "text": "I can make as many footholds as I need."
 },
 {
  "i": 334,
  "style": "Main",
  "name": "Spider",
  "text": "Monkey! Monkey!"
 },
 {
  "i": 335,
  "style": "Main",
  "name": "Franky",
  "text": "You, buy me some time."
 },
 {
  "i": 336,
  "style": "Main",
  "name": "Robin",
  "text": "What're you gonna do?"
 },
 {
  "i": 337,
  "style": "Main",
  "name": "Franky",
  "text": "These are some fine stone pillars you have here."
 },
 {
  "i": 338,
  "style": "Main",
