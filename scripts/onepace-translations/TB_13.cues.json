[
 {
  "i": 0,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}Let's travel all through the worldwide seas,"
 },
 {
  "i": 1,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 2,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}If you've made up your mind, let the signal for departure"
 },
 {
  "i": 3,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 4,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "We were able to escape from the set course"
 },
 {
  "i": 5,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "along the boundary between sky and sea."
 },
 {
  "i": 6,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now we're rowing our way"
 },
 {
  "i": 7,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "to a hidden adventure at the dark bottom of the sea."
 },
 {
  "i": 8,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Doesn't it sound fun just thinking about it?"
 },
 {
  "i": 9,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Let's travel all through the worldwide seas,"
 },
 {
  "i": 10,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 11,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 12,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 13,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "That feeling we had when we set sail"
 },
 {
  "i": 14,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "is something I'll never forget."
 },
 {
  "i": 15,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Because of that"
 },
 {
  "i": 16,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "nothing will be able to scare me..."
 },
 {
  "i": 17,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now, as the trip approaches, our racing heartbeats"
 },
 {
  "i": 18,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "engrave a rhythm of adventure in our shy hearts."
 },
 {
  "i": 19,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Get all the treasures"
 },
 {
  "i": 20,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(50,0)}while laughing out loud."
 },
 {
  "i": 21,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 22,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "making a splash..."
 },
 {
  "i": 23,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Fill your empty heart with dreams."
 },
 {
  "i": 24,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Spread your wings."
 },
 {
  "i": 25,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you color your heart with the blowing wind"
 },
 {
  "i": 26,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "you will move on."
 },
 {
  "i": 27,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(50,0)}Get all the treasures"
 },
 {
  "i": 28,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 29,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 30,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "making a splash..."
 },
 {
  "i": 31,
  "style": "Title",
  "name": "",
  "text": "{\\fad(2000,0)}Zoro vs. Ryuuma and\\NChopper's Rage!"
 },
 {
  "i": 32,
  "style": "Main",
  "name": "Franky",
  "text": "He made a hole!"
 },
 {
  "i": 33,
  "style": "Main",
  "name": "Brook",
  "text": "To send the stab flying... it takes a lot of strength."
 },
 {
  "i": 34,
  "style": "Main",
  "name": "Brook",
  "text": "A draw it seems."
 },
 {
  "i": 35,
  "style": "Main",
  "name": "Ryuuma",
  "text": "You almost got me."
 },
 {
  "i": 36,
  "style": "Main",
  "name": "Franky",
  "text": "What? When did that waistband guy counterattack?!"
 },
 {
  "i": 37,
  "style": "Main",
  "name": "Brook",
  "text": "It was almost... at the same time..."
 },
 {
  "i": 38,
  "style": "Main",
  "name": "Brook",
  "text": "That person's slash also flew..."
 },
 {
  "i": 39,
  "style": "Main",
  "name": "Brook",
  "text": "That samurai zombie moves thanks to my shadow,"
 },
 {
  "i": 40,
  "style": "Main",
  "name": "Brook",
  "text": "but he must truly have been\\Nan extraordinary samurai when alive."
 },
 {
  "i": 41,
  "style": "Main",
  "name": "Brook",
  "text": "It is possible that those two have the same type of strength as swordsmen."
 },
 {
  "i": 42,
  "style": "Main",
  "name": "Brook",
  "text": "It means they possess the same destructive power."
 },
 {
  "i": 43,
  "style": "Main",
  "name": "Brook",
  "text": "This match won't take too long."
 },
 {
  "i": 44,
  "style": "Main",
  "name": "Ryuuma",
  "text": "{\\fad(150,150)}Prelude..."
 },
 {
  "i": 45,
  "style": "Main",
  "name": "Ryuuma",
  "text": "{\\fad(150,150)}Au Fer!"
 },
 {
  "i": 46,
  "style": "Note",
  "name": "Ryuuma",
  "text": "{\\fad(150,150)}Iron"
 },
 {
  "i": 47,
  "style": "Main",
  "name": "Zoro",
  "text": "A weapon breaking technique?!"
 },
 {
  "i": 48,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(150,150)}Two Swords Style..."
 },
 {
  "i": 49,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(150,150)}Flash!"
 },
 {
  "i": 50,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(150,150)}Demon Bear!"
 },
 {
  "i": 51,
  "style": "Main",
  "name": "Ryuuma",
  "text": "{\\fad(150,150)}Gavotte..."
 },
 {
  "i": 52,
  "style": "Main",
  "name": "Ryuuma",
  "text": "{\\fad(150,150)}Bond Avant!"
 },
 {
  "i": 53,
  "style": "Note",
  "name": "Ryuuma",
  "text": "{\\fad(150,150)}Forward Leap"
 },
 {
  "i": 54,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(150,150)}Two Swords Style..."
 },
 {
  "i": 55,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(150,150)}Sword Draw..."
 },
 {
  "i": 56,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(150,150)}Castle Gate!"
 },
 {
  "i": 57,
  "style": "Thoughts",
  "name": "Zoro",
  "text": "He got me!"
 },
 {
  "i": 58,
  "style": "Main",
  "name": "Franky",
  "text": "The pillars broke!"
 },
 {
  "i": 59,
  "style": "Main",
  "name": "Franky",
  "text": "H-Hold on a minute! Hey!"
 },
 {
  "i": 60,
  "style": "Main",
  "name": "Franky",
  "text": "The whole floor is gonna collapse!"
 },
 {
  "i": 61,
  "style": "Main",
  "name": "Franky",
  "text": "This is dangerous!"
 },
 {
  "i": 62,
  "style": "Main",
  "name": "Franky",
  "text": "Hang on tight, we're outta here!"
 },
 {
  "i": 63,
  "style": "Main",
  "name": "Franky",
  "text": "The ceiling is coming down!"
 },
 {
  "i": 64,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(150,150)}Seventy-two Pound Cannon!"
 },
 {
  "i": 65,
  "style": "Note",
  "name": "Zoro",
  "text": "{\\fad(150,150)}Phoenix of the Seventy-two Earthly Desires"
 },
 {
  "i": 66,
  "style": "Main",
  "name": "Ryuuma",
  "text": "{\\fad(150,150)}Polka Continuation!"
 },
 {
  "i": 67,
  "style": "Main",
  "name": "Franky",
  "text": "{\\fad(150,150)}Weapons Left!"
 },
 {
  "i": 68,
  "style": "Main",
  "name": "Franky",
  "text": "That was close!"
 },
 {
  "i": 69,
  "style": "Main",
  "name": "Brook",
  "text": "Watch out! You'll fall!"
 },
 {
  "i": 70,
  "style": "Main",
  "name": "Zoro",
  "text": "I'm slipping!"
 },
 {
  "i": 71,
  "style": "Main",
  "name": "Brook",
  "text": "How can they get a foothold?"
 },
 {
  "i": 72,
  "style": "Main",
  "name": "Zoro",
  "text": "If this keeps up, my blades will end up breaking..."
 },
 {
  "i": 73,
  "style": "Main",
  "name": "Zoro",
  "text": "The body and skill of this corpse is almost the same as the legendary samurai himself."
 },
 {
  "i": 74,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(150,150)}One Sword Style..."
 },
 {
  "i": 75,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(150,150)}Flying Dragon..."
 },
 {
  "i": 76,
  "style": "Main",
  "name": "Ryuuma",
  "text": "{\\fad(150,150)}Three Pace Hum..."
 },
 {
  "i": 77,
  "style": "Main",
  "name": "Ryuuma",
  "text": "{\\fad(150,150)}Notch Slash!"
 },
 {
  "i": 78,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(150,150)}Blaze!"
 },
 {
  "i": 79,
  "style": "Main",
  "name": "Ryuuma",
  "text": "Did his wound just ignite?"
 },
 {
  "i": 80,
  "style": "Main",
  "name": "Ryuuma",
  "text": "I lost."
 },
 {
  "i": 81,
  "style": "Main",
  "name": "Ryuuma",
  "text": "Shuusui, the famous sword that once served a legendary samurai."
 },
 {
  "i": 82,
  "style": "Note",
  "name": "Ryuuma",
  "text": "Shuusui: Clear Autumn Water"
 },
 {
  "i": 83,
  "style": "Main",
  "name": "Ryuuma",
  "text": "Surely this sword will be satisfied under your command."
 },
 {
  "i": 84,
  "style": "Main",
  "name": "Franky",
  "text": "Did that samurai just say something?"
 },
 {
  "i": 85,
  "style": "Main",
  "name": "Franky",
  "text": "So that means..."
 },
 {
  "i": 86,
  "style": "Main",
  "name": "Franky",
  "text": "w-what exactly?"
 },
 {
  "i": 87,
  "style": "Main",
  "name": "Brook",
  "text": "It means..."
 },
 {
  "i": 88,
  "style": "Main",
  "name": "Brook",
  "text": "that the match is over!"
 },
 {
  "i": 89,
  "style": "Main",
  "name": "Brook",
  "text": "I've never seen a battle like this!"
 },
 {
  "i": 90,
  "style": "Main",
  "name": "Brook",
  "text": "That samurai..."
 },
 {
  "i": 91,
  "style": "Main",
  "name": "Brook",
  "text": "never fought against me seriously!"
 },
 {
  "i": 92,
  "style": "Main",
  "name": "Brook",
  "text": "And some fight that was."
 },
 {
  "i": 93,
  "style": "Main",
  "name": "Ryuuma",
  "text": "I feel sorry for..."
 },
 {
  "i": 94,
  "style": "Main",
  "name": "Ryuuma",
  "text": "giving this samurai body a complete defeat..."
 },
 {
  "i": 95,
  "style": "Main",
  "name": "Zoro",
  "text": "Having the feeling of shame is enough..."
 },
 {
  "i": 96,
  "style": "Main",
  "name": "Zoro",
  "text": "That's what makes a true swordsman in both body and soul."
 },
 {
  "i": 97,
  "style": "Main",
  "name": "Zoro",
  "text": "I wish I could've met you when you were alive."
 },
 {
  "i": 98,
  "style": "Main",
  "name": "Franky",
  "text": "T-This is...!"
 },
 {
  "i": 99,
  "style": "Main",
  "name": "Brook",
  "text": "It's back!"
 },
 {
  "i": 100,
  "style": "Main",
  "name": "Brook",
  "text": "After five long years, my shadow is finally back!"
 },
 {
  "i": 101,
  "style": "Main",
  "name": "Zoro",
  "text": "I'll be taking the sword, but..."
 },
 {
  "i": 102,
  "style": "Main",
  "name": "Zoro",
  "text": "let's pretend this duel never happened,"
 },
 {
  "i": 103,
  "style": "Main",
  "name": "Zoro",
  "text": "samurai of Wano Country."
 },
 {
  "i": 104,
  "style": "Main",
  "name": "Hogback",
  "text": "Well? How does it feel\\Nto get captured by your own friends?"
 },
 {
  "i": 105,
  "style": "Main",
  "name": "Jigoro",
  "text": "You failed to feed me salt with that weird ability!"
 },
 {
  "i": 106,
  "style": "Thoughts",
  "name": "Robin",
  "text": "He's strong..."
 },
 {
  "i": 107,
  "style": "Main",
  "name": "Chopper",
  "text": "Damn! I never thought Sanji would kick Robin!"
 },
 {
  "i": 108,
  "style": "Main",
  "name": "Chopper",
  "text": "This creature is no longer Sanji!"
 },
 {
  "i": 109,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "Who's this Sanji?"
 },
 {
  "i": 110,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "I'll kill you, damn bastard."
 },
 {
  "i": 111,
  "style": "Main",
  "name": "Hogback",
  "text": "Unfortunately for you, they no longer have memories of being your friends."
 },
 {
  "i": 112,
  "style": "Main",
  "name": "Hogback",
  "text": "Fresh zombies may have\\Nremains of their former selves,"
 },
 {
  "i": 113,
  "style": "Main",
  "name": "Hogback",
  "text": "but now that the body and shadow have merged completely..."
 },
 {
  "i": 114,
  "style": "Main",
  "name": "Hogback",
  "text": "their humanity is gone for good."
 },
 {
  "i": 115,
  "style": "Main",
  "name": "Hogback",
  "text": "They're my loyal zombies now!"
 },
 {
  "i": 116,
  "style": "Main",
  "name": "Hogback",
  "text": "And for a zombie, orders are absolute!"
 },
 {
  "i": 117,
  "style": "Main",
  "name": "Chopper",
  "text": "I'm almost glad that you've fallen this low, Hogback!"
 },
 {
  "i": 118,
  "style": "Main",
  "name": "Chopper",
  "text": "You once saved numerous human lives,\\Nthat's why I deeply admired you as a doctor,"
 },
 {
  "i": 119,
  "style": "Main",
  "name": "Chopper",
  "text": "even your zombie research."
 },
 {
  "i": 120,
  "style": "Main",
  "name": "Chopper",
  "text": "Death..."
 },
 {
  "i": 121,
  "style": "Main",
  "name": "Chopper",
  "text": "it comes without warning..."
 },
 {
  "i": 122,
  "style": "Main",
  "name": "Chopper",
  "text": "Because of this, many things are left unsaid between those dead and those left behind..."
 },
 {
  "i": 123,
  "style": "Main",
  "name": "Chopper",
  "text": "Not for many years..."
 },
 {
  "i": 124,
  "style": "Main",
  "name": "Chopper",
  "text": "just a few minutes would be enough!"
 },
 {
  "i": 125,
  "style": "Main",
  "name": "Chopper",
  "text": "If there was a way to bring back the dead for even a brief moment..."
 },
 {
  "i": 126,
  "style": "Main",
  "name": "Chopper",
  "text": "even if it was an evil and heretical practice..."
 },
 {
  "i": 127,
  "style": "Main",
  "name": "Chopper",
  "text": "it would be hugely appreciated by those who were brought back!"
 },
 {
  "i": 128,
  "style": "Main",
  "name": "Chopper",
  "text": "That's why, when you spoke of raising the dead, I thought your words were..."
 },
 {
  "i": 129,
  "style": "Main",
  "name": "Chopper",
  "text": "worthy of a true doctor!"
 },
 {
  "i": 130,
  "style": "Main",
  "name": "Hogback",
  "text": "Fool! Why would I do that for strangers?!"
 },
 {
  "i": 131,
  "style": "Main",
  "name": "Hogback",
  "text": "They requested my aid for the same reason you admired me!"
 },
 {
  "i": 132,
  "style": "Main",
  "name": "Hogback",
  "text": "It was because I was a genius!"
 },
 {
  "i": 133,
  "style": "Main",
  "name": "Hogback",
  "text": "It was all about the money!"
 },
 {
  "i": 134,
  "style": "Main",
  "name": "Hogback",
  "text": "I didn't want to help all those patients who kept coming incessantly from all over the world!"
 },
 {
  "i": 135,
  "style": "Main",
  "name": "Hogback",
  "text": "\"Please help my father!\""
 },
 {
  "i": 136,
  "style": "Main",
  "name": "Hogback",
  "text": "\"Save my child!\""
 },
 {
  "i": 137,
  "style": "Main",
  "name": "Hogback",
  "text": "\"Help my boyfriend!\""
 },
 {
  "i": 138,
  "style": "Main",
  "name": "Hogback",
  "text": "What a huge annoyance!"
 },
 {
  "i": 139,
  "style": "Main",
  "name": "Hogback",
  "text": "So troublesome."
 },
 {
  "i": 140,
  "style": "Main",
  "name": "Hogback",
  "text": "I had to pay for the incompetence of all those pathetic doctors who couldn't even save a life."
 },
 {
  "i": 141,
  "style": "Main",
  "name": "Hogback",
  "text": "Can you comprehend the trouble of being such a genius?!"
 },
 {
  "i": 142,
  "style": "Main",
  "name": "Hogback",
  "text": "Whether you respect me or not is up to you,"
 },
 {
  "i": 143,
  "style": "Main",
  "name": "Hogback",
  "text": "but the mere fact that I disappointed you is ridiculous."
 },
 {
  "i": 144,
  "style": "Main",
  "name": "Hogback",
  "text": "If you can't stand me as a doctor because of your absurd ideals..."
 },
 {
  "i": 145,
  "style": "Main",
  "name": "Hogback",
  "text": "Then you're deceiving yourself, stupid reindeer!"
 },
 {
  "i": 146,
  "style": "Main",
  "name": "Hogback",
  "text": "You want to tell me what a doctor should be?!{edited for clarity - Sky}"
 },
 {
  "i": 147,
  "style": "Main",
  "name": "Chopper",
  "text": "I don't intend to tell you anything!{Retranslated to match previous line - Sky}"
 },
 {
  "i": 148,
  "style": "Main",
  "name": "Chopper",
  "text": "I don't think of you as a doctor anymore!"
 },
 {
  "i": 149,
  "style": "Main",
  "name": "Chopper",
  "text": "The same goes for those zombies!"
 },
 {
  "i": 150,
  "style": "Main",
  "name": "Chopper",
  "text": "They're just empty shells moving to your will!"
 },
 {
  "i": 151,
  "style": "Main",
  "name": "Chopper",
  "text": "They're not alive!"
 },
 {
  "i": 152,
  "style": "Main",
  "name": "Chopper",
  "text": "Don't play with life!"
 },
 {
  "i": 153,
  "style": "Main",
  "name": "Hogback",
  "text": "What a cruel statement."
 },
 {
  "i": 154,
  "style": "Main",
  "name": "Hogback",
  "text": "You deny their livelihood despite seeing them move before your very eyes?!"
 },
 {
  "i": 155,
  "style": "Main",
  "name": "Hogback",
  "text": "Granting a new life to the dead is a true miracle!"
 },
 {
  "i": 156,
  "style": "Main",
  "name": "Hogback",
  "text": "How can you possibly deny the existence of this?!"
 },
 {
  "i": 157,
  "style": "Main",
  "name": "Hogback",
  "text": "Look!"
 },
 {
  "i": 158,
  "style": "Main",
  "name": "Hogback",
  "text": "Now then, lick the floor, Cindry.{the first , seems appropriate here, should probably leave it}{added \"then\" to give it proper pacing in english - Sky}"
 },
 {
  "i": 159,
  "style": "Main",
  "name": "Hogback",
  "text": "Yes, Hogback-sama."
 },
 {
  "i": 160,
  "style": "Main",
  "name": "Hogback",
  "text": "You saw that room, didn't you, Dr. Chopper?"
 },
 {
  "i": 161,
  "style": "Main",
  "name": "Hogback",
  "text": "That's my room."
 },
 {
  "i": 162,
  "style": "Main",
  "name": "Hogback",
  "text": "All those were pictures of the stage actress Victoria Cindry, back when she was alive."
 },
 {
  "i": 163,
  "style": "Main",
  "name": "Hogback",
  "text": "I completely fell in love with her."
 },
 {
  "i": 164,
  "style": "Main",
  "name": "Hogback",
  "text": "Not only me, but men from the entire country, fell for such beauty."
 },
 {
  "i": 165,
  "style": "Flashbacks",
  "name": "Cindry",
  "text": "It's fixed now, Doctor."
 },
 {
  "i": 166,
  "style": "Flashbacks",
  "name": "Hogback",
  "text": "S-Sorry, I didn't mean to disturb my patient just to get my buttons sewn!"
 },
 {
  "i": 167,
  "style": "Flashbacks",
  "name": "Cindry",
  "text": "It's no problem!"
 },
 {
  "i": 168,
  "style": "Main",
  "name": "Hogback",
  "text": "A very popular yet unpretentious person..."
 },
 {
  "i": 169,
  "style": "Main",
  "name": "Hogback",
  "text": "devoted to her family,"
 },
 {
  "i": 170,
  "style": "Main",
  "name": "Hogback",
  "text": "She was kind to everyone... truly a wonderful woman."
 },
 {
  "i": 171,
  "style": "Main",
  "name": "Hogback",
  "text": "but she..."
 },
 {
  "i": 172,
  "style": "Main",
  "name": "Hogback",
  "text": "rejected my proposal, the proposal of a doctor who had everything..."
 },
 {
  "i": 173,
  "style": "Main",
  "name": "Hogback",
  "text": "All because of that accursed fiancé of hers...!"
 },
 {
  "i": 174,
  "style": "Main",
  "name": "Hogback",
  "text": "And then..."
 },
 {
  "i": 175,
  "style": "Main",
  "name": "Hogback",
  "text": "Unbelievable news reached my ears..."
 },
 {
  "i": 176,
  "style": "Main",
  "name": "Hogback",
  "text": "Cindry... died in an accident."
 },
 {
  "i": 177,
  "style": "Main",
  "name": "Hogback",
  "text": "My pain was indescribable..."
 },
 {
  "i": 178,
  "style": "Main",
  "name": "Hogback",
  "text": "I abandoned my work..."
 },
 {
  "i": 179,
  "style": "Main",
  "name": "Hogback",
  "text": "It was then that a huge man appeared before me..."
 },
 {
  "i": 180,
  "style": "Main",
  "name": "Hogback",
  "text": "My master, Gekko Moriah!"
 },
 {
  "i": 181,
  "style": "Flashbacks",
  "name": "Hogback",
  "text": "Dr. Hogback, lend me your power!"
 },
 {
  "i": 182,
  "style": "Main",
  "name": "Hogback",
  "text": "So we agreed that, in exchange for resurrecting Cindry with his miraculous ability, I would stay on this ship.{maybe we should split this into 3 parts? to avoid the sceene bleeding? -punkid}"
 },
 {
  "i": 183,
  "style": "Main",
  "name": "Hogback",
  "text": "I stole her body..."
 },
 {
  "i": 184,
  "style": "Main",
  "name": "Hogback",
  "text": "and by doing so, I easily gained control over the actress Cindry!"
 },
 {
  "i": 185,
  "style": "Main",
  "name": "Hogback",
  "text": "Cindry-chan!"
 },
 {
  "i": 186,
  "style": "Main",
  "name": "Cindry",
  "text": "It would be best if all the plates disappear..."
 },
 {
  "i": 187,
  "style": "Main",
  "name": "Hogback",
  "text": "I didn't care about who the woman was inside her body..."
 },
 {
  "i": 188,
  "style": "Main",
  "name": "Hogback",
  "text": "As long as she had her beauty..."
 },
 {
  "i": 189,
  "style": "Main",
  "name": "Hogback",
  "text": "That's Cindry-chan's zombie!"
 },
 {
  "i": 190,
  "style": "Main",
  "name": "Hogback",
  "text": "I'm full of joy, and so is she."
 },
 {
  "i": 191,
  "style": "Main",
  "name": "Hogback",
  "text": "I granted her a second opportunity to live as a human in this world!"
 },
 {
  "i": 192,
  "style": "Main",
  "name": "Chopper",
  "text": "How can you call this human?!"
 },
 {
  "i": 193,
  "style": "Main",
  "name": "Chopper",
  "text": "Make her stop!"
 },
 {
  "i": 194,
  "style": "Main",
  "name": "Chopper",
  "text": "A person with no connection between heart and body can't be called human!"
 },
 {
  "i": 195,
  "style": "Main",
  "name": "Chopper",
  "text": "If you're using soulless bodies..."
 },
 {
  "i": 196,
  "style": "Main",
  "name": "Chopper",
  "text": "you're just creating monsters!"
 },
 {
  "i": 197,
  "style": "Main",
  "name": "Chopper",
  "text": "You make people unhappy by creating those zombies!"
 },
 {
  "i": 198,
  "style": "Main",
  "name": "Chopper",
  "text": "Now that I'm aware of this, I won't let you off!"
 },
 {
  "i": 199,
  "style": "Main",
  "name": "Hogback",
  "text": "Don't talk to me about \"life\" with your limited medical skills, pirate-deer!{edited to sound more like an insult - Sky}"
 },
 {
  "i": 200,
  "style": "Main",
  "name": "Hogback",
  "text": "Cindry-chan, get rid of them!"
 },
 {
  "i": 201,
  "style": "Main",
  "name": "Hogback",
  "text": "I'll turn you both into marionettes!"
 },
 {
  "i": 202,
  "style": "Main",
  "name": "Hogback",
  "text": "You should be grateful, Dr. Chopper."
 },
 {
  "i": 203,
  "style": "Main",
  "name": "Hogback",
  "text": "When you die, you'll become\\Nthe assistant of the person you admired!"
 },
 {
  "i": 204,
  "style": "Main",
  "name": "Cindry",
  "text": "{\\fad(150,150)}Angular Edge Plate..."
 },
 {
  "i": 205,
  "style": "Main",
  "name": "Cindry",
  "text": "{\\fad(150,150)}One!"
 },
 {
  "i": 206,
  "style": "Main",
  "name": "Cindry",
  "text": "{\\fad(150,150)}Two!"
 },
 {
  "i": 207,
  "style": "Main",
  "name": "Cindry",
  "text": "{\\fad(150,150)}Three!"
 },
 {
  "i": 208,
  "style": "Main",
  "name": "Chopper",
  "text": "Stop..."
 },
 {
  "i": 209,
  "style": "Main",
  "name": "Cindry",
  "text": "Bastard!"
 },
 {
  "i": 210,
  "style": "Main",
  "name": "Robin",
  "text": "Chopper!"
 },
 {
  "i": 211,
  "style": "Main",
  "name": "Hogback",
  "text": "Don't look down on her just because she's a woman!"
 },
 {
  "i": 212,
  "style": "Main",
  "name": "Hogback",
  "text": "I've increased her strength for battle!"
 },
 {
  "i": 213,
  "style": "Main",
  "name": "Chopper",
  "text": "You don't have to listen to him!"
 },
 {
  "i": 214,
  "style": "Main",
  "name": "Cindry",
  "text": "I will kill you!"
 },
 {
  "i": 215,
  "style": "Main",
  "name": "Chopper",
  "text": "I feel bad for you. You're already dead."
 },
 {
  "i": 216,
  "style": "Main",
  "name": "Chopper",
  "text": "How would the rest of your family feel if they knew about this?!"
 },
 {
  "i": 217,
  "style": "Main",
  "name": "Cindry",
  "text": "Let me... go!"
 },
 {
  "i": 218,
  "style": "Main",
  "name": "Chopper",
  "text": "Covered with patches, becoming just a mindless soldier..."
 },
 {
  "i": 219,
  "style": "Main",
  "name": "Chopper",
  "text": "Your relatives wouldn't bear to see you like this..."
 },
 {
  "i": 220,
  "style": "Main",
  "name": "Cindry",
  "text": "You damned... let me go!"
 },
 {
  "i": 221,
  "style": "Main",
  "name": "Chopper",
  "text": "The heart you were born with is dead now..."
 },
 {
  "i": 222,
  "style": "Main",
  "name": "Chopper",
  "text": "Your body moves under other people's wills..."
 },
 {
  "i": 223,
  "style": "Main",
  "name": "Chopper",
  "text": "What kind of life is that?!"
 },
 {
  "i": 224,
  "style": "Main",
  "name": "Hogback",
  "text": "You doubt your eyes?!"
 },
 {
  "i": 225,
  "style": "Main",
  "name": "Hogback",
  "text": "Accept it! This is the eternal dream of humans, revival of the dead!"
 },
 {
  "i": 226,
  "style": "Main",
  "name": "Hogback",
  "text": "The dead have been resurrected!"
 },
 {
  "i": 227,
  "style": "Main",
  "name": "Chopper",
  "text": "So if they can move, it's enough?!"
 },
 {
  "i": 228,
  "style": "Main",
  "name": "Chopper",
  "text": "Humans have more freedom than that!"
 },
 {
  "i": 229,
  "style": "Main",
  "name": "Chopper",
  "text": "You are not even treating them as humans!"
 },
 {
  "i": 230,
  "style": "Main",
  "name": "Chopper",
  "text": "Robin! Hurry and give her salt!"
 },
 {
  "i": 231,
  "style": "Main",
  "name": "Hogback",
  "text": "Dog-pen!"
 },
 {
  "i": 232,
  "style": "Main",
  "name": "Hogback",
  "text": "Jigoro!"
 },
 {
  "i": 233,
  "style": "Main",
  "name": "Hogback",
  "text": "Help Cindry!"
 },
 {
  "i": 234,
  "style": "Main",
  "name": "Hogback",
  "text": "Get rid of that nuisance!"
 },
 {
  "i": 235,
  "style": "Main",
  "name": "Robin",
  "text": "I failed!"
 },
 {
  "i": 236,
  "style": "Main",
  "name": "Robin",
  "text": "Chopper!"
 },
 {
  "i": 237,
  "style": "Main",
  "name": "Jigoro",
  "text": "{\\fad(150,150)}Three Swords Style..."
 },
 {
  "i": 238,
  "style": "Main",
  "name": "Jigoro",
  "text": "{\\fad(150,150)}One-hundred and Eight..."
 },
 {
  "i": 239,
  "style": "Main",
  "name": "Jigoro",
  "text": "{\\fad(150,150)}Pound Cannon!"
 },
 {
  "i": 240,
  "style": "Main",
  "name": "Chopper",
  "text": "Stop it, Zoro!"
 },
 {
  "i": 241,
  "style": "Main",
  "name": "Robin",
  "text": "{\\fad(150,150)}Doce Fleur!"
 },
 {
  "i": 242,
  "style": "Note",
  "name": "Robin",
  "text": "{\\fad(150,150)}Twelve Flowers"
 },
 {
  "i": 243,
  "style": "Main",
  "name": "Jigoro",
  "text": "You nuisance..."
 },
 {
  "i": 244,
  "style": "Main",
  "name": "Jigoro",
  "text": "Disappear!"
 },
 {
  "i": 245,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "Why'd you attack me too?!"
 },
 {
  "i": 246,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "Don't get in my way!"
 },
 {
  "i": 247,
  "style": "Main",
  "name": "Jigoro",
  "text": "Now you made me angry!"
 },
 {
  "i": 248,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "That'd be you!"
 },
 {
  "i": 249,
  "style": "Main",
  "name": "Dog-Penguin",
  "text": "I received that order!"
 },
 {
  "i": 250,
  "style": "Main",
  "name": "Jigoro",
  "text": "It was me!"
 },
 {
  "i": 251,
  "style": "Main",
  "name": "Hogback",
  "text": "Hey, what're you doing?!"
 },
 {
  "i": 252,
  "style": "Main",
  "name": "Hogback",
  "text": "Cut it out already!"
 },
 {
  "i": 253,
  "style": "Main",
  "name": "Hogback",
  "text": "You should be coopera-"
 },
 {
  "i": 254,
  "style": "Main",
  "name": "Chopper",
  "text": "Robin!"
 },
 {
  "i": 255,
  "style": "Main",
  "name": "Robin",
  "text": "Such an amusing incident, don't you think?"
 },
 {
  "i": 256,
  "style": "Main",
  "name": "Robin",
  "text": "All because of the order given to get rid of the nuisances."
 },
 {
  "i": 257,
  "style": "Main",
  "name": "Chopper",
  "text": "Even with their memories erased..."
 },
 {
  "i": 258,
  "style": "Main",
  "name": "Chopper",
  "text": "It seems that the true nature of those two is to always be in conflict."
 },
 {
  "i": 259,
  "style": "Main",
  "name": "Robin",
  "text": "I'm shocked..."
 },
 {
  "i": 260,
  "style": "Main",
  "name": "Robin",
  "text": "This seems like a tall tower."
 },
 {
  "i": 261,
  "style": "Main",
  "name": "Robin",
  "text": "Why don't you try telling us to jump off it?{Off of here? Remove 'from here'?}{The tower is mentioned in the last line, so \"it\" is fine - Sky}{dat grammar}"
 },
 {
  "i": 262,
  "style": "Main",
  "name": "Hogback",
  "text": "What're you implying?!"
 },
 {
  "i": 263,
  "style": "Main",
  "name": "Hogback",
  "text": "That's exactly what I'll say!"
 },
 {
  "i": 264,
  "style": "Main",
  "name": "Hogback",
  "text": "Jump! Jump!"
 },
 {
  "i": 265,
  "style": "Main",
  "name": "Hogback",
  "text": "You two there, jump off!"
 },
 {
  "i": 266,
  "style": "Main",
  "name": "Both",
  "text": "Yes."
 },
 {
  "i": 267,
  "style": "Main",
  "name": "Hogback",
  "text": "N-No, wait!"
 },
 {
  "i": 268,
  "style": "Main",
  "name": "Robin",
  "text": "We'd rather not."
 },
 {
  "i": 269,
  "style": "Main",
  "name": "Hogback",
  "text": "This is unforgivable!"
 },
 {
  "i": 270,
  "style": "Main",
  "name": "Hogback",
  "text": "You tricked me!"
 },
 {
  "i": 271,
  "style": "Main",
  "name": "Hogback",
  "text": "You're the lowest!"
 },
 {
  "i": 272,
  "style": "Main",
  "name": "Hogback",
  "text": "You're not human!"
 },
 {
  "i": 273,
  "style": "Main",
  "name": "Chopper",
  "text": "All the zombies will be purified once Luffy takes out Moriah..."
 },
 {
  "i": 274,
  "style": "Main",
  "name": "Chopper",
  "text": "I just want to pummel you, Hogback!"
 },
 {
  "i": 275,
  "style": "Main",
  "name": "Hogback",
  "text": "Cindry!"
 },
 {
  "i": 276,
  "style": "Main",
  "name": "Hogback",
  "text": "Buy me some time!"
 },
 {
  "i": 277,
  "style": "Main",
  "name": "Hogback",
  "text": "I'm getting out of here!"
 },
 {
  "i": 278,
  "style": "Main",
  "name": "Hogback",
  "text": "Why don't you answer?!"
 },
 {
  "i": 279,
  "style": "Main",
  "name": "Hogback",
  "text": "If you lose, I'll just give you another shadow!"
 },
 {
  "i": 280,
  "style": "Main",
  "name": "Hogback",
  "text": "Don't worry about dying!{Reworded - Sky}"
 },
 {
  "i": 281,
  "style": "Main",
  "name": "Cindry",
  "text": "My body..."
 },
 {
  "i": 282,
  "style": "Main",
  "name": "Cindry",
  "text": "won't move."
 },
 {
  "i": 283,
  "style": "Main",
  "name": "Hogback",
  "text": "C-Cindry!"
 }
]