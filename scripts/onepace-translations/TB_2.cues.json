[
 {
  "i": 0,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Let's travel all through the worldwide seas,"
 },
 {
  "i": 1,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 2,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 3,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 4,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "We were able to escape from the set course"
 },
 {
  "i": 5,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "along the boundary between sky and sea."
 },
 {
  "i": 6,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now we're rowing our way"
 },
 {
  "i": 7,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "to a hidden adventure at the dark bottom of the sea."
 },
 {
  "i": 8,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Doesn't it sound fun just thinking about it?"
 },
 {
  "i": 9,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Let's travel all through the worldwide seas,"
 },
 {
  "i": 10,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 11,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 12,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 13,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "That feeling we had when we set sail"
 },
 {
  "i": 14,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "is something I'll never forget."
 },
 {
  "i": 15,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Because of that"
 },
 {
  "i": 16,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "nothing will be able to scare me..."
 },
 {
  "i": 17,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now, as the trip approaches, our racing heartbeats"
 },
 {
  "i": 18,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "engrave a rhythm of adventure in our shy hearts."
 },
 {
  "i": 19,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Get all the treasures"
 },
 {
  "i": 20,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 21,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 22,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "making a splash..."
 },
 {
  "i": 23,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Fill your empty heart with dreams."
 },
 {
  "i": 24,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Spread your wings."
 },
 {
  "i": 25,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you color your heart with the blowing wind"
 },
 {
  "i": 26,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "you will move on."
 },
 {
  "i": 27,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Get all the treasures"
 },
 {
  "i": 28,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 29,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 30,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "making a splash..."
 },
 {
  "i": 31,
  "style": "Title",
  "name": "",
  "text": "{\\fad(2000,1600)}Adventure on the Ghost Island and\\Nthe Famous Doctor Hogback!"
 },
 {
  "i": 32,
  "style": "Main",
  "name": "Usopp",
  "text": "What is a ghost island, anyway?"
 },
 {
  "i": 33,
  "style": "Main",
  "name": "Chopper",
  "text": "Hey..."
 },
 {
  "i": 34,
  "style": "Main",
  "name": "Chopper",
  "text": "Hey, where did that ghost from earlier go?"
 },
 {
  "i": 35,
  "style": "Main",
  "name": "Chopper",
  "text": "Is it still onboard?"
 },
 {
  "i": 36,
  "style": "Main",
  "name": "Zoro",
  "text": "No, it floated towards that island."
 },
 {
  "i": 37,
  "style": "Main",
  "name": "Zoro",
  "text": "It probably lives there."
 },
 {
  "i": 38,
  "style": "Main",
  "name": "Robin",
  "text": "Earlier there was a lot of shaking..."
 },
 {
  "i": 39,
  "style": "Main",
  "name": "Robin",
  "text": "Perhaps it was the sound from that mouth-like gate closing?"
 },
 {
  "i": 40,
  "style": "Main",
  "name": "Robin",
  "text": "I think we were \"eaten\" by that mouth."
 },
 {
  "i": 41,
  "style": "Main",
  "name": "Luffy",
  "text": "Eaten?"
 },
 {
  "i": 42,
  "style": "Main",
  "name": "Robin",
  "text": "It is difficult to tell with all this fog,"
 },
 {
  "i": 43,
  "style": "Main",
  "name": "Robin",
  "text": "But it looks as if there's a fence that extends from the gate all the way around the island."
 },
 {
  "i": 44,
  "style": "Main",
  "name": "Robin",
  "text": "Which means that we have been trapped inside that fence."
 },
 {
  "i": 45,
  "style": "Captions",
  "name": "",
  "text": "{\\fad(800,0)\\pos(672,128)}Ghost Island\\N\"Thriller Bark\""
 },
 {
  "i": 46,
  "style": "Captions",
  "name": "",
  "text": "{\\fad(800,0)\\pos(1076,250)}Current Location"
 },
 {
  "i": 47,
  "style": "Captions",
  "name": "",
  "text": "{\\fad(800,0)\\pos(1118,660)}\"Mouth\" Gate"
 },
 {
  "i": 48,
  "style": "Main",
  "name": "Usopp",
  "text": "Oh yeah!"
 },
 {
  "i": 49,
  "style": "Main",
  "name": "Usopp",
  "text": "That must be why that skeleton told us to hurry and get out of here!"
 },
 {
  "i": 50,
  "style": "Main",
  "name": "Nami",
  "text": "That would mean that somebody made this into a wandering island!"
 },
 {
  "i": 51,
  "style": "Main",
  "name": "Nami",
  "text": "But why?"
 },
 {
  "i": 52,
  "style": "Main",
  "name": "Franky",
  "text": "Whatever the reason, what matters is that we are in the middle of the ocean."
 },
 {
  "i": 53,
  "style": "Main",
  "name": "Franky",
  "text": "We can not drop anchor here."
 },
 {
  "i": 54,
  "style": "Main",
  "name": "Usopp",
  "text": "Hey hey, why are you talking about stopping?!"
 },
 {
  "i": 55,
  "style": "Main",
  "name": "Usopp",
  "text": "We need to leave now, before we're cursed!"
 },
 {
  "i": 56,
  "style": "Main",
  "name": "Nami",
  "text": "Listen, everyone..."
 },
 {
  "i": 57,
  "style": "Main",
  "name": "Nami",
  "text": "I think I have the \"I can not go on that island\" disease."
 },
 {
  "i": 58,
  "style": "Main",
  "name": "Chopper",
  "text": "Me too!"
 },
 {
  "i": 59,
  "style": "Main",
  "name": "Chopper",
  "text": "I have that too!"
 },
 {
  "i": 60,
  "style": "Main",
  "name": "Luffy",
  "text": "Alright!"
 },
 {
  "i": 61,
  "style": "Main",
  "name": "Luffy",
  "text": "Then you guys can stay here!"
 },
 {
  "i": 62,
  "style": "Main",
  "name": "Usopp",
  "text": "You have \"all ready for adventure\" disease?!"
 },
 {
  "i": 63,
  "style": "Main",
  "name": "Usopp",
  "text": "Reconsider it!"
 },
 {
  "i": 64,
  "style": "Main",
  "name": "Usopp",
  "text": "Luffy, take a good look!"
 },
 {
  "i": 65,
  "style": "Main",
  "name": "Usopp",
  "text": "That creepy building over there..."
 },
 {
  "i": 66,
  "style": "Main",
  "name": "Usopp",
  "text": "That is a real haunted house!"
 },
 {
  "i": 67,
  "style": "Main",
  "name": "Usopp",
  "text": "You're underestimating..."
 },
 {
  "i": 68,
  "style": "Main",
  "name": "Usopp",
  "text": "Evil spirits."
 },
 {
  "i": 69,
  "style": "Main",
  "name": "Luffy",
  "text": "What're you talking about?"
 },
 {
  "i": 70,
  "style": "Main",
  "name": "Luffy",
  "text": "I am gonna be as careful as I can!"
 },
 {
  "i": 71,
  "style": "Main",
  "name": "Luffy",
  "text": "I will catch that ghost from before and keep it as a pet!"
 },
 {
  "i": 72,
  "style": "Main",
  "name": "Usopp",
  "text": "Way underestimating!"
 },
 {
  "i": 73,
  "style": "Main",
  "name": "Luffy",
  "text": "But anyway, we have got to get back\\Nour precious crewmate."
 },
 {
  "i": 74,
  "style": "Main",
  "name": "Luffy",
  "text": "Sanji, pirate lunch box!"
 },
 {
  "i": 75,
  "style": "Main",
  "name": "Usopp",
  "text": "Crewmate?"
 },
 {
  "i": 76,
  "style": "Main",
  "name": "Usopp",
  "text": "I am against that!"
 },
 {
  "i": 77,
  "style": "Main",
  "name": "Usopp",
  "text": "If you let that skeleton come with us, I will be too scared to sleep at night!"
 },
 {
  "i": 78,
  "style": "Main",
  "name": "Robin",
  "text": "I have the lunch."
 },
 {
  "i": 79,
  "style": "Main",
  "name": "Sanji",
  "text": "Luffy, Franky."
 },
 {
  "i": 80,
  "style": "Main",
  "name": "Sanji",
  "text": "You two take good care of Robin-chan."
 },
 {
  "i": 81,
  "style": "Main",
  "name": "Franky",
  "text": "Going to explore an unknown island just gives me the chills."
 },
 {
  "i": 82,
  "style": "Main",
  "name": "Nami",
  "text": "You're kidding me!"
 },
 {
  "i": 83,
  "style": "Main",
  "name": "Nami",
  "text": "Robin's going too?!"
 },
 {
  "i": 84,
  "style": "Main",
  "name": "Robin",
  "text": "I love thrills."
 },
 {
  "i": 85,
  "style": "Main",
  "name": "Franky",
  "text": "Alright!"
 },
 {
  "i": 86,
  "style": "Main",
  "name": "Franky",
  "text": "Alright you guys, we're gonna have to take a boat out to the island."
 },
 {
  "i": 87,
  "style": "Main",
  "name": "Franky",
  "text": "But you guys still haven't seen my present."
 },
 {
  "i": 88,
  "style": "Main",
  "name": "Franky",
  "text": "Soldier Dock System Channel Two."
 },
 {
  "i": 89,
  "style": "Main",
  "name": "all",
  "text": "Two?"
 },
 {
  "i": 90,
  "style": "Main",
  "name": "Franky",
  "text": "This system has five channels."
 },
 {
  "i": 91,
  "style": "Main",
  "name": "Franky",
  "text": "There are two zeros, and then,"
 },
 {
  "i": 92,
  "style": "Main",
  "name": "Franky",
  "text": "One,"
 },
 {
  "i": 93,
  "style": "Main",
  "name": "Franky",
  "text": "Two,"
 },
 {
  "i": 94,
  "style": "Main",
  "name": "Franky",
  "text": "Three,"
 },
 {
  "i": 95,
  "style": "Main",
  "name": "Franky",
  "text": "Four."
 },
 {
  "i": 96,
  "style": "Main",
  "name": "Franky",
  "text": "Each one has its own specialized use."
 },
 {
  "i": 97,
  "style": "Main",
  "name": "Nami",
  "text": "Hold on."
 },
 {
  "i": 98,
  "style": "Main",
  "name": "Nami",
  "text": "We've already seen Zero's paddles, along with Docks One and Three."
 },
 {
  "i": 99,
  "style": "Main",
  "name": "Usopp",
  "text": "But you said Two and Four were empty!"
 },
 {
  "i": 100,
  "style": "Main",
  "name": "Franky",
  "text": "I told you that 'cuz it's a present!"
 },
 {
  "i": 101,
  "style": "Main",
  "name": "Franky",
  "text": "The guys who aren't going to the island can test it out first."
 },
 {
  "i": 102,
  "style": "Main",
  "name": "Franky",
  "text": "Soldier Dock System Channel Two!"
 },
 {
  "i": 103,
  "style": "Main",
  "name": "Franky",
  "text": "Here it is!"
 },
 {
  "i": 104,
  "style": "Main",
  "name": "Luffy",
  "text": "What is it?"
 },
 {
  "i": 105,
  "style": "Main",
  "name": "Luffy",
  "text": "What is going to come out?"
 },
 {
  "i": 106,
  "style": "Main",
  "name": "Franky",
  "text": "The steam-powered..."
 },
 {
  "i": 107,
  "style": "Main",
  "name": "Franky",
  "text": "Paddleship!"
 },
 {
  "i": 108,
  "style": "Main",
  "name": "Franky",
  "text": "The shopping boat,"
 },
 {
  "i": 109,
  "style": "Main",
  "name": "Franky",
  "text": "Mini Merry #2!"
 },
 {
  "i": 110,
  "style": "Main",
  "name": "Usopp",
  "text": "It is Merry!"
 },
 {
  "i": 111,
  "style": "Main",
  "name": "Usopp",
  "text": "Merry came back to us!"
 },
 {
  "i": 112,
  "style": "Main",
  "name": "Chopper",
  "text": "It's kinda small, but now we can ride Merry again!"
 },
 {
  "i": 113,
  "style": "Main",
  "name": "Nami",
  "text": "I can't believe he had such a great present..."
 },
 {
  "i": 114,
  "style": "Main",
  "name": "Nami",
  "text": "Thank you, Franky!"
 },
 {
  "i": 115,
  "style": "Main",
  "name": "Sanji",
  "text": "If that's our shopping boat, I'd go shopping any time!"
 },
 {
  "i": 116,
  "style": "Main",
  "name": "Luffy",
  "text": "It's my turn! Hurry up, it's my turn!"
 },
 {
  "i": 117,
  "style": "Main",
  "name": "Zoro",
  "text": "That's really great."
 },
 {
  "i": 118,
  "style": "Main",
  "name": "Franky",
  "text": "Just hold on Straw Hat,"
 },
 {
  "i": 119,
  "style": "Main",
  "name": "Franky",
  "text": "We'll ride it here soon."
 },
 {
  "i": 120,
  "style": "Main",
  "name": "Franky",
  "text": "Let them have fun with it for now."
 },
 {
  "i": 121,
  "style": "Main",
  "name": "Luffy",
  "text": "Is that all of them, Franky?"
 },
 {
  "i": 122,
  "style": "Main",
  "name": "Luffy",
  "text": "Yeah."
 },
 {
  "i": 123,
  "style": "Main",
  "name": "Franky",
  "text": "Combined with One and Three, which you saw earlier, this is all of 'em!"
 },
 {
  "i": 124,
  "style": "Main",
  "name": "Franky",
  "text": "Channel Zero - Support Paddle!"
 },
 {
  "i": 125,
  "style": "Main",
  "name": "Franky",
  "text": "Channel One, a waver that can hold one person - White Wooden Horse #1!"
 },
 {
  "i": 126,
  "style": "Main",
  "name": "Franky",
  "text": "Channel Two, a shopping boat that can hold four people - Mini Merry #2!"
 },
 {
  "i": 127,
  "style": "Main",
  "name": "Franky",
  "text": "Channel Three, a scouting submarine that can hold three people - Shark Submerge #3!"
 },
 {
  "i": 128,
  "style": "Main",
  "name": "Franky",
  "text": "Right now, that is the whole Soldier Dock System."
 },
 {
  "i": 129,
  "style": "Main",
  "name": "Franky",
  "text": "Just think of them as soldiers helping out Thousand Sunny."
 },
 {
  "i": 130,
  "style": "Main",
  "name": "Luffy",
  "text": "I really like the way you think, Franky!"
 },
 {
  "i": 131,
  "style": "Main",
  "name": "Luffy",
  "text": "You! You! You!"
 },
 {
  "i": 132,
  "style": "Main",
  "name": "Franky",
  "text": "Yeah, I am just really great this week too..."
 },
 {
  "i": 133,
  "style": "Main",
  "name": "Franky",
  "text": "Super!"
 },
 {
  "i": 134,
  "style": "Main",
  "name": "Sanji",
  "text": "Nami-san!"
 },
 {
  "i": 135,
  "style": "Main",
  "name": "Sanji",
  "text": "Nami-san!"
 },
 {
  "i": 136,
  "style": "Main",
  "name": "Sanji",
  "text": "What's wrong?"
 },
 {
  "i": 137,
  "style": "Main",
  "name": "Sanji",
  "text": "Did something happen?"
 },
 {
  "i": 138,
  "style": "Main",
  "name": "Zoro",
  "text": "What're they up to?"
 },
 {
  "i": 139,
  "style": "Main",
  "name": "Zoro",
  "text": "I can't see anything with this fog."
 },
 {
  "i": 140,
  "style": "Main",
  "name": "Robin",
  "text": "It came from the direction of the island."
 },
 {
  "i": 141,
  "style": "Main",
  "name": "Luffy",
  "text": "You guys!"
 },
 {
  "i": 142,
  "style": "Main",
  "name": "Luffy",
  "text": "Hurry and let me ride on Mini Merry too!"
 },
 {
  "i": 143,
  "style": "Main",
  "name": "Sanji",
  "text": "Bastard, you need to worry about Nami-san's safety!"
 },
 {
  "i": 144,
  "style": "Main",
  "name": "Franky",
  "text": "And you need to worry about the other two's safety too."
 },
 {
  "i": 145,
  "style": "Main",
  "name": "Robin",
  "text": "Perhaps she screamed as she was cursed by a ghost?"
 },
 {
  "i": 146,
  "style": "Main",
  "name": "Zoro",
  "text": "Stop that, it's not funny."
 },
 {
  "i": 147,
  "style": "Main",
  "name": "Luffy",
  "text": "What?"
 },
 {
  "i": 148,
  "style": "Main",
  "name": "Sanji",
  "text": "Nobody was touching the anchor..."
 },
 {
  "i": 149,
  "style": "Main",
  "name": "Franky",
  "text": "It's still brand new, so the gears shouldn't be that worn out yet..."
 },
 {
  "i": 150,
  "style": "Main",
  "name": "Zoro",
  "text": "Hurry and bring it up, the ship's gonna overbalance!"
 },
 {
  "i": 151,
  "style": "Main",
  "name": "Franky",
  "text": "What?"
 },
 {
  "i": 152,
  "style": "Main",
  "name": "Franky",
  "text": "Did someone do that?"
 },
 {
  "i": 153,
  "style": "Main",
  "name": "Sanji",
  "text": "No."
 },
 {
  "i": 154,
  "style": "Main",
  "name": "Sanji",
  "text": "Nobody's close enough."
 },
 {
  "i": 155,
  "style": "Main",
  "name": "Sanji",
  "text": "Luffy!"
 },
 {
  "i": 156,
  "style": "Main",
  "name": "Sanji",
  "text": "What are you doing?"
 },
 {
  "i": 157,
  "style": "Main",
  "name": "Sanji",
  "text": "Stop screwing around at a time like this!"
 },
 {
  "i": 158,
  "style": "Main",
  "name": "Luffy",
  "text": "Nyo, yats not ish!"
 },
 {
  "i": 159,
  "style": "Note",
  "name": "Luffy",
  "text": "{\\an8}No, that's not it!"
 },
 {
  "i": 160,
  "style": "Main",
  "name": "Luffy",
  "text": "Yaim noi joing anyjing!"
 },
 {
  "i": 161,
  "style": "Note",
  "name": "Luffy",
  "text": "{\\an8}I'm not doing anything!"
 },
 {
  "i": 162,
  "style": "Main",
  "name": "Franky",
  "text": "Look out, Straw Hat!"
 },
 {
  "i": 163,
  "style": "Main",
  "name": "Franky",
  "text": "Hey, bastard!"
 },
 {
  "i": 164,
  "style": "Main",
  "name": "Franky",
  "text": "What the hell was that for?!"
 },
 {
  "i": 165,
  "style": "Main",
  "name": "Zoro",
  "text": "Sorry, my sword just did that..."
 },
 {
  "i": 166,
  "style": "Main",
  "name": "Sanji",
  "text": "This is weird..."
 },
 {
  "i": 167,
  "style": "Main",
  "name": "Franky",
  "text": "With the exception of us... on this deck..."
 },
 {
  "i": 168,
  "style": "Main",
  "name": "Zoro",
  "text": "There's something else."
 },
 {
  "i": 169,
  "style": "Main",
  "name": "Franky",
  "text": "Maybe a ghost did it?"
 },
 {
  "i": 170,
  "style": "Main",
  "name": "Franky",
  "text": "Or a devil fruit user, or somethin' like that?"
 },
 {
  "i": 171,
  "style": "Main",
  "name": "Luffy",
  "text": "Yeah, it felt like someone was grabbing me."
 },
 {
  "i": 172,
  "style": "Main",
  "name": "Robin",
  "text": "I heard the growl of a wild beast."
 },
 {
  "i": 173,
  "style": "Main",
  "name": "Franky",
  "text": "A beast?"
 },
 {
  "i": 174,
  "style": "Main",
  "name": "Sanji",
  "text": "Anyway, I'm worried about Nami-san!"
 },
 {
  "i": 175,
  "style": "Main",
  "name": "Sanji",
  "text": "You guys take care of the ship!"
 },
 {
  "i": 176,
  "style": "Main",
  "name": "Sanji",
  "text": "I'm gonna go save those guys!"
 },
 {
  "i": 177,
  "style": "Main",
  "name": "all",
  "text": "So uncool!"
 },
 {
  "i": 178,
  "style": "Main",
  "name": "Luffy",
  "text": "Woah, Sanji's floating!"
 },
 {
  "i": 179,
  "style": "Main",
  "name": "Franky",
  "text": "How is that possible?!"
 },
 {
  "i": 180,
  "style": "Main",
  "name": "Zoro",
  "text": "You made a \"hogeh\"-noise."
 },
 {
  "i": 181,
  "style": "Main",
  "name": "Sanji",
  "text": "Shut up, you!"
 },
 {
  "i": 182,
  "style": "Main",
  "name": "Sanji",
  "text": "You would've done the same!"
 },
 {
  "i": 183,
  "style": "Main",
  "name": "Franky",
  "text": "We can't even leave the ship?"
 },
 {
  "i": 184,
  "style": "Main",
  "name": "Zoro",
  "text": "What are they trying to do?"
 },
 {
  "i": 185,
  "style": "Main",
  "name": "Zoro",
  "text": "If they wanted us dead, they could've done that by now..."
 },
 {
  "i": 186,
  "style": "Main",
  "name": "Sanji",
  "text": "What's wrong, Robin-chan?"
 },
 {
  "i": 187,
  "style": "Main",
  "name": "Robin",
  "text": "Something's... grabbing me..."
 },
 {
  "i": 188,
  "style": "Main",
  "name": "Sanji",
  "text": "How dare you do something like that!"
 },
 {
  "i": 189,
  "style": "Main",
  "name": "Sanji",
  "text": "Robin-chan!"
 },
 {
  "i": 190,
  "style": "Main",
  "name": "Luffy",
  "text": "There really is an animal!"
 },
 {
  "i": 191,
  "style": "Main",
  "name": "Luffy",
  "text": "What now?"
 },
 {
  "i": 192,
  "style": "Main",
  "name": "Franky",
  "text": "Look!"
 },
 {
  "i": 193,
  "style": "Main",
  "name": "Franky",
  "text": "A wave!"
 },
 {
  "i": 194,
  "style": "Main",
  "name": "Franky",
  "text": "It has gotta be some sort of artificial one to be inside this fence!"
 },
 {
  "i": 195,
  "style": "Main",
  "name": "Franky",
  "text": "The ship's gonna capsize!"
 },
 {
  "i": 196,
  "style": "Main",
  "name": "Sanji",
  "text": "Robin-chan, is it gone?"
 },
 {
  "i": 197,
  "style": "Main",
  "name": "Robin",
  "text": "I'm fine, I think it left."
 },
 {
  "i": 198,
  "style": "Main",
  "name": "Zoro",
  "text": "Hey, Hogeh, raise the anchor, or we're gonna sink!"
 },
 {
  "i": 199,
  "style": "Main",
  "name": "Sanji",
  "text": "Who the hell is \"Hogeh\"?!"
 },
 {
  "i": 200,
  "style": "Main",
  "name": "Zoro",
  "text": "Usopp! Chopper!"
 },
 {
  "i": 201,
  "style": "Main",
  "name": "Zoro",
  "text": "Can you hear us?"
 },
 {
  "i": 202,
  "style": "Main",
  "name": "Sanji",
  "text": "Damn, we're gonna be seperated from Nami-san."
 },
 {
  "i": 203,
  "style": "Main",
  "name": "Luffy",
  "text": "Hey Franky!"
 },
 {
  "i": 204,
  "style": "Main",
  "name": "Luffy",
  "text": "Do something with the secret weapon!"
 },
 {
  "i": 205,
  "style": "Main",
  "name": "Franky",
  "text": "Alright, I've got the \"Flying Surprise Pool\" we can use!"
 },
 {
  "i": 206,
  "style": "Main",
  "name": "Luffy",
  "text": "That sounds fun!"
 },
 {
  "i": 207,
  "style": "Main",
  "name": "all",
  "text": "You idiot!"
 },
 {
  "i": 208,
  "style": "Main",
  "name": "Usopp",
  "text": "O-Ouch!"
 },
 {
  "i": 209,
  "style": "Main",
  "name": "Nami",
  "text": "Of course you're hurt."
 },
 {
  "i": 210,
  "style": "Main",
  "name": "Nami",
  "text": "We must've fallen down here."
 },
 {
  "i": 211,
  "style": "Main",
  "name": "Chopper",
  "text": "Where are we?"
 },
 {
  "i": 212,
  "style": "Main",
  "name": "Nami",
  "text": "We're on the ghost island."
 },
 {
  "i": 213,
  "style": "Main",
  "name": "both",
  "text": "Ghost!"
 },
 {
  "i": 214,
  "style": "Main",
  "name": "Nami",
  "text": "Oh, stop that!"
 },
 {
  "i": 215,
  "style": "Main",
  "name": "Nami",
  "text": "You don't need to be scared!"
 },
 {
  "i": 216,
  "style": "Main",
  "name": "Usopp",
  "text": "But just what happened to us?"
 },
 {
  "i": 217,
  "style": "Main",
  "name": "Nami",
  "text": "We were having so much fun on Mini Merry that we accidentally hit the bank."
 },
 {
  "i": 218,
  "style": "Main",
  "name": "Nami",
  "text": "We were distracted and couldn't see in the fog..."
 },
 {
  "i": 219,
  "style": "Main",
  "name": "Nami",
  "text": "All three of us were sent flying..."
 },
 {
  "i": 220,
  "style": "Main",
  "name": "Nami",
  "text": "And in the blink of an eye, we were here."
 },
 {
  "i": 221,
  "style": "Main",
  "name": "Nami",
  "text": "It's 100% my fault, but..."
 },
 {
  "i": 222,
  "style": "Main",
  "name": "Nami",
  "text": "You'll forgive me since I'm cute, right?"
 },
 {
  "i": 223,
  "style": "Main",
  "name": "Usopp",
  "text": "I'll get you for this!"
 },
 {
  "i": 224,
  "style": "Captions",
  "name": "text",
  "text": "{\\pos(541.489,214.5)}I'm very sorry."
 },
 {
  "i": 225,
  "style": "Main",
  "name": "Usopp",
  "text": "But anyway, it's weird that just after getting to this island there's a huge ditch!"
 },
 {
  "i": 226,
  "style": "Main",
  "name": "Nami",
  "text": "It's probably to catch their enemies."
 },
 {
  "i": 227,
  "style": "Main",
  "name": "Nami",
  "text": "We're just lucky it wasn't filled with spikes."
 },
 {
  "i": 228,
  "style": "Main",
  "name": "Chopper",
  "text": "Yeah,"
 },
 {
  "i": 229,
  "style": "Main",
  "name": "Chopper",
  "text": "We're safe 'cuz we landed on these skeletons."
 },
 {
  "i": 230,
  "style": "Main",
  "name": "Nami",
  "text": "I told you to stop!"
 },
 {
  "i": 231,
  "style": "Main",
  "name": "Usopp",
  "text": "But this must be the entrance."
 },
 {
  "i": 232,
  "style": "Main",
  "name": "Usopp",
  "text": "If we just wait here, Luffy will find us."
 },
 {
  "i": 233,
  "style": "Main",
  "name": "Chopper",
  "text": "But we're lower than sea level, that's kinda scary."
 },
 {
  "i": 234,
  "style": "Main",
  "name": "Usopp",
  "text": "Yeah, it's dangerous, and they might not be able to see us here."
 },
 {
  "i": 235,
  "style": "Main",
  "name": "Nami",
  "text": "So should we wait on the bank above?"
 },
 {
  "i": 236,
  "style": "Main",
  "name": "Usopp",
  "text": "The bank?"
 },
 {
  "i": 237,
  "style": "Main",
  "name": "Usopp",
  "text": "But I don't know which way..."
 },
 {
  "i": 238,
  "style": "Main",
  "name": "Usopp",
  "text": "What's that?"
 },
 {
  "i": 239,
  "style": "Main",
  "name": "Usopp",
  "text": "A dog?"
 },
 {
  "i": 240,
  "style": "Main",
  "name": "Nami",
  "text": "That's not a dog..."
 },
 {
  "i": 241,
  "style": "Main",
  "name": "Usopp",
  "text": "Then... then what is it?"
 },
 {
  "i": 242,
  "style": "Main",
  "name": "Chopper",
  "text": "That... it can't be..."
 },
 {
  "i": 243,
  "style": "Main",
  "name": "Chopper",
  "text": "Ce... Ce..."
 },
 {
  "i": 244,
  "style": "Main",
  "name": "Chopper",
  "text": "Cerberus!"
 },
 {
  "i": 245,
  "style": "Main",
  "name": "Usopp",
  "text": "It's Cerberus!"
 },
 {
  "i": 246,
  "style": "Main",
  "name": "Nami",
  "text": "W-What is Cerberus?"
 },
 {
  "i": 247,
  "style": "Main",
  "name": "Usopp",
  "text": "It's the guard dog of hell!"
 },
 {
  "i": 248,
  "style": "Main",
  "name": "Nami",
  "text": "It really exists?!"
 },
 {
  "i": 249,
  "style": "Main",
  "name": "Usopp",
  "text": "It must, it's right behind us!"
 },
 {
  "i": 250,
  "style": "Main",
  "name": "Chopper",
  "text": "So this is hell?!"
 },
 {
  "i": 251,
  "style": "Main",
  "name": "Nami",
  "text": "We're in hell!"
 },
 {
  "i": 252,
  "style": "Main",
  "name": "Usopp",
  "text": "Just keep running!"
 },
 {
  "i": 253,
  "style": "Main",
  "name": "Usopp",
  "text": "If it catches us, it'll eat us!"
 },
 {
  "i": 254,
  "style": "Main",
  "name": "Usopp",
  "text": "Hey, what is it, Chopper?"
 },
 {
  "i": 255,
  "style": "Main",
  "name": "Nami",
  "text": "Chopper, what do you see?"
 },
 {
  "i": 256,
  "style": "Main",
  "name": "Chopper",
  "text": "\"Kon\"...?"
 },
 {
  "i": 257,
  "style": "Main",
  "name": "Chopper",
  "text": "Hey, look at it carefully!"
 },
 {
  "i": 258,
  "style": "Main",
  "name": "Chopper",
  "text": "Isn't one of them a fox?!"
 },
 {
  "i": 259,
  "style": "Main",
  "name": "Usopp",
  "text": "Now it's saying \"gon\"!"
 },
 {
  "i": 260,
  "style": "Main",
  "name": "Nami",
  "text": "It really didn't like it!"
 },
 {
  "i": 261,
  "style": "Main",
  "name": "Chopper",
  "text": "I'm sorry! I'm sorry! I'm sorry!"
 },
 {
  "i": 262,
  "style": "Main",
  "name": "Nami",
  "text": "Look, stairs!"
 },
 {
  "i": 263,
  "style": "Main",
  "name": "Nami",
  "text": "We can leave that way!"
 },
 {
  "i": 264,
  "style": "Main",
  "name": "Chopper",
  "text": "Thank god!"
 },
 {
  "i": 265,
  "style": "Main",
  "name": "Usopp",
  "text": "Does it have a bad sense of smell, even though it's a dog?"
 },
 {
  "i": 266,
  "style": "Main",
  "name": "Usopp",
  "text": "It left..."
 },
 {
  "i": 267,
  "style": "Main",
  "name": "Nami",
  "text": "What now?"
 },
 {
  "i": 268,
  "style": "Main",
  "name": "Nami",
  "text": "We ended up in a forest..."
 },
 {
  "i": 269,
  "style": "Main",
  "name": "Chopper",
  "text": "If that thing's walking around, then if we're anywhere not hidden we're in danger..."
 },
 {
  "i": 270,
  "style": "Main",
  "name": "Hildon",
  "text": "You are correct, sir."
 },
 {
  "i": 271,
  "style": "Main",
  "name": "Usopp",
  "text": "Who are you?!"
 },
 {
  "i": 272,
  "style": "Main",
  "name": "Hildon",
  "text": "I am known as Hildon."
 },
 {
  "i": 273,
  "style": "Main",
  "name": "Hildon",
  "text": "I saw that you all were being chased by the guard dog,"
 },
 {
  "i": 274,
  "style": "Main",
  "name": "Hildon",
  "text": "So I followed you in secret, in case you had trouble."
 },
 {
  "i": 275,
  "style": "Main",
  "name": "Hildon",
  "text": "It will be night soon, after all."
 },
 {
  "i": 276,
  "style": "Main",
  "name": "Hildon",
  "text": "This forest will become incredibly dangerous to those like yourselves who are unfamiliar with it."
 },
 {
  "i": 277,
  "style": "Main",
  "name": "Hildon",
  "text": "So if you wish, I can take you to our mansion."
 },
 {
  "i": 278,
  "style": "Main",
  "name": "Nami",
  "text": "Mansion?"
 },
 {
  "i": 279,
  "style": "Main",
  "name": "Hildon",
  "text": "Yes..."
 },
 {
  "i": 280,
  "style": "Main",
  "name": "Hildon",
  "text": "Doctor Hogback-sama's mansion."
 },
 {
  "i": 281,
  "style": "Main",
  "name": "Nami",
  "text": "What is it?"
 },
 {
  "i": 282,
  "style": "Main",
  "name": "Usopp",
  "text": "What's wrong, Chopper?"
 },
 {
  "i": 283,
  "style": "Main",
  "name": "Chopper",
  "text": "Hogback?"
 },
 {
  "i": 284,
  "style": "Main",
  "name": "Nami",
  "text": "Hey..."
 },
 {
  "i": 285,
  "style": "Main",
  "name": "Nami",
  "text": "I couldn't see the horses very well through the fog, but..."
 },
 {
  "i": 286,
  "style": "Main",
  "name": "Nami",
  "text": "Is there something wrong with them?"
 },
 {
  "i": 287,
  "style": "Main",
  "name": "Hildon",
  "text": "Oh, it's only your imagination."
 },
 {
  "i": 288,
  "style": "Main",
  "name": "Nami",
  "text": "That... that's alright then..."
 },
 {
  "i": 289,
  "style": "Main",
  "name": "Usopp",
  "text": "Anyway, you saved us."
 },
 {
  "i": 290,
  "style": "Main",
  "name": "Usopp",
  "text": "Thanks, we were in trouble."
 },
 {
  "i": 291,
  "style": "Main",
  "name": "Hildon",
  "text": "Oh no, it's my pleasure."
 },
 {
  "i": 292,
  "style": "Main",
  "name": "Hildon",
  "text": "Would you like a drink?"
 },
 {
  "i": 293,
  "style": "Main",
  "name": "Hildon",
  "text": "This forest is full of odd animals, so walking through it is dangerous."
 },
 {
  "i": 294,
  "style": "Main",
  "name": "Chopper",
  "text": "Yeah, I was pretty surprised."
 },
 {
  "i": 295,
  "style": "Main",
  "name": "Chopper",
  "text": "I thought Cerberus was just a made-up creature."
 },
 {
  "i": 296,
  "style": "Main",
  "name": "Usopp",
  "text": "It looked like a mutant or something."
 },
 {
  "i": 297,
  "style": "Main",
  "name": "Usopp",
  "text": "I was wondering if we'd ever be able to get down from that tree."
 },
 {
  "i": 298,
  "style": "Main",
  "name": "Hildon",
  "text": "If you're waiting for others, the mansion is ideal."
 },
 {
  "i": 299,
  "style": "Main",
  "name": "Hildon",
  "text": "It's very visible, and very safe."
 },
 {
  "i": 300,
  "style": "Main",
  "name": "Chopper",
  "text": "And we'll also be able to meet Doctor Hogback."
 },
 {
  "i": 301,
  "style": "Main",
  "name": "Usopp",
  "text": "Is he really that famous?"
 },
 {
  "i": 302,
  "style": "Main",
  "name": "Chopper",
  "text": "Every doctor's heard of him."
 },
 {
  "i": 303,
  "style": "Main",
  "name": "Chopper",
  "text": "He's a surgical genius!"
 },
 {
  "i": 304,
  "style": "Main",
  "name": "Chopper",
  "text": "With his miraculous operations, he's saved countless numbers of people!"
 },
 {
  "i": 305,
  "style": "Main",
  "name": "Chopper",
  "text": "He has all the status and honor a doctor can get,"
 },
 {
  "i": 306,
  "style": "Main",
  "name": "Chopper",
  "text": "And he's respected by doctors everywhere!"
 },
 {
  "i": 307,
  "style": "Main",
  "name": "Chopper",
  "text": "But one day,"
 },
 {
  "i": 308,
  "style": "Main",
  "name": "Chopper",
  "text": "he suddenly disappeared."
 },
 {
  "i": 309,
  "style": "Main",
  "name": "Chopper",
  "text": "There were rumors that he had been abducted,"
 },
 {
  "i": 310,
  "style": "Main",
  "name": "Chopper",
  "text": "and the doctors of the world were all in an uproar."
 },
 {
  "i": 311,
  "style": "Main",
  "name": "Chopper",
  "text": "But after years went by without a trace,\\NHogback's name is now simply a legend..."
 },
 {
  "i": 312,
  "style": "Main",
  "name": "Chopper",
  "text": "That Doctor Hogback?!"
 },
 {
  "i": 313,
  "style": "Main",
  "name": "Hildon",
  "text": "Yes, even now the Doctor is researching new things."
 },
 {
  "i": 314,
  "style": "Main",
  "name": "Chopper",
  "text": "I hope I can get an autograph!"
 },
 {
  "i": 315,
  "style": "Main",
  "name": "Hildon",
  "text": "I'm sure we can arrange it."
 },
 {
  "i": 316,
  "style": "Main",
  "name": "Nami",
  "text": "No way..."
 },
 {
  "i": 317,
  "style": "Main",
  "name": "Nami",
  "text": "There are even lions in this forest?"
 },
 {
  "i": 318,
  "style": "Main",
  "name": "Usopp",
  "text": "What was that for?!"
 },
 {
  "i": 319,
  "style": "Main",
  "name": "Usopp",
  "text": "Don't scare me like that!"
 },
 {
  "i": 320,
  "style": "Main",
  "name": "Usopp",
  "text": "What's wrong?"
 },
 {
  "i": 321,
  "style": "Main",
  "name": "Nami",
  "text": "W-Well, just now, there was a l-lion..."
 },
 {
  "i": 322,
  "style": "Main",
  "name": "Nami",
  "text": "Like this."
 },
 {
  "i": 323,
  "style": "Main",
  "name": "Usopp",
  "text": "Yeah, right!"
 },
 {
  "i": 324,
  "style": "Main",
  "name": "Nami",
  "text": "Then, take a look for yourself!"
 },
 {
  "i": 325,
  "style": "Main",
  "name": "Nami",
  "text": "See?"
 },
 {
  "i": 326,
  "style": "Main",
  "name": "zombie",
  "text": "{\\i1}Food, food, food!"
 },
 {
  "i": 327,
  "style": "Main",
  "name": "all",
  "text": "Something's there!"
 },
 {
  "i": 328,
  "style": "Main",
  "name": "all",
  "text": "Something's definitely there!"
 },
 {
  "i": 329,
  "style": "Main",
  "name": "Nami",
  "text": "Wait up a sec!"
 },
 {
  "i": 330,
  "style": "Main",
  "name": "Nami",
  "text": "Please stop the cart, Hildon-san!"
 },
 {
  "i": 331,
  "style": "Main",
  "name": "Hildon",
  "text": "Why are you so upset?"
 },
 {
  "i": 332,
  "style": "Main",
  "name": "Hildon",
  "text": "Perhaps you were just seeing things?"
 },
 {
  "i": 333,
  "style": "Main",
  "name": "Usopp",
  "text": "No, she wasn't!"
 },
 {
  "i": 334,
  "style": "Main",
  "name": "Usopp",
  "text": "There's something out there!"
 },
 {
  "i": 335,
  "style": "Main",
  "name": "Usopp",
  "text": "This forest is too weird!"
 },
 {
  "i": 336,
  "style": "Main",
  "name": "Hildon",
  "text": "Yes, it is a strange forest."
 },
 {
  "i": 337,
  "style": "Main",
  "name": "Hildon",
  "text": "And, due to the thick fog and people's paranoia, {depending on whether there's a pause at the beginning, the comma should be kept or removed}"
 },
 {
  "i": 338,
  "style": "Main",
  "name": "Hildon",
  "text": "many people believe they see things out here."
 },
 {
  "i": 339,
  "style": "Main",
  "name": "Chopper",
  "text": "So, it wasn't real? {remove the comma?}"
 },
 {
  "i": 340,
  "style": "Main",
  "name": "Chopper",
  "text": "That's good..."
 },
 {
  "i": 341,
  "style": "Main",
  "name": "Usopp",
  "text": "No, wait..."
 },
 {
  "i": 342,
  "style": "Main",
  "name": "Usopp",
  "text": "An illusion?"
 },
 {
  "i": 343,
  "style": "Main",
  "name": "Usopp",
  "text": "No, it was way too clear!"
 },
 {
  "i": 344,
  "style": "Main",
  "name": "Nami",
  "text": "Hildon-san,"
 },
 {
  "i": 345,
  "style": "Main",
  "name": "Nami",
  "text": "I'm sorry, but could you just bring us to the coast?"
 },
 {
  "i": 346,
  "style": "Main",
  "name": "Nami",
  "text": "I know it's dangerous, but we can handle it."
 },
 {
  "i": 347,
  "style": "Main",
  "name": "Chopper",
  "text": "But then I can't meet Doctor Hogback! {once again, watch out for pauses on the first comma}"
 },
 {
  "i": 348,
  "style": "Main",
  "name": "Chopper",
  "text": "I wanna meet him!"
 },
 {
  "i": 349,
  "style": "Main",
  "name": "Usopp",
  "text": "No, no, I know how you feel."
 },
 {
  "i": 350,
  "style": "Main",
  "name": "Usopp",
  "text": "But this time we gotta rely on our special ability, the \"something's fishy here” sensor!"
 },
 {
  "i": 351,
  "style": "Main",
  "name": "Usopp",
  "text": "Would you die to meet that doctor..."
 },
 {
  "i": 352,
  "style": "Main",
  "name": "Usopp",
  "text": "Would you survive and not meet him so you can leave the island..."
 },
 {
  "i": 353,
  "style": "Main",
  "name": "Usopp",
  "text": "Which do you pick?"
 },
 {
  "i": 354,
  "style": "Main",
  "name": "Chopper",
  "text": "Well, I don't wanna die."
 },
 {
  "i": 355,
  "style": "Main",
  "name": "Chopper",
  "text": "I'm too scared."
 },
 {
  "i": 356,
  "style": "Main",
  "name": "Hildon",
  "text": "Oh, is that so?"
 },
 {
  "i": 357,
  "style": "Main",
  "name": "Hildon",
  "text": "If that is what you wish..."
 },
 {
  "i": 358,
  "style": "Main",
  "name": "Hildon",
  "text": "Everyone, please wait here."
 },
 {
  "i": 359,
  "style": "Main",
  "name": "Hildon",
  "text": "Stop the cart!"
 },
 {
  "i": 360,
  "style": "Main",
  "name": "Nami",
  "text": "Sorry for taking away your chance, Chopper..."
 },
 {
  "i": 361,
  "style": "Main",
  "name": "Chopper",
  "text": "It's okay, I'm just no good at running off and doing my own thing like Luffy does..."
 },
 {
  "i": 362,
  "style": "Captions",
  "name": "text",
  "text": "{\\fad(600,0)}10 minutes later..."
 },
 {
  "i": 363,
  "style": "Main",
  "name": "text",
  "text": "{\\fad(800,800)}{\\c&HFDB873&\\fs70}Silence..."
 },
 {
  "i": 364,
  "style": "Main",
  "name": "Usopp",
  "text": "That's weird, all he was doing was turning it..."
 },
 {
  "i": 365,
  "style": "Main",
  "name": "Usopp",
  "text": "There's nobody there!"
 },
 {
  "i": 366,
  "style": "Main",
  "name": "Usopp",
  "text": "The horses are gone too!"
 },
 {
  "i": 367,
  "style": "Main",
  "name": "Usopp",
  "text": "We're all alone in the middle of a graveyard!"
 },
 {
  "i": 368,
  "style": "Main",
  "name": "Nami",
  "text": "What?!"
 },
 {
  "i": 369,
  "style": "Main",
  "name": "Nami",
  "text": "How?"
 },
 {
  "i": 370,
  "style": "Main",
  "name": "Chopper",
  "text": "He abandoned us?"
 },
 {
  "i": 371,
  "style": "Main",
  "name": "Chopper",
  "text": "M-Maybe he just went to the bathroom!"
 },
 {
  "i": 372,
  "style": "Main",
  "name": "Usopp",
  "text": "Hildon!"
 },
 {
  "i": 373,
  "style": "Main",
  "name": "Usopp",
  "text": "Hey, where'd you go?"
 },
 {
  "i": 374,
  "style": "Main",
  "name": "Usopp",
  "text": "But why a graveyard, of all places?"
 },
 {
  "i": 375,
  "style": "Main",
  "name": "Nami",
  "text": "What?"
 },
 {
  "i": 376,
  "style": "Main",
  "name": "Nami",
  "text": "No... no way!"
 },
 {
  "i": 377,
  "style": "Main",
  "name": "all",
  "text": "Zo..."
 },
 {
  "i": 378,
  "style": "Main",
  "name": "all",
  "text": "Zombies!"
 },
 {
  "i": 379,
  "style": "Main",
  "name": "Usopp",
  "text": "Ow, ow!"
 },
 {
  "i": 380,
  "style": "Main",
  "name": "Nami",
  "text": "Usopp!"
 },
 {
  "i": 381,
  "style": "Main",
  "name": "Chopper",
  "text": "They're gonna tip the cart!"
 },
 {
  "i": 382,
  "style": "Main",
  "name": "Chopper",
  "text": "These guys're really strong!"
 },
 {
  "i": 383,
  "style": "Main",
  "name": "Usopp",
  "text": "He bit me!"
 },
 {
  "i": 384,
  "style": "Main",
  "name": "Usopp",
  "text": "Dammit, he bit me!"
 },
 {
  "i": 385,
  "style": "Main",
  "name": "Usopp",
  "text": "Now I'm gonna turn into a zombie!"
 },
 {
  "i": 386,
  "style": "Secondary",
  "name": "Nami",
  "text": "Usopp!"
 },
 {
  "i": 387,
  "style": "Main",
  "name": "Nami",
  "text": "I'll save you!"
 },
 {
  "i": 388,
  "style": "Main",
  "name": "Nami",
  "text": "No, don't!"
 },
 {
  "i": 389,
  "style": "Main",
  "name": "Nami",
  "text": "Stop!"
 },
 {
  "i": 390,
  "style": "Main",
  "name": "Usopp",
  "text": "Save me!"
 },
 {
  "i": 391,
  "style": "Main",
  "name": "Chopper",
  "text": "Let Usopp go!"
 },
 {
  "i": 392,
  "style": "Main",
  "name": "Chopper",
  "text": "Bastard!"
 },
 {
  "i": 393,
  "style": "Main",
  "name": "Chopper",
  "text": "I'm sorry!"
 },
 {
  "i": 394,
  "style": "Main",
  "name": "zombie",
  "text": "Hey, you dropped this."
 },
 {
  "i": 395,
  "style": "Main",
  "name": "zombie",
  "text": "Thanks."
 },
 {
  "i": 396,
  "style": "Main",
  "name": "Nami",
  "text": "Save me!"
 },
 {
  "i": 397,
  "style": "Main",
  "name": "Nami",
  "text": "They're gonna bite me!"
 },
 {
  "i": 398,
  "style": "Main",
  "name": "both",
  "text": "Nami!"
 },
 {
  "i": 399,
  "style": "Main",
  "name": "Nami",
  "text": "Let go..."
 },
 {
  "i": 400,
  "style": "Main",
  "name": "Nami",
  "text": "Stay back!"
 },
 {
  "i": 401,
  "style": "Main",
  "name": "Usopp",
  "text": "A zombie's weakness is..."
 },
 {
  "i": 402,
  "style": "Main",
  "name": "Usopp",
  "text": "{\\fad(150,150)}Deadly..."
 },
 {
  "i": 403,
  "style": "Main",
  "name": "Usopp",
  "text": "{\\fad(150,150)}Flame Star!"
 },
 {
  "i": 404,
  "style": "Main",
  "name": "zombie",
  "text": "Fire!"
 },
 {
  "i": 405,
  "style": "Main",
  "name": "zombie",
  "text": "Careful, you'll burn up!"
 },
 {
  "i": 406,
  "style": "Main",
  "name": "Usopp",
  "text": "It worked a lot better than I'd thought..."
 },
 {
  "i": 407,
  "style": "Main",
  "name": "zombie",
  "text": "How dare you do that to us, bastard!"
 },
 {
  "i": 408,
  "style": "Main",
  "name": "zombie",
  "text": "What would you've done if you'd hit us, idiot?!"
 },
 {
  "i": 409,
  "style": "Main",
  "name": "zombie",
  "text": "You rotten person!"
 },
 {
  "i": 410,
  "style": "Main",
  "name": "Chopper",
  "text": "But now the zombies are really mad!"
 },
 {
  "i": 411,
  "style": "Main",
  "name": "Chopper",
  "text": "Let's go, Nami!"
 },
 {
  "i": 412,
  "style": "Main",
  "name": "Usopp",
  "text": "Let’s get away now!"
 },
 {
  "i": 413,
  "style": "Main",
  "name": "Usopp",
  "text": "Now that we're this far, it's closest to just run to the mansion!"
 },
 {
  "i": 414,
  "style": "Main",
  "name": "Chopper",
  "text": "Yeah, let's do that!"
 },
 {
  "i": 415,
  "style": "Main",
  "name": "Nami",
  "text": "That was scary..."
 },
 {
  "i": 416,
  "style": "Main",
  "name": "Usopp",
  "text": "It's alright!"
 },
 {
  "i": 417,
  "style": "Main",
  "name": "Usopp",
  "text": "Once we get out of the graveyard, we'll be fine if we run as fast as we can!"
 },
 {
  "i": 418,
  "style": "Main",
  "name": "Usopp",
  "text": "All zombies can do is groan and walk really slowly!"
 },
 {
  "i": 419,
  "style": "Main",
  "name": "Zombies",
  "text": "Slowly, slowly!"
 },
 {
  "i": 420,
  "style": "Main",
  "name": "Zombies",
  "text": "Wait, you bastard!"
 },
 {
  "i": 421,
  "style": "Main",
  "name": "Usopp",
  "text": "They're fast!"
 },
 {
  "i": 422,
  "style": "Main",
  "name": "zombie",
  "text": "I'm tired..."
 },
 {
  "i": 423,
  "style": "Main",
  "name": "Usopp",
  "text": "They have no stamina!"
 },
 {
  "i": 424,
  "style": "Main",
  "name": "Usopp",
  "text": "I think... we lost them..."
 },
 {
  "i": 425,
  "style": "Main",
  "name": "Usopp",
  "text": "What is wrong with this island?"
 },
 {
  "i": 426,
  "style": "Main",
  "name": "Usopp",
  "text": "It's just covered with things that shouldn't be alive..."
 },
 {
  "i": 427,
  "style": "Main",
  "name": "Usopp",
  "text": "Hey, guys..."
 },
 {
  "i": 428,
  "style": "Main",
  "name": "Usopp",
  "text": "If I turn into a zombie, then you can just{\\fscx250}-{\\r}"
 },
 {
  "i": 429,
  "style": "Main",
  "name": "Nami",
  "text": "What are you talking about?"
 },
 {
  "i": 430,
  "style": "Main",
  "name": "Usopp",
  "text": "I read it in a book on zombies I found in Sunny's library."
 },
 {
  "i": 431,
  "style": "Main",
  "name": "Nami",
  "text": "For being scared of these things, you sure read a lot about them."
 },
 {
  "i": 432,
  "style": "Main",
  "name": "Usopp",
  "text": "Well, here we are."
 },
 {
  "i": 433,
  "style": "Main",
  "name": "Usopp",
  "text": "I just want a glass of water."
 },
 {
  "i": 434,
  "style": "Main",
  "name": "Chopper",
  "text": "I can finally meet him!"
 },
 {
  "i": 435,
  "style": "Main",
  "name": "Chopper",
  "text": "This is great!"
 },
 {
  "i": 436,
  "style": "Main",
  "name": "Nami",
  "text": "I bet that on an island like this..."
 },
 {
  "i": 437,
  "style": "Main",
  "name": "Nami",
  "text": "You can't find a single honest person living on it."
 },
 {
  "i": 438,
  "style": "Main",
  "name": "Nami",
  "text": "Excuse us!"
 },
 {
  "i": 439,
  "style": "Main",
  "name": "Nami",
  "text": "Is this Mr. Doctor Hogback's mansion?"
 }
]