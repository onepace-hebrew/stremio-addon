[
 {
  "i": 0,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Let's travel all through the worldwide seas,"
 },
 {
  "i": 1,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 2,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 3,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 4,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "We were able to escape from the set course"
 },
 {
  "i": 5,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "along the boundary between sky and sea."
 },
 {
  "i": 6,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now we're rowing our way"
 },
 {
  "i": 7,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "to a hidden adventure at the dark bottom of the sea."
 },
 {
  "i": 8,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Doesn't it sound fun just thinking about it?"
 },
 {
  "i": 9,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Let's travel all through the worldwide seas,"
 },
 {
  "i": 10,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 11,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 12,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 13,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "That feeling we had when we set sail"
 },
 {
  "i": 14,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "is something I'll never forget."
 },
 {
  "i": 15,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Because of that"
 },
 {
  "i": 16,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "nothing will be able to scare me..."
 },
 {
  "i": 17,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now, as the trip approaches, our racing heartbeats"
 },
 {
  "i": 18,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "engrave a rhythm of adventure in our shy hearts."
 },
 {
  "i": 19,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Get all the treasures"
 },
 {
  "i": 20,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 21,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 22,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "making a splash..."
 },
 {
  "i": 23,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Fill your empty heart with dreams."
 },
 {
  "i": 24,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Spread your wings."
 },
 {
  "i": 25,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you color your heart with the blowing wind"
 },
 {
  "i": 26,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "you will move on."
 },
 {
  "i": 27,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Get all the treasures"
 },
 {
  "i": 28,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 29,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 30,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "making a splash..."
 },
 {
  "i": 31,
  "style": "Title",
  "name": "",
  "text": "{\\fad(2000,2000)}The Mysterious Visitor!\\NThe Two Warlords Meet!"
 },
 {
  "i": 32,
  "style": "Main",
  "name": "Squirrel",
  "text": "W-What a scary woman."
 },
 {
  "i": 33,
  "style": "Main",
  "name": "Squirrel",
  "text": "We told her..."
 },
 {
  "i": 34,
  "style": "Main",
  "name": "Squirrel",
  "text": "Everything."
 },
 {
  "i": 35,
  "style": "Main",
  "name": "Squirrel",
  "text": "But Perona-sama also loves treasure."
 },
 {
  "i": 36,
  "style": "Main",
  "name": "Squirrel",
  "text": "That's right!"
 },
 {
  "i": 37,
  "style": "Captions",
  "name": "Sign",
  "text": "{\\fad(600,600)}Treasure Room of Mast Mansion"
 },
 {
  "i": 38,
  "style": "Main",
  "name": "Squirrel",
  "text": "She won't be able to take it from her!"
 },
 {
  "i": 39,
  "style": "Main",
  "name": "Squirrel",
  "text": "{\\an8}Then again, we told her about the shortcut."
 },
 {
  "i": 40,
  "style": "Main",
  "name": "Squirrel",
  "text": "{\\an8}She got us."
 },
 {
  "i": 41,
  "style": "Main",
  "name": "Nami",
  "text": "How conceited!"
 },
 {
  "i": 42,
  "style": "Main",
  "name": "Nami",
  "text": "Not only is she stealing our treasure..."
 },
 {
  "i": 43,
  "style": "Main",
  "name": "Nami",
  "text": "But she also plans to take the Sunny and escape?!"
 },
 {
  "i": 44,
  "style": "Main",
  "name": "Nami",
  "text": "I'm not letting that happen!"
 },
 {
  "i": 45,
  "style": "Main",
  "name": "Nami",
  "text": "Moreover, what's with this bridge?"
 },
 {
  "i": 46,
  "style": "Main",
  "name": "Nami",
  "text": "Why is this the only thin part?"
 },
 {
  "i": 47,
  "style": "Main",
  "name": "Nami",
  "text": "Although it's strangely well made."
 },
 {
  "i": 48,
  "style": "Main",
  "name": "Oz",
  "text": "I've had enough of you!"
 },
 {
  "i": 49,
  "style": "Main",
  "name": "Oz",
  "text": "I will crush you all!"
 },
 {
  "i": 50,
  "style": "Main",
  "name": "Nami",
  "text": "I didn't see anything!"
 },
 {
  "i": 51,
  "style": "Main",
  "name": "Oz",
  "text": "You better get ready!"
 },
 {
  "i": 52,
  "style": "Main",
  "name": "Oz",
  "text": "I'm gonna squash you all!"
 },
 {
  "i": 53,
  "style": "Main",
  "name": "Oz",
  "text": "No bone will be left unbroken!"
 },
 {
  "i": 54,
  "style": "Main",
  "name": "Chopper",
  "text": "He's extremely angry now!"
 },
 {
  "i": 55,
  "style": "Main",
  "name": "Usopp",
  "text": "Not good! Not good!"
 },
 {
  "i": 56,
  "style": "Main",
  "name": "Sanji",
  "text": "Here he comes."
 },
 {
  "i": 57,
  "style": "Main",
  "name": "Oz",
  "text": "I can't move!"
 },
 {
  "i": 58,
  "style": "Main",
  "name": "Oz",
  "text": "My horns are...!"
 },
 {
  "i": 59,
  "style": "Main",
  "name": "Oz",
  "text": "Damn it!"
 },
 {
  "i": 60,
  "style": "Main",
  "name": "Oz",
  "text": "My horns got stuck in the ground!"
 },
 {
  "i": 61,
  "style": "Main",
  "name": "Chopper",
  "text": "It's over..."
 },
 {
  "i": 62,
  "style": "Main",
  "name": "Franky",
  "text": "You can't move, huh?"
 },
 {
  "i": 63,
  "style": "Main",
  "name": "Zombie",
  "text": "That sounds like Oars' screams."
 },
 {
  "i": 64,
  "style": "Main",
  "name": "Zombie",
  "text": "But... that's impossible!"
 },
 {
  "i": 65,
  "style": "Main",
  "name": "Oz",
  "text": "Cut it out already!"
 },
 {
  "i": 66,
  "style": "Main",
  "name": "Usopp",
  "text": "Withdraw!"
 },
 {
  "i": 67,
  "style": "Main",
  "name": "",
  "text": "Right!"
 },
 {
  "i": 68,
  "style": "Main",
  "name": "Oz",
  "text": "What cruel guys."
 },
 {
  "i": 69,
  "style": "Main",
  "name": "Sanji",
  "text": "So flipping him over doesn't work."
 },
 {
  "i": 70,
  "style": "Main",
  "name": "Usopp",
  "text": "Look!"
 },
 {
  "i": 71,
  "style": "Main",
  "name": "Usopp",
  "text": "A mountain of meat!"
 },
 {
  "i": 72,
  "style": "Main",
  "name": "Oz",
  "text": "What?!"
 },
 {
  "i": 73,
  "style": "Main",
  "name": "Franky",
  "text": "{\\fad(150,150)}Knee Crusher!"
 },
 {
  "i": 74,
  "style": "Main",
  "name": "Zoro",
  "text": "Making him kneel counts as a down?"
 },
 {
  "i": 75,
  "style": "Main",
  "name": "Franky",
  "text": "Even if there were any rules, I don't think he'd play by them."
 },
 {
  "i": 76,
  "style": "Main",
  "name": "Usopp",
  "text": "They did it! Totally kneeling!"
 },
 {
  "i": 77,
  "style": "Main",
  "name": "Chopper",
  "text": "Alright! Totally kneeling!"
 },
 {
  "i": 78,
  "style": "Secondary",
  "name": "Oz",
  "text": "How humiliating."
 },
 {
  "i": 79,
  "style": "Main",
  "name": "Franky",
  "text": "We won't lose to you!"
 },
 {
  "i": 80,
  "style": "Main",
  "name": "Franky",
  "text": "We'll just have to hold you until Straw Hat defeats Moriah!"
 },
 {
  "i": 81,
  "style": "Main",
  "name": "Franky",
  "text": "Hurry and retrieve the shadows, Straw Hat!"
 },
 {
  "i": 82,
  "style": "Main",
  "name": "Zoro",
  "text": "Why do we have to wait?"
 },
 {
  "i": 83,
  "style": "Main",
  "name": "Zoro",
  "text": "Let's beat him ourselves."
 },
 {
  "i": 84,
  "style": "Main",
  "name": "Franky",
  "text": "H-H-Hey! We're just holding off this monster so he doesn't go after Straw Hat!"
 },
 {
  "i": 85,
  "style": "Main",
  "name": "Franky",
  "text": "Don't tell me you wanna beat this thing?!"
 },
 {
  "i": 86,
  "style": "Main",
  "name": "Oz",
  "text": "First there's no meat..."
 },
 {
  "i": 87,
  "style": "Main",
  "name": "Oz",
  "text": "Then they take me down to my knees."
 },
 {
  "i": 88,
  "style": "Main",
  "name": "Zoro",
  "text": "Once you start a battle, you have to end it!"
 },
 {
  "i": 89,
  "style": "Main",
  "name": "Franky",
  "text": "He's an insanely huge zombie!"
 },
 {
  "i": 90,
  "style": "Main",
  "name": "Franky",
  "text": "There's no choice but to purify him!"
 },
 {
  "i": 91,
  "style": "Main",
  "name": "Usopp",
  "text": "He's right, Zoro!"
 },
 {
  "i": 92,
  "style": "Main",
  "name": "Usopp",
  "text": "Let's just buy some time!"
 },
 {
  "i": 93,
  "style": "Main",
  "name": "Sanji",
  "text": "If you don't like it, you're free to run."
 },
 {
  "i": 94,
  "style": "Main",
  "name": "Sanji",
  "text": "I'm not gonna wait for Luffy either."
 },
 {
  "i": 95,
  "style": "Main",
  "name": "Oz",
  "text": "{\\fad(150,150)}Rubber..."
 },
 {
  "i": 96,
  "style": "Main",
  "name": "Zoro",
  "text": "Even if a dinosaur were to step on it, it wouldn't bend a millimeter."
 },
 {
  "i": 97,
  "style": "Main",
  "name": "Zoro",
  "text": "I heard this black sword's greatest trait is its hardness."
 },
 {
  "i": 98,
  "style": "Main",
  "name": "Zoro",
  "text": "This Great Grade Sword I just obtained, Shuusui..."
 },
 {
  "i": 99,
  "style": "Note",
  "name": "Zoro",
  "text": "Shuusui: Clear Autumn Water"
 },
 {
  "i": 100,
  "style": "Main",
  "name": "Zoro",
  "text": "This is the perfect chance to test its power!"
 },
 {
  "i": 101,
  "style": "Main",
  "name": "Usopp",
  "text": "Wait!"
 },
 {
  "i": 102,
  "style": "Main",
  "name": "Usopp",
  "text": "Luffy's gonna beat Moriah for us!"
 },
 {
  "i": 103,
  "style": "Main",
  "name": "Nami",
  "text": "Wait a minute, you!"
 },
 {
  "i": 104,
  "style": "Main",
  "name": "Zombie",
  "text": "Who is that?"
 },
 {
  "i": 105,
  "style": "Main",
  "name": "Zombie",
  "text": "It's the pirate woman."
 },
 {
  "i": 106,
  "style": "Main",
  "name": "Nami",
  "text": "What're you planning to do with the treasure I was planning to steal?!"
 },
 {
  "i": 107,
  "style": "Main",
  "name": "Nami",
  "text": "And with the Sunny?!"
 },
 {
  "i": 108,
  "style": "Main",
  "name": "Pelona",
  "text": "I thought it was someone else, but it's just the pirate woman."
 },
 {
  "i": 109,
  "style": "Main",
  "name": "Pelona",
  "text": "Is your wedding with Absalom over already?"
 },
 {
  "i": 110,
  "style": "Main",
  "name": "Nami",
  "text": "Like I'd marry that perverted, invisible beast man!"
 },
 {
  "i": 111,
  "style": "Main",
  "name": "Pelona",
  "text": "So you escaped after all."
 },
 {
  "i": 112,
  "style": "Main",
  "name": "Pelona",
  "text": "What a useless man."
 },
 {
  "i": 113,
  "style": "Main",
  "name": "Pelona",
  "text": "So... what will you do?"
 },
 {
  "i": 114,
  "style": "Main",
  "name": "Pelona",
  "text": "It's true that I plan to take your ship to leave the island."
 },
 {
  "i": 115,
  "style": "Main",
  "name": "Pelona",
  "text": "If you want to prevent that, you'll have defeat me."
 },
 {
  "i": 116,
  "style": "Main",
  "name": "Pelona",
  "text": "For a weakling like you, this amount of mini hollows will be enough to tear you apart."
 },
 {
  "i": 117,
  "style": "Main",
  "name": "Pelona",
  "text": "That nega-nose is my only natural enemy."
 },
 {
  "i": 118,
  "style": "Main",
  "name": "Nami",
  "text": "Who's that?"
 },
 {
  "i": 119,
  "style": "Main",
  "name": "Zombie",
  "text": "Perona-sama, run away!"
 },
 {
  "i": 120,
  "style": "Main",
  "name": "Pelona",
  "text": "Who the hell are you?!"
 },
 {
  "i": 121,
  "style": "Main",
  "name": "Zombie",
  "text": "We don't know who he is, but he's an enemy!"
 },
 {
  "i": 122,
  "style": "Main",
  "name": "Zombie",
  "text": "Just now, our brothers were erased right before our eyes!"
 },
 {
  "i": 123,
  "style": "Main",
  "name": "Zombie",
  "text": "He's no pushover!"
 },
 {
  "i": 124,
  "style": "Main",
  "name": "Zombie",
  "text": "He's dangerous!"
 },
 {
  "i": 125,
  "style": "Main",
  "name": "Pelona",
  "text": "Of course he..."
 },
 {
  "i": 126,
  "style": "Main",
  "name": "Pelona",
  "text": "is not a pushover..."
 },
 {
  "i": 127,
  "style": "Main",
  "name": "Pelona",
  "text": "He is..."
 },
 {
  "i": 128,
  "style": "Main",
  "name": "Pelona",
  "text": "One of the Royal Warlords of the Sea,"
 },
 {
  "i": 129,
  "style": "Main",
  "name": "Pelona",
  "text": "The Tyrant, Bartholomew Kuma."
 },
 {
  "i": 130,
  "style": "Main",
  "name": "Pelona",
  "text": "A man who committed every brutality a pirate can."
 },
 {
  "i": 131,
  "style": "Main",
  "name": "Zombie",
  "text": "No way! A Royal Warlord of the Sea?!"
 },
 {
  "i": 132,
  "style": "Main",
  "name": "Zombie",
  "text": "Impossible!"
 },
 {
  "i": 133,
  "style": "Main",
  "name": "Zombie",
  "text": "A man equal to Moriah-sama?!"
 },
 {
  "i": 134,
  "style": "Main",
  "name": "Zombie",
  "text": "Why's he on Thriller Bark?!"
 },
 {
  "i": 135,
  "style": "Main",
  "name": "Nami",
  "text": "No way."
 },
 {
  "i": 136,
  "style": "Main",
  "name": "Kuma",
  "text": "Are you Moriah's subordinate?"
 },
 {
  "i": 137,
  "style": "Main",
  "name": "Pelona",
  "text": "M-Moriah-sama-"
 },
 {
  "i": 138,
  "style": "Main",
  "name": "Pelona",
  "text": "No!"
 },
 {
  "i": 139,
  "style": "Main",
  "name": "Pelona",
  "text": "Gekko Moriah has nothing to do with me anymore!"
 },
 {
  "i": 140,
  "style": "Main",
  "name": "Pelona",
  "text": "I-I was about to... leave this island!"
 },
 {
  "i": 141,
  "style": "Main",
  "name": "Kuma",
  "text": "If you were to go on a trip, where would you like to go?"
 },
 {
  "i": 142,
  "style": "Main",
  "name": "Zombie",
  "text": "He wants to chat?!"
 },
 {
  "i": 143,
  "style": "Main",
  "name": "Pelona",
  "text": "Why do you want to hear-"
 },
 {
  "i": 144,
  "style": "Main",
  "name": "Pelona",
  "text": "But if I went on vacation, I'd stay in a dark, damp, and evil old castle..."
 },
 {
  "i": 145,
  "style": "Main",
  "name": "Pelona",
  "text": "Spending my days singing cursed songs."
 },
 {
  "i": 146,
  "style": "Main",
  "name": "Zombie",
  "text": "She answered!"
 },
 {
  "i": 147,
  "style": "Main",
  "name": "Zombie",
  "text": "As expected from the Ghost Princess!"
 },
 {
  "i": 148,
  "style": "Main",
  "name": "Pelona",
  "text": "I got carried away!"
 },
 {
  "i": 149,
  "style": "Main",
  "name": "Pelona",
  "text": "How dare you make fun of me!"
 },
 {
  "i": 150,
  "style": "Main",
  "name": "Pelona",
  "text": "I was overwhelmed by your reputation for a moment."
 },
 {
  "i": 151,
  "style": "Main",
  "name": "Pelona",
  "text": "But I have no reason to fear."
 },
 {
  "i": 152,
  "style": "Main",
  "name": "Pelona",
  "text": "There's no human I can't make kneel with my ability."
 },
 {
  "i": 153,
  "style": "Main",
  "name": "Pelona",
  "text": "Are you listening?!"
 },
 {
  "i": 154,
  "style": "Main",
  "name": "Pelona",
  "text": "Your shadow must be really powerful, Kuma!"
 },
 {
  "i": 155,
  "style": "Main",
  "name": "Pelona",
  "text": "I will defeat you and give Moriah-sama your shadow as a farewell gift!"
 },
 {
  "i": 156,
  "style": "Main",
  "name": "Pelona",
  "text": "{\\fad(150,150)}Negative Ghost..."
 },
 {
  "i": 157,
  "style": "Main",
  "name": "Pelona",
  "text": "Plus...!"
 },
 {
  "i": 158,
  "style": "Main",
  "name": "Pelona",
  "text": "{\\fad(150,150)}Special Hollow!"
 },
 {
  "i": 159,
  "style": "Main",
  "name": "Zombie",
  "text": "Here it comes!"
 },
 {
  "i": 160,
  "style": "Main",
  "name": "Zombie",
  "text": "Perona-sama's ultimate combo!"
 },
 {
  "i": 161,
  "style": "Main",
  "name": "Kuma",
  "text": "Judging by your actions..."
 },
 {
  "i": 162,
  "style": "Main",
  "name": "Kuma",
  "text": "I assume you aren't going to tell me Moriah's whereabouts."
 },
 {
  "i": 163,
  "style": "Main",
  "name": "Nami",
  "text": "Where'd she...?"
 },
 {
  "i": 164,
  "style": "Main",
  "name": "Zombie",
  "text": "Where did you go, Perona-sama?!"
 },
 {
  "i": 165,
  "style": "Main",
  "name": "Zombie",
  "text": "Perona-sama!"
 },
 {
  "i": 166,
  "style": "Main",
  "name": "Zombie",
  "text": "Hey, what's going on?!"
 },
 {
  "i": 167,
  "style": "Main",
  "name": "Zombie",
  "text": "Perona-sama vanished!"
 },
 {
  "i": 168,
  "style": "Main",
  "name": "Zombie",
  "text": "Bastard, what have you done to our princess?!"
 },
 {
  "i": 169,
  "style": "Main",
  "name": "Zombie",
  "text": "This is unforgivable!"
 },
 {
  "i": 170,
  "style": "Main",
  "name": "Zombie",
  "text": "We won't forgive you!"
 },
 {
  "i": 171,
  "style": "Main",
  "name": "Zombie",
  "text": "This is unforgivable!"
 },
 {
  "i": 172,
  "style": "Main",
  "name": "Zombie",
  "text": "He's too scary!"
 },
 {
  "i": 173,
  "style": "Main",
  "name": "Zombie",
  "text": "Run!"
 },
 {
  "i": 174,
  "style": "Main",
  "name": "Kuma",
  "text": "The Burglar Cat, right?"
 },
 {
  "i": 175,
  "style": "Main",
  "name": "Kuma",
  "text": "One of Straw Hat's crewmates."
 },
 {
  "i": 176,
  "style": "Main",
  "name": "Kuma",
  "text": "Is it true that Monkey D. Luffy..."
 },
 {
  "i": 177,
  "style": "Main",
  "name": "Kuma",
  "text": "has a brother?"
 },
 {
  "i": 178,
  "style": "Thoughts",
  "name": "Nami",
  "text": "What?"
 },
 {
  "i": 179,
  "style": "Thoughts",
  "name": "Nami",
  "text": "He got here in an instant!"
 },
 {
  "i": 180,
  "style": "Thoughts",
  "name": "Nami",
  "text": "Did he warp?"
 },
 {
  "i": 181,
  "style": "Main",
  "name": "Nami",
  "text": "It is!"
 },
 {
  "i": 182,
  "style": "Main",
  "name": "Nami",
  "text": "You mean Ace, right?"
 },
 {
  "i": 183,
  "style": "Main",
  "name": "Nami",
  "text": "What about him?!"
 },
 {
  "i": 184,
  "style": "Main",
  "name": "Kuma",
  "text": "I see. So it was true."
 },
 {
  "i": 185,
  "style": "Main",
  "name": "Nami",
  "text": "What do you mean?"
 },
 {
  "i": 186,
  "style": "Main",
  "name": "Nami",
  "text": "Did you come for Luffy?"
 },
 {
  "i": 187,
  "style": "Main",
  "name": "Nami",
  "text": "What're you after?!"
 },
 {
  "i": 188,
  "style": "Main",
  "name": "Nami",
  "text": "Are you really a Warlord?!"
 },
 {
  "i": 189,
  "style": "Main",
  "name": "Kuma",
  "text": "Whatever I do... is my problem."
 },
 {
  "i": 190,
  "style": "Main",
  "name": "Nami",
  "text": "He's dangerous."
 },
 {
  "i": 191,
  "style": "Main",
  "name": "Nami",
  "text": "Is he after Luffy?"
 },
 {
  "i": 192,
  "style": "Main",
  "name": "Nami",
  "text": "I must tell everyone."
 },
 {
  "i": 193,
  "style": "Main",
  "name": "Luffy",
  "text": "I got you, Moriah!"
 },
 {
  "i": 194,
  "style": "Main",
  "name": "Luffy",
  "text": "You're not going anywhere, you bastard!"
 },
 {
  "i": 195,
  "style": "Main",
  "name": "Luffy",
  "text": "Now fight me!"
 },
 {
  "i": 196,
  "style": "Main",
  "name": "Luffy",
  "text": "And give everyone's shadows back!"
 },
 {
  "i": 197,
  "style": "Main",
  "name": "Luffy",
  "text": "A shadow?"
 },
 {
  "i": 198,
  "style": "Captions",
  "name": "Sign",
  "text": "{\\fad(600,0)}Dawn.\\NThe Shadow Recovery Time Limit Approaches"
 },
 {
  "i": 199,
  "style": "Main",
  "name": "Luffy",
  "text": "{\\an8}D-Damn it!"
 },
 {
  "i": 200,
  "style": "Main",
  "name": "Luffy",
  "text": "{\\an8}He tricked me!"
 },
 {
  "i": 201,
  "style": "Main",
  "name": "Luffy",
  "text": "You!"
 },
 {
  "i": 202,
  "style": "Main",
  "name": "Luffy",
  "text": "Wait!"
 },
 {
  "i": 203,
  "style": "Main",
  "name": "Luffy",
  "text": "Moriah's shadow!"
 },
 {
  "i": 204,
  "style": "Main",
  "name": "Luffy",
  "text": "Don't leave me here!"
 },
 {
  "i": 205,
  "style": "Main",
  "name": "Luffy",
  "text": "Where am I?!"
 },
 {
  "i": 206,
  "style": "Main",
  "name": "Luffy",
  "text": "Hey!"
 },
 {
  "i": 207,
  "style": "Main",
  "name": "Luffy",
  "text": "Damn it, this is bad!"
 },
 {
  "i": 208,
  "style": "Main",
  "name": "Luffy",
  "text": "I promised everyone I'd get all the shadows back."
 },
 {
  "i": 209,
  "style": "Main",
  "name": "Luffy",
  "text": "I'm in serious trouble without mine."
 },
 {
  "i": 210,
  "style": "Main",
  "name": "Luffy",
  "text": "Let's see..."
 },
 {
  "i": 211,
  "style": "Main",
  "name": "Luffy",
  "text": "What was gonna happen to me without my shadow?"
 },
 {
  "i": 212,
  "style": "Main",
  "name": "Luffy",
  "text": "That's right!"
 },
 {
  "i": 213,
  "style": "Main",
  "name": "Luffy",
  "text": "If we stay like this, we'll dissolve in the sun's light!"
 },
 {
  "i": 214,
  "style": "Main",
  "name": "Luffy",
  "text": "This is bad. I gotta hurry before the night's over."
 },
 {
  "i": 215,
  "style": "Main",
  "name": "Zoro",
  "text": "Now, come."
 },
 {
  "i": 216,
  "style": "Main",
  "name": "Zoro",
  "text": "I will be your opponent!"
 },
 {
  "i": 217,
  "style": "Main",
  "name": "Oz",
  "text": "Fine."
 },
 {
  "i": 218,
  "style": "Main",
  "name": "Zoro",
  "text": "The difference in weight is clear between this black sword, Shuusui, and its predecessor Yubashiri."
 },
 {
  "i": 219,
  "style": "Note",
  "name": "Zoro",
  "text": "Yubashiri: Snow Run"
 },
 {
  "i": 220,
  "style": "Main",
  "name": "Usopp",
  "text": "Hey Zoro, watch out!"
 },
 {
  "i": 221,
  "style": "Main",
  "name": "Zoro",
  "text": "With this weight...!"
 },
 {
  "i": 222,
  "style": "Main",
  "name": "Chopper",
  "text": "Incredible!"
 },
 {
  "i": 223,
  "style": "Main",
  "name": "Chopper",
  "text": "He deflected that punch!"
 },
 {
  "i": 224,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(150,150)}Three Swords Style..."
 },
 {
  "i": 225,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(150,150)}108 Pound Cannon!"
 },
 {
  "i": 226,
  "style": "Main",
  "name": "Zoro",
  "text": "It's huge!"
 },
 {
  "i": 227,
  "style": "Main",
  "name": "Zoro",
  "text": "Shuusui's strike absorbed the slashes of the other two swords to join into one!"
 },
 {
  "i": 228,
  "style": "Main",
  "name": "Zoro",
  "text": "But... it seems there's too much pointless destruction in the blade."
 },
 {
  "i": 229,
  "style": "Main",
  "name": "Zoro",
  "text": "Proof that I've yet to master it."
 },
 {
  "i": 230,
  "style": "Main",
  "name": "Zoro",
  "text": "Its destructive power is way bigger, but..."
 },
 {
  "i": 231,
  "style": "Main",
  "name": "Zoro",
  "text": "This is no easy sword to control, it seems."
 },
 {
  "i": 232,
  "style": "Main",
  "name": "Zoro",
  "text": "You've given me something good,"
 },
 {
  "i": 233,
  "style": "Main",
  "name": "Zoro",
  "text": "Swordmaster Ryuuma."
 },
 {
  "i": 234,
  "style": "Main",
  "name": "Oz",
  "text": "You're not bad."
 },
 {
  "i": 235,
  "style": "Main",
  "name": "Oz",
  "text": "Had I taken that, I'd be history."
 },
 {
  "i": 236,
  "style": "Main",
  "name": "Oz",
  "text": "You bastard!"
 },
 {
  "i": 237,
  "style": "Main",
  "name": "Oz",
  "text": "I'll crush you all!"
 },
 {
  "i": 238,
  "style": "Main",
  "name": "Usopp",
  "text": "Hey!"
 },
 {
  "i": 239,
  "style": "Main",
  "name": "Usopp",
  "text": "Don't attack so recklessly."
 },
 {
  "i": 240,
  "style": "Main",
  "name": "Usopp",
  "text": "Even if you manage to defeat him, only Luffy's shadow will be released."
 },
 {
  "i": 241,
  "style": "Main",
  "name": "Usopp",
  "text": "We don't even know where your and Sanji's shadows are!"
 },
 {
  "i": 242,
  "style": "Main",
  "name": "Usopp",
  "text": "But... if Luffy beats Moriah, we'll get all the shadows at once."
 },
 {
  "i": 243,
  "style": "Main",
  "name": "Usopp",
  "text": "There's no point in hurting yourself fighting that huge zombie!"
 },
 {
  "i": 244,
  "style": "Main",
  "name": "Usopp",
  "text": "For now, just have faith in Luffy and keep this monster at bay!"
 },
 {
  "i": 245,
  "style": "Main",
  "name": "Zoro",
  "text": "I have plenty of faith in him."
 },
 {
  "i": 246,
  "style": "Main",
  "name": "Zoro",
  "text": "Luffy also has his weakness, you know..."
 },
 {
  "i": 247,
  "style": "Main",
  "name": "Zoro",
  "text": "His gullibility."
 },
 {
  "i": 248,
  "style": "Main",
  "name": "Zoro",
  "text": "An invisible man..."
 },
 {
  "i": 249,
  "style": "Main",
  "name": "Zoro",
  "text": "A ghost woman..."
 },
 {
  "i": 250,
  "style": "Main",
  "name": "Zoro",
  "text": "A ruler of shadows."
 },
 {
  "i": 251,
  "style": "Main",
  "name": "Zoro",
  "text": "This island is infested with people who have such abilities."
 },
 {
  "i": 252,
  "style": "Main",
  "name": "Zoro",
  "text": "Don't expect that they'll fight Luffy fair and square."
 },
 {
  "i": 253,
  "style": "Main",
  "name": "Robin",
  "text": "That is true."
 },
 {
  "i": 254,
  "style": "Main",
  "name": "Franky",
  "text": "Yeah."
 },
 {
  "i": 255,
  "style": "Main",
  "name": "Zoro",
  "text": "If he fools Luffy and morning comes..."
 },
 {
  "i": 256,
  "style": "Main",
  "name": "Zoro",
  "text": "Neither he, nor I, nor the cook..."
 },
 {
  "i": 257,
  "style": "Main",
  "name": "Zoro",
  "text": "None of us three will be able to fight anymore."
 },
 {
  "i": 258,
  "style": "Main",
  "name": "Zoro",
  "text": "But... if we can at least make Luffy go back to normal before daybreak..."
 },
 {
  "i": 259,
  "style": "Main",
  "name": "Zoro",
  "text": "He might still do something!"
 },
 {
  "i": 260,
  "style": "Main",
  "name": "Franky",
  "text": "I don't think we even have thirty minutes before daybreak."
 },
 {
  "i": 261,
  "style": "Main",
  "name": "Franky",
  "text": "The fog is extremely thick in this sea."
 },
 {
  "i": 262,
  "style": "Main",
  "name": "Franky",
  "text": "It must be restricting the reach of the morning light by now."
 },
 {
  "i": 263,
  "style": "Main",
  "name": "Sanji",
  "text": "So it's almost morning."
 },
 {
  "i": 264,
  "style": "Main",
  "name": "Sanji",
  "text": "We're only alive because of this fog."
 },
 {
  "i": 265,
  "style": "Main",
  "name": "Sanji",
  "text": "Whether it's morning or not, I'm finally starting to feel the danger of the situation."
 },
 {
  "i": 266,
  "style": "Main",
  "name": "Usopp",
  "text": "W-What?"
 },
 {
  "i": 267,
  "style": "Main",
  "name": "Sanji",
  "text": "What's this shaking?!"
 },
 {
  "i": 268,
  "style": "Main",
  "name": "Zombie",
  "text": "What's this?!"
 },
 {
  "i": 269,
  "style": "Main",
  "name": "Zombie",
  "text": "Just like before, the ship is stuck in another weird sea current!"
 },
 {
  "i": 270,
  "style": "Main",
  "name": "Zombie",
  "text": "Hey, look at the sky!"
 },
 {
  "i": 271,
  "style": "Main",
  "name": "Zombie",
  "text": "I can see the predawn sky!"
 },
 {
  "i": 272,
  "style": "Main",
  "name": "Zombie",
  "text": "The fog has started to clear!"
 },
 {
  "i": 273,
  "style": "Main",
  "name": "Zombie",
  "text": "What's going on?!"
 },
 {
  "i": 274,
  "style": "Main",
  "name": "Zombie",
  "text": "Could it be... that we're already out of the Florian Triangle?!"
 },
 {
  "i": 275,
  "style": "Main",
  "name": "Zombie",
  "text": "It's Oars' fault for messing with the rudder before!"
 },
 {
  "i": 276,
  "style": "Main",
  "name": "Zombie",
  "text": "That bastard and his dumb games!"
 },
 {
  "i": 277,
  "style": "Main",
  "name": "Zombie",
  "text": "Moriah-sama!"
 },
 {
  "i": 278,
  "style": "Main",
  "name": "Zombie",
  "text": "Big trouble!"
 },
 {
  "i": 279,
  "style": "Main",
  "name": "Zombie",
  "text": "The Thriller Bark ship has come out of this foggy sea!"
 },
 {
  "i": 280,
  "style": "Main",
  "name": "Zombie",
  "text": "It's all Oars' fault!"
 },
 {
  "i": 281,
  "style": "Main",
  "name": "Zombie",
  "text": "Moriah-sama!"
 },
 {
  "i": 282,
  "style": "Main",
  "name": "Moria",
  "text": "Leave it that way."
 },
 {
  "i": 283,
  "style": "Main",
  "name": "Moria",
  "text": "What's the big deal anyways?"
 },
 {
  "i": 284,
  "style": "Main",
  "name": "Moria",
  "text": "We're pirates!"
 },
 {
  "i": 285,
  "style": "Main",
  "name": "Moria",
  "text": "We sail up and down the seas as we please!"
 },
 {
  "i": 286,
  "style": "Main",
  "name": "Zombie",
  "text": "E-Even so..."
 },
 {
  "i": 287,
  "style": "Main",
  "name": "Moria",
  "text": "More importantly; we have a most unusual visitor today, so be silent."
 },
 {
  "i": 288,
  "style": "Main",
  "name": "Moria",
  "text": "Isn't that right?"
 },
 {
  "i": 289,
  "style": "Main",
  "name": "Moria",
  "text": "The Tyrant, Kuma."
 },
 {
  "i": 290,
  "style": "Main",
  "name": "Moria",
  "text": "The only man among the Warlords of the Sea that is truly loyal to the government!"
 },
 {
  "i": 291,
  "style": "Main",
  "name": "Moria",
  "text": "You're very important to the government, but..."
 },
 {
  "i": 292,
  "style": "Main",
  "name": "Moria",
  "text": "I've no idea what someone as uncanny as you could be scheming."
 },
 {
  "i": 293,
  "style": "Main",
  "name": "Kuma",
  "text": "If you were to travel, where'd you go?"
 },
 {
  "i": 294,
  "style": "Main",
  "name": "Moria",
  "text": "Hey, hey, stop it."
 },
 {
  "i": 295,
  "style": "Main",
  "name": "Moria",
  "text": "I'm fully aware of your abilities."
 },
 {
  "i": 296,
  "style": "Main",
  "name": "Moria",
  "text": "Have you come here to pick a fight?"
 },
 {
  "i": 297,
  "style": "Main",
  "name": "Moria",
  "text": "Speak your business."
 },
 {
  "i": 298,
  "style": "Main",
  "name": "Moria",
  "text": "Why have you come here?"
 },
 {
  "i": 299,
  "style": "Main",
  "name": "Kuma",
  "text": "I have a certain matter to report."
 },
 {
  "i": 300,
  "style": "Main",
  "name": "Kuma",
  "text": "The replacement for the Royal Warlord of the Sea, Crocodile."
 },
 {
  "i": 301,
  "style": "Main",
  "name": "Kuma",
  "text": "His successor has been chosen."
 },
 {
  "i": 302,
  "style": "Main",
  "name": "Moria",
  "text": "You should've said that in the first place."
 },
 {
  "i": 303,
  "style": "Main",
  "name": "Moria",
  "text": "Who is he and what sea is he from?"
 },
 {
  "i": 304,
  "style": "Main",
  "name": "Moria",
  "text": "There are countless pirates."
 },
 {
  "i": 305,
  "style": "Main",
  "name": "Kuma",
  "text": "The name of the successor is..."
 },
 {
  "i": 306,
  "style": "Main",
  "name": "Kuma",
  "text": "Marshall D. Teach,"
 },
 {
  "i": 307,
  "style": "Main",
  "name": "Kuma",
  "text": "A man commonly known as Blackbeard."
 },
 {
  "i": 308,
  "style": "Main",
  "name": "Moria",
  "text": "Blackbeard?"
 },
 {
  "i": 309,
  "style": "Main",
  "name": "Moria",
  "text": "Never heard of him."
 },
 {
  "i": 310,
  "style": "Main",
  "name": "Kuma",
  "text": "He's a fugitive from Whitebeard's crew."
 },
 {
  "i": 311,
  "style": "Main",
  "name": "Kuma",
  "text": "He caused quite an uproar around the world recently."
 },
 {
  "i": 312,
  "style": "Main",
  "name": "Kuma",
  "text": "The news have yet to reach the sea of the mist."
 },
 {
  "i": 313,
  "style": "Main",
  "name": "Kuma",
  "text": "He earned the title through merit."
 },
 {
  "i": 314,
  "style": "Main",
  "name": "Moria",
  "text": "So, what's his former bounty?"
 },
 {
  "i": 315,
  "style": "Main",
  "name": "Kuma",
  "text": "Zero."
 },
 {
  "i": 316,
  "style": "Main",
  "name": "Moria",
  "text": "I see."
 },
 {
  "i": 317,
  "style": "Main",
  "name": "Moria",
  "text": "An unassigned quantity."
 },
 {
  "i": 318,
  "style": "Main",
  "name": "Moria",
  "text": "It's impressive that the government acknowledged him."
 },
 {
  "i": 319,
  "style": "Main",
  "name": "Moria",
  "text": "Well, they must be at ease now that they've filled the gap."
 },
 {
  "i": 320,
  "style": "Main",
  "name": "Moria",
  "text": "Then I guess this means the world is keeping its balance, right?"
 },
 {
  "i": 321,
  "style": "Main",
  "name": "Kuma",
  "text": "No."
 },
 {
  "i": 322,
  "style": "Main",
  "name": "Kuma",
  "text": "I think quite the opposite."
 },
 {
  "i": 323,
  "style": "Main",
  "name": "Kuma",
  "text": "But that matters not."
 },
 {
  "i": 324,
  "style": "Main",
  "name": "Kuma",
  "text": "More importantly, the government has a bigger concern right now."
 },
 {
  "i": 325,
  "style": "Main",
  "name": "Kuma",
  "text": "Since the events at Enies Lobby... the actions of the Straw Hat pirates are being watched very thoroughly."
 },
 {
  "i": 326,
  "style": "Main",
  "name": "Kuma",
  "text": "It was most likely that they'd be delayed here traveling from Water 7 to Fishman Island."
 },
 {
  "i": 327,
  "style": "Main",
  "name": "Kuma",
  "text": "So... have you realized what the government's current concern is?"
 },
 {
  "i": 328,
  "style": "Main",
  "name": "Kuma",
  "text": "That yet another..."
 },
 {
  "i": 329,
  "style": "Main",
  "name": "Kuma",
  "text": "Warlord of the Sea will fall at the hands of the Straw Hat pirates."
 },
 {
  "i": 330,
  "style": "Main",
  "name": "Kuma",
  "text": "That's what the government fears."
 },
 {
  "i": 331,
  "style": "Main",
  "name": "Moria",
  "text": "Don't mess around!"
 },
 {
  "i": 332,
  "style": "Main",
  "name": "Moria",
  "text": "They're worried about me?!"
 },
 {
  "i": 333,
  "style": "Main",
  "name": "Moria",
  "text": "Just because someone else got stripped of their title by some puny pirates..."
 },
 {
  "i": 334,
  "style": "Main",
  "name": "Moria",
  "text": "they think the same will happen to me?!"
 },
 {
  "i": 335,
  "style": "Main",
  "name": "Kuma",
  "text": "If you can't take care of them yourself, I'm willing to help you."
 },
 {
  "i": 336,
  "style": "Main",
  "name": "Moria",
  "text": "Who do you think you're talking to, bastard?!"
 },
 {
  "i": 337,
  "style": "Main",
  "name": "Moria",
  "text": "Do you actually think I'd lose to that insignificant and amateurish crew?!"
 },
 {
  "i": 338,
  "style": "Main",
  "name": "Kuma",
  "text": "In battle, nothing is 100% sure."
 },
 {
  "i": 339,
  "style": "Main",
  "name": "Kuma",
  "text": "Back at Enies Lobby, who would have imagined that Rob Lucci could be defeated?"
 },
 {
  "i": 340,
  "style": "Main",
  "name": "Moria",
  "text": "That's exactly my point!"
 },
 {
  "i": 341,
  "style": "Main",
  "name": "Moria",
  "text": "Is the government so scared that they're sending two Warlords of the Sea to eliminate them?!"
 },
 {
  "i": 342,
  "style": "Main",
  "name": "",
  "text": "Huh!?"
 },
 {
  "i": 343,
  "style": "Main",
  "name": "Kuma",
  "text": "I'm only here to report."
 },
 {
  "i": 344,
  "style": "Main",
  "name": "Kuma",
  "text": "I did not receive such orders."
 },
 {
  "i": 345,
  "style": "Main",
  "name": "Moria",
  "text": "Then, just shut up and watch!"
 },
 {
  "i": 346,
  "style": "Main",
  "name": "Moria",
  "text": "And also, give this message to that pack of know-nothings!"
 },
 {
  "i": 347,
  "style": "Main",
  "name": "Moria",
  "text": "\"The Straw Hat Pirates you're so scared of have easily been..."
 },
 {
  "i": 348,
  "style": "Main",
  "name": "Moria",
  "text": "turned into loyal soldiers of Gekko Moriah's zombie army!\""
 },
 {
  "i": 349,
  "style": "Main",
  "name": "Franky",
  "text": "The fog..."
 },
 {
  "i": 350,
  "style": "Main",
  "name": "Franky",
  "text": "This is terrible."
 },
 {
  "i": 351,
  "style": "Main",
  "name": "Usopp",
  "text": "That thick fog was our only ray of hope."
 },
 {
  "i": 352,
  "style": "Main",
  "name": "Sanji",
  "text": "Who would have plotted for the fog to clear out at a moment like this?!"
 },
 {
  "i": 353,
  "style": "Main",
  "name": "Sanji",
  "text": "At this rate, we'll get burnt by the morning light straight on!"
 },
 {
  "i": 354,
  "style": "Main",
  "name": "Moria",
  "text": "An unexpectedly refreshing night sky."
 },
 {
  "i": 355,
  "style": "Main",
  "name": "Usopp",
  "text": "I-It's Moriah...!"
 },
 {
  "i": 356,
  "style": "Main",
  "name": "Usopp",
  "text": "It's Moriah!"
 },
 {
  "i": 357,
  "style": "Secondary",
  "name": "Chopper",
  "text": "Huh?"
 },
 {
  "i": 358,
  "style": "Main",
  "name": "Moria",
  "text": "It's nearly daybreak."
 },
 {
  "i": 359,
  "style": "Main",
  "name": "Moria",
  "text": "Do you really have time to fool around?"
 },
 {
  "i": 360,
  "style": "Main",
  "name": "Usopp",
  "text": "Why're you here?"
 },
 {
  "i": 361,
  "style": "Main",
  "name": "Usopp",
  "text": "What happened to Luffy?!"
 },
 {
  "i": 362,
  "style": "Main",
  "name": "Sanji",
  "text": "Hey, what're you talking about, Usopp?"
 },
 {
  "i": 363,
  "style": "Main",
  "name": "Sanji",
  "text": "Where's Moriah?!"
 },
 {
  "i": 364,
  "style": "Main",
  "name": "Usopp",
  "text": "Are you blind?!"
 },
 {
  "i": 365,
  "style": "Main",
  "name": "Usopp",
  "text": "He's over there!"
 },
 {
  "i": 366,
  "style": "Main",
  "name": "Usopp",
  "text": "His belly...!"
 },
 {
  "i": 367,
  "style": "Main",
  "name": "Usopp",
  "text": "He's inside Oars' belly!"
 },
 {
  "i": 368,
  "style": "Main",
  "name": "Franky",
  "text": "Inside his belly?!"
 },
 {
  "i": 369,
  "style": "Main",
  "name": "Chopper",
  "text": "H-He is!"
 },
 {
  "i": 370,
  "style": "Main",
  "name": "Sanji",
  "text": "Then, where's Luffy?"
 },
 {
  "i": 371,
  "style": "Main",
  "name": "Sanji",
  "text": "Was he tricked after all?"
 },
 {
  "i": 372,
  "style": "Main",
  "name": "Franky",
  "text": "Or maybe..."
 },
 {
  "i": 373,
  "style": "Main",
  "name": "Chopper",
  "text": "Luffy won't fall that easily!"
 },
 {
  "i": 374,
  "style": "Main",
  "name": "Oz",
  "text": "Found him! He's in a cockpit?"
 },
 {
  "i": 375,
  "style": "Main",
  "name": "Oz",
  "text": "What, there was a cockpit in my belly all along?"
 },
 {
  "i": 376,
  "style": "Main",
  "name": "Oz",
  "text": "This is really cool!"
 },
 {
  "i": 377,
  "style": "Main",
  "name": "Oz",
  "text": "I'm somewhat like a robot!"
 },
 {
  "i": 378,
  "style": "Main",
  "name": "Moria",
  "text": "Now, I will give you a chance to fight me."
 },
 {
  "i": 379,
  "style": "Main",
  "name": "Moria",
  "text": "If you defeat me, you can release all the shadows!"
 },
 {
  "i": 380,
  "style": "Main",
  "name": "Moria",
  "text": "You can come at me all together!"
 },
 {
  "i": 381,
  "style": "Main",
  "name": "Moria",
  "text": "But be aware that unless you defeat Oars, you can't reach me!"
 },
 {
  "i": 382,
  "style": "Main",
  "name": "Usopp",
  "text": "That bastard!"
 },
 {
  "i": 383,
  "style": "Main",
  "name": "Usopp",
  "text": "That's dirty!"
 },
 {
  "i": 384,
  "style": "Main",
  "name": "Chopper",
  "text": "We can't purify Oars unless we defeat Moriah."
 },
 {
  "i": 385,
  "style": "Main",
  "name": "Chopper",
  "text": "But, Moriah is inside Oars now."
 },
 {
  "i": 386,
  "style": "Main",
  "name": "Sanji",
  "text": "We've got a clearer target now, it seems."
 },
 {
  "i": 387,
  "style": "Main",
  "name": "Zoro",
  "text": "Let's do it!"
 },
 {
  "i": 388,
  "style": "Main",
  "name": "Zoro",
  "text": "Usopp."
 },
 {
  "i": 389,
  "style": "Main",
  "name": "Zoro",
  "text": "Since little portions don't work, go find a large quantity of salt and bring it!"
 },
 {
  "i": 390,
  "style": "Main",
  "name": "Zoro",
  "text": "That's the only way to purify Oars."
 },
 {
  "i": 391,
  "style": "Main",
  "name": "Zoro",
  "text": "We'll do as much as we can to weaken him!"
 },
 {
  "i": 392,
  "style": "Main",
  "name": "Usopp",
  "text": "Alright, I got it!"
 },
 {
  "i": 393,
  "style": "Main",
  "name": "Usopp",
  "text": "I'll get it!"
 },
 {
  "i": 394,
  "style": "Main",
  "name": "Usopp",
  "text": "I'm sure there was a kitchen in the mansion!"
 },
 {
  "i": 395,
  "style": "Main",
  "name": "Usopp",
  "text": "There must be a large supply of salt in there."
 },
 {
  "i": 396,
  "style": "Main",
  "name": "Moria",
  "text": "Salt, huh?"
 },
 {
  "i": 397,
  "style": "Main",
  "name": "Moria",
  "text": "Hey, Oars."
 },
 {
  "i": 398,
  "style": "Main",
  "name": "Moria",
  "text": "Eliminate that long-nose heading for the mansion."
 },
 {
  "i": 399,
  "style": "Main",
  "name": "Moria",
  "text": "Don't let him reach the kitchen alive."
 },
 {
  "i": 400,
  "style": "Main",
  "name": "Oz",
  "text": "Yes, Master."
 },
 {
  "i": 401,
  "style": "Main",
  "name": "Sanji",
  "text": "Damn it!"
 },
 {
  "i": 402,
  "style": "Main",
  "name": "Sanji",
  "text": "Usopp!"
 },
 {
  "i": 403,
  "style": "Main",
  "name": "Sanji",
  "text": "No good."
 },
 {
  "i": 404,
  "style": "Main",
  "name": "Sanji",
  "text": "Now that Moriah is here, he's acting like a brain for Oars."
 },
 {
  "i": 405,
  "style": "Main",
  "name": "Chopper",
  "text": "Usopp!"
 },
 {
  "i": 406,
  "style": "Main",
  "name": "Chopper",
  "text": "Where are you?!"
 },
 {
  "i": 407,
  "style": "Main",
  "name": "Chopper",
  "text": "Answer me!"
 },
 {
  "i": 408,
  "style": "Main",
  "name": "Brook",
  "text": "He's safe!"
 },
 {
  "i": 409,
  "style": "Main",
  "name": "Brook",
  "text": "I thought you'd need a large quantity of salt."
 },
 {
  "i": 410,
  "style": "Main",
  "name": "Brook",
  "text": "So I brought plenty of it!"
 },
 {
  "i": 411,
  "style": "Main",
  "name": "All",
  "text": "Brook!"
 }
]