 },
 {
  "i": 23,
  "style": "Title",
  "name": "",
  "text": "{\\fad(200,3500)}The Power That Can Deflect Anything?!\\NZoro Fights Prepared to Die!"
 },
 {
  "i": 24,
  "style": "Main",
  "name": "Usopp",
  "text": "Hey, Zoro!"
 },
 {
  "i": 25,
  "style": "Main",
  "name": "Nami",
  "text": "Robin!"
 },
 {
  "i": 26,
  "style": "Main",
  "name": "Chopper",
  "text": "Sanji!"
 },
 {
  "i": 27,
  "style": "Main",
  "name": "Both",
  "text": "Your bodies are vanishing!"
 },
 {
  "i": 28,
  "style": "Main",
  "name": "Franky",
  "text": "Why?!"
 },
 {
  "i": 29,
  "style": "Main",
  "name": "Franky",
  "text": "Didn't we win?!"
 },
 {
  "i": 30,
  "style": "Main",
  "name": "Franky",
  "text": "Hey! Didn't we make it on time?!"
 },
 {
  "i": 31,
  "style": "Main",
  "name": "Pirate",
  "text": "She's disappearing!"
 },
 {
  "i": 32,
  "style": "Main",
  "name": "Pirate",
  "text": "Captain Lola!"
 },
 {
  "i": 33,
  "style": "Main",
  "name": "Pirate",
  "text": "Everyone!"
 },
 {
  "i": 34,
  "style": "Main",
  "name": "Pirate",
  "text": "Didn't we win?!"
 },
 {
  "i": 35,
  "style": "Main",
  "name": "Pirate",
  "text": "Damn it!"
 },
 {
  "i": 36,
  "style": "Captions",
  "name": "MSG",
  "text": "A pirate ship somewhere in the Grand Line"
 },
 {
  "i": 37,
  "style": "Main",
  "name": "Pirate",
  "text": "{\\an8}Captain!"
 },
 {
  "i": 38,
  "style": "Main",
  "name": "Pirate",
  "text": "Come to the deck for a moment, please!"
 },
 {
  "i": 39,
  "style": "Main",
  "name": "Captain",
  "text": "Stop babbling nonsense and go back to sleep."
 },
 {
  "i": 40,
  "style": "Main",
  "name": "Captain",
  "text": "We will get erased by the morning sun if we step outside."
 },
 {
  "i": 41,
  "style": "Main",
  "name": "Captain",
  "text": "It's been two years since Moriah stole our shadows."
 },
 {
  "i": 42,
  "style": "Main",
  "name": "Captain",
  "text": "We no longer..."
 },
 {
  "i": 43,
  "style": "Main",
  "name": "Pirate",
  "text": "But Captain!"
 },
 {
  "i": 44,
  "style": "Main",
  "name": "Pirate",
  "text": "Take a look at my feet!"
 },
 {
  "i": 45,
  "style": "Main",
  "name": "Captain",
  "text": "You have... your shadow!"
 },
 {
  "i": 46,
  "style": "Main",
  "name": "Captain",
  "text": "My shadow's back!"
 },
 {
  "i": 47,
  "style": "Main",
  "name": "Pirate",
  "text": "Everyone else's too, Captain!"
 },
 {
  "i": 48,
  "style": "Main",
  "name": "Pirate",
  "text": "Everyone's shadows are back!"
 },
 {
  "i": 49,
  "style": "Main",
  "name": "Pirate",
  "text": "Captain, you don't think someone actually beat Moriah?"
 },
 {
  "i": 50,
  "style": "Main",
  "name": "Captain",
  "text": "Don't be foolish."
 },
 {
  "i": 51,
  "style": "Main",
  "name": "Captain",
  "text": "That's impossible."
 },
 {
  "i": 52,
  "style": "Main",
  "name": "Captain",
  "text": "Moriah is a pirate who once fought against one of the Four Emperors, Kaido, or so I heard."
 },
 {
  "i": 53,
  "style": "Main",
  "name": "Captain",
  "text": "I can't think of a guy who could actually defeat him."
 },
 {
  "i": 54,
  "style": "Captions",
  "name": "MSG",
  "text": "Grand Line, as well as various places in West Blue"
 },
 {
  "i": 55,
  "style": "Main",
  "name": "Castaway",
  "text": "I've got my shadow back!"
 },
 {
  "i": 56,
  "style": "Main",
  "name": "Castaway",
  "text": "It's been such a long time since I last saw the sunlight!"
 },
 {
  "i": 57,
  "style": "Main",
  "name": "Castaway",
  "text": "Our zombies at Thriller Bark must have been destroyed!"
 },
 {
  "i": 58,
  "style": "Main",
  "name": "Is he mexican?",
  "text": "Moriah's curse has been lifted!"
 },
 {
  "i": 59,
  "style": "Main",
  "name": "Pirate",
  "text": "Boss!"
 },
 {
  "i": 60,
  "style": "Main",
  "name": "Guy",
  "text": "I see the morning sun!"
 },
 {
  "i": 61,
  "style": "Main",
  "name": "Guy",
  "text": "Look at my shadow!"
 },
 {
  "i": 62,
  "style": "Main",
  "name": "Guy",
  "text": "My shadow is following me!"
 },
 {
  "i": 63,
  "style": "Main",
  "name": "Margarita",
  "text": "My reflection is in the mirror!"
 },
 {
  "i": 64,
  "style": "Main",
  "name": "Master",
  "text": "Hey, what was that noise, Margarita?!"
 },
 {
  "i": 65,
  "style": "Main",
  "name": "Margarita",
  "text": "My shadow!"
 },
 {
  "i": 66,
  "style": "Main",
  "name": "Margarita",
  "text": "My shadow is back!"
 },
 {
  "i": 67,
  "style": "Main",
  "name": "Master",
  "text": "What?"
 },
 {
  "i": 68,
  "style": "Main",
  "name": "Master",
  "text": "You got your shadow back?"
 },
 {
  "i": 69,
  "style": "Main",
  "name": "Master",
  "text": "Your shadow that was stolen by pirates over ten years ago?!"
 },
 {
  "i": 70,
  "style": "Main",
  "name": "Master",
  "text": "It's true."
 },
 {
  "i": 71,
  "style": "Main",
  "name": "Margarita",
  "text": "Master, please forgive me!"
 },
 {
  "i": 72,
  "style": "Main",
  "name": "Margarita",
  "text": "I was so surprised that I dropped the family heirloom plates!"
 },
 {
  "i": 73,
  "style": "Main",
  "name": "Margarita",
  "text": "I had a grudge against them, but not anymore."
 },
 {
  "i": 74,
  "style": "Main",
  "name": "Margarita",
  "text": "I didn't mean to break them."
 },
 {
  "i": 75,
  "style": "Main",
  "name": "Margarita",
  "text": "I'm terribly sorry."
 },
 {
  "i": 76,
  "style": "Main",
  "name": "Margarita",
  "text": "I'll leave the mansion immediately."
 },
 {
  "i": 77,
  "style": "Main",
  "name": "Master",
  "text": "What're you talking about?"
 },
 {
  "i": 78,
  "style": "Main",
  "name": "Master",
  "text": "They were just some plates after all."
 },
 {
  "i": 79,
  "style": "Main",
  "name": "Master",
  "text": "Did you get hurt?"
 },
 {
  "i": 80,
  "style": "Main",
  "name": "Master",
  "text": "Anyway, let's celebrate."
 },
 {
  "i": 81,
  "style": "Main",
  "name": "Master",
  "text": "I'm so happy for you, Margarita."
 },
 {
  "i": 82,
  "style": "Main",
  "name": "Master",
  "text": "Aren't you happy?"
 },
 {
  "i": 83,
  "style": "Main",
  "name": "Margarita",
  "text": "Yes!"
 },
 {
  "i": 84,
  "style": "Captions",
  "name": "",
  "text": "{\\fad(500,0)}Thriller Bark"
 },
 {
  "i": 85,
  "style": "Main",
  "name": "Zoro",
  "text": "It seems we're alive."
 },
 {
  "i": 86,
  "style": "Main",
  "name": "Robin",
  "text": "For a moment, I felt like I was going to heaven."
 },
 {
  "i": 87,
  "style": "Main",
  "name": "Sanji",
  "text": "That's fine!"
 },
 {
  "i": 88,
  "style": "Main",
  "name": "Sanji",
  "text": "I wouldn't mind going to heaven as long as it's with Robin-chan!"
 },
 {
  "i": 89,
  "style": "Main",
  "name": "Usopp",
  "text": "This isn't funny, you idiots!"
 },
 {
  "i": 90,
  "style": "Main",
  "name": "Usopp",
  "text": "We really thought you were dead! You were vanishing into thin air!"
 },
 {
  "i": 91,
  "style": "Main",
  "name": "Both",
  "text": "What a scary view."
 },
 {
  "i": 92,
  "style": "Main",
  "name": "Pirate",
  "text": "The morning sun!"
 },
 {
  "i": 93,
  "style": "Main",
  "name": "Pirate",
  "text": "We don't have to fear the sun anymore!"
 },
 {
  "i": 94,
  "style": "Main",
  "name": "Lola",
  "text": "We have our shadows!"
 },
 {
  "i": 95,
  "style": "Main",
  "name": "Pirate",
  "text": "Our days in that gloomy forest are finally over!"
 },
 {
  "i": 96,
  "style": "Main",
  "name": "Pirate",
  "text": "All right!"
 },
 {
  "i": 97,
  "style": "Main",
  "name": "Pirate",
  "text": "All right!"
 },
 {
  "i": 98,
  "style": "Main",
  "name": "Chopper",
  "text": "Everyone over there seems fine as well."
 },
 {
  "i": 99,
  "style": "Main",
  "name": "Robin",
  "text": "Our existence was erased for a moment, when the sun shone upon us."
 },
 {
  "i": 100,
  "style": "Main",
  "name": "Robin",
  "text": "But at the last second, our shadows returned. Thus our bodies were regenerated."
 },
 {
  "i": 101,
  "style": "Main",
  "name": "Sanji",
  "text": "It's just like Moriah said when he transformed the shadow to change the body's shape."
 },
 {
  "i": 102,
  "style": "Main",
  "name": "Sanji",
  "text": "As far as I understand, shadow and body must have the same shape."
 },
 {
  "i": 103,
  "style": "Main",
  "name": "Zoro",
  "text": "Take it easy."
 },
 {
  "i": 104,
  "style": "Main",
  "name": "Zoro",
  "text": "Never again will your shadow and body be separated in such a strange way."
 },
 {
  "i": 105,
  "style": "Main",
  "name": "Usopp",
  "text": "Anyway, I'm glad no one was completely erased."
 },
 {
  "i": 106,
  "style": "Main",
  "name": "Franky",
  "text": "I feel sleepy all of a sudden."
 },
 {
  "i": 107,
  "style": "Main",
  "name": "Franky",
  "text": "Does anyone have cola?"
 },
 {
  "i": 108,
  "style": "Main",
  "name": "Sanji",
  "text": "All these weird creatures we've come across since we entered this island..."
 },
 {
  "i": 109,
  "style": "Main",
  "name": "Sanji",
  "text": "Were merely illusions created by Moriah."
 },
 {
  "i": 110,
  "style": "Main",
  "name": "Sanji",
  "text": "Now that he's gone, there's nothing left on the island."
 },
 {
  "i": 111,
  "style": "Main",
  "name": "Sanji",
  "text": "Everything disappears, like the morning after waking up from a nightmare."
 },
 {
  "i": 112,
  "style": "Main",
  "name": "Sanji",
  "text": "Truly a devilish haunted mansion."
 },
 {
  "i": 113,
  "style": "Main",
  "name": "Hogback",
  "text": "Wake up!"
 },
 {
  "i": 114,
  "style": "Main",
  "name": "Hogback",
  "text": "Absalom!"
 },
 {
  "i": 115,
  "style": "Main",
  "name": "Hogback",
  "text": "Hey, wake up!"
 },
 {
  "i": 116,
  "style": "Main",
  "name": "Absalom",
  "text": "Lola!"
 },
 {
  "i": 117,
  "style": "Main",
  "name": "Hogback",
  "text": "Don't panic."
 },
 {
  "i": 118,
  "style": "Main",
  "name": "Hogback",
  "text": "It no longer has a shadow."
 },
 {
  "i": 119,
  "style": "Main",
  "name": "Absalom",
  "text": "Hogback."
 },
 {
  "i": 120,
  "style": "Main",
  "name": "Absalom",
  "text": "What happened to me?"
 },
 {
  "i": 121,
  "style": "Main",
  "name": "Hogback",
  "text": "I have no idea what happened to you."
 },
 {
  "i": 122,
  "style": "Main",
  "name": "Hogback",
  "text": "Beaten by someone I assume, pathetic."
 },
 {
  "i": 123,
  "style": "Main",
  "name": "Hogback",
  "text": "More importantly, Moriah-sama was-"
 },
 {
  "i": 124,
  "style": "Main",
  "name": "Absalom",
  "text": "What?!"
 },
 {
  "i": 125,
  "style": "Main",
  "name": "Absalom",
  "text": "Moriah-sama was beaten by Straw Hat?!"
 },
 {
  "i": 126,
  "style": "Main",
  "name": "Hogback",
  "text": "Don't talk so loud!"
 },
 {
  "i": 127,
  "style": "Main",
  "name": "Hogback",
  "text": "Be quiet!"
 },
 {
  "i": 128,
  "style": "Main",
  "name": "Hogback",
  "text": "You're too loud!"
 },
 {
  "i": 129,
  "style": "Main",
  "name": "Hogback",
  "text": "Thriller Bark is nothing but a worthless pile of rubble now."
 },
 {
  "i": 130,
  "style": "Main",
  "name": "Hogback",
  "text": "But I don't plan on spending my days as a loser!"
 },
 {
  "i": 131,
  "style": "Main",
  "name": "Hogback",
  "text": "What about you?"
 },
 {
  "i": 132,
  "style": "Main",
  "name": "Absalom",
  "text": "Me?"
 },
 {
  "i": 133,
  "style": "Main",
  "name": "Zoro",
  "text": "Didn't Luffy's body shrink a while ago?"
 },
 {
  "i": 134,
  "style": "Main",
  "name": "Chopper",
  "text": "Luffy's body shrinks for a moment as a side effect of that Giant Gear."
 },
 {
  "i": 135,
  "style": "Main",
  "name": "Usopp",
  "text": "His new techniques are too much for his body, aren't they?"
 },
 {
  "i": 136,
  "style": "Main",
  "name": "Usopp",
  "text": "The stronger the enemies we encounter, the more reckless this guy will get."
 },
 {
  "i": 137,
  "style": "Main",
  "name": "Usopp",
  "text": "If we keep going like this..."
 },
 {
  "i": 138,
  "style": "Main",
  "name": "Usopp",
  "text": "A zombie!"
 },
 {
  "i": 139,
  "style": "Main",
  "name": "Usopp",
  "text": "So there was still one left?!"
 },
 {
  "i": 140,
  "style": "Main",
  "name": "Old man",
  "text": "No, just a heavily injured old man."
 },
 {
  "i": 141,
  "style": "Main",
  "name": "Usopp",
  "text": "No way! You're practically a zombie!"
 },
 {
  "i": 142,
  "style": "Main",
  "name": "Sanji",
  "text": "It's that geezer we met at the graveyard."
 },
 {
  "i": 143,
  "style": "Main",
  "name": "Old man",
  "text": "I don't believe it."
 },
 {
  "i": 144,
  "style": "Main",
  "name": "Old man",
  "text": "I didn't think the day would come when we could walk under the sun again."
 },
 {
  "i": 145,
  "style": "Main",
  "name": "Old man",
  "text": "Thank you so much!"
 },
 {
  "i": 146,
  "style": "Main",
  "name": "Old man",
  "text": "How can we ever repay this favor!"
 },
 {
  "i": 147,
  "style": "Main",
  "name": "Pirate",
  "text": "Hey! Old man Spoil!"
 },
 {
  "i": 148,
  "style": "Main",
  "name": "Pirate",
  "text": "Old man!"
 },
 {
  "i": 149,
  "style": "Main",
  "name": "Pirate",
  "text": "President of the victim association!"
 },
 {
  "i": 150,
  "style": "Main",
  "name": "Old man",
  "text": "Oh! You guys are fine too?"
 },
 {
  "i": 151,
  "style": "Main",
  "name": "Lola",
  "text": "Yes, are you?"
 },
 {
  "i": 152,
  "style": "Main",
  "name": "Old man",
  "text": "Yes."
 },
 {
  "i": 153,
  "style": "Main",
  "name": "Usopp",
  "text": "You know each other?"
 },
 {
  "i": 154,
  "style": "Main",
  "name": "Lola",
  "text": "By the way, you two, where's your gratitude?"
 },
 {
  "i": 155,
  "style": "Main",
  "name": "Pirate",
  "text": "We too, thank you from the bottom of our hearts!"
 },
 {
  "i": 156,
  "style": "Main",
  "name": "Pirate",
  "text": "I apologize for all the sudden meddling and all!"
 },
 {
  "i": 157,
  "style": "Main",
  "name": "Pirate",
  "text": "It's just that when we saw you guys rampaging, we decided to take a chance, and place our hopes in you!"
 },
 {
  "i": 158,
  "style": "Main",
  "name": "Lola",
  "text": "Thank you very much!"
 },
 {
  "i": 159,
  "style": "Main",
  "name": "Lola",
  "text": "I speak for everyone in the Thriller Bark Victim Association when I say..."
 },
 {
  "i": 160,
  "style": "Main",
  "name": "Lola",
  "text": "We will never forget this debt!"
 },
 {
  "i": 161,
  "style": "Main",
  "name": "All",
  "text": "Thank you very much!"
 },
 {
  "i": 162,
  "style": "Main",
  "name": "Old man",
  "text": "Feel free to ask for anything!"
 },
 {
  "i": 163,
  "style": "Main",
  "name": "Old man",
  "text": "Though it's not much, we have plenty of food."
 },
 {
  "i": 164,
  "style": "Main",
  "name": "Lola",
  "text": "In return, you can marry me."
 },
 {
  "i": 165,
  "style": "Main",
  "name": "Men",
  "text": "Hell no!"
 },
 {
  "i": 166,
  "style": "Main",
  "name": "Zoro",
  "text": "You keep thanking us, but..."
 },
 {
  "i": 167,
  "style": "Main",
  "name": "Lola",
  "text": "Don't say that!"
 },
 {
  "i": 168,
  "style": "Main",
  "name": "Zoro",
  "text": "It's like Luffy said, old man."
 },
 {
  "i": 169,
  "style": "Main",
  "name": "Lola",
  "text": "You there!"
 },
 {
  "i": 170,
  "style": "Main",
  "name": "Zoro",
  "text": "We had our own reasons for fighting."
 },
 {
  "i": 171,
  "style": "Main",
  "name": "Lola",
  "text": "Won't you marry me?!"
 },
 {
  "i": 172,
  "style": "Main",
  "name": "Zoro",
  "text": "We just happened to help you by accident."
 },
 {
  "i": 173,
  "style": "Main",
  "name": "Nami",
  "text": "What're you saying?!"
 },
 {
  "i": 174,
  "style": "Main",
  "name": "Nami",
  "text": "If they want to thank us so badly, then let them do it!"
 },
 {
  "i": 175,
  "style": "Main",
  "name": "Pirate",
  "text": "That's right, bro!"
 },
 {
  "i": 176,
  "style": "Main",
  "name": "Pirate",
  "text": "Ask anything you want!"
 },
 {
  "i": 177,
  "style": "Main",
  "name": "Pirate",
  "text": "Whether it was an accident or not, we're very grateful you defeated Moriah!"
 },
 {
  "i": 178,
  "style": "Main",
  "name": "Nami",
  "text": "Is that so?"
 },
 {
  "i": 179,
  "style": "Main",
  "name": "Usopp",
  "text": "Um... Your eyes..."
 },
 {
  "i": 180,
  "style": "Main",
  "name": "Nami",
  "text": "That's right! I completely forgot about it!"
 },
 {
  "i": 181,
  "style": "Main",
  "name": "Usopp",
  "text": "What's the matter?"
 },
 {
  "i": 182,
  "style": "Main",
  "name": "Nami",
  "text": "I forgot about him!"
 },
 {
  "i": 183,
  "style": "Main",
  "name": "Robin",
  "text": "Is something wrong?"
 },
 {
  "i": 184,
  "style": "Main",
  "name": "Nami",
  "text": "We're in big trouble!"
 },
 {
  "i": 185,
  "style": "Main",
  "name": "Den-Den Mushi",
  "text": "{\\i1}I see.{\\i0}"
 },
 {
  "i": 186,
  "style": "Main",
  "name": "Den-Den Mushi",
  "text": "{\\i1}So it turned out as I feared.{\\i0}"
 },
 {
  "i": 187,
  "style": "Main",
  "name": "Kuma",
  "text": "It appears so."
 },
 {
  "i": 188,
  "style": "Main",
  "name": "Usopp",
  "text": "Who's that over there?"
 },
 {
  "i": 189,
  "style": "Main",
  "name": "Nami",
  "text": "He's here."
 },
 {
  "i": 190,
  "style": "Main",
  "name": "Nami",
  "text": "Stay calm and listen."
 },
 {
  "i": 191,
  "style": "Main",
  "name": "Nami",
  "text": "I didn't want to bring this up while in the middle of the battle with Moriah, but..."
 },
 {
  "i": 192,
  "style": "Main",
  "name": "Nami",
  "text": "On this island..."
 },
 {
  "i": 193,
  "style": "Main",
  "name": "Nami",
  "text": "There was another..."
 },
 {
  "i": 194,
  "style": "Main",
  "name": "Nami",
  "text": "Warlord of the Sea!"
 },
 {
  "i": 195,
  "style": "Main",
  "name": "Usopp",
  "text": "What did you just say?!"
 },
 {
  "i": 196,
  "style": "Main",
  "name": "Usopp",
  "text": "That's a..."
 },
 {
  "i": 197,
  "style": "Main",
  "name": "All",
  "text": "Warlord of the Sea?!"
 },
 {
  "i": 198,
  "style": "Main",
  "name": "Den-Den Mushi",
  "text": "Just when we finally found a replacement for Crocodile."
 },
 {
  "i": 199,
  "style": "Main",
  "name": "Den-Den Mushi",
  "text": "We can't afford to have another empty gap in the Warlords."
 },
 {
  "i": 200,
  "style": "Main",
  "name": "Den-Den Mushi",
  "text": "Is there still breath in him?"
 },
 {
  "i": 201,
  "style": "Main",
  "name": "Kuma",
  "text": "Who knows."
 },
 {
  "i": 202,
  "style": "Main",
  "name": "Den-Den Mushi",
  "text": "As long as there's a breath of life in him,"
 },
 {
  "i": 203,
  "style": "Main",
  "name": "Den-Den Mushi",
  "text": "we will wait for his recovery and allow him to take up his place as a Warlord again."
 },
 {
  "i": 204,
  "style": "Main",
  "name": "Den-Den Mushi",
  "text": "We'll worry about that later."
 },
 {
  "i": 205,
  "style": "Main",
  "name": "Den-Den Mushi",
  "text": "If we keep losing one after another, the dignity of the Warlords will end up disappearing."
 },
 {
  "i": 206,
  "style": "Main",
  "name": "Den-Den Mushi",
  "text": "We can't let this information get spread around the world."
 },
 {
  "i": 207,
  "style": "Main",
  "name": "Den-Den Mushi",
  "text": "Seriously, what a bunch of troublemakers."
 },
 {
  "i": 208,
  "style": "Main",
  "name": "Lola",
  "text": "It's true... Even Moriah falls short of that giant's size,"
 },
 {
  "i": 209,
  "style": "Main",
  "name": "Lola",
  "text": "That pirate known as \"The Tyrant\","
 },
 {
  "i": 210,
  "style": "Main",
  "name": "Lola",
  "text": "Bartholomew Kuma."
 },
 {
  "i": 211,
  "style": "Main",
  "name": "Pirate",
  "text": "He is Kuma the Tyrant?!"
 },
 {
  "i": 212,
  "style": "Main",
  "name": "Den-Den Mushi",
  "text": "Do you understand what I'm saying?"
 },
 {
  "i": 213,
  "style": "Main",
  "name": "Den-Den Mushi",
  "text": "There must not be any witnesses of Moriah's defeat."
 },
 {
  "i": 214,
  "style": "Main",
  "name": "Den-Den Mushi",
  "text": "This is a direct order from the World Government..."
 },
 {
  "i": 215,
  "style": "Main",
  "name": "Den-Den Mushi",
  "text": "The Straw Hat crew, along with any survivors on the island must be..."
 },
 {
  "i": 216,
  "style": "Main",
  "name": "Den-Den Mushi",
  "text": "eliminated."
 },
 {
  "i": 217,
  "style": "Main",
  "name": "Kuma",
  "text": "Simple enough."
 },
 {
  "i": 218,
  "style": "Main",
  "name": "Pirate",
  "text": "What was that just now?!"
 },
 {
  "i": 219,
  "style": "Main",
  "name": "Pirate",
  "text": "Did he say \"eliminated\"?!"
 },
 {
  "i": 220,
  "style": "Main",
  "name": "Pirate",
  "text": "Hey, hey! Eliminate..."
 },
 {
  "i": 221,
  "style": "Main",
  "name": "Pirate",
  "text": "Us?!"
 },
 {
  "i": 222,
  "style": "Main",
  "name": "Pirate",
  "text": "Why?!"
 },
 {
  "i": 223,
  "style": "Main",
  "name": "Pirate",
  "text": "I can't believe this is happening!"
 },
 {
  "i": 224,
  "style": "Main",
  "name": "Pirate",
  "text": "Just when we finally got free from Moriah's power!"
 },
 {
  "i": 225,
  "style": "Main",
  "name": "Usopp",
  "text": "No way!"
 },
 {
  "i": 226,
  "style": "Main",
  "name": "Usopp",
  "text": "We have to fight two Warlords consecutively?!"
 },
 {
  "i": 227,
  "style": "Main",
  "name": "Zoro",
  "text": "You guys, step back."
 },
 {
  "i": 228,
  "style": "Main",
  "name": "Zoro",
  "text": "I'll handle this!"
 },
 {
  "i": 229,
  "style": "Main",
  "name": "Nami",
  "text": "Be careful! {Padding before this with breathing. Cut if possible}"
 },
 {
  "i": 230,
  "style": "Main",
  "name": "Nami",
  "text": "He's got some sort of ability!"
 },
 {
  "i": 231,
  "style": "Main",
  "name": "Nami",
  "text": "He completely let a person vanish just by touching her with his hand!"
 },
 {
  "i": 232,
  "style": "Main",
  "name": "Usopp",
  "text": "H-He vanished a person just by touching them?!"
 },
 {
  "i": 233,
  "style": "Main",
  "name": "Chopper",
  "text": "S-So scary! {Non-Canon}"
 },
 {
  "i": 234,
  "style": "Main",
  "name": "Nami",
  "text": "Plus, he can move instantly from one location to another!"
 },
 {
  "i": 235,
  "style": "Main",
  "name": "Nami",
  "text": "Those hands are dangerous!"
 },
 {
  "i": 236,
  "style": "Main",
  "name": "Pirate",
  "text": "What?!"
 },
 {
  "i": 237,
  "style": "Main",
  "name": "Pirate",
  "text": "He's here!"
 },
 {
  "i": 238,
  "style": "Main",
  "name": "Pirate",
  "text": "He's huge!"
 },
 {
  "i": 239,
  "style": "Main",
  "name": "Pirate",
  "text": "When did he-"
 },
 {
  "i": 240,
  "style": "Main",
  "name": "Pirate",
  "text": "Dammit! Just when we finally got our freedom!"
 },
 {
  "i": 241,
  "style": "Main",
  "name": "Pirate",
  "text": "Like I'm gonna die in this place!"
 },
 {
  "i": 242,
  "style": "Main",
  "name": "Pirate",
  "text": "That's right! We won't let anyone get in our way anymore!"
 },
 {
  "i": 243,
  "style": "Main",
  "name": "Pirate",
  "text": "Everyone, get him!"
 },
 {
  "i": 244,
  "style": "Main",
  "name": "Pirate",
  "text": "Yes, yes! Get him!"
 },
 {
  "i": 245,
  "style": "Main",
  "name": "Lola",
  "text": "Stop it, you fools!"
 },
 {
  "i": 246,
  "style": "Main",
  "name": "Lola",
  "text": "You're no match for him!"
 },
 {
  "i": 247,
  "style": "Main",
  "name": "Pirate",
  "text": "Even the guys who weren't touched were pierced by something."
 },
 {
  "i": 248,
  "style": "Main",
  "name": "Kuma",
  "text": "Pirate Hunter Zoro."
 },
 {
  "i": 249,
  "style": "Main",
  "name": "Kuma",
  "text": "I'll start with you."
 },
 {
  "i": 250,
  "style": "Main",
  "name": "Pirate",
  "text": "Hey, hang in there!"
 },
 {
  "i": 251,
  "style": "Main",
  "name": "Pirate",
  "text": "Are you okay?"
 },
 {
  "i": 252,
  "style": "Main",
  "name": "Pirate",
  "text": "What the hell did he do?!"
 },
 {
  "i": 253,
  "style": "Main",
  "name": "Pirate",
  "text": "Something went through him without touching him!"
 },
 {
  "i": 254,
  "style": "Main",
  "name": "Pirate",
  "text": "That's his ability?"
 },
 {
  "i": 255,
  "style": "Main",
  "name": "Lola",
  "text": "What a cruel thing to do."
 },
 {
  "i": 256,
  "style": "Main",
  "name": "Lola",
  "text": "Just when we finally managed to break free from our suffering in Moriah's forest after so many years."
 },
 {
  "i": 257,
  "style": "Main",
  "name": "Lola",
  "text": "We don't even have the chance to celebrate before another Shichibukai shows up to exterminate us all."
 },
 {
  "i": 258,
  "style": "Main",
  "name": "Pirate",
  "text": "This isn't fair!"
 },
 {
  "i": 259,
  "style": "Main",
  "name": "Pirate",
  "text": "You don't know what the Straw Hats went through to finish this battle!"
 },
 {
  "i": 260,
  "style": "Main",
  "name": "Pirate",
  "text": "We will fight in their place, regardless of the odds!"
 },
 {
  "i": 261,
  "style": "Main",
  "name": "Pirate",
  "text": "Even if our enemy is a Warlord!"
 },
 {
  "i": 262,
  "style": "Main",
  "name": "Pirate",
  "text": "You're not as tough as Moriah or Oars anyways!"
 },
 {
  "i": 263,
  "style": "Main",
  "name": "Zoro",
  "text": "Shut up and stay back!"
 },
 {
  "i": 264,
  "style": "Main",
  "name": "Zoro",
  "text": "He's after me, didn't you hear him?"
 },
 {
  "i": 265,
  "style": "Main",
  "name": "Zoro",
  "text": "I'll take him on."
 },
 {
  "i": 266,
  "style": "Main",
  "name": "Zoro",
  "text": "I don't need your help."
 },
 {
  "i": 267,
  "style": "Main",
  "name": "Zoro",
  "text": "Don't humiliate me."
 },
 {
  "i": 268,
  "style": "Main",
  "name": "Kuma",
  "text": "You people have quite a reputation."
 },
 {
  "i": 269,
  "style": "Main",
  "name": "Kuma",
  "text": "Straw Hat's ship sure is full of exceptional people."
 },
 {
  "i": 270,
  "style": "Main",
  "name": "Lola",
  "text": "This isn't the time to feel flattered!"
 },
 {
  "i": 271,
  "style": "Main",
  "name": "Kuma",
  "text": "You've caused too many disturbances."
 },
 {
  "i": 272,
  "style": "Main",
  "name": "Kuma",
  "text": "It's not just your captain; your whole crew has become quite noteworthy."
 },
 {
  "i": 273,
  "style": "Main",
  "name": "Usopp",
  "text": "Hey, Zoro, wait!"
 },
 {
  "i": 274,
  "style": "Main",
  "name": "Usopp",
  "text": "Don't be reckless!"
 },
 {
  "i": 275,
  "style": "Main",
  "name": "Usopp",
  "text": "You're completely worn out, aren't you?!"
 },
 {
  "i": 276,
  "style": "Main",
  "name": "Zoro",
  "text": "When it rains, it pours; disasters hit one after another."
 },
 {
  "i": 277,
  "style": "Main",
  "name": "Zoro",
  "text": "It's not like anything will change if we complain."
 },
 {
  "i": 278,
  "style": "Main",
  "name": "Zoro",
  "text": "If I die here, it means this is as far as I could go!"
 },
 {
  "i": 279,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(250,250)}Two Sword Style..."
 },
 {
  "i": 280,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(250,250)}Draw and Resheath Technique!"
 },
 {
  "i": 281,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(250,250)}Castle Gate!"
 },
 {
  "i": 282,
  "style": "Main",
  "name": "Zoro",
  "text": "What the hell was that?!"
 },
 {
  "i": 283,
  "style": "Main",
  "name": "Usopp",
  "text": "Look! It didn't even touch him and he's already hurting!"
 },
 {
  "i": 284,
  "style": "Main",
  "name": "Nami",
  "text": "What is his ability?!"
 },
 {
  "i": 285,
  "style": "Main",
  "name": "Nami",
  "text": "What's that mark he left in the rubble?!"
 },
 {
  "i": 286,
  "style": "Main",
  "name": "Pirate",
  "text": "Look! His palm!"
 },
 {
  "i": 287,
  "style": "Main",
  "name": "Pirate",
  "text": "A p-paw?!"
 },
 {
  "i": 288,
  "style": "Main",
  "name": "Pirate",
  "text": "How can a human have paws?"
 },
 {
  "i": 289,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(250,250)}36 Pound Cannon!"
 },
 {
  "i": 290,
  "style": "Main",
  "name": "Pirate",
  "text": "Look out!"
 },
 {
  "i": 291,
  "style": "Main",
  "name": "Chopper",
  "text": "He deflected Zoro's attack with his hand!"
 },
 {
  "i": 292,
  "style": "Main",
  "name": "Chopper",
  "text": "How can he do that?!"
 },
 {
  "i": 293,
  "style": "Main",
  "name": "Zoro",
  "text": "So that's your ability."
 },
 {
  "i": 294,
  "style": "Main",
  "name": "Kuma",
  "text": "The power to deflect anything."
 },
 {
  "i": 295,
  "style": "Main",
  "name": "Kuma",
  "text": "I'm a paw-man with the power of the Paw Fruit."
 },
 {
  "i": 296,
  "style": "Main",
  "name": "Sanji",
  "text": "A-A paw-man?!"
 },
 {
  "i": 297,
  "style": "Main",
  "name": "Usopp",
  "text": "That sounds so harmless."
 },
 {
  "i": 298,
  "style": "Main",
  "name": "Usopp",
  "text": "Are there more lamely named fruits out there?"
 },
 {
  "i": 299,
  "style": "Main",
  "name": "Franky",
  "text": "I dunno whether he's a Warlord or a charitable guy, but..."
 },
 {
  "i": 300,
  "style": "Main",
  "name": "Franky",
  "text": "We're probably overestimating this guy."
 },
 {
  "i": 301,
  "style": "Main",
  "name": "Chopper",
  "text": "Franky!"
 },
 {
  "i": 302,
  "style": "Main",
  "name": "Chopper",
  "text": "Franky!"
 },
 {
  "i": 303,
  "style": "Main",
  "name": "Kuma",
  "text": "Cyborg Franky."
 },
 {
  "i": 304,
  "style": "Main",
  "name": "Kuma",
  "text": "Is that all you have to offer?"
 },
 {
  "i": 305,
  "style": "Main",
  "name": "Robin",
  "text": "He might be deflecting the air..."
 },
 {
  "i": 306,
  "style": "Main",
  "name": "Robin",
  "text": "Mere artillery is useless against Franky."
 },
 {
  "i": 307,
  "style": "Main",
  "name": "Kuma",
  "text": "It's called Pad Cannon."
 },
 {
  "i": 308,
  "style": "Main",
  "name": "Kuma",
  "text": "The air deflected at the speed of light generates a powerful shock wave that can pierce through anything."
 },
 {
  "i": 309,
  "style": "Main",
  "name": "Kuma",
  "text": "Your time's up."
 },
 {
  "i": 310,
  "style": "Main",
  "name": "Kuma",
  "text": "{\\fad(250,250)}Swift Pad Cannon!"
 },
 {
  "i": 311,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(250,250)}Streaming Wolf Blades!"
 },
 {
  "i": 312,
  "style": "Main",
  "name": "Usopp",
  "text": "Zoro!"
 },
 {
  "i": 313,
  "style": "Main",
  "name": "Chopper",
  "text": "He repelled even that attack!"
 },
 {
  "i": 314,
  "style": "Main",
  "name": "Zoro",
  "text": "You!"
 },
 {
  "i": 315,
  "style": "Main",
  "name": "Pirate",
  "text": "It’s useless!"
 },
 {
  "i": 316,
  "style": "Main",
  "name": "Pirate",
  "text": "He can't keep this up!"
 },
 {
  "i": 317,
  "style": "Main",
  "name": "Pirate",
  "text": "It's a miracle that he can even fight in that condition!"
 },
 {
  "i": 318,
  "style": "Main",
  "name": "Pirate",
  "text": "He took enough damage to kill a normal human just from that monster Oars!"
 },
 {
  "i": 319,
  "style": "Main",
  "name": "Usopp",
  "text": "Zoro, behind you!"
 },
 {
  "i": 320,
  "style": "Main",
  "name": "Usopp",
  "text": "Run!"
 },
 {
  "i": 321,
  "style": "Main",
  "name": "Both",
  "text": "Zoro!"
 },
 {
  "i": 322,
  "style": "Main",
  "name": "Sanji",
  "text": "That's as far as you go!"
 },
 {
  "i": 323,
  "style": "Note",
  "name": "Sanji",
  "text": "{\\fad(250,250)}Grind"
 },
 {
  "i": 324,
  "style": "Main",
  "name": "Sanji",
  "text": "{\\fad(250,250)}Concasse!"
 },
 {
  "i": 325,
  "style": "Main",
  "name": "Chopper",
  "text": "Sanji!"
 },
 {
  "i": 326,
  "style": "Main",
  "name": "Usopp",
  "text": "Try deflecting that with your paws!"
 },
 {
  "i": 327,
  "style": "Main",
  "name": "Usopp",
  "text": "Your skull must've been smashed to bits, bastard!"
 },
 {
  "i": 328,
  "style": "Main",
  "name": "Zoro",
  "text": "Bastard, mind your own..."
 },
 {
  "i": 329,
  "style": "Main",
  "name": "Kuma",
  "text": "Black Leg Sanji."
 },
 {
  "i": 330,
  "style": "Main",
  "name": "Kuma",
  "text": "So that's you."
 },
 {
  "i": 331,
  "style": "Main",
  "name": "Usopp",
  "text": "He didn't even falter from Sanji's kick."
 },
 {
  "i": 332,
  "style": "Main",
  "name": "Usopp",
  "text": "What's going on?"
 },
 {
  "i": 333,
  "style": "Main",
  "name": "Sanji",
  "text": "What's with his toughness?!"
 },
 {
  "i": 334,
  "style": "Main",
  "name": "Sanji",
  "text": "Is his face made of steel?!"
 },
 {
  "i": 335,
  "style": "Main",
  "name": "Usopp",
  "text": "{\\fad(250,250)}F-F-Fire Bird Star!"
 },
 {
  "i": 336,
  "style": "Main",
  "name": "Kuma",
  "text": "King of the Snipers."
 },
 {
  "i": 337,
  "style": "Main",
  "name": "Kuma",
  "text": "What an outrageous alias."
 },
 {
  "i": 338,
  "style": "Main",
  "name": "Kuma",
  "text": "I have no interest in destroying you all when you are in such a worn-out state."
 },
 {
  "i": 339,
  "style": "Main",
  "name": "Kuma",
  "text": "My mission is to exterminate every single one of you, but..."
 },
 {
  "i": 340,
  "style": "Main",
  "name": "Franky",
  "text": "What is he doing?"
 },
 {
  "i": 341,
  "style": "Main",
  "name": "Nami",
  "text": "The air..."
 },
 {
  "i": 342,
  "style": "Main",
  "name": "Nami",
  "text": "Is he compressing the air with his paws?"
 },
 {
  "i": 343,
  "style": "Main",
  "name": "Chopper",
  "text": "It's getting smaller."
 },
 {
  "i": 344,
  "style": "Main",
  "name": "Nami",
  "text": "By deflecting the atmosphere with his paws he's pressurizing lots of air, condensing it more and more."
 },
 {
  "i": 345,
  "style": "Main",
  "name": "Robin",
  "text": "The power of that much condensed air, trying to return to its former size..."
 },
 {
  "i": 346,
  "style": "Main",
  "name": "Robin",
  "text": "Will without a doubt generate a massive shock wave."
 },
 {
  "i": 347,
  "style": "Main",
  "name": "Robin",
  "text": "Just like a bomb."
 },
 {
  "i": 348,
  "style": "Main",
  "name": "Chopper",
  "text": "W-What?"
 },
 {
  "i": 349,
  "style": "Main",
  "name": "Usopp",
  "text": "A bomb?!"
 },
 {
  "i": 350,
  "style": "Main",
  "name": "Usopp",
  "text": "You mean he's creating a bomb?!"
 },
 {
  "i": 351,
  "style": "Main",
  "name": "Kuma",
  "text": "I will spare your lives."
 },
 {
  "i": 352,
  "style": "Main",
  "name": "Kuma",
  "text": "But in exchange,"
 },
 {
  "i": 353,
  "style": "Main",
  "name": "Kuma",
  "text": "I want you to bring me Straw Hat Luffy's head."
 },
 {
  "i": 354,
  "style": "Main",
  "name": "Kuma",
  "text": "As long as they have him, the government won't mind."
 },
 {
  "i": 355,
  "style": "Main",
  "name": "Usopp",
  "text": "Betray our comrade...?!"
 },
 {
  "i": 356,
  "style": "Main",
  "name": "Kuma",
  "text": "Now, bring him to me."
 },
 {
  "i": 357,
  "style": "Main",
  "name": "All",
  "text": "{\\fad(0,5000)}We refuse!"
 },
 {
  "i": 358,
  "style": "Main",
  "name": "Kuma",
  "text": "Such a shame."
 },
 {
  "i": 359,
  "style": "Main",
  "name": "Kuma",
  "text": "{\\fad(250,250)}Ursus Shock."
 },
 {
  "i": 360,
  "style": "Main",
  "name": "Zoro",
  "text": "{\\fad(250,250)}Lion's Song!"
 },
 {
  "i": 361,
  "style": "Main",
  "name": "Zoro",
  "text": "What the hell are you?!"
 },
 {
  "i": 362,
  "style": "Main",
  "name": "Zoro",
  "text": "A cyborg, just like Franky?!"
 },
 {
  "i": 363,
  "style": "Main",
  "name": "Zoro",
  "text": "No. His body is even harder than steel!"
 },
 {
  "i": 364,
  "style": "Main",
  "name": "Zoro",
  "text": "He melted the steel..."
 },
 {
  "i": 365,
  "style": "Main",
  "name": "Kuma",
  "text": "Cyborg."
 },
 {
  "i": 366,
  "style": "Main",
  "name": "Kuma",
  "text": "That's certainly true."
 },
 {
  "i": 367,
  "style": "Main",
  "name": "Kuma",
  "text": "But I'm completely different from Cyborg Franky."
 },
 {
  "i": 368,
  "style": "Main",
  "name": "Kuma",
  "text": "I'm what is called a Pacifista."
 },
 {
  "i": 369,
  "style": "Main",
  "name": "Kuma",
  "text": "A human weapon from the government that is yet to be completed."
 },
 {
  "i": 370,
  "style": "Main",
  "name": "Zoro",
  "text": "Pacifista?"
 },
 {
  "i": 371,
  "style": "Main",
  "name": "Kuma",
  "text": "I was developed by the government's genius scientist."
 },
 {
  "i": 372,
  "style": "Main",
  "name": "Kuma",
  "text": "Dr. Vegapunk."
 },
 {
  "i": 373,
  "style": "Main",
  "name": "Kuma",
  "text": "He is the most brilliant person in the world."
 },
 {
  "i": 374,
  "style": "Main",
  "name": "Kuma",
  "text": "It is said his knowledge is 500 years ahead of our time."
 },
 {
  "i": 375,
  "style": "Main",
  "name": "Zoro",
  "text": "So he possesses such a body, and he's a Devil's Fruit user!"
 },
 {
  "i": 376,
  "style": "Main",
  "name": "Zoro",
  "text": "I can't hope to beat that."
 },
 {
  "i": 377,
  "style": "Main",
  "name": "Zoro",
  "text": "And as expected, I can no longer move."
 },
 {
  "i": 378,
  "style": "Main",
  "name": "Zoro",
  "text": "Is there anything I can do to stop you from taking Luffy's head?"
 },
 {
  "i": 379,
  "style": "Main",
  "name": "Kuma",
  "text": "That's as far as I can negotiate."
 },
 {
  "i": 380,
  "style": "Main",
  "name": "Zoro",
  "text": "I understand."
 },
 {
  "i": 381,
  "style": "Main",
  "name": "Zoro",
  "text": "Then, go ahead and take it..."
 },
 {
  "i": 382,
  "style": "Main",
  "name": "Zoro",
  "text": "But..."
 },
 {
  "i": 383,
  "style": "Main",
  "name": "Zoro",
  "text": "Not his head!"
 },
 {
  "i": 384,
  "style": "Main",
  "name": "Zoro",
  "text": "I beg you to take my life instead of his!"
 },
 {
  "i": 385,
  "style": "Main",
  "name": "Zoro",
  "text": "I may not be as worthy as him yet, but..."
 },
 {
  "i": 386,
  "style": "Main",
  "name": "Zoro",
  "text": "The head of the man who would one day become the strongest swordsman..."
 },
 {
  "i": 387,
  "style": "Main",
  "name": "Zoro",
  "text": "Isn't bad either!"
 },
 {
  "i": 388,
  "style": "Main",
  "name": "Kuma",
  "text": "Even with such an ambition, you'd sacrifice yourself for this man?"
 },
 {
  "i": 389,
  "style": "Main",
  "name": "Zoro",
  "text": "The way I see it, this is the only way to help the crew."
 },
 {
  "i": 390,
  "style": "Main",
  "name": "Zoro",
  "text": "How can I protect my ambition when I can't even protect my captain!"
 },
 {
  "i": 391,
  "style": "Main",
  "name": "Zoro",
  "text": "Luffy's the man who is gonna be the Pirate King!"
 },
 {
  "i": 392,
  "style": "Main",
  "name": "Sanji",
  "text": "Hold it, hold it, you bastard!"
 },
 {
  "i": 393,
  "style": "Main",
  "name": "Sanji",
  "text": "What'll happen if you die?"
 },
 {
  "i": 394,
  "style": "Main",
  "name": "Sanji",
  "text": "What about your ambition, idiot?"
 },
 {
  "i": 395,
  "style": "Main",
  "name": "Sanji",
  "text": "Hey, big guy!"
 },
 {
  "i": 396,
  "style": "Main",
  "name": "Zoro",
  "text": "Hey!"
 },
 {
  "i": 397,
  "style": "Main",
  "name": "Sanji",
  "text": "Forget this moss-head swordsman."
 },
 {
  "i": 398,
  "style": "Main",
  "name": "Sanji",
  "text": "Take my life instead!"
 },
 {
  "i": 399,
  "style": "Main",
  "name": "Sanji",
  "text": "The Marines are still taking me lightly, but..."
 },
 {
  "i": 400,
  "style": "Main",
  "name": "Sanji",
  "text": "Before long, the one who's bound to become the most dangerous person in this crew is..."
 },
 {
  "i": 401,
  "style": "Main",
  "name": "Sanji",
  "text": "Me, Black-Leg Sanji!"
 },
 {
  "i": 402,
  "style": "Main",
  "name": "Sanji",
  "text": "What're you waiting for?"
 },
 {
  "i": 403,
  "style": "Main",
  "name": "Sanji",
  "text": "I'm prepared to exchange my life for his!"
 },
 {
  "i": 404,
  "style": "Main",
  "name": "Sanji",
  "text": "The flower of my glorious death shall bloom on this spot."
 },
 {
  "i": 405,
  "style": "Main",
  "name": "Sanji",
  "text": "Hey, make sure to..."
 },
 {
  "i": 406,
  "style": "Main",
  "name": "Sanji",
  "text": "Say goodbye to everyone for me."
 },
 {
  "i": 407,
  "style": "Main",
  "name": "Sanji",
  "text": "Tell them I'm sorry, but they'll have to look for a new cook."
 },
 {
  "i": 408,
  "style": "Main",
  "name": "Sanji",
  "text": "W-Why you!"
 },
 {
  "i": 409,
  "style": "Main",
  "name": "Zoro",
  "text": "That's my last request."
 },
 {
  "i": 410,
  "style": "Main",
  "name": "Kuma",
  "text": "If I were to claim Straw Hat's life after this, I'd feel ashamed."
 },
 {
  "i": 411,
  "style": "Main",
  "name": "Zoro",
  "text": "I'm in your debt."
 },
 {
  "i": 412,
  "style": "Main",
  "name": "Kuma",
  "text": "Trust me in what I'm about to do,"
 },
 {
  "i": 413,
  "style": "Main",
  "name": "Kuma",
  "text": "I'll keep my promise no matter what."
 },
 {
  "i": 414,
  "style": "Main",
  "name": "Kuma",
  "text": "But in exchange, I will make you..."
 },
 {
  "i": 415,
  "style": "Main",
  "name": "Kuma",
  "text": "Experience hell itself."
 },
 {
  "i": 416,
  "style": "Main",
  "name": "Kuma",
  "text": "What I just extracted from his body is his pain and fatigue."
 },
 {
  "i": 417,
  "style": "Main",
  "name": "Kuma",
  "text": "All the damage he accumulated during his battle with Moriah is within this."
 },
 {
  "i": 418,
  "style": "Main",
  "name": "Kuma",
  "text": "If you really intend to take his place, then you must literally share his suffering."
 },
 {
  "i": 419,
  "style": "Main",
  "name": "Kuma",
  "text": "Adding such damage to your current condition will eliminate your chances of survival."
 },
 {
  "i": 420,
  "style": "Main",
  "name": "Kuma",
  "text": "It will be certain death."
 },
 {
  "i": 421,
  "style": "Main",
  "name": "Kuma",
  "text": "Have a taste."
 },
 {
  "i": 422,
  "style": "Main",
  "name": "Kuma",
  "text": "How was it?"
 },
 {
  "i": 423,
  "style": "Main",
  "name": "Zoro",
  "text": "Please let me... do this somewhere else!"
 },
 {
  "i": 424,
  "style": "Main",
  "name": "Kuma",
  "text": "He has good friends."
 },
 {
  "i": 425,
  "style": "Main",
  "name": "Kuma",
  "text": "As expected from your son,"
 },
 {
  "i": 426,
  "style": "Main",
  "name": "Kuma",
  "text": "Dragon."
 },
 {
  "i": 427,
  "style": "Main",
  "name": "Pirate",
  "text": "Hey! Is everyone alright?!"
 },
 {
  "i": 428,
  "style": "Main",
  "name": "Lola",
  "text": "He was so sure that attack would be enough to exterminate us all that he didn't even check if it did!"
 },
 {
  "i": 429,
  "style": "Main",
  "name": "Lola",
  "text": "Take that, stupid bear-man!"
 },
 {
  "i": 430,
  "style": "Main",
  "name": "Nami",
  "text": "That hurts."
 },
 {
  "i": 431,
  "style": "Main",
  "name": "Franky",
  "text": "Hey, hey, are you kidding me?"
 },
 {
  "i": 432,
  "style": "Main",
  "name": "Franky",
  "text": "What happened to you?"
 },
 {
  "i": 433,
  "style": "Main",
  "name": "Luffy",
  "text": "Hey look, my body is as light as a feather!"
 },
 {
  "i": 434,
  "style": "Main",
  "name": "Luffy",
  "text": "I dunno why!"
 },
 {
  "i": 435,
  "style": "Main",
  "name": "Usopp",
  "text": "Liar, that's not possible!"
 },
 {
  "i": 436,
  "style": "Main",
  "name": "Robin",
  "text": "Maybe he took so much damage that now he feels fine."
 },
 {
  "i": 437,
  "style": "Main",
  "name": "Sanji",
  "text": "It's not as simple as that!"
 },
 {
  "i": 438,
  "style": "Main",
  "name": "Sanji",
  "text": "Where did that idiot go?!"
 },
 {
  "i": 439,
  "style": "Main",
  "name": "Sanji",
  "text": "There he is."
 },
 {
  "i": 440,
  "style": "Main",
  "name": "Sanji",
  "text": "You sure scared me for a second."
 },
 {
  "i": 441,
  "style": "Main",
  "name": "Sanji",
  "text": "Hey, where did that Warlord-"
 },
 {
  "i": 442,
  "style": "Main",
  "name": "Sanji",
  "text": "What's with all this blood!?"
 },
 {
  "i": 443,
  "style": "Main",
  "name": "Sanji",
  "text": "Hey!"
 },
 {
  "i": 444,
  "style": "Main",
  "name": "Sanji",
  "text": "Hey, are you alive?!"
 },
 {
  "i": 445,
  "style": "Main",
  "name": "Sanji",
  "text": "Where is he?!"
 },
 {
  "i": 446,
  "style": "Main",
  "name": "Sanji",
  "text": "What the hell happened here?!"
 },
 {
  "i": 447,
  "style": "Main",
  "name": "Zoro",
  "text": "No-"
 },
 {
  "i": 448,
  "style": "Main",
  "name": "Zoro",
  "text": "Nothing..."
 },
 {
  "i": 449,
  "style": "Main",
  "name": "Zoro",
  "text": "at all!"
 }
]