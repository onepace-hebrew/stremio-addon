 },
 {
  "i": 14,
  "style": "Lyrics",
  "name": "",
  "text": "We have no interest in treasure chests"
 },
 {
  "i": 15,
  "style": "Lyrics",
  "name": "",
  "text": "A pocket of romance, and"
 },
 {
  "i": 16,
  "style": "Lyrics",
  "name": "",
  "text": "We are!"
 },
 {
  "i": 17,
  "style": "Lyrics",
  "name": "",
  "text": "Let's pile up all the dreams,"
 },
 {
  "i": 18,
  "style": "Lyrics",
  "name": "",
  "text": "And go find the thing we're looking for..."
 },
 {
  "i": 19,
  "style": "Lyrics",
