[
 {
  "i": 0,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Let's travel all through the worldwide seas,"
 },
 {
  "i": 1,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 2,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 3,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 4,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "We were able to escape from the set course"
 },
 {
  "i": 5,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "along the boundary between sky and sea."
 },
 {
  "i": 6,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now we're rowing our way"
 },
 {
  "i": 7,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "to a hidden adventure at the dark bottom of the sea."
 },
 {
  "i": 8,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Doesn't it sound fun just thinking about it?"
 },
 {
  "i": 9,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Let's travel all through the worldwide seas,"
 },
 {
  "i": 10,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "raising our battle cry."
 },
 {
  "i": 11,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you've made up your mind, let the signal for departure"
 },
 {
  "i": 12,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "ring out."
 },
 {
  "i": 13,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}That feeling we had when we set sail"
 },
 {
  "i": 14,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "is something I'll never forget."
 },
 {
  "i": 15,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Because of that"
 },
 {
  "i": 16,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "nothing will be able to scare me..."
 },
 {
  "i": 17,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Now, as the trip approaches, our racing heartbeats"
 },
 {
  "i": 18,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "engrave a rhythm of adventure in our shy hearts."
 },
 {
  "i": 19,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,50)}Get all the treasures"
 },
 {
  "i": 20,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 21,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 22,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(50,50)}making a splash..."
 },
 {
  "i": 23,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Fill your empty heart with dreams."
 },
 {
  "i": 24,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Spread your wings."
 },
 {
  "i": 25,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "If you color your heart with the blowing wind"
 },
 {
  "i": 26,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "{\\fad(0,90)}you will move on."
 },
 {
  "i": 27,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Get all the treasures"
 },
 {
  "i": 28,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "while laughing out loud."
 },
 {
  "i": 29,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "Give them all out at a big party"
 },
 {
  "i": 30,
  "style": "Jungle P lyrics",
  "name": "",
  "text": "making a splash..."
 },
 {
  "i": 31,
  "style": "Title",
  "name": "",
  "text": "{\\fad(2000,2000)}Show Yourselves, Straw Hat Pirates!\\NThe Crew's Hopeless Counterattack!"
 },
 {
  "i": 32,
  "style": "Main",
  "name": "Hogback",
  "text": "Hey! What's wrong, Cindry-chan?!"
 },
 {
  "i": 33,
  "style": "Main",
  "name": "Cindry",
  "text": "My body..."
 },
 {
  "i": 34,
  "style": "Main",
  "name": "Cindry",
  "text": "Won't move."
 },
 {
  "i": 35,
  "style": "Main",
  "name": "Cindry",
  "text": "Tears came out..."
 },
 {
  "i": 36,
  "style": "Main",
  "name": "Cindry",
  "text": "Involuntarily."
 },
 {
  "i": 37,
  "style": "Main",
  "name": "Hogback",
  "text": "Your body won't move?!"
 },
 {
  "i": 38,
  "style": "Main",
  "name": "Hogback",
  "text": "What the hell are you talking about?!"
 },
 {
  "i": 39,
  "style": "Main",
  "name": "Hogback",
  "text": "Stop that false crying already!"
 },
 {
  "i": 40,
  "style": "Main",
  "name": "Hogback",
  "text": "Who do you think you have to thank for moving as if you had a soul?!"
 },
 {
  "i": 41,
  "style": "Main",
  "name": "Hogback",
  "text": "You zombies only exist to obey your master's orders!"
 },
 {
  "i": 42,
  "style": "Main",
  "name": "Robin",
  "text": "It's as if the owner of the body is fighting back..."
 },
 {
  "i": 43,
  "style": "Main",
  "name": "Chopper",
  "text": "Even though she died ten years ago..."
 },
 {
  "i": 44,
  "style": "Main",
  "name": "Chopper",
  "text": "Does a body without a soul have feelings...?"
 },
 {
  "i": 45,
  "style": "Main",
  "name": "Robin",
  "text": "Probably..."
 },
 {
  "i": 46,
  "style": "Main",
  "name": "Robin",
  "text": "Even if we investigated all the libraries in the world, we wouldn't find an answer."
 },
 {
  "i": 47,
  "style": "Main",
  "name": "Cindry",
  "text": "I'll kill... you both..."
 },
 {
  "i": 48,
  "style": "Main",
  "name": "Hogback",
  "text": "That's it!"
 },
 {
  "i": 49,
  "style": "Main",
  "name": "Hogback",
  "text": "You've finally come to your senses, Cindry-chan!"
 },
 {
  "i": 50,
  "style": "Main",
  "name": "Hogback",
  "text": "Be sure to distract them until I'm out of here!"
 },
 {
  "i": 51,
  "style": "Main",
  "name": "Robin",
  "text": "It's a shame..."
 },
 {
  "i": 52,
  "style": "Main",
  "name": "Robin",
  "text": "Here I thought I was witness to a miracle..."
 },
 {
  "i": 53,
  "style": "Main",
  "name": "Robin",
  "text": "{\\fad(150,150)}Doce Fleur!"
 },
 {
  "i": 54,
  "style": "Note",
  "name": "Note",
  "text": "{\\fad(150,150)}Twelve Flowers"
 },
 {
  "i": 55,
  "style": "Main",
  "name": "Chopper",
  "text": "Wait!"
 },
 {
  "i": 56,
  "style": "Main",
  "name": "Hogback",
  "text": "W-What's with this shaking?!"
 },
 {
  "i": 57,
  "style": "Main",
  "name": "Hogback",
  "text": "Damn it!"
 },
 {
  "i": 58,
  "style": "Main",
  "name": "Hogback",
  "text": "You stupid pirate-deer! Acting like a person and siding with the dead!"
 },
 {
  "i": 59,
  "style": "Main",
  "name": "Hogback",
  "text": "You're not even human!"
 },
 {
  "i": 60,
  "style": "Main",
  "name": "Hogback",
  "text": "You stupid monster!"
 },
 {
  "i": 61,
  "style": "Main",
  "name": "Chopper",
  "text": "Our captain..."
 },
 {
  "i": 62,
  "style": "Main",
  "name": "Chopper",
  "text": "Doesn't care whether you're a monster, a cyborg, a pervert, a long-nose, or a moss head..."
 },
 {
  "i": 63,
  "style": "Main",
  "name": "Chopper",
  "text": "He can make anyone follow him!"
 },
 {
  "i": 64,
  "style": "Main",
  "name": "Chopper",
  "text": "Unlike you, who makes use of mindless corpses for your own schemes!"
 },
 {
  "i": 65,
  "style": "Main",
  "name": "Hogback",
  "text": "Let go of me, bastard!"
 },
 {
  "i": 66,
  "style": "Main",
  "name": "Chopper",
  "text": "Robin!"
 },
 {
  "i": 67,
  "style": "Main",
  "name": "Robin",
  "text": "Alright, leave it to me!"
 },
 {
  "i": 68,
  "style": "Note",
  "name": "Robin",
  "text": "{\\fad(150,150)}Leg Flower"
 },
 {
  "i": 69,
  "style": "Main",
  "name": "Robin",
  "text": "{\\fad(150,150)}Pierna Fleur!"
 },
 {
  "i": 70,
  "style": "Main",
  "name": "Hogback",
  "text": "Huh? What?!"
 },
 {
  "i": 71,
  "style": "Main",
  "name": "Hogback",
  "text": "W-Wait a minute, Dr. Chopper!"
 },
 {
  "i": 72,
  "style": "Main",
  "name": "Hogback",
  "text": "If you smash my head from such a high place..."
 },
 {
  "i": 73,
  "style": "Main",
  "name": "Hogback",
  "text": "The brain of the world's greatest genius would be destroyed!"
 },
 {
  "i": 74,
  "style": "Main",
  "name": "Hogback",
  "text": "Is that what you want?!"
 },
 {
  "i": 75,
  "style": "Main",
  "name": "Hogback",
  "text": "I'm fine with that."
 },
 {
  "i": 76,
  "style": "Main",
  "name": "Chopper",
  "text": "Your head is more rotten than those zombies of yours!"
 },
 {
  "i": 77,
  "style": "Main",
  "name": "Chopper",
  "text": "Take this!"
 },
 {
  "i": 78,
  "style": "Main",
  "name": "Chopper",
  "text": "{\\fad(150,150)}Robi-Cho Suplex!"
 },
 {
  "i": 79,
  "style": "Captions",
  "name": "Sign",
  "text": "{\\fad(600,600)}Nearby, in the Special Freezer Room"
 },
 {
  "i": 80,
  "style": "Main",
  "name": "Luffy",
  "text": "{\\an8}It's much bigger than a giant."
 },
 {
  "i": 81,
  "style": "Main",
  "name": "Luffy",
  "text": "So this is my zombie."
 },
 {
  "i": 82,
  "style": "Main",
  "name": "Moria",
  "text": "I've been expecting you, Oars!"
 },
 {
  "i": 83,
  "style": "Main",
  "name": "Moria",
  "text": "The body and shadow have merged at last!"
 },
 {
  "i": 84,
  "style": "Main",
  "name": "Moria",
  "text": "Are you a fully obedient zombie now?"
 },
 {
  "i": 85,
  "style": "Main",
  "name": "Moria",
  "text": "Answer! Who is your master?"
 },
 {
  "i": 86,
  "style": "Main",
  "name": "Oz",
  "text": "My Master is Moriah-sama."
 },
 {
  "i": 87,
  "style": "Main",
  "name": "Luffy",
  "text": "What?!"
 },
 {
  "i": 88,
  "style": "Main",
  "name": "Luffy",
  "text": "Hey, what're you saying?!"
 },
 {
  "i": 89,
  "style": "Main",
  "name": "Luffy",
  "text": "Are you really my shadow?!"
 },
 {
  "i": 90,
  "style": "Main",
  "name": "Luffy",
  "text": "Don't listen to him!"
 },
 {
  "i": 91,
  "style": "Main",
  "name": "Oz",
  "text": "Who're you, straw hat guy?"
 },
 {
  "i": 92,
  "style": "Main",
  "name": "Moria",
  "text": "Then, I shall give you your first order."
 },
 {
  "i": 93,
  "style": "Main",
  "name": "Moria",
  "text": "They are currently rampaging throughout every corner of Thriller Bark."
 },
 {
  "i": 94,
  "style": "Main",
  "name": "Moria",
  "text": "Those are the Straw Hat Pirates."
 },
 {
  "i": 95,
  "style": "Main",
  "name": "Moria",
  "text": "Pulverize them without mercy, and send them back to their ship."
 },
 {
  "i": 96,
  "style": "Main",
  "name": "Moria",
  "text": "Whether they live or die, I don't care!"
 },
 {
  "i": 97,
  "style": "Main",
  "name": "Moria",
  "text": "A little violence won't kill those over 100 million anyway."
 },
 {
  "i": 98,
  "style": "Main",
  "name": "Moria",
  "text": "Don't hold back!"
 },
 {
  "i": 99,
  "style": "Main",
  "name": "Moria",
  "text": "Give them a taste of your power!"
 },
 {
  "i": 100,
  "style": "Main",
  "name": "Oz",
  "text": "Yes, Moriah-sama."
 },
 {
  "i": 101,
  "style": "Main",
  "name": "Oz",
  "text": "Ah! Found you, Straw Hat."
 },
 {
  "i": 102,
  "style": "Main",
  "name": "Moria",
  "text": "See you later, Straw Hat!"
 },
 {
  "i": 103,
  "style": "Main",
  "name": "Luffy",
  "text": "You're not getting away!"
 },
 {
  "i": 104,
  "style": "Main",
  "name": "Oz",
  "text": "{\\fad(150,150)}Rubber..."
 },
 {
  "i": 105,
  "style": "Main",
  "name": "Luffy",
  "text": "W-W-Wait a minute!"
 },
 {
  "i": 106,
  "style": "Main",
  "name": "Luffy",
  "text": "That's dangerous!"
 },
 {
  "i": 107,
  "style": "Main",
  "name": "Oz",
  "text": "{\\fad(150,150)}Bell!"
 },
 {
  "i": 108,
  "style": "Main",
  "name": "Robin",
  "text": "What?!"
 },
 {
  "i": 109,
  "style": "Main",
  "name": "Chopper",
  "text": "Luffy's zombie!"
 },
 {
  "i": 110,
  "style": "Main",
  "name": "Hogback",
  "text": "Oars!"
 },
 {
  "i": 111,
  "style": "Main",
  "name": "Robin",
  "text": "The floor is crumbling!"
 },
 {
  "i": 112,
  "style": "Main",
  "name": "Robin",
  "text": "Chopper, this way!"
 },
 {
  "i": 113,
  "style": "Main",
  "name": "Chopper",
  "text": "That was close."
 },
 {
  "i": 114,
  "style": "Main",
  "name": "Robin",
  "text": "So this is..."
 },
 {
  "i": 115,
  "style": "Main",
  "name": "Robin",
  "text": "Luffy?"
 },
 {
  "i": 116,
  "style": "Main",
  "name": "Chopper",
  "text": "Both Hogback and Cindry fell to the floor below us."
 },
 {
  "i": 117,
  "style": "Main",
  "name": "Hogback",
  "text": "Damn!"
 },
 {
  "i": 118,
  "style": "Main",
  "name": "Hogback",
  "text": "Too heavy!"
 },
 {
  "i": 119,
  "style": "Main",
  "name": "Hogback",
  "text": "Cindry-chan, move this rock..."
 },
 {
  "i": 120,
  "style": "Main",
  "name": "Hogback",
  "text": "C-Cindry-chan, quickly!"
 },
 {
  "i": 121,
  "style": "Main",
  "name": "Hogback",
  "text": "Hurry up and help me!"
 },
 {
  "i": 122,
  "style": "Main",
  "name": "Hogback",
  "text": "Look, Oars is coming!"
 },
 {
  "i": 123,
  "style": "Main",
  "name": "Hogback",
  "text": "I..."
 },
 {
  "i": 124,
  "style": "Main",
  "name": "Hogback",
  "text": "I, the great genius..."
 },
 {
  "i": 125,
  "style": "Main",
  "name": "Hogback",
  "text": "I'm gonna get squished!"
 },
 {
  "i": 126,
  "style": "Main",
  "name": "Hogback",
  "text": "Hey, why're you just standing there?!"
 },
 {
  "i": 127,
  "style": "Main",
  "name": "Hogback",
  "text": "I'm your master!"
 },
 {
  "i": 128,
  "style": "Main",
  "name": "Cindry",
  "text": "My body..."
 },
 {
  "i": 129,
  "style": "Main",
  "name": "Cindry",
  "text": "won't move."
 },
 {
  "i": 130,
  "style": "Main",
  "name": "Hogback",
  "text": "What?!"
 },
 {
  "i": 131,
  "style": "Main",
  "name": "Hogback",
  "text": "Again with that ridiculous nonsense!"
 },
 {
  "i": 132,
  "style": "Main",
  "name": "Hogback",
  "text": "You zombies only exist to be loyal!"
 },
 {
  "i": 133,
  "style": "Main",
  "name": "Hogback",
  "text": "Quickly, help me!"
 },
 {
  "i": 134,
  "style": "Main",
  "name": "Hogback",
  "text": "You're nothing but a pretty face!"
 },
 {
  "i": 135,
  "style": "Main",
  "name": "Hogback",
  "text": "You worthless corpse!"
 },
 {
  "i": 136,
  "style": "Main",
  "name": "Hogback",
  "text": "Hey! Hurry up, Cindry!"
 },
 {
  "i": 137,
  "style": "Main",
  "name": "Hogback",
  "text": "Oars is here!"
 },
 {
  "i": 138,
  "style": "Main",
  "name": "Hogback",
  "text": "Oars, look down, you fool!"
 },
 {
  "i": 139,
  "style": "Main",
  "name": "Hogback",
  "text": "It's me, you ungrateful idiot!"
 },
 {
  "i": 140,
  "style": "Main",
  "name": "Hogback",
  "text": "I'm the one who fixed your body so you could move again!"
 },
 {
  "i": 141,
  "style": "Captions",
  "name": "Sign",
  "text": "{\\fad(550,0)}Nearby, in the corridor outside Perona's room"
 },
 {
  "i": 142,
  "style": "Main",
  "name": "Usopp",
  "text": "{\\an8}W-W-Wait a minute!"
 },
 {
  "i": 143,
  "style": "Main",
  "name": "Usopp",
  "text": "{\\an8}W-What's going on?!"
 },
 {
  "i": 144,
  "style": "Main",
  "name": "Usopp",
  "text": "These tremors are completely different!"
 },
 {
  "i": 145,
  "style": "Main",
  "name": "Usopp",
  "text": "Lu-Lu-Lu...!"
 },
 {
  "i": 146,
  "style": "Main",
  "name": "Usopp",
  "text": "Luffy's zombie!"
 },
 {
  "i": 147,
  "style": "Captions",
  "name": "Sign",
  "text": "{\\fad(550,0)}Nearby, in the church"
 },
 {
  "i": 148,
  "style": "Main",
  "name": "Sanji",
  "text": "Hey, hey, hey, hey! What's with this shaking?!"
 },
 {
  "i": 149,
  "style": "Main",
  "name": "Sanji",
  "text": "No way!"
 },
 {
  "i": 150,
  "style": "Main",
  "name": "Sanji",
  "text": "Luffy's zombie?!"
 },
 {
  "i": 151,
  "style": "Main",
  "name": "Sanji",
  "text": "Damn!"
 },
 {
  "i": 152,
  "style": "Main",
  "name": "Sanji",
  "text": "Nami-san, this isn't the time to be sleeping!"
 },
 {
  "i": 153,
  "style": "Main",
  "name": "Sanji",
  "text": "It can't be helped..."
 },
 {
  "i": 154,
  "style": "Main",
  "name": "Sanji",
  "text": "We need to escape."
 },
 {
  "i": 155,
  "style": "Main",
  "name": "Sanji",
  "text": "Nami-san?"
 },
 {
  "i": 156,
  "style": "Main",
  "name": "Sanji",
  "text": "Nami-san disappeared."
 },
 {
  "i": 157,
  "style": "Main",
  "name": "Sanji",
  "text": "Don't tell me...!"
 },
 {
  "i": 158,
  "style": "Main",
  "name": "Absalom",
  "text": "The tables have turned..."
 },
 {
  "i": 159,
  "style": "Main",
  "name": "Sanji",
  "text": "Bastard!"
 },
 {
  "i": 160,
  "style": "Main",
  "name": "Sanji",
  "text": "You're still conscious?!"
 },
 {
  "i": 161,
  "style": "Main",
  "name": "Sanji",
  "text": "You beast-man, show yourself!"
 },
 {
  "i": 162,
  "style": "Main",
  "name": "Absalom",
  "text": "It seems this demon has finally become our servant!"
 },
 {
  "i": 163,
  "style": "Main",
  "name": "Absalom",
  "text": "Checkmate!"
 },
 {
  "i": 164,
  "style": "Main",
  "name": "Absalom",
  "text": "This time the bride is mine!"
 },
 {
  "i": 165,
  "style": "Main",
  "name": "Sanji",
  "text": "Damn it!"
 },
 {
  "i": 166,
  "style": "Main",
  "name": "Sanji",
  "text": "Give back Nami-san!"
 },
 {
  "i": 167,
  "style": "Main",
  "name": "Sanji",
  "text": "Where are you hiding?!"
 },
